Newspeak3
'Root'
class Browsing usingPlatform: p ide: webIde
(* :exemplar: ide browsing *)
 = Object new (
	(* An IDE for Newspeak on the web.
    Copyright 2016-2017 Google Inc.
    Copyright 2018-2022 Gilad Bracha. *)
	
	(* imports *)
	
	|
		private StringBuilder = p kernel StringBuilder.
		private Subject = p hopscotch Subject.
		private Presenter = p hopscotch Presenter.
		private Fragment = p hopscotch Fragment.
		private SearchFieldFragment = p hopscotch fragments SearchFieldFragment.
		private Window = p hopscotch Window.
		private DOMParser = p hopscotch DOMParser.
		private Color = p graphics Color.
		private Gradient = p hopscotch Gradient.
		private List = p collections List.
		private Map = p collections Map.
		private Set = p collections Set.
		
		(* private OrderedMap = [p collections OrderedMap] on: Error do: [:e | Map]. *)
		private Exception = p kernel Exception.
		private Proxy = p kernel Proxy.
		private ActivationMirror = p mirrors ActivationMirror.
		private ClassMirror = p mirrors ClassMirror.
		private ObjectMirror = p mirrors ObjectMirror.
		private ClosureMirror = p mirrors ClosureMirror.
		private Message = p kernel Message.
		private ClassDeclarationBuilder = p mirrors ClassDeclarationBuilder.
		private Snapshotter = p operatingSystem = 'emscripten' ifTrue: [
				p victoryFuel Snapshotter
			].
		private Deserializer = p operatingSystem = 'emscripten' ifTrue: [
				p victoryFuel Deserializer
			].
		private JSObject = p js global at: 'Object'.
		private JSArray = p js global at: 'Array'.
		private JSUint8Array = p js global at: #Uint8Array.
		private JSMath = p js global at: 'Math'.
		private JSPromise = p js global at: 'Promise'.
		private JSZip = p js global at: 'JSZip'.
		private Date = p js global at: 'Date'.
		
		(* module variables *)
		document = p js global at: 'document'.
		body = document at: 'body'.
		localStorage = p js localStorage.
		atomicInstaller = p mirrors installer.
		compiler = p mirrors compiler.
		cachedPlatform = p.
		ide = webIde.
		detailAreaRatio = 3 asFloat.
		captionColor = Color h: 240 s: 0.05 asFloat v: 0.9 asFloat.
		cssConverter = cssConversionTable.
		objectViews <Map[Symbol, List[Presenter class]]> = Map new.
		currentWindow <IDEWindow>
		nonExemplarClasses <Set[Symbol]> = Set withAll: {#Number. #Class. }.
		
		(* Style *)
		styleHeaderPadRight <Float> = 0.0.
		styleButtonSize <Float> = 30.
	|
	p hopscotch homeSubjectClass: HomeSubject.
	initializeObjectViews.
	installDiffSideBySideStyles.
) (
	public class AssortedMethodsPresenter onSubject: s = DefinitionListPresenter onSubject: s (
		(* The subject is a collection of MethodSubjects that can come from diverse sources (in the sense that they do not have to belong to the same class). The presenter displays them as a column of expandable method presenters and takes care of reasonably handling the various creation and deletion requests coming from them. *)
		
		|
			public title ::= 'Assorted Methods'.
			
			(* The title to use for the presenter *)
			methodPresenters <List[ExpandableMethodPresenter]> ::= List new.
		|
	) (
		addButton = (
			^nothing
		)
		public addNewItemTemplate = (
			(* Handle a user's request to create a new method by displaying a new method template. *)
			
			shouldNotImplement
		)
		definitionListMenu = (
			^menuWithLabelsAndActions: {{'Inspect Presenter'. [
					respondToInspectPresenter
				]. }. }
		)
		public isKindOfAssortedMethodsPresenter ^<Boolean> = (
			^true
		)
		isMyKind: f <Fragment> ^<Boolean> = (
			^f isKindOfAssortedMethodsPresenter
		)
		contentPresenters ^<List[MethodPresenter]> = (
			| methods <List[MethodSubject]> = subject elements sort: [:m1 <MethodSubject> :m2 <MethodSubject> |
					lexicallyLessOrEqual: m1 name than: m2 name
				]. |
			^methods collect: [:each | each presenter showClassName: true ]
		)
		elementDescription ^<String> = (
			^'methods grouped by some criteria'
		)
		listDescription ^<String> = (
			^'assorted method list'
		)
	) : ()
	public class AssortedMethodsSubject onModel: m <Collection[MethodSubject]> = ProgrammingSubject onModel: m (
		|
			public title ::= 'Assorted Methods'.
			elements_slot <Collection[MethodSubject | LazySlotSubject]>
		|
	) (
		public createPresenter = (
			^(AssortedMethodsPresenter onSubject: self) title: title
		)
		public isKindOfAssortedMethodsSubject ^<Boolean> = (
			^true
		)
		isMyKind: f <Fragment> ^<Boolean> = (
			^f isKindOfAssortedMethodsSubject
		)
		public methodTemplateText ^<String> = (
			^'messageSelector = (
)'
		)
		public methodSubjects ^<Collection[MethodSubject]> = (
			^model
		)
		public elements ^<Collection[MethodSubject]> = (
			(* Answer a collection of subjects on individual elements of the collection which is our subject. *)
			
			elements_slot isNil ifTrue: [
					elements_slot:: methodSubjects.
					^elements_slot
				].
			updateElements.
			^elements_slot
		)
		updateElements = (
			| obsoleteSubjects <List[MethodSubject]> = List new. |
			elements_slot do: [:s <MethodSubject> |
					(methodSubjects includes: s) ifFalse: [ obsoleteSubjects add: s ]
				].
			obsoleteSubjects do: [:s <MethodSubject> | elements_slot remove: s ].
			methodSubjects do: [:m <MethodSubject> |
					(elements_slot includes: m) ifFalse: [ elements_slot add: m ]
				]
		)
	) : ()
	class BasicView onSubject: s = ProgrammingPresenter onSubject: s (
	) (
		public isKindOfBasicView ^<Boolean> = (
			^true
		)
		isMyKind: other <Fragment> ^<Boolean> = (
			^other isKindOfBasicView
		)
		public title = (
			^'Basic'
		)
		slots = (
			| ss = subject slots. |
			ss isEmpty ifTrue: [ ^nothing ].
			^minorHeadingBlock: (column: {(label: #Slots) bold. taggedColumn: (ss collect: [:slot <SlotSubject> |
								slot presenter
							]). })
		)
		lazySlots = (
			| lss = subject lazySlots. |
			lss isEmpty ifTrue: [ ^nothing ].
			^minorHeadingBlock: (column: {(label: 'Lazy Slots') bold. taggedColumn: (lss collect: [:slot <SlotSubject> |
								slot presenter
							]). })
		)
		public definition = (
			^column: {slots. lazySlots. }
		)
	) : ()
	public class BitOfWisdom text: s <String> actionLabel: l <String> actionBlock: b <[]> image: i = Object new (
		|
			public text <String> = s.
			public image <Image> = i.
			public actionLabel <String> = l.
			public actionBlock <[]> = b.
		|
	) (
	) : (
		public text: s <String> ^<BitOfWisdom> = (
			^text: s actionLabel: nil actionBlock: nil image: nil
		)
		public text: s <String> actionLabel: l <String> actionBlock: b <[]> ^<BitOfWisdom> = (
			^self text: s actionLabel: l actionBlock: b image: nil
		)
		public text: s image: i ^<BitOfWisdom> = (
			^text: s actionLabel: nil actionBlock: nil image: i
		)
	)
	class ClassActionsPresenter onSubject: s = ProgrammingPresenter onSubject: s (
	) (
		public isKindOfClassActionsPresenter ^<Boolean> = (
			^true
		)
		isMyKind: f <Fragment> ^<Boolean> = (
			^f isKindOfClassActionsPresenter
		)
		definition = (
			^(row: {testActions. mediumBlank. deployAction. mediumBlank. editDeploymentsAction. mediumBlank. runAppAction. }) mainAxisAlignToEnd
		)
		future_deployAction = (
			(* Eventually, we'll use the deployment manager for deployment.
    At that point, this method will replace the current #deployAction
    implementation. Alas, this will take a while, as we need to implement
    a general strategy for reconstituting serialized aliens for this to work. *)
			
			subject isApplicationConfiguration ifFalse: [ ^nothing ].
			^link: '[deploy]'
				action: [
					openMenu:: menuWithLabelsAndActions: (ide deployment configurations collect: [:dc <DeploymentConfiguration> |
								{'to ' , dc name. [
									ide deployment deploy: (ide namespacing Root at: subject name) on: dc
								]. }
							])
				]
		)
		respondToRunTests = (
			| thread |
			thread:: cachedPlatform mirrors ActivationMirror invokeSuspended: [
					enterSubject:: subject testingSubject
				].
			thread resume.
			thread isFulfilled ifFalse: [
					enterSubject:: ide debugging ThreadSubject onModel: thread
				]
		)
		respondToShowTests = (
			| thread |
			thread:: cachedPlatform mirrors ActivationMirror invokeSuspended: [
					enterSubject:: subject inactiveTestingSubject
				].
			thread resume.
			thread isFulfilled ifFalse: [
					enterSubject:: ide debugging ThreadSubject onModel: thread
				]
		)
		public testActions = (
			subject isTestConfiguration ifFalse: [ ^nothing ].
			^row: {link: '[run tests]' action: [ respondToRunTests ]. link: '[show tests]'
					action: [ respondToShowTests ]. }
		)
		public runAppAction = (
			subject isApplicationConfiguration ifFalse: [ ^nothing ].
			^row: {link: '[run]' action: [ respondToRunApp: false ]. link: '[debug]'
					action: [ respondToRunApp: true ]. }
		)
		public editDeploymentsAction = (
			| DeploymentConfigurationSubject = ide deployment DeploymentConfigurationSubject. |
			subject isApplicationConfiguration ifFalse: [ ^nothing ].
			^link: '[configurations]'
				action: [
					openMenu:: menuWithLabelsAndActions: (ide deployment configurations collect: [:dc <DeploymentConfiguration> |
								{dc name. [ enterSubject:: DeploymentConfigurationSubject onModel: dc ]. }
							]) , {{'Create New Deployment'. [
							enterSubject:: DeploymentConfigurationSubject onModel: ide deployment defaultConfiguration
						]. }. }
				]
		)
		respondToRunApp: paused = (
			subject runApp: paused
		)
		deployAsNSO = (
			(* The serialize-then-download runs inside the Save click. For most NSO
     outputs this fits within the activation window; for very large apps
     it may not (Phase B concern, same shape as vfuel-of-the-IDE). *)
			
			confirmSave: 'Deploy ' , subject name , ' as Newspeak Object?'
				saving: [ subject deployAsNSO ]
		)
		public deployAction = (
			subject isApplicationConfiguration ifFalse: [ ^nothing ].
			^link: '[deploy]'
				action: [
					openMenu:: menuWithLabelsAndActions: {{'as Newspeak Object (NSO)'. [
							deployAsNSO
						]. }. {'as VictoryFuel'. [ deployAsVictoryFuel ]. }. {'as VictoryFuel with Mirrors'. [
							deployAsVictoryFuelWithMirrors
						]. }. {'as VictoryFuel with Hopscotch'. [
							deployAsVictoryFuelWithHopscotch
						]. }. {'as Web Page'. [ deployAsWebPage ]. }. {'as Web Page with Mirror Builders'. [
							deployAsWebPageWithMirrorBuilders
						]. }. }
				]
		)
		deployAsWebPage = (
			deployAsWebPageWithRuntimeConfig: ide deployment Runtime
		)
		deployAsWebPageWithMirrorBuilders = (
			deployAsWebPageWithRuntimeConfig: ide deployment RuntimeWithMirrorBuilders
		)
		deployAsWebPageWithRuntimeConfig: runtimeClass <Class> = (
			| deployment <DeploymentManager JSPackager JSDeployment> = (ide deployment jsPackagerForPlatform: cachedPlatform) packageApplicationConfiguration: (ide namespacing Root at: subject name)
				withRuntimeConfiguration: runtimeClass
				usingNamespace: ide namespacing Root. |
			confirmSave: 'Compiled ' , subject name , '. Save the deployment?'
				saving: [ deployment save ]
		)
		deployAsVictoryFuelWithMirrors = (
			| bytes = subject bytesForVictoryFuelWithMirrors. |
			confirmSave: 'Snapshotted ' , subject name , ' (with mirrors). Save VictoryFuel?'
				saving: [
					ide webFiles downloadFileName: subject name , '.vfuel' fromBytes: bytes
				]
		)
		deployAsVictoryFuelWithHopscotch = (
			| bytes = subject bytesForVictoryFuelWithHopscotch. |
			confirmSave: 'Snapshotted ' , subject name , ' (with Hopscotch). Save VictoryFuel?'
				saving: [
					ide webFiles downloadFileName: subject name , '.vfuel' fromBytes: bytes
				]
		)
		deployAsVictoryFuel = (
			| bytes = subject bytesForVictoryFuel. |
			confirmSave: 'Snapshotted ' , subject name , '. Save VictoryFuel?'
				saving: [
					ide webFiles downloadFileName: subject name , '.vfuel' fromBytes: bytes
				]
		)
		confirmSave: msg <String> saving: saveBlock <[]> = (
			(* Chrome enforces a transient-activation window for downloads. Any
     compute / serialize work that runs in the deploy menu click can
     exhaust that window before the actual file write. Route the file
     write through a confirmation Subject so the user's click on Save
     provides fresh activation.

     Phase A (here): saveBlock runs from the Save click. Work inside
     the block (zip generation, large serializations) can still exceed
     the fresh activation window for IDE-sized outputs.

     Phase B (TODO): pre-prepare the bytes / blob in the deploy click
     and have saveBlock just write them; or use the File System Access
     API to pre-pick a destination handle before the long work and
     write asynchronously when it's ready. *)
			
			enterSubject:: ide browsing InteractionSubject confirm: msg
				yesLabel: 'Save'
				onYes: saveBlock
				returnTo: subject
		)
	) : ()
	class ClassEntryPresenter onSubject: s <ClassSubject> = EntryPresenter onSubject: s (
	) (
		classCommentSummary ^<String> = (
			| fullComment <String> = subject classCommentText. endOfFirstSentence <Integer> = fullComment indexOf: '.'. firstSentence <String> = fullComment copyFrom: 1
				to: endOfFirstSentence. |
			^firstSentence
		)
		expandedDefinition = (
			^subject presenter
		)
		public tag ^<String> = (
			^subject name
		)
		public isKindOfClassEntryPresenter ^<Boolean> = (
			^true
		)
		isMyKind: f <Fragment> ^<Boolean> = (
			^f isKindOfClassEntryPresenter
		)
		collapsedDefinition = (
			^column: {helpSection. row1: {defaultBlank. (image: ide images classImage) height: styleButtonSize. defaultBlank. accessIndicator. defaultBlank. link: tag
						action: [ enterSubject:: ClassSubject onDeclaration: subject classMirror ]. }
					row2: {(row: {deferred: [
								(label: subject classCommentSummary) smallFont;
									color: secondaryTextColor
							]. }) compressibility: 1. filler compressibility: 0. helpButton. mediumBlank. (ClassActionsPresenter onSubject: subject) elasticity: 1. mediumBlank. entryActionsMenu. }. }
		)
		respondToDelete = (
			| enclosing = subject enclosingClassSubject. |
			updateGUI: [ subject deleteClass ]
		)
		entryActionsMenu = (
			^dropDownMenu: [
					menuWithLabelsAndActions: {{'Inspect Presenter'. [
							respondToInspectPresenter
						]. }. #separator. {'Delete '. [ respondToDelete ]. }. }
				]
		)
		helpText = (
			| mapping = Map new. menuImage = Utilities uriForIconNamed: #dropDownImage. referenceImage = Utilities uriForIconNamed: #itemReferencesImage. goldenIcon = Utilities uriForIconNamed: #classImage. |
			mapping at: #hopscotchToggleEntry
				put: (collapsed: [ defaultBlank ] expanded: [ expandedDefinition ]);
				at: #className put: (link: tag action: [ enterSubject:: subject ]);
				at: #hopscotchEntryMenuButton put: entryActionsMenu;
				at: #hopscotchMethodReferencesButton
					put: (dropDownMenu: [ messagesMenu ] image: ide images itemReferencesImage);
				at: #hopscotchHelpButton put: helpButton.
			^ampleforth: 'This is a class entry presenter, representing a nested class. Below, you see, from left to right: 
  <ul>
  <li><img src=''' , goldenIcon , ''' alt="" width="25"> The icon identifying this entry as a class.
  <li>The class name <div class="className"> </div> If you click on it, the system will open a presenter on the class. This will be either a class presenter, or an object presenter on an exemplar of the class (if the system can find one). You can also expand a presenter on the class in place using the toggle <div class="hopscotchToggleEntry"> </div>  at the top left of this entry.</li>
  <li>A summary of their class comment, if any. </li>
  <li><div class="hopscotchHelpButton"> </div> Shows this help message.</li>
  <li><div class="hopscotchEntryMenuButton"> </div> Opens a menu of additional operations, such as deleting this class from the enclosing class or inspecting this presenter.</li>
  </ul>
  '
				mapping: mapping
		)
	) : ()
	class ClassFactoryPresenter onSubject: s <ClassFactorySubject> = MethodPresenter onSubject: s (
		(* Present the factory method, colorized. *)
		
		|
			toggle <ToggleComposer>
			public showClassName <Boolean> ::= false.
			
			(* Captured by editorDefinition so respondToTypecheck can read the
    pending header source from the editor buffer. *)
			headerEditor <CodeMirrorFragment>
		|
	) (
		installHistory = (
			(* Override MethodPresenter>>installHistory: class headers carry a
       ClassDeclarationMirror. Wrap in the multi-repo presenter so
       drafts AND any tracking permanent repos appear. *)
			
			historyHolder content: (MemberRepoHistorySubject onModel: (MemberRepoHistoryModel forClassMirror: subject classMirror)) createPresenter
		)
		changeResponse ^<[:CodeMirrorFragment :Event | Object]> = (
			^[:ed <CodeMirrorFragment> :event <Event> |
				colorizeHeaderSource: (crToLf: ed textBeingAccepted) withEditor: ed
			]
		)
		colorizeHeaderSource: s <String> withEditor: cm <CodeMirrorFragment> = (
			ide colorizer colorizeHeader: s
				fromClass: subject classMirror
				via: (colorizingBlockFor: cm)
		)
		definition = (
			toggle:: collapsed: [ collapsedDefinition ] expanded: [ expandedDefinition ].
			^toggle
		)
		public isKindOfClassFactoryPresenter ^<Boolean> = (
			^true
		)
		isMyKind: f <Fragment> ^<Boolean> = (
			^f isKindOfClassFactoryPresenter
		)
		nestingInformationLine ^<Fragment> = (
			| enclosingClasses rowElements |
			enclosingClasses:: subject enclosingClasses.
			rowElements:: List new.
			enclosingClasses do: [:each |
					rowElements add: ((label: ' in ') color: tertiaryTextColor).
					rowElements add: (linkToBrowseEnclosingClass: each)
				].
			^row: rowElements asArray
		)
		editorDefinition = (
			(* Re-base the header source to indent 0 for display (see MethodPresenter). *)
			
			| src = ide prettyPrintClassHeaderOr: (crToLf: subject classHeaderSource). editor = codeMirror: src. |
			editor changeResponse: changeResponse;
				cancelResponse: cancelResponse;
				acceptResponse: acceptResponse.
			colorizeHeaderSource: src withEditor: editor.
			headerEditor:: editor.
			^editor
		)
		cancelResponse ^<[:CodeMirrorFragment | Object]> = (
			^[:ed <CodeMirrorFragment> |
				| src = ide prettyPrintClassHeaderOr: (crToLf: subject classHeaderSource). |
				ed text: src.
				colorizeHeaderSource: src withEditor: ed.
				ed leaveEditState
			]
		)
		acceptResponse ^<[:CodeMirrorFragment :Event | Object]> = (
			^[:ed <CodeMirrorFragment> :event <Event> |
				| b <ClassDeclarationBuilder> = subject classMirror asBuilder. |
				updateGUI: [
						[
							| canonical |
							canonical:: ide prettyPrintClassHeaderOr: ed textBeingAccepted.
							b header source: canonical.
							ide installFromBuilders: {b. }.
							subject clearTypeErrors.
							[
								ide reportRecheckFrom: (ide typechecker declarationForMember: subject classMirror instanceSide name
										kind: #classHeader
										ofClass: subject classMirror instanceSide)
									onSubject: subject
							] on: Error do: [:e <Exception> | ].
							ed text: canonical.
							colorizeHeaderSource: (crToLf: canonical) withEditor: ed.
							ed leaveEditState
						] on: Error do: [:ex <Exception> | ed showMessage: ex printString ]
					].
				ed editor focus
			]
		)
		respondToTypecheck = (
			(* Override MethodPresenter>>respondToTypecheck. The factory IS the
       class header; route through typecheckClassHeader: instead of
       typecheckMethodSource:. Uses the captured headerEditor for the
       in-progress buffer, falling back to the installed header. *)
			
			| ed source typed mixin errs failureMessage |
			ed:: headerEditor.
			typed:: ed isNil ifTrue: [ nil ] ifFalse: [ ed textBeingAccepted ].
			source:: (typed isNil or: [ typed isEmpty ]) ifTrue: [
					subject classHeaderSource
				]
				ifFalse: [ typed ].
			mixin:: subject classMirror instanceSide.
			subject clearTypeErrors.
			failureMessage:: nil.
			errs:: [ ide typechecker typecheckClassHeader: source ofClass: mixin ] on: Error
				do: [:e |
					failureMessage:: 'Typechecker failed: ' , e printString.
					nil
				].
			updateGUI: [
					failureMessage isNil ifFalse: [
							subject typeErrorMessages add: failureMessage
						]
						ifTrue: [
							errs isEmpty ifTrue: [ subject typeErrorMessages add: 'No type errors.' ]
								ifFalse: [
									errs do: [:e |
											subject typeErrorMessages add: 'Type error: ' , e message , ' [' , e start printString , '-' , e end printString , ']'
										]
								]
						]
				]
		)
		slotList ^<Fragment> = (
			| sl |
			^column: {(sl:: subject classMirror instanceSide slots) size > 0 ifTrue: [
						column: {(label: 'Slots') bold. smallBlank. row: {(column: (sl collect: [:ea <SlotDeclarationMirror> |
											row: {defaultBlank. accessIndicator: ea accessModifier. defaultBlank. label: ea name. }
										])) elasticity: 1. }. }
					]
					ifFalse: [ nothing ]. }
		)
		collapsedDefinition ^<Fragment> = (
			^column: {helpSection. headerDefinition. historySection. chatSection. column: typeErrorMessages. label: subject classCommentSummary. mediumBlank. slotList. }
		)
		expandedDefinition = (
			^column: {helpSection. headerDefinition. historySection. chatSection. editorDefinition. column: typeErrorMessages. }
		)
		headerDefinition ^<Fragment> = (
			^row: {defaultBlank. accessIndicator. defaultBlank. (link: subject name
					action: [ toggle toggle ]) color: actionLinkColor. showClassName ifTrue: [
						nestingInformationLine
					]
					ifFalse: [ nothing ]. filler. 
				(* Disabled for now. The story is a bit more complex for factory debugging.
    deferred: [debugButton].
    smallBlank. *)
				dropDownMenu: [ messagesMenu ] image: ide images itemReferencesImage. smallBlank. (imageButton: ide images historyImage
					action: [ toggleHistory ]
					size: styleButtonSize) toolTip: 'Show / hide history of this class header'. smallBlank. aiChatButton: [
						ide aiSupport setClassHeaderFocusOn: subject classDeclaration
					]
					ifFocused: [
						ide aiSupport isFocusedOnClassHeader: subject classDeclaration
					]. smallBlank. helpButton. smallBlank. dropDownMenu: [
						methodMenuFor: subject name
					]. }
		)
		helpText = (
			| mapping = Map new. menuImage = Utilities uriForIconNamed: #dropDownImage. referenceImage = Utilities uriForIconNamed: #itemReferencesImage. exemplarHeaderDescription = hasExemplars ifTrue: [
					'<li><div class="hopscotchDebugMethodButton"> </div> Opens a debugger on an invocation of the method, with the arguments given by the method exemplar.</li>'
				]
				ifFalse: [ '' ]. menuDescription = hasExemplars ifTrue: [
					'deleting the method, inspecting this presenter or opening an evaluator.'
				]
				ifFalse: [ 'deleting the method or inspecting this presenter.' ]. editorEvaluatorDescription = hasExemplars ifTrue: [
					'<br>The editor is also an evaluator. See it''s help section for more details.'
				]
				ifFalse: [ '' ]. |
			mapping at: #hopscotchAccessIndicator put: accessIndicator;
				at: #hopscotchMethodMenuButton put: (dropDownMenu: [ methodMenu ]);
				at: #hopscotchDebugMethodButton put: debugButton;
				at: #hopscotchMethodReferencesButton
					put: (dropDownMenu: [ messagesMenu ] image: ide images itemReferencesImage);
				at: #hopscotchHistoryButton
					put: ((imageButton: ide images historyImage
						action: [ toggleHistory ]
						size: styleButtonSize) toolTip: 'Show / hide history of this class header');
				at: #hopscotchAiChatButton
					put: (aiChatButton: [
							ide aiSupport setClassHeaderFocusOn: subject classDeclaration
						]
						ifFocused: [
							ide aiSupport isFocusedOnClassHeader: subject classDeclaration
						]);
				at: #hopscotchHelpButton put: helpButton.
			^ampleforth: 'This is a class factory method presenter. It can be either expanded or collapsed. In the collapsed state,  the factory header is shown.
  <br><br>From left to right, the factory header displays:
  <ul>
  <li><div class="hopscotchAccessIndicator"></div> The factory''s access modifier. It is always green, as Newspeak primary factories are public by definition.</li>
  <li>The factory method selector.</li>' , exemplarHeaderDescription , '<li><div class="hopscotchMethodReferencesButton"> </div> Allows you to find senders and implementors of the factory method''s selector and of its slot accessors.</li>
  <li><div class="hopscotchHistoryButton"> </div> Shows or hides the history of changes to this class header, drawn from the drafts repository. Expand a row to see the historical header pre-loaded as a pending edit on the live header; accept to revert (the revert lands as a new append-only Accept commit).</li>
  <li><div class="hopscotchAiChatButton"> </div> Opens the AI chat with this class header (factory + slots) as the current focus. The chat appears as a collapsible region just below the header. While this header holds the focus, the brain icon shows an amber highlight; clicking another brain elsewhere moves the focus there. The shared conversation continues across all presenters.</li>
  <li><div class="hopscotchHelpButton"> </div> Shows this help message.</li>
  <li><div class="hopscotchMethodMenuButton"> </div> Opens a menu of additional operations, such as ' , menuDescription , '</li>
  </ul>
  Below the header we see the first sentence of the class comment, and below that a list of the classes'' slots. Each slot is prefixed by its access modifier. The color of the access modifier indicates whether the slot is public (green), protected (yellow) or private (red).
  <br><br>
  When the factory method presenter is expanded, an editor pane containing the factory source is displayed underneath the header. You can edit the source, allowing you change the factory name, the superclass clauses, and  to add, remove or modify slot declarations and any other factory code. Once the code is changed, indicators appear at the top right corner of the editor pane. You can accept the changes by pressing, or revert back to the original by pressing . You can also accept changes by pressing Cmd-return (on mac) or Ctl-return (on Linux or Windows).
  ' , editorEvaluatorDescription
				mapping: mapping
		)
	) : ()
	class ClassFactorySubject onClassModel: m <ClassModel> = MethodSubject onMethodModel: m (
	) (
		public accessModifier ^<Symbol> = (
			^#public
		)
		public classCommentSummary ^<String> = (
			| fullComment <String> = classCommentText. endOfFirstSentence <Integer> = fullComment indexOf: '.'. firstSentence <String> = fullComment copyFrom: 1
				to: endOfFirstSentence. |
			^firstSentence
		)
		classCommentText ^<String> = (
			| comment = classMirror header classComment. |
			nil = comment ifTrue: [ ^'' ].
			^comment
		)
		public classDeclaration ^<ClassDeclarationMirror> = (
			^classMirror
		)
		public classHeaderSource = (
			^classMirror header source
		)
		public classMirror ^<ClassDeclarationMirror> = (
			^model klass
		)
		public createPresenter ^<ClassFactoryPresenter> = (
			^ClassFactoryPresenter onSubject: self
		)
		public delete = (
			Error signal: 'cannot delete primary class factory'
		)
		isMyKind: s <Subject> ^<Boolean> = (
			^s isKindOfClassFactorySubject
		)
		public name ^<Symbol> = (
			^classMirror primaryFactorySelector
		)
		public isKindOfClassFactorySubject ^<Boolean> = (
			^true
		)
		public metadata ^<Map[String, String]> = (
			^classMirror header metadata
		)
		public primaryFactorySelector ^<Symbol> = (
			^classMirror primaryFactorySelector
		)
		public source ^<String> = (
			^classHeaderSource
		)
		public enclosingClassScope ^<ObjectMirror | Nil> = (
			(* Produce an object that will serve as the enclosing scope when debugging the factory live *)
			
			| enclosing <ObjectMirror> = enclosingScope. |
			#BOGUS.
			enclosing isNil ifTrue: [ ^nil ].
			enclosing getClass enclosingObject reflectee isNil ifTrue: [
					^
					(* return ide scope *)
					hiddenWorkspace
				].
			^enclosing getClass enclosingObject
		)
		public enclosingScope ^<ObjectMirror> = (
			#BOGUS
		)
		public messages ^<List[Symbol]> = (
			| result <List[Symbol]> = List new. |
			classMirror instanceSide slots do: [:slot <SlotDeclarationMirror> |
					result add: slot name.
					slot isMutable ifTrue: [ result add: slot name , ':' ]
				].
			classMirror header selectors do: [:message |
					(result indexOf: message) = 0 ifTrue: [ result add: message ]
				].
			^result
		)
	) : (
		public onModel: m <ClassDeclarationMirror> = (
			^onClassModel: (ClassModel declaration: m exemplar: nil)
		)
	)
	class ClassPresenter onSubject: s = ProgrammingPresenter onSubject: s (
		|
			public lazySlotsPresenter <LazySlotGroupPresenter>
			public nestedClassesPresenter <NestedClassGroupPresenter>
			public instanceMethodsPresenter <MethodGroupPresenter>
			public classMethodsPresenter <MethodGroupPresenter>
			classActionsPresenter <ClassActionsPresenter> ::= (ClassActionsPresenter onSubject: subject) elasticity: 1.
			
			(* Captured by classSourceDefinition so the 'Pretty Print' menu
     action can address the current header editor. *)
			headerEditor <CodeMirrorFragment>
		|
	) (
		changeResponse ^<[:CodeMirrorFragment :Event | Object]> = (
			^[:ed <CodeMirrorFragment> :event <Event> |
				colorizeHeaderSource: (crToLf: ed textBeingAccepted) withEditor: ed
			]
		)
		classActionsMenu = (
			^menuWithLabelsAndActions: {{'Save to File'. [ respondToSave ]. }. #separator. {'Pretty Print'. [
					respondToPrettyPrint
				]. }. #separator. {'Typecheck Class'. [
					enterSubject:: subject typecheckReportSubject
				]. }. #separator. {'Inspect Mirror'. [ inspectObject: subject classMirror ]. }. {'Inspect Presenter'. [
					respondToInspectPresenter
				]. }. #separator. {'Delete'. [ respondToDelete ]. }. }
		)
		respondToPrettyPrint = (
			(* Pretty-print the current class header source and replace the
       editor contents in place. Does NOT trigger Accept. *)
			
			| ed source formatted |
			ed:: headerEditor.
			ed isNil ifTrue: [ ^self ].
			source:: ed textBeingAccepted.
			(source isNil or: [ source isEmpty ]) ifTrue: [
					source:: subject classHeaderSource
				].
			formatted:: [ ide prettyPrinter prettyPrintClassHeader: source ] on: Exception
				do: [:e |
					ed showMessage: 'Pretty print failed: ' , e printString.
					^self
				].
			ed text: formatted.
			colorizeHeaderSource: (crToLf: formatted) withEditor: ed.
			ed editor focus
		)
		classCommentSummary ^<String> = (
			| fullComment <String> = subject classCommentText. endOfFirstSentence <Integer> = fullComment indexOf: '.'. firstSentence <String> = fullComment copyFrom: 1
				to: endOfFirstSentence. |
			^firstSentence
		)
		classNameAndContainmentDefinition ^<Fragment> = (
			^column: {classNameAndHierarchySummary. preambleLine. label: subject classCommentSummary. }
		)
		classSourceDefinition = (
			(* Re-base the header source to indent 0 for display (see MethodPresenter). *)
			
			| src = ide prettyPrintClassHeaderOr: (crToLf: subject classHeaderSource). editor = codeMirror: src. |
			editor changeResponse: changeResponse;
				acceptResponse: acceptResponse.
			colorizeHeaderSource: src withEditor: editor.
			headerEditor:: editor.
			^editor
		)
		colorizeHeaderSource: s <String> withEditor: cm <CodeMirrorFragment> = (
			ide colorizer colorizeHeader: s
				fromClass: subject classMirror
				via: (colorizingBlockFor: cm)
		)
		expandedHeadingDefinition ^<Fragment> = (
			^column: {classNameAndHierarchySummary. subject factorySubject presenter. }
		)
		headingDefinition ^<Fragment> = (
			^(column: {expanded: [ expandedHeadingDefinition ]
					collapsed: [ classNameAndHierarchySummary ]. }) color: (Color h: 240
					s: 0.05
					v: 0.9)
		)
		initializerDefinition ^<Fragment> = (
			^nothing
		)
		inspectSelf ^<Fragment> = (
			^row: {filler. link: 'Inspect Presenter'
					action: [
						enterSubject:: ObjectSubject onModel: (ObjectMirror reflecting: self)
					]. }
		)
		public isKindOfClassPresenter ^<Boolean> = (
			^true
		)
		isMyKind: f <Fragment> ^<Boolean> = (
			^f isKindOfClassPresenter
		)
		minorClassHeadingBlock: body = (
			^(padded: body with: {10. 5. styleHeaderPadRight. 5. }) color: minorClassHeadingColor
		)
		minorClassHeadingColor = (
			^Gradient from: (Color h: 240 s: 0.02 v: 0.94)
				to: (Color h: 240 s: 0.02 v: 0.9)
		)
		preambleLine = (
			(* The line showing the class constructor syntax, e.g. 'Foo foo: x = Bar'. The superclass clause, if present, becomes a link to browse the superclass. *)
			
			| preamble <String> equalIndex <Integer> prefix <String> suffix <String> |
			preamble:: subject classMirror header preamble.
			equalIndex:: preamble indexOf: "=".
			equalIndex = 0 ifTrue: [
					prefix:: preamble.
					suffix:: ''
				]
				ifFalse: [
					prefix:: preamble copyFrom: 1 to: equalIndex - 1.
					suffix:: preamble copyFrom: equalIndex + 1 to: preamble size
				].
			^suffix isEmpty ifTrue: [ label: prefix ]
				ifFalse: [
					row: {label: prefix , ' = '. link: suffix
							action: [ respondToBrowseSuperclass ]. }
				]
		)
		respondToDelete = (
			| enclosing = subject enclosingClassSubject. |
			updateGUI: [
					subject deleteClass.
					enclosing isNil ifFalse: [ enterSubject: enclosing ]
						ifTrue: [ enterSubject: NamespaceSubject new ]
				]
		)
		acceptResponse ^<[:CodeMirrorFragment :Event | Object]> = (
			^[:ed <CodeMirrorFragment> :event <Event> |
				| b <ClassDeclarationBuilder> = subject classMirror asBuilder. canonical |
				canonical:: ide prettyPrintClassHeaderOr: ed textBeingAccepted.
				b header source: canonical.
				ide installFromBuilders: {b. }.
				ed text: canonical.
				colorizeHeaderSource: (crToLf: canonical) withEditor: ed.
				ed leaveEditState
			]
		)
		nestedClass: cdm <ClassDeclarationMirror> = (
			^collapsed: [
					row: {defaultBlank. accessIndicator. defaultBlank. link: cdm simpleName
							action: [ enterSubject:: ClassSubject onDeclaration: cdm ]. }
				]
				expanded: [ (ClassSubject onModel: cdm) presenter ]
		)
		classNameAndHierarchySummary = (
			| parts <List[Fragment]> |
			parts:: List new.
			subject enclosingClassSubjects do: [:ecs |
					parts add: (link: ecs name action: [ enterSubject:: ecs ])
				]
				separatedBy: [ parts add: (label: ' in ') ].
			^column: {row: {smallBlank. (image: ide images classImage) height: styleButtonSize. smallBlank. row: parts. filler. classActionsPresenter. smallBlank. itemReferencesButtonWithAction: [
							browseSelector: subject name
						]. smallBlank. saveButtonWithAction: [ respondToSave ]. smallBlank. refreshButton. smallBlank. aiChatButton: [
							ide aiSupport setClassFocusOn: subject classMirror
						]
						ifFocused: [ ide aiSupport isFocusedOnClass: subject classMirror ]. smallBlank. helpButton. smallBlank. dropDownMenu: [
							classActionsMenu
						]. }. }
		)
		helpText ^<Fragment> = (
			| mapping = Map new. menuImage = Utilities uriForIconNamed: #dropDownImage. referenceImage = Utilities uriForIconNamed: #itemReferencesImage. classActions <ClassActionsPresenter> = classActionsPresenter. appActionsHelp <String> = subject isApplicationConfiguration ifTrue: [
					mapping at: #classDeployAction put: classActions deployAction;
						at: #classEditDeploymentsAction put: classActions editDeploymentsAction;
						at: #classRunAppAction put: classActions runAppAction.
					'Next, because this is a application configuration class,  come links for managing application configurations
            <ul>
            <li><div class = "classDeployAction"></div>Bring up a menu of options for deploying this application configuration</li>
            <li><div class = "classEditDeploymentsAction"></div>Add or modify deployment options.</li>
            <li><div class = "classRunAppAction"></div>Run or debug the app.</li>
            </ul>'
				]
				ifFalse: [ '' ]. testActionsHelp <String> = subject isTestConfiguration ifTrue: [
					mapping at: #classTestActions put: classActions testActions.
					' Next, because this is a test configuration class,  come links <div class = "classTestActions"></div>for running or displaying the tests for this test configuration.'
				]
				ifFalse: [ '' ]. |
			subject isApplicationConfiguration ifTrue: [ ] ifFalse: [ ].
			mapping at: #classTestActions put: classActions testActions;
				at: #classDeployAction put: classActions deployAction;
				at: #classEditDeploymentsAction put: classActions editDeploymentsAction;
				at: #classRunAppAction put: classActions runAppAction;
				at: #hopscotchClassActionsMenuButton
					put: (dropDownMenu: [ classActionsMenu ]);
				at: #hopscotchClassReferencesButton
					put: (itemReferencesButtonWithAction: [ browseSelector: subject name ]);
				at: #hopscotchAiChatButton
					put: (aiChatButton: [ ide aiSupport setClassFocusOn: subject classMirror ]
						ifFocused: [ ide aiSupport isFocusedOnClass: subject classMirror ]);
				at: #hopscotchHelpButton put: helpButton;
				at: #hopscotchRefreshButton put: refreshButton;
				at: #hopscotchSaveButton put: (saveButtonWithAction: [ respondToSave ]).
			^ampleforth: 'A class presenter provides a structured view of a class. The first line tells you the class name and what classes, if any, it is nested in. ' , appActionsHelp , testActionsHelp , ' The class presenter also provides the following buttons:
  <ul>
  <li> <div class="hopscotchClassReferencesButton"> </div>Allows you to find references to it. </li>
  <li><div class="hopscotchSaveButton"> </div> Downloads it (i.e., saves it to a file).</li>
  <li><div class="hopscotchRefreshButton"> </div> Refreshes the display</li>
  <li><div class="hopscotchAiChatButton"> </div> Opens the AI chat with this class as the current focus. The chat appears as a collapsible region just below the header. While this view holds the focus, the brain icon shows an amber highlight; clicking another brain elsewhere moves the focus there. The shared conversation continues across all presenters.</li>
  <li><div class="hopscotchHelpButton"> </div> Shows this help message.</li>
  <li> <div class="hopscotchClassActionsMenuButton"> </div> Opens a menu of additional operations, such as deleting the class or inspecting this presenter or a mirror on this class declaration.</ul> <br>
  The line below provides access to the class'' primary factory. You can access senders and implementers of the factory and the slots it defines via  <img src="' , referenceImage , '" alt="" width="30" height="30">, or access the menu via <img src="' , menuImage , '" alt="" width="30" height="30">. <br>
  The following three sections manage nested classes, instance and class methods respectively. '
				mapping: mapping
		)
		public definition ^<Fragment> = (
			^column: {helpSection. headingDefinition. chatSection. lazySlotsPresenter:: subject lazySlotsSubject presenter. nestedClassesPresenter:: subject nestedClassesSubject presenter. instanceMethodsPresenter:: subject methodsSubject presenter. classMethodsPresenter:: subject classMethodsSubject presenter. }
		)
		respondToSave = (
			ide webFiles downloadFileName: subject name , '.ns'
				fromString: subject compilationUnitSource
		)
	) : ()
	public class ClassSubject onClassModel: m <ClassModel> = ProgrammingSubject onModel: m (
		|
			public exemplar <ObjectMirror> ::= classModel exemplar.
		|
	) (
		lazy public factorySubject <ClassFactorySubject> = ClassFactorySubject onModel: classMirror.
		lazy objectSubject <ObjectSubject> = ObjectSubject onModel: exemplar.
		lazy public classMethodsSubject <MethodGroupSubject> = MethodGroupSubject onModel: (MirrorGroupModel mirrorGroup: classMirror classSide methods
				ofMixin: classMirror classSide
				exemplar: exemplar).
		lazy public methodsSubject <MethodGroupSubject> = MethodGroupSubject onModel: (MirrorGroupModel mirrorGroup: classMirror instanceSide methods
				ofMixin: classMirror instanceSide
				exemplar: instanceExemplar).
		lazy public nestedClassesSubject <NestedClassGroupSubject> = NestedClassGroupSubject onModel: (MirrorGroupModel mirrorGroup: classMirror instanceSide
				ofMixin: classMirror instanceSide
				exemplar: instanceExemplar).
		lazy public lazySlotsSubject <LazySlotGroupSubject> = LazySlotGroupSubject onModel: (MirrorGroupModel mirrorGroup: classMirror instanceSide lazySlots
				ofMixin: classMirror instanceSide
				exemplar: instanceExemplar).
		public accessModifier = (
			^classMirror accessModifier
		)
		public classCommentSummary ^<String> = (
			| fullComment <String> = classCommentText. endOfFirstSentence <Integer> = fullComment indexOf: '.'. firstSentence <String> = fullComment copyFrom: 1
				to: endOfFirstSentence. |
			^firstSentence
		)
		public classCommentText ^<String> = (
			| comment = classMirror header classComment. |
			nil = comment ifTrue: [ ^'' ].
			^comment
		)
		public classHeaderSource = (
			^classMirror header source
		)
		public isApplicationConfiguration ^<Boolean> = (
			^isTopLevel and: [
					classMirror primaryFactorySelector = #packageUsing: or: [
							classMirror classSide methods includesMirrorNamed: #packageUsing:
						]
				]
		)
		public isKindOfClassSubject ^<Boolean> = (
			^true
		)
		isMyKind: s <Subject> ^<Boolean> = (
			^s isKindOfClassSubject
		)
		public testingSubject = (
			#NAMESPACEBOGUS.
			^ide minitestUI TestingInProgressSubject onConfiguration: (ide namespacing Root at: name)
				platform: cachedPlatform
				minitest: ide minitest
		)
		public title = (
			^name
		)
		public bytesForVictoryFuel ^<ByteArray> = (
			^bytesForVictoryFuelWithRuntime: ide psoupDeploymentRuntime
		)
		public bytesForVictoryFuelWithMirrors ^<ByteArray> = (
			^bytesForVictoryFuelWithRuntime: ide psoupWithMirrorsDeploymentRuntime
		)
		public bytesForVictoryFuelWithRuntime: runtimeClass ^<ByteArray> = (
			| appDef <Class> = ide namespacing Root at: name. |
			^ide deployment PSoupPackager packageApplicationConfiguration: appDef
				withRuntimeConfiguration: runtimeClass
				usingNamespace: ide namespacing Root
		)
		public compilationUnitSource ^<String> = (
			(* Canonicalize the file source on the way out so a saved/exported file is
		   pretty-printed with its members nested under the class -- the same
		   prettyPrintCompilationUnit: path that produced the committed codebase. Falls back
		   to the raw assembly on a parse error. (ide is reachable here by lexical scope.) *)
			
			isTopLevel ifTrue: [
					| raw = compilationUnitFromSource: classMirror source forClassNamed: name. |
					^[ ide prettyPrinter prettyPrintCompilationUnit: raw ] on: Error
						do: [:e | raw ]
				].
			^classMirror source
		)
		public inactiveTestingSubject = (
			#NAMESPACEBOGUS.
			^ide minitestUI TestingOutcomeSubject onConfiguration: (ide namespacing Root at: name)
				platform: cachedPlatform
				minitest: ide minitest
		)
		public isTestConfiguration = (
			^isTopLevel and: [
					classMirror primaryFactorySelector = #packageTestsUsing: or: [
							classMirror classSide methods includesMirrorNamed: #packageTestsUsing:
						]
				]
		)
		public createPresenter = (
			^chosenPresenter
		)
		public isTopLevel = (
			^nil = classMirror enclosingClass
		)
		public name = (
			^classMirror name
		)
		public classModel ^<ClassModel> = (
			^model
		)
		public classMirror ^<ClassDeclarationMirror> = (
			^classModel klass
		)
		public enclosingClassSubject ^<ClassSubject> = (
			^isTopLevel ifFalse: [
					ClassSubject onDeclaration: classMirror enclosingClass
				]
		)
		public enclosingClassSubjects ^<List[ClassSubject]> = (
			| them = List new. c |
			c:: classMirror.
			[ c isNil ] whileFalse: [
					them add: (ClassSubject onDeclaration: c).
					c:: c enclosingClass
				].
			^them
		)
		chosenPresenter ^<ObjectPresenter | ClassPresenter> = (
			exemplar isNil ifFalse: [ ^objectSubject presenter ].
			exemplar:: computeExemplarFor: classMirror enclosing: classModel enclosing.
			
			(* (*  Can't happen, as we no longer return a thread from #computeExemplarFor:enclosing *)
  exemplar isKindOfThreadMirror ifTrue: [
    ('Error in exemplar evaluation for ', title) out.
    ^ClassPresenter onSubject: self.
  ]. *)
			exemplar isNil ifTrue: [
					nil ~= (classMirror header metadata at: #exemplar ifAbsent: [ ]) ifTrue: [
							('Error in exemplar evaluation for ' , title) out
						].
					^ClassPresenter onSubject: self
				].
			classModel exemplar: exemplar.
			^objectSubject presenter openClass: true;
				yourself
		)
		public deleteClass = (
			| builder |
			nil = classMirror enclosingClass ifTrue: [ ^deleteTopLevelClassNamed: name ].
			builder:: classMirror enclosingClass asBuilder.
			builder instanceSide nestedClasses removeMirrorNamed: classMirror name.
			ide installFromBuilders: {builder. }
		)
		public bytesForVictoryFuelWithHopscotch ^<ByteArray> = (
			^bytesForVictoryFuelWithRuntime: ide psoupWithHopscotchDeploymentRuntime
		)
		public nonExemplarPresenter ^<ClassPresenter> = (
			^ClassPresenter onSubject: self
		)
		public deployAsNSO = (
			| appDef <Class> = ide namespacing Root at: name. |
			ide deployment deployApp: appDef
		)
		public runApp: paused = (
			| manifest = ide namespacing manifest. appConfig args = {}. thread |
			appConfig:: ide namespacing Root at: name
				ifAbsent: [
					
					(* If the app's class was not in the IDE namespace, we will put it there *)
					
					(* An app must be top level; it cannot be dependent on an enclosing instance *)
					isTopLevel ifFalse: [
							'runApp: says Apps must be top level' out.
							^self
						].
					
					(* Put the app's class in the IDE namespace *)
					ide namespacing Root at: name put: classMirror applyToObject reflectee
				].
			thread:: ActivationMirror invokeSuspended: 
				(* bogus: No guarantee that all the dependencies are in the root namespace. *)
				[ (appConfig packageUsing: manifest) main: AppPlatform new args: args ].
			paused ifFalse: [ thread resume ].
			thread isFulfilled ifFalse: [
					Utilities enterSubject: (ide debugging ThreadSubject onModel: thread)
				]
		)
		public typecheckReportSubject ^<ClassTypecheckReportSubject> = (
			(* Typecheck this class and all nested classes (header, instance and
	   class methods, lazy slots). Populates each member's typeErrorMessages
	   banner (errors only) as a side effect, and returns a summary report
	   subject listing every member. One typechecker is shared across the
	   whole walk. *)
			
			| tc <NewspeakTypechecker> = ide freshTypechecker. entries <List[TypecheckReportEntry]> = List new. |
			collectTypecheckEntriesWith: tc into: entries prefix: ''.
			^ClassTypecheckReportSubject onClassNamed: name entries: entries
		)
		public collectTypecheckEntriesWith: tc <NewspeakTypechecker> into: entries <List[TypecheckReportEntry]> prefix: prefix <String> = (
			| mixin = classMirror instanceSide. classSideMixin = classMirror classSide. |
			addEntryTo: entries
				label: prefix , name , ' (class header)'
				banner: factorySubject
				nav: self
				errors: [ tc typecheckClassHeader: classHeaderSource ofClass: mixin ].
			methodsSubject elements do: [:ms <MethodSubject> |
					addEntryTo: entries
						label: prefix , ms name , ' (method)'
						banner: ms
						nav: ms
						errors: [ tc typecheckMethodSource: ms source ofClass: mixin ]
				].
			classMethodsSubject elements do: [:ms <MethodSubject> |
					addEntryTo: entries
						label: prefix , ms name , ' (class method)'
						banner: ms
						nav: ms
						errors: [ tc typecheckMethodSource: ms source ofClass: classSideMixin ]
				].
			lazySlotsSubject elements do: [:ls <LazySlotSubject> |
					addEntryTo: entries
						label: prefix , ls name , ' (lazy slot)'
						banner: ls
						nav: ls
						errors: [ tc typecheckLazySlot: ls source ofClass: mixin ]
				].
			nestedClassesSubject elements do: [:nc <ClassSubject> |
					nc collectTypecheckEntriesWith: tc
						into: entries
						prefix: prefix , name , ' >> '
				]
		)
		addEntryTo: entries <List[TypecheckReportEntry]> label: lbl <String> banner: bannerSubject <Subject> nav: navSubject <Subject> errors: errorBlock <[Set]> = (
			| errs <Set> messages <List[String]> = List new. failure <String> |
			failure:: nil.
			errs:: errorBlock on: Error
				do: [:e <Error> |
					failure:: 'Typechecker failed: ' , e printString.
					nil
				].
			failure isNil ifFalse: [ messages add: failure ]
				ifTrue: [
					errs do: [:e |
							messages add: 'Type error: ' , e message , ' [' , e start printString , '-' , e end printString , ']'
						]
				].
			bannerSubject clearTypeErrors.
			messages do: [:m <String> | bannerSubject typeErrorMessages add: m ].
			entries add: (TypecheckReportEntry label: lbl
					bannerSubject: bannerSubject
					navSubject: navSubject
					messages: messages
					hasErrors: messages isEmpty not)
		)
		instanceExemplar ^<ObjectMirror | Nil> = (
			(* The exemplar to use as a live 'self' for the INSTANCE side of the presented class.
     [exemplar] is valid for that only when it really is an instance of the class. When a
     class object is being inspected, the same class is presented but [exemplar] is the
     class object itself - a valid receiver for class-side methods only, never an instance
     of the class. In that case there is no instance in hand, so return nil and let the
     instance-side groups fall back to a fabricated exemplar (or none), exactly as when a
     class presenter is opened without an inspected object. *)
			
			exemplar isNil ifTrue: [ ^nil ].
			exemplar getClass isMeta ifTrue: [ ^nil ].
			^exemplar
		)
	) : (
		public fromModel: cm <ClassModel> ^<Instance> = (
			^onClassModel: cm
		)
		public onDeclaration: cd <ClassDeclarationMirror> ^<Instance> = (
			^onClassModel: (ClassModel declaration: cd exemplar: nil)
		)
		public onModel: cm <ClassModel> ^<Instance> = (
			^onClassModel: cm
		)
	)
	public class TypecheckReportEntry label: lbl <String> bannerSubject: bs <Subject> navSubject: ns <Subject> messages: msgs <List[String]> hasErrors: he <Boolean> = Object new (
		(* One row of a whole-class typecheck report: a member's display label, the
   subject whose banner was populated, the subject to navigate to when the
   label is clicked, the formatted error messages, and whether any were found. *)
		
		|
			public label <String> = lbl.
			public bannerSubject <Subject> = bs.
			public navSubject <Subject> = ns.
			public messages <List[String]> = msgs.
			public hasErrors <Boolean> = he.
		|
	) (
	) : ()
	public class ClassTypecheckReportSubject onClassNamed: cn <String> entries: es <List[TypecheckReportEntry]> = Subject onModel: cn (
		(* A transient summary of typechecking a whole class (and its nested classes).
   Built by ClassSubject>>typecheckReportSubject. *)
		
		|
			public className <String> = cn.
			public entries <List[TypecheckReportEntry]> = es.
		|
	) (
		public createPresenter ^<Presenter> = (
			^ClassTypecheckReportPresenter onSubject: self
		)
		public title ^<String> = (
			^'Typecheck: ' , className
		)
		public refreshmentSubject ^<Subject> = (
			(* The report is a point-in-time snapshot; there is nothing to recompute. *)
			
			^self
		)
		public isKindOfClassTypecheckReportSubject ^<Boolean> = (
			^true
		)
		isMyKind: s <Subject> ^<Boolean> = (
			^s isKindOfClassTypecheckReportSubject
		)
	) : ()
	public class ClassTypecheckReportPresenter onSubject: s <ClassTypecheckReportSubject> = ProgrammingPresenter onSubject: s (
		(* Renders a whole-class typecheck report: a title, then one block per member
   with the member name as a link (navigating to the member) followed by its
   red error lines or a green 'No type errors.' confirmation. *)
		
	) (
		public definition ^<Fragment> = (
			| rows <List[Fragment]> = List new. |
			rows add: (label: subject title) bold.
			rows add: smallBlank.
			subject entries do: [:entry <TypecheckReportEntry> |
					rows add: (entryRow: entry)
				].
			^column: rows
		)
		entryRow: entry <TypecheckReportEntry> ^<Fragment> = (
			| rows <List[Fragment]> = List new. |
			rows add: ((link: entry label action: [ enterSubject:: entry navSubject ]) color: actionLinkColor).
			entry hasErrors ifTrue: [
					entry messages do: [:m <String> |
							rows add: ((label: m) color: (Color r: 0.7 g: 0 b: 0))
						]
				]
				ifFalse: [
					rows add: ((label: 'No type errors.') color: (Color r: 0 g: 0.5 b: 0))
				].
			rows add: smallBlank.
			^column: rows
		)
		public isKindOfClassTypecheckReportPresenter ^<Boolean> = (
			^true
		)
		isMyKind: other <Fragment> ^<Boolean> = (
			^other isKindOfClassTypecheckReportPresenter
		)
	) : ()
	public class DefinitionListPresenter onSubject: s = ProgrammingPresenter onSubject: s (
		(* DefinitionListPresenter is an abstract superclass of presenters that displays helper ''transient'' presenters that visually appear to belong to the main list of subject presenters. One common example is a method list presenter which can at times include presenters for methods being added. *)
		
	) (
		lazy public state <DefinitionListPresenterState> ::= DefinitionListPresenterState new.
		lazy contentList <ToggleList> = taggedColumn: contentPresenters.
		addButton = (
			^addButtonWithAction: [ updateGUI: [ respondToAdd ] ]
		)
		public addNewItemTemplate = (
			(* A subclass must redefine this to show a template for the user to fill out to create a new item in the group. *)
			
			subclassResponsibility
		)
		public collapseAll = (
			(* Collapse all presenters in the content list. This operation depends on the type of content elements, so it is applicable often but not always. Still, it's handy to have it here available for reuse. *)
			
			contentList childrenDo: [:each <ToggleComposer> | each collapse ]
		)
		definitionListMenu = (
			subclassResponsibility
		)
		public expandAll = (
			(* Expand all presenters in the content list. This operation depends on the type of content elements, so it is applicable often but not always. Still, it's handy to have it here available for reuse. *)
			
			contentList childrenDo: [:each <ToggleComposer> | each expand ]
		)
		public isKindOfDefinitionListPresenter ^<Boolean> = (
			^true
		)
		isMyKind: f <Fragment> ^<Boolean> = (
			^f isKindOfDefinitionListPresenter
		)
		respondToAdd = (
			addNewItemTemplate
		)
		public title = (
			subclassResponsibility
		)
		updateVisualsFromSameKind: oldPresenter <Self> ^<Alien[Element]> = (
			state:: oldPresenter state.
			substanceSlot:: nil.
			ensureSubstance.
			^super updateVisualsFromSameKind: oldPresenter
		)
		definition ^<Fragment> = (
			^column: {helpSection. minorHeadingBlock: (row: {(label: title) bold. defaultBlank. addButton. filler. expandButtonWithAction: [
								expandAll
							]. defaultBlank. collapseButtonWithAction: [ collapseAll ]. defaultBlank. refreshButton. defaultBlank. helpButton. defaultBlank. dropDownMenu: [
								definitionListMenu
							]. }). state prefixHolder. contentList. }
		)
		listDescription ^<String> = (
			subclassResponsibility
		)
		elementDescription ^<String> = (
			subclassResponsibility
		)
		menuOperationsHelp ^<String> = (
			^'inspecting this presenter'
		)
		buttonListHelp ^<String> = (
			^'  <li> <div class="hopscotchAddButton"> </div>Add an element to the list.</li>
  <li> <div class="hopscotchExpandAllButton"> </div>Expands all elements of the list.</li>
  <li> <div class="hopscotchCollapseAllButton"> </div>Collapses all elements of the list.</li>
  <li> <div class="hopscotchRefreshButton"> </div> Refreshes the list (just in case of UI bugs).</li>
  <li> <div class="hopscotchHelpButton"> </div> Shows this help message.</li>
  <li> <div class="definitionListMenuButton"> </div> Opens a menu of additional operations, ' , menuOperationsHelp , '.</li>'
		)
		specificHelp ^<String> = (
			^''
		)
		helpText = (
			| mapping = Map new. |
			mapping at: #hopscotchAddButton put: addButton;
				at: #hopscotchExpandAllButton put: (expandButtonWithAction: [ expandAll ]);
				at: #hopscotchCollapseAllButton
					put: (collapseButtonWithAction: [ collapseAll ]);
				at: #definitionListMenuButton put: (dropDownMenu: [ definitionListMenu ]);
				at: #hopscotchHelpButton put: helpButton;
				at: #hopscotchRefreshButton put: refreshButton.
			^ampleforth: 'This is a ' , listDescription , ' presenter.  It lists the ' , elementDescription , '.
  The elements of the list are collapsed by default. You can open an element by clicking on it; or you can click on the toggle to its left to expand or collapse it. The list also provides the following buttons:
  <ul>
  ' , buttonListHelp , '  
  </ul>
  ' , specificHelp
				mapping: mapping
		)
	) : ()
	public class DefinitionListPresenterState new = Object new (
		|
			prefixes <List[DefinitionTemplate]> = List new.
			prefixPresenter = PrefixPresenter new.
			public prefixHolder <HolderComposer> = prefixPresenter holder: fragmentForPrefixes.
		|
	) (
		class PrefixPresenter new = Presenter onSubject: nil (
			(* A trick/hack to give the enclosing object access to the fragment factories it needs.
The only way to create fragments outside the Hopscotch module is via the factories inherited from Presenter.
DefinitionListPresenterState is not a presenter, and yet it manufactures bits of presentation. Hence, we create
this presenter class, which publicizes the required inherited factories. Each instance of DefinitionListPresenterState has a single instance of this class,
which it uses to access the needed factories. *)
			
		) (
			public column: ds <List[Fragment]> ^<ColumnComposer> = (
				^super column: ds
			)
			public holder: c <Fragment> ^<HolderComposer> = (
				^super holder: c
			)
			public isKindOfPrefixPresenter ^<Boolean> = (
				^true
			)
			isMyKind: f <Fragment> ^<Boolean> = (
				^f isKindOfPrefixPresenter
			)
		) : ()
		public addPrefix: p <DefinitionTemplate> = (
			prefixes add: p.
			updatePrefixes
		)
		fragmentForPrefixes ^<Fragment> = (
			^prefixPresenter column: prefixes
		)
		public isKindOfDefinitionListPresenterState ^<Boolean> = (
			^true
		)
		public removePrefix: p <DefinitionTemplate> = (
			prefixes remove: p.
			updatePrefixes
		)
		updatePrefixes = (
			prefixHolder isNil ifFalse: [ prefixHolder content: fragmentForPrefixes ]
		)
	) : ()
	public class DefinitionListSubject onModel: m = Subject onModel: m (
		(* DefinitionListSubject manages helper ''transient'' subjects, for example a method list which can at times include presenters for methods being added or residue presenters of removed methods. *)
		
		|
			public prefixes <List[Fragment]> = List new.
			public content <List[Subject]> = List new.
		|
	) (
		public createPresenter ^<DefinitionListPresenter> = (
			^DefinitionListPresenter onSubject: self
		)
		public isKindOfDefinitionListSubject ^<Boolean> = (
			^true
		)
		isMyKind: s <Subject> ^<Boolean> = (
			^s isKindOfDefinitionListSubject
		)
	) : ()
	public class DefinitionTemplate caption: c <String> initialText: t <String | Text> colorizerBlock: cb <[:String :CodeMirrorFragment | Object]> acceptResponse: onAccept <[DefinitionTemplate]> cancelResponse: onCancel <[DefinitionTemplate]> = ProgrammingPresenter onSubject: nil (
		(* A template for a nested definition such as a method or nested class, that may be added to a DefinitionList. *)
		
		|
			public caption = c.
			public initialText = t.
			public initiallyInEditState ::= true.
			public acceptResponse = onAccept.
			public cancelResponse = onCancel.
			public editor
			public colorizerBlock = cb.
		|
	) (
		public = other <Object> ^<Boolean> = (
			other isKindOfDefinitionTemplate ifFalse: [ ^false ].
			^other text = text
		)
		definition ^<Fragment> = (
			^(row: {mediumBlank. elastic: (column: {smallBlank. label: caption. editorDefinition. mediumBlank. }). smallBlank. }) color: (Gradient from: (Color h: 100
						s: 0.3
						v: 0.9)
					to: (Color h: 100 s: 0.3 v: 0.8))
		)
		editorDefinition ^<Fragment> = (
			editor:: 
			(* acceptLabelText: 'save';
		cancelLabelText: 'cancel'; *)
			(codeMirror: initialText) acceptResponse: [ acceptResponse value: self ];
				changeResponse: [:cm <CodeMirrorFragment> :event <Event> |
						colorizerBlock value: cm textBeingAccepted value: cm
					];
				cancelResponse: [ cancelResponse value: self ].
			initiallyInEditState ifTrue: [ editor updateEditState ].
			colorizerBlock value: initialText value: editor.
			^editor
		)
		public hash ^<Integer> = (
			^text hash
		)
		public isKindOfDefinitionTemplate ^<Boolean> = (
			^true
		)
		isMyKind: f <Fragment> ^<Boolean> = (
			^f isKindOfDefinitionTemplate
		)
		public tag ^<String> = (
			^printString
		)
		public text = (
			^editor textBeingAccepted
		)
	) : ()
	public class EntryPresenter onSubject: s = ProgrammingPresenter onSubject: s (
	) (
		public collapse = (
			substance collapse
		)
		public expand = (
			substance expand
		)
		public isKindOfEntryPresenter ^<Boolean> = (
			^true
		)
		isMyKind: f <Fragment> ^<Boolean> = (
			^f isKindOfEntryPresenter
		)
		row1: row1 row2: row2 = (
			^row: {(row: row1) width: 0 elasticity: 1. (row: {mediumBlank. } , row2) width: 0
					elasticity: 2. }
		)
		definition = (
			^collapsed: [ collapsedDefinition ] expanded: [ expandedDefinition ]
		)
		entryActionsMenuFor: key = (
			^menuWithLabelsAndActions: {{'Add to namespace…'. [
					respondToAddEntry: key toNamespace: nil
				]. }. {'Remove ' , key. [ updateGUI: [ ide namespacing removeKey: key ] ]. }. {'Inspect Presenter'. [
					respondToInspectPresenter
				]. }. }
		)
		respondToAddEntry: key toNamespace: ignored = (
			(* Pull this entry into another namespace by Root key. The picker
	   is a non-modal InteractionSubject prompt; on accept, the target
	   is validated and the entry copied. Validation failures and the
	   success path log to the JS console (no per-namespace status
	   banner yet) -- successful adds also re-render the namespace
	   via updateGUI: so the new entry shows up. *)
			
			| val |
			val:: ide namespacing Root at: key asSymbol
				ifAbsent: [
					cachedPlatform js global console log: 'Cannot find ' , key , ' in Root.'.
					^nil
				].
			enterSubject:: ide browsing InteractionSubject prompt: 'Add ' , key , ' to which namespace (Root key)?'
				default: ''
				onAccept: [:targetName |
					(targetName isNil or: [ targetName isEmpty ]) ifFalse: [
							doAddEntry: key value: val toNamespaceName: targetName
						]
				]
				returnTo: subject
		)
		doAddEntry: key <Symbol | String> value: val toNamespaceName: targetName <String> = (
			| target |
			target:: ide namespacing Root at: targetName asSymbol ifAbsent: [ nil ].
			target isNil ifTrue: [
					cachedPlatform js global console log: 'No namespace named ' , targetName , ' in Root.'.
					^nil
				].
			[ target at: key asSymbol put: val ] on: Exception
				do: [:e |
					cachedPlatform js global console log: targetName , ' is not a namespace: ' , e messageText.
					^nil
				].
			updateGUI: [ ].
			cachedPlatform js global console log: 'Added ' , key , ' to ' , targetName , '.'
		)
	) : ()
	public class EvaluationViewState onModel: m <ObjectMirror | ActivationMirror> = Object new (
		(* An evaluator maintains a list of results of prior evaluations. *)
		
		|
			public mirror <ObjectMirror | ActivationMirror> = m.
			results_slot <List[ThreadMirror]> ::= List new.
			public lastEvalWasLive <Boolean> ::= false.
			public isLive <Boolean> ::= false.
			lastExpression_slot <String> ::= 'nil'.
			transcriptBuffer <String> ::= ''.
		|
	) (
		public isKindOfEvaluationViewState ^<Boolean> = (
			^true
		)
		public results ^<List[ThreadMirror]> = (
			^results_slot
		)
		public = another <Object> ^<Boolean> = (
			^another isKindOfEvaluationViewState and: [ mirror = another mirror ]
		)
		public hash ^<Integer> = (
			^self class hash bitXor: mirror hash
		)
		public lastExpression = (
			^lastExpression_slot
		)
		public lastResult = (
			^results_slot add: ([ mirror evaluate: lastExpression_slot ] on: Error
					do: [:ce | ce ])
		)
		public evaluateLive: e <String> ^<ThreadMirror> = (
			| result = [ mirror evaluate: e ] on: Error do: [:ce | ce ]. |
			^lastEvalWasLive ifTrue: [
					lastExpression_slot:: e.
					(e isEmpty not and: [ e last = '.' last ]) ifTrue: [
							lastEvalWasLive:: false
						].
					results_slot at: results_slot size put: result
				]
				ifFalse: [
					lastEvalWasLive:: e last ~= '.' last.
					results_slot add: result
				]
		)
		public results: rs <List[ThreadMirror]> ^<List[ThreadMirror]> = (
			results_slot:: rs
		)
		public lastExpression: e <String> = (
			lastExpression_slot:: e
		)
		public evaluate: e <String> ^<ThreadMirror> = (
			lastEvalWasLive:: false.
			lastExpression_slot:: e.
			^results_slot add: ([ mirror evaluate: e ] on: Error do: [:ce | ce ])
		)
		public clear = (
			results do: [:t |
					t isKindOfThreadMirror ifTrue: [
							(t isBroken or: [ t isSuspended ]) ifTrue: [ t terminate ]
						]
				].
			lastEvalWasLive:: false.
			results_slot:: List new
		)
		public transcript ^<String> = (
			^transcriptBuffer
		)
		public cr = (
			show: String lf
		)
		public print: o = (
			show: o printString
		)
		public show: message <String> = (
			transcriptBuffer: transcriptBuffer , message
		)
	) : ()
	class HomePresenter onSubject: s = ProgrammingPresenter onSubject: s (
	) (
		aboutSystemDefinition = (
			^(label: 'Newspeak WebIDE — ' , ide buildVersion) smallFont
		)
		actionsMenu = (
			^menuWithLabelsAndActions: {{'Inspect Presenter'. [
					respondToInspectPresenter
				]. }. }
		)
		column1: definitions1 column2: definitions2 column3: definitions3 = (
			^row: {(column: definitions1) width: 0 elasticity: 1. (column: definitions2) width: 0
					elasticity: 1. (column: definitions3) width: 0 elasticity: 1. }
		)
		didYouKnow = (
			| wisdom |
			wisdom:: subject randomBitOfWisdom.
			nil = wisdom actionLabel ifFalse: [ ^textAndActionWisdom: wisdom ].
			nil = wisdom image ifFalse: [ ^textAndImageWisdom: wisdom ].
			^textDisplay: wisdom text
		)
		public isKindOfHomePresenter ^<Boolean> = (
			^true
		)
		navigateToNamespace = (
			enterSubject:: NamespaceSubject new
		)
		navigateToWorkspaces = (
			enterSubject:: ide theWorkspaceManager AllWorkspacesSubject new
		)
		navigateToRepositories = (
			enterSubject:: ide repositories list
		)
		textAndActionWisdom: wisdom = (
			^column: {textDisplay: wisdom text. (link: wisdom actionLabel
					action: wisdom actionBlock) smallFont. }
		)
		textAndImageWisdom: wisdom = (
			^row: {(image: wisdom image) height: styleButtonSize. mediumBlank. elastic: (textDisplay: wisdom text). }
		)
		definition = (
			^column: {helpSection. majorHeadingBlock: (row: {(label: 'Navigation') bold. filler. helpButton. dropDownMenu: [
								actionsMenu
							]. }). mediumBlank. indentedBlock: (column1: {link: 'Newspeak Source'
							action: [ navigateToNamespace ]. }
						column2: {link: 'Workspaces' action: [ navigateToWorkspaces ]. }
						column3: {link: 'Repositories' action: [ navigateToRepositories ]. }). mediumBlank. 
				(* majorHeadingBlock: (label: 'Recently Visited' asText allBold).
		mediumBlank.
		indentedBlock:
			(holder: [recentStuffDefinition]).
		largeBlank. *)
				majorHeadingBlock: (label: 'Did you know?') bold. mediumBlank. indentedBlock: (holder: [
							didYouKnow
						]). mediumBlank. indentedBlock: aboutSystemDefinition. }
		)
		isMyKind: f <Fragment> ^<Boolean> = (
			^f isKindOfHomePresenter
		)
		public helpText ^<Fragment> = (
			| mapping = Map new. |
			mapping at: #hopscotchHelpButton put: helpButton;
				at: #hopscotchMenu put: (dropDownMenu: [ actionsMenu ]).
			^ampleforth: 'This is the IDE''s home page.<br><br>
The home page includes links to a variety of useful places, like the workspace manager, where you can evaluate code, and the IDE''s root namespace, which lists all top level classes and documents.<br> Directly above those links are the following widgets:
<ul>
<li><div class="hopscotchHelpButton"> </div> The help button, which shows this help message.</li>
<li><div class="hopscotchMenu"> </div> The menu button. The only item in it is ''Inspect Presenter'' which will take you to an object inspector on this presenter (the home presenter). Inspect presenter is found in almost every menu; it lets you immediately find out what code is controlling the UI you are using at that point. It''s a great way to learn about the system.</li>
</ul>
'
				mapping: mapping
		)
	) : ()
	public class HomeSubject onModel: m
	(* :exemplar: HomeSubject new *)
	 = ProgrammingSubject onModel: m (
		(* The Home screen is stateful.  The state is simply whether the
    help text is displayed or not. *)
		
	) (
		public = anotherSubject <Subject> ^<Boolean> = (
			(* As there is just one possible logical home of the system, all subjects representing it are considered equal. *)
			
			^anotherSubject isKindOfHomeSubject
		)
		public isKindOfHomeSubject ^<Boolean> = (
			^true
		)
		isMyKind: s <Subject> ^<Boolean> = (
			^s isKindOfHomeSubject
		)
		public randomBitOfWisdom = (
			| bits = bitsOfWisdom. |
			^(bits at: (JSMath random * bits size) floor asInteger + 1) value
		)
		public hash ^<Integer> = (
			^self class hash
		)
		public createPresenter = (
			^HomePresenter onSubject: self
		)
		public title = (
			^'Newspeak Home'
		)
		bitsOfWisdom = (
			(* This defines the bits of wisdom displayed at the bottom of the Hopscotch home page. Each time a page opens a new element is selected at random. An element may evaluate to nil, which will select another element at random. *)
			
			^{[
				BitOfWisdom text: 'This is the "expand all" button which appears in headers of expandable item groups.'
					image: ide images expandImage
			]. [
				BitOfWisdom text: 'This is the "collapse all" button which appears in headers of expandable item groups.'
					image: ide images collapseImage
			]. [
				BitOfWisdom text: 'This is the "add" button which appears in headers of groups of items you can add to, such as methods of a class or classes of a package.'
					image: ide images addImage
			]. 
			(* (*Untrue. Also not the right thing to do *)
	[BitOfWisdom
		text: 'Expressions evaluated in debuggers and inspectors can access a workspace via the name _. This allows you to bypass modularity during development and access values you forgot to import, e.g. _ collections List.']. *)
			[
				BitOfWisdom text: 'This icon identifies Newspeak classes.'
					image: ide images classImage
			]. [
				BitOfWisdom text: 'This icon identifies namespaces.'
					image: ide images classPresenterImage
			]. [
				BitOfWisdom text: 'War is peace. Freedom is slavery. Ignorance is strength.'
			]. }
		)
	) : (
		public new = (
			^onModel: nil
		)
	)
	class IntegerView onSubject: s = ProgrammingPresenter onSubject: s (
	) (
		public definition = (
			^column: {label: 'binary' radix: 2. label: 'octal' radix: 8. label: 'decimal'
					radix: 10. label: 'hex' radix: 16. }
		)
		public isKindOfIntegerView ^<Boolean> = (
			^true
		)
		isMyKind: other <Fragment> ^<Boolean> = (
			^other isKindOfIntegerView
		)
		label: label radix: radix = (
			^row: {smallBlank. (label: label) width: 0 elasticity: 1. smallBlank. (label: (subject objectMirror reflectee asStringRadix: radix)) width: 0
					elasticity: detailAreaRatio. }
		)
	) : ()
	class KeysAndValuesView title: t onSubject: s = ProgrammingPresenter onSubject: s (
		|
			public title <String> = t.
		|
	) (
		public isKindOfKeysAndValuesView ^<Boolean> = (
			^true
		)
		isMyKind: other <Fragment> ^<Boolean> = (
			^other isKindOfKeysAndValuesView
		)
		public definition = (
			^taggedColumn: (subject keysAndValues collect: [:slot <SlotSubject> |
						slot presenter
					])
		)
	) : (
		public onSubject: s = (
			^title: s classMirror mixin name onSubject: s
		)
	)
	class LazySlotGroupPresenter onSubject: s <Subject> = MirrorGroupPresenter onSubject: s (
		(* Presents the subject, an NSLazySlotGroup, as a column of presenters for the lazy slots in the group. Automatically gets updated after the subject mirror group. Anything that has to do with adding, editing or deleting NS lazy slots goes here. *)
		
		|
			groupedByCategory <Boolean> ::= false.
		|
	) (
		public deleteLazySlotInPresenter: presenter <Presenter> ifSuccess: successResponse <[]> ifFailure: failureResponse <[]> = (
			updateGUI: [
					subject deleteLazySlotWithSubject: presenter subject.
					successResponse value
				]
		)
		public title = (
			^' Lazy slots'
		)
		listDescription ^<String> = (
			^' Lazy slots'
		)
		elementDescription ^<String> = (
			^'Lazy slots of the surrounding class'
		)
		public addNewItemTemplate = (
			(* Handle a user's request to create a new lazy slot by displaying a new lazy slot template. *)
			
			addNewItemTemplate: subject lazySlotTemplateText
		)
		public addNewItemTemplate: src = (
			(* Handle a user's request to create a new lazy slot by displaying a new lazy slot template. *)
			
			| template prefixState <DefinitionListPresenterState> = state. |
			template:: DefinitionTemplate caption: 'Adding new lazy slot:'
				initialText: src
				colorizerBlock: [:text <String> :cm <CodeMirrorFragment> |
					subject colorizeSource: text editor: cm
				]
				acceptResponse: [:ed | createNewLazySlotFromTemplate: template ]
				cancelResponse: [:ed | updateGUI: [ prefixState removePrefix: template ] ].
			updateGUI: [ prefixState addPrefix: template ]
		)
		createNewLazySlotFromTemplate: template <DefinitionTemplate> = (
			| prefixState <DefinitionListPresenterState> = state. |
			subject compileSource: template text
				ifSuccess: [:newSlot <LazySlotMirror> |
					prefixState removePrefix: template.
					updateGUI: [ ]
				]
				ifFailure: [:message | template editor showMessage: message ]
		)
		elementPresenterClass ^<ProgrammingPresenter class> = (
			^LazySlotPresenter
		)
	) : ()
	public class LazySlotGroupSubject onModel: m <MirrorGroupModel[LazySlotMirror]> = MirrorGroupSubject onModel: m (
		(* Represents the collection of lazy slots of a Newspeak class. Holds onto the mirror group for the lazy slots. *)
		
	) (
		elementFor: m <Mirror> = (
			^elementModelClass mirror: m exemplar: exemplar
		)
		public createPresenter = (
			^LazySlotGroupPresenter onSubject: self
		)
		elementSubjectClass ^<MethodSubject class> = (
			^LazySlotSubject
		)
		public isKindOfLazySlotGroupSubject ^<Boolean> = (
			^true
		)
		isMyKind: s <Subject> ^<Boolean> = (
			^s isKindOfLazySlotGroupSubject
		)
		modelMirrorCollection ^<Collection[Mirror]> = (
			^List withAll: definingMixin lazySlots
		)
		elementModelClass ^<LazySlotModel class> = (
			^LazySlotModel
		)
		public colorizeSource: source <String> editor: cm <CodeMirrorFragment> ^<TextFragment> = (
			^ide colorizer colorizeLazySlot: source
				fromClass: definingMixin declaration
				via: (colorizingBlockFor: cm)
		)
		public compileSource: source <String> ifSuccess: successBlock <[:MethodMirror | Object]> ifFailure: failureBlock <[:String | Object]> = (
			(* Run the source through prettyPrintLazySlotOr: first so the
	   stored declaration matches what the pretty printer would
	   emit on reopen -- enforces canonical formatting at accept
	   time. Falls back to the original on any printer failure. *)
			
			| canonical |
			canonical:: ide prettyPrintLazySlotOr: source.
			[
				| builder <MixinBuilder> newBuilder <LazySlotBuilder> newMirror <LazySlotMirror> |
				builder:: definingMixin asBuilder.
				newBuilder:: builder lazySlots addFromSource: canonical.
				ide installFromBuilders: {builder declaration. }.
				newMirror:: definingMixin lazySlots findMirrorNamed: newBuilder name.
				successBlock value: newMirror
			] on: Error do: [:ex <Exception> | failureBlock value: ex printString ]
		)
		public lazySlotTemplateText ^<String> = (
			^'lazy slotName = expression.'
		)
		public deleteLazySlotWithSubject: lazySlotSubject <LazySlotSubject> = (
			| builder <MixinBuilder> |
			builder:: definingMixin asBuilder.
			builder lazySlots removeMirrorNamed: lazySlotSubject selector.
			ide installFromBuilders: {builder declaration. }
		)
	) : ()
	class MethodGroupPresenter onSubject: s <Subject> = MirrorGroupPresenter onSubject: s (
		(* Presents the subject, an NSMethodGroup, as a column of presenters for the methods in the group. Automatically gets updated after the subject mirror group. Anything that has to do with adding, editing or deleting NS methods goes here. *)
		
		|
			groupedByCategory <Boolean> ::= false.
		|
	) (
		public addNewItemTemplate = (
			(* Handle a user's request to create a new method by displaying a new method template. *)
			
			addNewItemTemplate: subject methodTemplateText
		)
		createNewMethodFromTemplate: template <DefinitionTemplate> = (
			| prefixState <DefinitionListPresenterState> = state. |
			subject compileSource: template text
				ifSuccess: [:newMethod <MethodMirror> |
					
					(* newSubject <MethodSubject> = MethodSubject onModel: newMethod.
			newPresenter <MethodPresenter> = createPresenterForSubject: newSubject. *)
					
					(* newToggle <ToggleComposer> = newPresenter visual; substance. *)
					prefixState removePrefix: template.
					updateGUI: [ ]
				]
				ifFailure: [:message | template editor showMessage: message ]
		)
		public deleteMethodInPresenter: presenter <Presenter> ifSuccess: successResponse <[]> ifFailure: failureResponse <[]> = (
			updateGUI: [
					subject deleteMethodWithSubject: presenter subject.
					successResponse value
				]
		)
		elementPresenterClass ^<ProgrammingPresenter class> = (
			^MethodPresenter
		)
		public title = (
			| side = subject definingMixin isMeta ifTrue: [ 'Class' ]
				ifFalse: [ 'Instance' ]. |
			^side , ' Methods'
		)
		public addNewItemTemplate: src = (
			(* Handle a user's request to create a new method by displaying a new method template. *)
			
			| template prefixState <DefinitionListPresenterState> = state. |
			template:: DefinitionTemplate caption: 'Adding new method:'
				initialText: src
				colorizerBlock: [:text <String> :cm <CodeMirrorFragment> |
					subject colorizeSource: text editor: cm
				]
				acceptResponse: [:ed | createNewMethodFromTemplate: template ]
				cancelResponse: [:ed | updateGUI: [ prefixState removePrefix: template ] ].
			updateGUI: [ prefixState addPrefix: template ]
		)
		listDescription ^<String> = (
			| side = subject definingMixin isMeta ifTrue: [ 'class' ]
				ifFalse: [ 'instance' ]. |
			^side , ' methods'
		)
		elementDescription ^<String> = (
			| side = subject definingMixin isMeta ifTrue: [ 'class' ]
				ifFalse: [ 'instance' ]. |
			^side , ' methods of the surrounding class'
		)
	) : ()
	public class MethodGroupSubject onModel: m <MirrorGroupModel[MethodMirror]> = MirrorGroupSubject onModel: m (
		(* Represents the collection of methods of a Newspeak class. Holds onto the mirror group for the methods. *)
		
	) (
		elementFor: m <Mirror> = (
			^elementModelClass mirror: m exemplar: exemplar
		)
		public colorizeSource: source <String> editor: cm <CodeMirrorFragment> ^<TextFragment> = (
			^ide colorizer colorizeMethod: source
				fromClass: definingMixin declaration
				via: (colorizingBlockFor: cm)
		)
		public createPresenter = (
			^MethodGroupPresenter onSubject: self
		)
		elementSubjectClass ^<MethodSubject class> = (
			^MethodSubject
		)
		public isKindOfMethodGroupSubject ^<Boolean> = (
			^true
		)
		isMyKind: s <Subject> ^<Boolean> = (
			^s isKindOfMethodGroupSubject
		)
		public methodTemplateText ^<String> = (
			^'messageSelector = (
)'
		)
		public compileSource: source <String> ifSuccess: successBlock <[:MethodMirror | Object]> ifFailure: failureBlock <[:String | Object]> = (
			(* Canonicalise via prettyPrintMethodOr: before compiling. See
	   the LazySlotGroupPresenter sibling above for rationale. *)
			
			| canonical |
			canonical:: ide prettyPrintMethodOr: source.
			[
				| builder <MixinBuilder> newBuilder <MethodBuilder> newMirror <MethodMirror> |
				builder:: definingMixin asBuilder.
				newBuilder:: builder methods addFromSource: canonical.
				ide installFromBuilders: {builder declaration. }.
				newMirror:: definingMixin methods findMirrorNamed: newBuilder name.
				successBlock value: newMirror
			] on: Error do: [:ex <Exception> | failureBlock value: ex printString ]
		)
		public deleteMethodWithSubject: methodSubject <MethodSubject> = (
			| builder <MixinBuilder> |
			builder:: definingMixin asBuilder.
			builder methods removeMirrorNamed: methodSubject selector.
			ide installFromBuilders: {builder declaration. }
		)
		modelMirrorCollection ^<Collection[Mirror]> = (
			^List withAll: definingMixin methods
		)
		elementModelClass ^<MethodModel class> = (
			^MethodModel
		)
	) : ()
	public class LazySlotPresenter onSubject: s <LazySlotSubject> = ProgrammingPresenter onSubject: s (
		(* A presenter for a single lazy slot. *)
		
		|
			public showClassName ::= false.
			
			(* Inline holder for the per-lazy-slot history view, populated by
       the history button click. Same pattern as chatHolder on the
       superclass. *)
			historyHolder = holder: nothing.
			
			(* Captured by codeMirrorDefinition so the 'Pretty Print' menu
       action can address the current editor. *)
			slotEditor <CodeMirrorFragment>
			
			(* Captured by evaluatorDefinition when this slot has exemplars and
       the editor is an EvaluatorPresenter rather than a plain
       CodeMirror. Lets respondToTypecheckSlot read the in-progress
       text via the evaluator's embedded codeMirror. *)
			slotEvaluatorPresenter <EvaluatorPresenter>
		|
	) (
		public historySection = (
			^historyHolder
		)
		installHistory = (
			historyHolder content: (MemberRepoHistorySubject onModel: (MemberRepoHistoryModel forLazySlotModel: subject slotModel)) createPresenter
		)
		toggleHistory = (
			historyHolder content isKindOfBlankFragment ifTrue: [ installHistory ]
				ifFalse: [ historyHolder content: nothing ]
		)
		updateVisualsFromSameKind: oldPresenter <Self> ^<Alien[Element]> = (
			| oldHistory |
			oldHistory:: oldPresenter historySection content.
			oldHistory isKindOfBlankFragment ifFalse: [ installHistory ].
			^super updateVisualsFromSameKind: oldPresenter
		)
		public collapse = (
			^substance collapse
		)
		public expand = (
			^substance expand
		)
		messagesMenu = (
			| messagesAndActions messageItems classItems |
			messagesAndActions:: List new.
			messagesAndActions add: {subject name. [ browseSelector: subject name ]. }.
			messageItems:: referencesMenuMessageItems.
			messageItems isEmpty not ifTrue: [
					messagesAndActions add: #separator;
						addAll: messageItems
				].
			^menuWithLabelsAndActions: messagesAndActions
		)
		nestingInfo = (
			^showClassName ifTrue: [ nestingInformationLine ] ifFalse: [ nothing ]
		)
		nestingInformationLine = (
			| enclosingClasses rowElements |
			enclosingClasses:: subject enclosingClasses.
			rowElements:: List new.
			enclosingClasses do: [:each |
					rowElements add: ((label: ' in ') color: tertiaryTextColor).
					rowElements add: (linkToBrowseEnclosingClass: each)
				].
			^row: rowElements asArray
		)
		public tag ^<String> = (
			^subject name
		)
		errorDisplay: msg <String> ^<Fragment> = (
			^row: {label: msg. button: 'Clear'
					action: [ subject errorMessages remove: msg ]. }
		)
		errorMessages ^<Array[Fragment]> = (
			^(subject errorMessages collect: [:msg <String> | errorDisplay: msg ]) asArray
		)
		typeErrorDisplay: msg <String> ^<Fragment> = (
			| textColor |
			textColor:: msg = 'No type errors.' ifTrue: [ Color r: 0 g: 0.5 b: 0 ]
				ifFalse: [ Color r: 0.7 g: 0 b: 0 ].
			^row: {(label: msg) color: textColor. button: 'Clear'
					action: [ updateGUI: [ subject typeErrorMessages remove: msg ] ]. }
		)
		typeErrorMessages ^<Array[Fragment]> = (
			^(subject typeErrorMessages collect: [:msg <String> | typeErrorDisplay: msg ]) asArray
		)
		editorDefinition ^<CodeMirrorFragment | EvaluatorPresenter> = (
			^hasExemplars ifTrue: [ evaluatorDefinition ]
				ifFalse: [ codeMirrorDefinition ]
		)
		public enclosingObjectPresenter ^<ObjectPresenter | Nil> = (
			| candidate <Fragment> ::= parent. |
			[
				candidate isNil or: [
						candidate isKindOfIDEWindow or: [ candidate isKindOfObjectPresenter ]
					]
			] whileFalse: [ candidate:: candidate parent ].
			candidate isNil ifTrue: [ ^nil ].
			candidate isKindOfIDEWindow ifTrue: [ ^nil ].
			subject methodMirror definingMixin name = candidate subject classMirror mixin name ifFalse: [
					^nil
				].
			^candidate
		)
		enclosingClassPresenter ^<ClassPresenter | Nil> = (
			| candidate <Fragment> ::= parent. |
			[ candidate isKindOfIDEWindow or: [ candidate isKindOfClassPresenter ] ] whileFalse: [
					candidate:: candidate parent
				].
			^candidate isKindOfIDEWindow ifFalse: [ candidate ]
		)
		debugButton ^<ButtonFragment> = (
			hasExemplars ifFalse: [ ^nothing ].
			subject exemplars size = 1 ifTrue: [
					^button: 'Debug' action: [ debugExemplar: subject exemplars first ]
				]
				ifFalse: [
					| messagesAndActions = List new. |
					subject exemplars do: [:ex <String> |
							messagesAndActions add: {ex. [ debugExemplar: ex ]. }
						].
					^dropDownMenu: [ menuWithLabelsAndActions: messagesAndActions ]
				]
		)
		hasExemplars ^<Boolean> = (
			subject exemplars isEmpty ifTrue: [ ^false ].
			
			(* If we have an enclosing object defined, we can proceed *)
			subject enclosingScope isNil ifTrue: [ ^false ].
			^true
		)
		evaluatorDefinition ^<EvaluatorPresenter> = (
			subject threadForExemplar: subject exemplar.
			slotEvaluatorPresenter:: subject evaluator presenter.
			^slotEvaluatorPresenter
		)
		linkToBrowseEnclosingClass: klass <ClassDeclarationMirror> = (
			^(link: klass simpleName
				action: [ enterSubject:: ClassSubject onDeclaration: klass ]) color: secondaryTextColor
		)
		public isKindOfLazySlotPresenter ^<Boolean> = (
			^true
		)
		isMyKind: f <Fragment> ^<Boolean> = (
			^f isKindOfLazySlotPresenter
		)
		acceptResponse ^<[:CodeMirrorFragment :Event | Object]> = (
			^[:ed <CodeMirrorFragment> :event <Event> |
				| b <MixinBuilder> = subject slotMirror definingMixin asBuilder. canonical |
				updateGUI: [
						[
							canonical:: ide prettyPrintLazySlotOr: ed textBeingAccepted.
							b lazySlots addFromSource: canonical.
							ide installFromBuilders: {b declaration. }.
							subject clearTypeErrors.
							[
								ide reportRecheckFrom: (ide typechecker declarationForMember: subject name
										kind: #lazySlot
										ofClass: subject slotMirror definingMixin)
									onSubject: subject
							] on: Error do: [:e <Exception> | ].
							ed text: canonical.
							colorizeLazySlotSource: (crToLf: canonical) withEditor: ed.
							ed leaveEditState
						] on: Error do: [:ex <Exception> | ed showMessage: ex printString ]
					].
				ed editor focus
			]
		)
		colorizeLazySlotSource: s <String> withEditor: cm <CodeMirrorFragment> = (
			ide colorizer colorizeLazySlot: s
				fromClass: subject classDeclaration
				via: (colorizingBlockFor: cm)
		)
		changeResponse ^<[:CodeMirrorFragment :Event | Object]> = (
			^[:ed <CodeMirrorFragment> :event <Event> |
				colorizeLazySlotSource: (crToLf: ed textBeingAccepted) withEditor: ed
			]
		)
		codeMirrorDefinition ^<CodeMirrorFragment> = (
			(* Re-base the source to indent 0 for display (see MethodPresenter). *)
			
			| src = ide prettyPrintLazySlotOr: (crToLf: subject source). cm = codeMirror: src. |
			cm changeResponse: changeResponse;
				cancelResponse: cancelResponse;
				acceptResponse: acceptResponse.
			colorizeLazySlotSource: src withEditor: cm.
			slotEditor:: cm.
			^cm
		)
		respondToPrettyPrint = (
			(* Pretty-print the current lazy-slot source and replace the
       editor contents in place. Does NOT trigger Accept. On parse
       failure, shows an inline message and leaves the text unchanged. *)
			
			| ed source formatted |
			ed:: slotEditor.
			ed isNil ifTrue: [ ^self ].
			source:: ed textBeingAccepted.
			(source isNil or: [ source isEmpty ]) ifTrue: [ source:: subject source ].
			formatted:: [ ide prettyPrinter prettyPrintLazySlot: source ] on: Exception
				do: [:e |
					ed showMessage: 'Pretty print failed: ' , e printString.
					^self
				].
			ed text: formatted.
			colorizeLazySlotSource: (crToLf: formatted) withEditor: ed.
			ed editor focus
		)
		debugExemplar: e <String>
		(* :exemplar1: debugExemplar: 'definition' *)
		 = (
			| thread <ThreadMirror | Error> = subject threadForExemplar: e. |
			thread isKindOfThreadMirror ifTrue: [
					enterSubject:: ide debugging ThreadSubject onModel: thread
				]
				ifFalse: [
					alert: 'internal IDE failure in LazySlotPresenter>>debugExemplar: ' , thread printString
				]
		)
		respondToAddSlotWorkspace = (
			subject threadForExemplar: subject exemplar.
			updateGUI: [ subject addSlotWorkspace ]
		)
		respondToTypecheckSlot = (
			(* Run the typechecker on the current lazy-slot source (editor buffer
       if non-empty, else the installed source) and surface results in
       the typeErrorMessages banner column below the editor.
       Source priority: codeMirror editor (no-exemplar mode), else the
       embedded evaluator's editor (exemplar mode), else the installed
       source. *)
			
			| source typed mixin errs failureMessage |
			typed:: slotEditor isNil ifTrue: [
					slotEvaluatorPresenter isNil ifTrue: [ nil ]
						ifFalse: [ slotEvaluatorPresenter editorText ]
				]
				ifFalse: [ slotEditor textBeingAccepted ].
			source:: (typed isNil or: [ typed isEmpty ]) ifTrue: [ subject source ]
				ifFalse: [ typed ].
			mixin:: subject slotMirror definingMixin.
			subject clearTypeErrors.
			failureMessage:: nil.
			errs:: [ ide typechecker typecheckLazySlot: source ofClass: mixin ] on: Error
				do: [:e |
					failureMessage:: 'Typechecker failed: ' , e printString.
					nil
				].
			updateGUI: [
					failureMessage isNil ifFalse: [
							subject typeErrorMessages add: failureMessage
						]
						ifTrue: [
							errs isEmpty ifTrue: [ subject typeErrorMessages add: 'No type errors.' ]
								ifFalse: [
									errs do: [:e |
											subject typeErrorMessages add: 'Type error: ' , e message , ' [' , e start printString , '-' , e end printString , ']'
										]
								]
						]
				]
		)
		public definition ^<Fragment> = (
			| toggle |
			toggle:: collapsed: [ slotHeader: [ toggle expand ] ]
				expanded: [
					column: {slotHeader: [ toggle collapse ]. editorDefinition. column: errorMessages. column: typeErrorMessages. subject hasSlotWorkspace ifTrue: [
								subject workspace presenter
							]
							ifFalse: [ nothing ]. }
				].
			^toggle
		)
		slotHeader: toggleBlock <[]> ^<Fragment> = (
			^column: {helpSection. row: {accessIndicator. defaultBlank. (link: subject name
						action: toggleBlock) color: actionLinkColor. nestingInfo. filler. deferred: [
							debugButton
						]. smallBlank. dropDownMenu: [ messagesMenu ]
						image: ide images itemReferencesImage. smallBlank. (imageButton: ide images historyImage
						action: [ toggleHistory ]
						size: styleButtonSize) toolTip: 'Show / hide history of this lazy slot'. smallBlank. aiChatButton: [
							| side |
							side:: subject slotMirror definingMixin isMeta ifTrue: [ 'class' ]
								ifFalse: [ 'instance' ].
							ide aiSupport setLazySlotFocusOn: subject classDeclaration
								side: side
								name: subject name
						]
						ifFocused: [
							| side |
							side:: subject slotMirror definingMixin isMeta ifTrue: [ 'class' ]
								ifFalse: [ 'instance' ].
							ide aiSupport isFocusedOnLazySlot: subject classDeclaration
								side: side
								name: subject name
						]. smallBlank. helpButton. smallBlank. dropDownMenu: [
							slotMenuFor: subject name
						]. }. historySection. chatSection. }
		)
		helpText = (
			| mapping = Map new. menuImage = Utilities uriForIconNamed: #dropDownImage. referenceImage = Utilities uriForIconNamed: #itemReferencesImage. exemplarHeaderDescription = hasExemplars ifTrue: [
					'<li><div class="hopscotchDebugMethodButton"> </div> Opens a debugger on an invocation of the slot initializer, with the arguments given by its exemplar.</li>'
				]
				ifFalse: [ '' ]. menuDescription = hasExemplars ifTrue: [
					'deleting the lazy slot, inspecting this presenter or opening an evaluator'
				]
				ifFalse: [ 'deleting the lazy slot or inspecting this presenter' ]. editorEvaluatorDescription = hasExemplars ifTrue: [
					'<br>The editor is also an evaluator. See its help section for more details.'
				]
				ifFalse: [ '' ]. |
			mapping at: #hopscotchAccessIndicator put: accessIndicator;
				at: #hopscotchSlotMenuButton
					put: (dropDownMenu: [ slotMenuFor: subject name ]);
				at: #hopscotchDebugMethodButton put: debugButton;
				at: #hopscotchSlotReferencesButton
					put: (dropDownMenu: [ messagesMenu ] image: ide images itemReferencesImage);
				at: #hopscotchHistoryButton
					put: ((imageButton: ide images historyImage
						action: [ toggleHistory ]
						size: styleButtonSize) toolTip: 'Show / hide history of this lazy slot');
				at: #hopscotchAiChatButton
					put: (aiChatButton: [
							| side |
							side:: subject slotMirror definingMixin isMeta ifTrue: [ 'class' ]
								ifFalse: [ 'instance' ].
							ide aiSupport setLazySlotFocusOn: subject classDeclaration
								side: side
								name: subject name
						]
						ifFocused: [
							| side |
							side:: subject slotMirror definingMixin isMeta ifTrue: [ 'class' ]
								ifFalse: [ 'instance' ].
							ide aiSupport isFocusedOnLazySlot: subject classDeclaration
								side: side
								name: subject name
						]);
				at: #hopscotchHelpButton put: helpButton.
			^ampleforth: 'This is a lazy slot presenter. A lazy slot is initialized on first access by evaluating its initializer expression; the result is cached so future reads return the same value. The presenter can be either expanded or collapsed. In the collapsed state, only the slot header is shown.
  <br><br>From left to right, the slot header displays:
  <ul>
  <li><div class="hopscotchAccessIndicator"></div> The slot''s access modifier. The color indicates whether the slot is public (green), protected (yellow) or private (red).</li>
  <li>The slot name.</li>' , exemplarHeaderDescription , '<li><div class="hopscotchSlotReferencesButton"> </div> Allows you to find senders and implementors of the slot''s name (its getter) and any messages sent within its initializer.</li>
  <li><div class="hopscotchHistoryButton"> </div> Shows or hides the history of changes to this lazy slot, drawn from the drafts repository. Expand a row to see the historical declaration pre-loaded as a pending edit on the live slot; accept to revert (the revert lands as a new append-only Accept commit).</li>
  <li><div class="hopscotchAiChatButton"> </div> Opens the AI chat with this lazy slot as the current focus. The chat appears as a collapsible region just below the slot header. While this slot holds the focus, the brain icon shows an amber highlight; clicking another brain elsewhere moves the focus there. The shared conversation continues across all presenters.</li>
  <li><div class="hopscotchHelpButton"> </div> Shows this help message.</li>
  <li><div class="hopscotchSlotMenuButton"> </div> Opens a menu of additional operations, such as ' , menuDescription , '.</li>
  </ul>
  When expanded, an editor pane shows the slot''s declaration (lazy slotName = initializer.). You can edit the declaration; once changed, indicators appear at the top right corner of the editor pane. You can accept the changes by pressing, or revert back to the original by pressing . You can also accept changes by pressing Cmd-return (on mac) or Ctl-return (on Linux or Windows).
  ' , editorEvaluatorDescription
				mapping: mapping
		)
		slotMenuFor: slotName <String> = (
			| labelsAndActions ::= {{'Delete #' , slotName. [
				updateGUI: [ subject delete ]
			]. }. #separator. {'Pretty Print'. [ respondToPrettyPrint ]. }. #separator. {'Typecheck'. [
				respondToTypecheckSlot
			]. }. #separator. {'Inspect Presenter'. [ respondToInspectPresenter ]. }. }. |
			hasExemplars ifTrue: [
					labelsAndActions:: labelsAndActions , {#separator. {'Add Evaluator'. [
						respondToAddSlotWorkspace
					]. }. }
				].
			^menuWithLabelsAndActions: labelsAndActions
		)
		cancelResponse ^<[:CodeMirrorFragment | Object]> = (
			^[:ed <CodeMirrorFragment> |
				| src = ide prettyPrintLazySlotOr: (crToLf: subject source). |
				ed text: src.
				colorizeLazySlotSource: src withEditor: ed.
				ed leaveEditState
			]
		)
		referencesMenuMessageItems = (
			| items = List new. sortedMessages |
			sortedMessages:: subject messages sort: [:m1 :m2 |
					lexicallyLessOrEqual: m1 than: m2
				].
			sortedMessages do: [:selector |
					selector == subject name ifFalse: [
							items add: {selector copyFrom: 1 to: (64 min: selector size). [
									browseSelector: selector
								]. }
						]
				].
			^items
		)
	) : ()
	public class LazySlotSubject onLazySlotModel: mm <LazySlotModel | ClassModel> = Subject onModel: mm (
		(* Manages the UI for a lazy slot definition. Not be confused with LazyObjectSlotSubject, which deals with lazy slots storage. *)
		
		|
			public errorMessages <Set[String]> = Set new.
			public typeErrorMessages <Set[String]> = Set new.
			public exemplars <List[String]> = computeExemplars.
			public exemplar <String>
			evaluator_slot <EvaluationSubject>
			workspace_slot <EvaluationSubject>
			public threadMap <Map[Symbol, ThreadMirror | Error]> = Map new.
		|
	) (
		public createPresenter ^<Presenter> = (
			^LazySlotPresenter onSubject: self
		)
		public enclosingClasses ^<List[ClassDeclarationMirror]> = (
			(* Returns all classes the model is nested in, beginning with the immediately enclosing class and up to the top level. *)
			
			| classes <List[ClassDeclarationMirror]> = List new. currentClass <ClassDeclarationMirror> ::= classDeclaration. |
			[ currentClass isNil ] whileFalse: [
					classes add: currentClass.
					currentClass:: currentClass enclosingClass
				].
			^classes
		)
		public messages ^<List[Symbol]> = (
			^slotMirror selectors
		)
		public source ^<String> = (
			^slotMirror source
		)
		public clearErrors = (
			errorMessages removeAll: errorMessages
		)
		public clearTypeErrors = (
			typeErrorMessages removeAll: typeErrorMessages
		)
		public delete = (
			| b <MixinBuilder> = slotMirror definingMixin asBuilder. |
			b lazySlots removeMirrorNamed: slotMirror name.
			ide installFromBuilders: {b declaration. }
		)
		public compileSource: src <String> ifSuccess: successBlock <[:MethodMirror | Object]> ifFailure: failureBlock <[:String | Object]> = (
			(* Canonicalise via prettyPrintLazySlotOr: before compiling. *)
			
			| canonical |
			canonical:: ide prettyPrintLazySlotOr: src.
			[
				| builder <MixinBuilder> newBuilder <LazySlotBuilder> newMirror <LazySlotMirror> |
				builder:: slotMirror definingMixin asBuilder.
				newBuilder:: builder lazySlots addFromSource: canonical.
				ide installFromBuilders: {builder declaration. }.
				newMirror:: definingMixin lazySlots findMirrorNamed: newBuilder name.
				successBlock value: newMirror
			] on: Error do: [:ex <Exception> | failureBlock value: ex printString ]
		)
		public isKindOfLazySlotSubject ^<Boolean> = (
			^true
		)
		public workspace = (
			workspace_slot isNil ifTrue: [
					| activationMirror = (threadMap at: exemplar) suspendedActivation. evalState = EvaluationViewState onModel: activationMirror. |
					workspace_slot:: EvaluatorSubject onModel: evalState.
					workspace_slot initialSource: ''
				].
			^workspace_slot
		)
		computeExemplars ^<List[String]> = (
			| keys <Collection[String]> = metadata keys select: [:k <String> |
					k startsWith: 'exemplar'
				]. es <List[String]> = List new. |
			keys do: [:k <String> | es add: (metadata at: k) ].
			exemplar:: es isEmpty ifTrue: [
					(Utilities isInstantiableUnarySelector: name) ifTrue: [ es add: name ]
				]
				ifFalse: [ es first ].
			^es
		)
		public threadForExemplar: e <String> ^<ThreadMirror | Error>
		(* :exemplar1: threadForExemplar: 'definition' *)
		 = (
			| thread <ThreadMirror | Error> = threadMap at: e asSymbol
				ifAbsentPut: [ processExemplar: e ]. |
			^thread
		)
		public metadata ^<Map[String, String]> = (
			^slotMirror metadata
		)
		public accessModifier ^<Symbol> = (
			^slotMirror accessModifier
		)
		public classDeclaration ^<ClassDeclarationMirror> = (
			^slotMirror definingMixin declaration
		)
		public slotModel ^<LazySlotModel | ClassModel> = (
			^model
		)
		public processExemplar: e <String> ^<ThreadMirror>
		(* :exemplar1: processExemplar: 'definition' *)
		 = (
			| ast = (compiler parser parseExpression: e) statements first. selector = ast message selector. hasSelector = selector = slotMirror name. args <List[Object]> = ast message arguments collect: [:a <ExprAST> |
					| argThread <ThreadMirror> = enclosingScope evaluate: (e copyFrom: a start
							to: a end). |
					argThread isBroken ifTrue: [
							currentWindow enterSubject: (ide debugging ThreadSubject onModel: argThread)
						].
					argThread result reflectee
				]. thread <ThreadMirror> = selector = slotMirror name ifTrue: [
					enclosingScope sendSuspended: selector with: args
				]
				ifFalse: [ enclosingScope evaluate: e ]. |
			thread isBroken ifTrue: [
					currentWindow enterSubject: (ide debugging ThreadSubject onModel: thread)
				].
			^thread
		)
		public addSlotWorkspace = (
			workspace
		)
		public enclosingScope ^<ObjectMirror | Nil> = (
			| mirror <ObjectMirror | Nil> = slotModel exemplar. |
			mirror isNil ifFalse: [ ^mirror ].
			
			(* If no exemplar known, use the exemplar of the enclosing class *)
			^computeExemplarFor: classDeclaration enclosing: nil
		)
		public hasSlotWorkspace ^<Boolean> = (
			^workspace_slot isNil not
		)
		public mirror ^<LazySlotMirror> = (
			^model mirror
		)
		public name ^<Symbol> = (
			^slotMirror name
		)
		public slotMirror ^<LazySlotMirror> = (
			^slotModel slotMirror
		)
		isMyKind: f <Fragment> ^<Boolean> = (
			^f isKindOfLazySlotSubject
		)
		public evaluator = (
			evaluator_slot isNil ifTrue: [
					| activationMirror = (threadMap at: exemplar) suspendedActivation. evalState = EvaluationViewState onModel: activationMirror. |
					evaluator_slot:: LazySlotEvaluatorSubject onModel: evalState.
					evaluator_slot initialSource: source
				].
			^evaluator_slot
		)
	) : (
		public fromModel: lsm <LazySlotModel> ^<Instance> = (
			^onLazySlotModel: lsm
		)
		public onModel: m <LazySlotMirror | ClassDeclarationMirror> = (
			^onLazySlotModel: (LazySlotModel slot: m exemplar: nil)
		)
	)
	public class MethodPresenter onSubject: s <MethodSubject> = ProgrammingPresenter onSubject: s (
		(* A presenter for a single method. *)
		
		|
			public showClassName ::= false.
			public mustBeExpanded ::= false.
			
			(* Inline holder for the per-method history view, populated by the
       history button click. Same pattern as chatHolder on the superclass. *)
			historyHolder = holder: nothing.
			
			(* Captured by codeMirrorDefinition so the 'Pretty Print' menu
       action can address the current editor. *)
			methodEditor <CodeMirrorFragment>
			
			(* Captured by evaluatorDefinition when the method has exemplars and
       the editor is an EvaluatorPresenter rather than a plain
       CodeMirror. Lets respondToTypecheck read the in-progress text via
       the evaluator's embedded codeMirror. *)
			methodEvaluatorPresenter <EvaluatorPresenter>
		|
	) (
		public historySection = (
			^historyHolder
		)
		installHistory = (
			(* Embed the multi-repo history presenter directly. The history
       button itself is the toggle (see toggleHistory); the embedded
       presenter has its own per-row toggles for individual entries
       and (when multiple repos are present) a chip row to pick which
       permanent repo to expand alongside drafts. *)
			
			historyHolder content: (MemberRepoHistorySubject onModel: (MemberRepoHistoryModel forMethodModel: subject methodModel)) createPresenter
		)
		toggleHistory = (
			historyHolder content isKindOfBlankFragment ifTrue: [ installHistory ]
				ifFalse: [ historyHolder content: nothing ]
		)
		updateVisualsFromSameKind: oldPresenter <Self> ^<Alien[Element]> = (
			(* Preserve whether the embedded history view was showing across
       refresh: if the old historyHolder had non-blank content,
       reinstall a fresh MethodHistoryPresenter on the new holder.
       Cached history + blob fetches on DraftsRepo make the rebuild
       cheap and synchronous. *)
			
			| oldHistory |
			oldHistory:: oldPresenter historySection content.
			oldHistory isKindOfBlankFragment ifFalse: [ installHistory ].
			^super updateVisualsFromSameKind: oldPresenter
		)
		colorizeMethodSource: s <String> withEditor: cm <CodeMirrorFragment> = (
			ide colorizer colorizeMethod: s
				fromClass: subject classDeclaration
				via: (colorizingBlockFor: cm)
		)
		messagesMenu = (
			| messagesAndActions messageItems classItems |
			messagesAndActions:: List new.
			messagesAndActions add: {subject name. [ browseSelector: subject name ]. }.
			messageItems:: referencesMenuMessageItems.
			messageItems isEmpty not ifTrue: [
					messagesAndActions add: #separator;
						addAll: messageItems
				].
			^menuWithLabelsAndActions: messagesAndActions
		)
		public isKindOfMethodPresenter ^<Boolean> = (
			^true
		)
		isMyKind: f <Fragment> ^<Boolean> = (
			^f isKindOfMethodPresenter
		)
		nestingInfo = (
			^showClassName ifTrue: [ nestingInformationLine ] ifFalse: [ nothing ]
		)
		nestingInformationLine = (
			| enclosingClasses rowElements |
			enclosingClasses:: subject enclosingClasses.
			rowElements:: List new.
			enclosingClasses do: [:each |
					rowElements add: ((label: ' in ') color: tertiaryTextColor).
					rowElements add: (linkToBrowseEnclosingClass: each)
				].
			^row: rowElements asArray
		)
		public tag ^<String> = (
			^subject name
		)
		changeResponse ^<[:CodeMirrorFragment :Event | Object]> = (
			^[:ed <CodeMirrorFragment> :event <Event> |
				colorizeMethodSource: (crToLf: ed textBeingAccepted) withEditor: ed
			]
		)
		cancelResponse ^<[:CodeMirrorFragment | Object]> = (
			^[:ed <CodeMirrorFragment> |
				| src = ide prettyPrintMethodOr: (crToLf: subject source). |
				ed text: src.
				colorizeMethodSource: src withEditor: ed.
				ed leaveEditState
			]
		)
		errorDisplay: msg <String> ^<Fragment> = (
			^row: {label: msg. button: 'Clear'
					action: [ subject errorMessages remove: msg ]. }
		)
		errorMessages ^<Array[Fragment]> = (
			^(subject errorMessages collect: [:msg <String> | errorDisplay: msg ]) asArray
		)
		typeErrorDisplay: msg <String> ^<Fragment> = (
			| textColor |
			textColor:: msg = 'No type errors.' ifTrue: [ Color r: 0 g: 0.5 b: 0 ]
				ifFalse: [ Color r: 0.7 g: 0 b: 0 ].
			^row: {(label: msg) color: textColor. button: 'Clear'
					action: [ updateGUI: [ subject typeErrorMessages remove: msg ] ]. }
		)
		typeErrorMessages ^<Array[Fragment]> = (
			^(subject typeErrorMessages collect: [:msg <String> | typeErrorDisplay: msg ]) asArray
		)
		acceptResponse ^<[:CodeMirrorFragment :Event | Object]> = (
			^[:ed <CodeMirrorFragment> :event <Event> |
				| b <MixinBuilder> = subject methodMirror definingMixin asBuilder. canonical |
				updateGUI: [
						[
							canonical:: ide prettyPrintMethodOr: ed textBeingAccepted.
							b methods addFromSource: canonical.
							ide installFromBuilders: {b declaration. }.
							subject clearTypeErrors.
							[
								ide reportRecheckFrom: (ide typechecker declarationForMember: subject name
										kind: #method
										ofClass: subject methodMirror definingMixin)
									onSubject: subject
							] on: Error do: [:e <Exception> | ].
							ed text: canonical.
							colorizeMethodSource: (crToLf: canonical) withEditor: ed.
							ed leaveEditState
						] on: Error do: [:ex <Exception> | ed showMessage: ex printString ]
					].
				ed editor focus
			]
		)
		codeMirrorDefinition ^<CodeMirrorFragment> = (
			(* Show the source re-based to indent 0 (body relative to the column-0
			   selector), not at the member's enclosing-class depth. Pretty-printing
			   is the only safe re-indent (string/comment bodies stay verbatim);
			   prettyPrintMethodOr: falls back to the raw source on a parse error. *)
			
			| src = ide prettyPrintMethodOr: (crToLf: subject source). cm = codeMirror: src. |
			cm changeResponse: changeResponse;
				cancelResponse: cancelResponse;
				acceptResponse: acceptResponse.
			colorizeMethodSource: src withEditor: cm.
			methodEditor:: cm.
			^cm
		)
		respondToPrettyPrint = (
			(* Pretty-print the current method source and replace the editor
       contents in place. Does NOT trigger Accept — the user decides
       whether to commit. On parse failure, shows an inline message
       under the editor and leaves the text unchanged. *)
			
			| ed source formatted |
			ed:: methodEditor.
			ed isNil ifTrue: [ ^self ].
			source:: ed textBeingAccepted.
			(source isNil or: [ source isEmpty ]) ifTrue: [ source:: subject source ].
			formatted:: [ ide prettyPrinter prettyPrintMethod: source ] on: Exception
				do: [:e |
					ed showMessage: 'Pretty print failed: ' , e printString.
					^self
				].
			ed text: formatted.
			colorizeMethodSource: (crToLf: formatted) withEditor: ed.
			ed editor focus
		)
		editorDefinition ^<CodeMirrorFragment | EvaluatorPresenter> = (
			^hasExemplars ifTrue: [ evaluatorDefinition ]
				ifFalse: [ codeMirrorDefinition ]
		)
		methodMenuFor: methodName <String> = (
			| labelsAndActions ::= {{'Delete #' , methodName. [
				updateGUI: [ subject delete ]
			]. }. #separator. {'Pretty Print'. [ respondToPrettyPrint ]. }. #separator. {'Typecheck'. [
				respondToTypecheck
			]. }. #separator. {'Inspect Presenter'. [ respondToInspectPresenter ]. }. }. |
			hasExemplars ifTrue: [
					labelsAndActions:: labelsAndActions , {#separator. {'Add Evaluator'. [
						respondToAddMethodWorkspace
					]. }. }
				].
			^menuWithLabelsAndActions: labelsAndActions
		)
		public enclosingObjectPresenter ^<ObjectPresenter | Nil> = (
			| candidate <Fragment> ::= parent. |
			[
				candidate isNil or: [
						candidate isKindOfIDEWindow or: [ candidate isKindOfObjectPresenter ]
					]
			] whileFalse: [ candidate:: candidate parent ].
			candidate isNil ifTrue: [ ^nil ].
			candidate isKindOfIDEWindow ifTrue: [ ^nil ].
			subject methodMirror definingMixin name = candidate subject classMirror mixin name ifFalse: [
					^nil
				].
			^candidate
		)
		enclosingClassPresenter ^<ClassPresenter | Nil> = (
			| candidate <Fragment> ::= parent. |
			[ candidate isKindOfIDEWindow or: [ candidate isKindOfClassPresenter ] ] whileFalse: [
					candidate:: candidate parent
				].
			^candidate isKindOfIDEWindow ifFalse: [ candidate ]
		)
		debugButton ^<ButtonFragment> = (
			hasExemplars ifFalse: [ ^nothing ].
			subject exemplars size = 1 ifTrue: [
					^button: 'Debug' action: [ debugExemplar: subject exemplars first ]
				]
				ifFalse: [
					| messagesAndActions = List new. |
					subject exemplars do: [:ex <String> |
							messagesAndActions add: {ex. [ debugExemplar: ex ]. }
						].
					^dropDownMenu: [ menuWithLabelsAndActions: messagesAndActions ]
				]
		)
		hasExemplars ^<Boolean> = (
			subject exemplars isEmpty ifTrue: [ ^false ].
			
			(* If we have an enclosing object defined, we can proceed *)
			subject enclosingScope isNil ifTrue: [ ^false ].
			^true
		)
		evaluatorDefinition ^<EvaluatorPresenter> = (
			subject threadForExemplar: subject exemplar.
			methodEvaluatorPresenter:: subject evaluator presenter.
			^methodEvaluatorPresenter
		)
		respondToAddMethodWorkspace = (
			subject threadForExemplar: subject exemplar.
			updateGUI: [ subject addMethodWorkspace ]
		)
		respondToTypecheck = (
			(* Run the typechecker on the current method source (editor buffer
       if non-empty, else the installed source) and surface results in
       the typeErrorMessages banner column below the editor.
       Source priority: codeMirror editor (no-exemplar mode), else the
       embedded evaluator's editor (exemplar mode), else the installed
       source. *)
			
			| source typed mixin errs failureMessage |
			typed:: methodEditor isNil ifTrue: [
					methodEvaluatorPresenter isNil ifTrue: [ nil ]
						ifFalse: [ methodEvaluatorPresenter editorText ]
				]
				ifFalse: [ methodEditor textBeingAccepted ].
			source:: (typed isNil or: [ typed isEmpty ]) ifTrue: [ subject source ]
				ifFalse: [ typed ].
			mixin:: subject methodMirror definingMixin.
			subject clearTypeErrors.
			failureMessage:: nil.
			errs:: [ ide typechecker typecheckMethodSource: source ofClass: mixin ] on: Error
				do: [:e |
					failureMessage:: 'Typechecker failed: ' , e printString.
					nil
				].
			updateGUI: [
					failureMessage isNil ifFalse: [
							subject typeErrorMessages add: failureMessage
						]
						ifTrue: [
							errs isEmpty ifTrue: [ subject typeErrorMessages add: 'No type errors.' ]
								ifFalse: [
									errs do: [:e |
											subject typeErrorMessages add: 'Type error: ' , e message , ' [' , e start printString , '-' , e end printString , ']'
										]
								]
						]
				]
		)
		debugExemplar: e <String>
		(* :exemplar1: debugExemplar: 'definition' *)
		 = (
			| thread <ThreadMirror | Error> = subject threadForExemplar: e. |
			thread isKindOfThreadMirror ifTrue: [
					enterSubject:: ide debugging ThreadSubject onModel: thread
				]
				ifFalse: [
					alert: 'internal IDE failure in MethodPresenter>>debugExemplar: ' , thread printString
				]
		)
		linkToBrowseEnclosingClass: klass <ClassDeclarationMirror> = (
			^(link: klass simpleName
				action: [ enterSubject:: ClassSubject onDeclaration: klass ]) color: secondaryTextColor
		)
		methodHeader: toggleBlock <[]> ^<Fragment> = (
			^column: {helpSection. row: {accessIndicator. defaultBlank. (link: subject name
						action: toggleBlock) color: actionLinkColor. nestingInfo. filler. deferred: [
							debugButton
						]. smallBlank. dropDownMenu: [ messagesMenu ]
						image: ide images itemReferencesImage. smallBlank. (imageButton: ide images historyImage
						action: [ toggleHistory ]
						size: styleButtonSize) toolTip: 'Show / hide history of this method'. smallBlank. aiChatButton: [
							| side |
							side:: subject methodMirror definingMixin isMeta ifTrue: [ 'class' ]
								ifFalse: [ 'instance' ].
							ide aiSupport setMethodFocusOn: subject classDeclaration
								side: side
								selector: subject name
						]
						ifFocused: [
							| side |
							side:: subject methodMirror definingMixin isMeta ifTrue: [ 'class' ]
								ifFalse: [ 'instance' ].
							ide aiSupport isFocusedOnMethod: subject classDeclaration
								side: side
								selector: subject name
						]. smallBlank. helpButton. smallBlank. dropDownMenu: [
							methodMenuFor: subject name
						]. }. historySection. chatSection. }
		)
		helpText = (
			| mapping = Map new. menuImage = Utilities uriForIconNamed: #dropDownImage. referenceImage = Utilities uriForIconNamed: #itemReferencesImage. exemplarHeaderDescription = hasExemplars ifTrue: [
					'<li><div class="hopscotchDebugMethodButton"> </div> Opens a debugger on an invocation of the method, with the arguments given by the method exemplar.</li>'
				]
				ifFalse: [ '' ]. editorEvaluatorDescription = hasExemplars ifTrue: [
					'<br>The editor is also an evaluator. See it''s help section for more details.'
				]
				ifFalse: [ '' ]. |
			mapping at: #hopscotchAccessIndicator put: accessIndicator;
				at: #hopscotchMethodMenuButton put: (dropDownMenu: [ methodMenu ]);
				at: #hopscotchDebugMethodButton put: debugButton;
				at: #hopscotchMethodReferencesButton
					put: (dropDownMenu: [ messagesMenu ] image: ide images itemReferencesImage);
				at: #hopscotchHistoryButton
					put: ((imageButton: ide images historyImage
						action: [ toggleHistory ]
						size: styleButtonSize) toolTip: 'Show / hide history of this method');
				at: #hopscotchAiChatButton
					put: (aiChatButton: [
							| side |
							side:: subject methodMirror definingMixin isMeta ifTrue: [ 'class' ]
								ifFalse: [ 'instance' ].
							ide aiSupport setMethodFocusOn: subject classDeclaration
								side: side
								selector: subject name
						]
						ifFocused: [
							| side |
							side:: subject methodMirror definingMixin isMeta ifTrue: [ 'class' ]
								ifFalse: [ 'instance' ].
							ide aiSupport isFocusedOnMethod: subject classDeclaration
								side: side
								selector: subject name
						]);
				at: #hopscotchHelpButton put: helpButton;
				at: #hopscotchMethodMenuButton
					put: (dropDownMenu: [ methodMenuFor: subject name ]).
			^ampleforth: 'This is a method presenter. A method presenter can be either expanded or collapsed. In the collapsed state, only the method header is shown.
  <br><br>From left to right, the method header displays:
  <ul>
  <li><div class="hopscotchAccessIndicator"></div> The method''s access modifier. The color of the access modifier indicates whether the method is public (green), protected (yellow) or private (red).</li>
  <li>The method selector</li>' , exemplarHeaderDescription , '<li><div class="hopscotchMethodReferencesButton"> </div> Allows you to find senders and implementors of the method''s selector and all messages sent within the method.</li>
  <li><div class="hopscotchHistoryButton"> </div> Shows or hides the history of changes to this method, drawn from the drafts repository. The history appears as a collapsible region just below the method header. Each row is a commit that touched this method''s file -- expand a row to see the historical source pre-loaded as a pending edit on the live method, accept to revert (the revert lands as a new append-only Accept commit).</li>
  <li><div class="hopscotchAiChatButton"> </div> Opens the AI chat with this method as the current focus. The chat appears as a collapsible region just below the method header. While this method holds the focus, the brain icon shows an amber highlight; clicking another brain elsewhere moves the focus there. The shared conversation continues across all presenters.</li>
  <li><div class="hopscotchHelpButton"> </div> Shows this help message.</li>
  <li><div class="hopscotchMethodMenuButton"> </div> Opens a menu of additional operations, such as ' , menuHelp , '.</li>
  </ul>
  When the method presenter is expanded, an editor pane containing the method source is displayed underneath the header. You can edit the method. Once the code is changed, indicators appear at the top right corner of the editor pane. You can accept the changes by pressing, or revert back to the original by pressing . You can also accept changes by pressing Cmd-return (on mac) or Ctl-return (on Linux or Windows).
  ' , editorEvaluatorDescription
				mapping: mapping
		)
		menuHelp ^<String> = (
			^hasExemplars ifTrue: [
					'deleting the method, inspecting this presenter or opening an evaluator'
				]
				ifFalse: [ 'deleting the method or inspecting this presenter' ]
		)
		public definition ^<Fragment> = (
			| toggle |
			toggle:: collapsed: [ methodHeader: [ toggle expand ] ]
				expanded: [
					column: {methodHeader: [ toggle collapse ]. editorDefinition. column: errorMessages. column: typeErrorMessages. subject hasMethodWorkspace ifTrue: [
								subject workspace presenter
							]
							ifFalse: [ nothing ]. }
				]
				initiallyExpanded: mustBeExpanded.
			^toggle
		)
		public expand = (
			mustBeExpanded: true.
			^substance expand
		)
		public collapse = (
			mustBeExpanded: false.
			^substance collapse
		)
		public initiallyExpanded = (
			mustBeExpanded: true
		)
		referencesMenuMessageItems = (
			| items = List new. sortedMessages likelyMessages = subject messages select: [:s <String> |
					0 = (s indexOf: ' ')
				]. |
			sortedMessages:: likelyMessages sort: [:m1 :m2 |
					lexicallyLessOrEqual: m1 than: m2
				].
			sortedMessages do: [:selector |
					selector == subject name ifFalse: [
							items add: {selector copyFrom: 1 to: (64 min: selector size). [
									browseSelector: selector
								]. }
						]
				].
			^items
		)
	) : ()
	public class MethodSubject onMethodModel: mm <MethodModel | ClassModel> = Subject onModel: mm (
		(* Manages the UI for a method. *)
		
		|
			public errorMessages <Set[String]> = Set new.
			public typeErrorMessages <Set[String]> = Set new.
			public exemplars <List[String]> = computeExemplars.
			public exemplar <String>
			evaluator_slot <EvaluationSubject>
			workspace_slot <EvaluationSubject>
			public threadMap <Map[Symbol, ThreadMirror | Error]> = Map new.
		|
	) (
		public createPresenter ^<Presenter> = (
			^MethodPresenter onSubject: self
		)
		public enclosingClasses ^<List[ClassDeclarationMirror]> = (
			(* Returns all classes the model is nested in, beginning with the immediately enclosing class and up to the top level. *)
			
			| classes <List[ClassDeclarationMirror]> = List new. currentClass <ClassDeclarationMirror> ::= classDeclaration. |
			[ currentClass isNil ] whileFalse: [
					classes add: currentClass.
					currentClass:: currentClass enclosingClass
				].
			^classes
		)
		public messages ^<List[Symbol]> = (
			^methodMirror selectors
		)
		public name ^<Symbol> = (
			^methodMirror name
		)
		public source ^<String> = (
			^methodMirror source
		)
		public clearErrors = (
			errorMessages removeAll: errorMessages
		)
		public clearTypeErrors = (
			typeErrorMessages removeAll: typeErrorMessages
		)
		public delete = (
			| b <MixinBuilder> = methodMirror definingMixin asBuilder. |
			b methods removeMirrorNamed: methodMirror name.
			ide installFromBuilders: {b declaration. }
		)
		public compileSource: src <String> ifSuccess: successBlock <[:MethodMirror | Object]> ifFailure: failureBlock <[:String | Object]> = (
			(* Canonicalise via prettyPrintMethodOr: before compiling. *)
			
			| canonical |
			canonical:: ide prettyPrintMethodOr: src.
			[
				| builder <MixinBuilder> newBuilder <MethodBuilder> newMirror <MethodMirror> |
				builder:: methodMirror definingMixin asBuilder.
				newBuilder:: builder methods addFromSource: canonical.
				ide installFromBuilders: {builder declaration. }.
				newMirror:: definingMixin methods findMirrorNamed: newBuilder name.
				successBlock value: newMirror
			] on: Error do: [:ex <Exception> | failureBlock value: ex printString ]
		)
		public isKindOfMethodSubject ^<Boolean> = (
			^true
		)
		isMyKind: f <Fragment> ^<Boolean> = (
			^f isKindOfMethodSubject
		)
		public evaluator = (
			evaluator_slot isNil ifTrue: [
					| activationMirror = (threadMap at: exemplar) suspendedActivation. evalState = EvaluationViewState onModel: activationMirror. |
					evaluator_slot:: MethodEvaluatorSubject onModel: evalState.
					evaluator_slot initialSource: source
				].
			^evaluator_slot
		)
		public addMethodWorkspace = (
			workspace
		)
		public hasMethodWorkspace ^<Boolean> = (
			^workspace_slot isNil not
		)
		public workspace = (
			workspace_slot isNil ifTrue: [
					| activationMirror = (threadMap at: exemplar) suspendedActivation. evalState = EvaluationViewState onModel: activationMirror. |
					workspace_slot:: EvaluatorSubject onModel: evalState.
					workspace_slot initialSource: ''
				].
			^workspace_slot
		)
		public threadForExemplar: e <String> ^<ThreadMirror | Error>
		(* :exemplar1: threadForExemplar: 'definition' *)
		 = (
			| thread <ThreadMirror | Error> = threadMap at: e asSymbol
				ifAbsentPut: [ processExemplar: e ]. |
			^thread
		)
		public mirror ^<MethodMirror> = (
			^model mirror
		)
		public enclosingScope ^<ObjectMirror | Nil> = (
			(* Produce an object that will serve as the enclosing scope when displaying the method live *)
			
			^mirror definingMixin isMeta ifTrue: [ enclosingClassScope ]
				ifFalse: [ enclosingInstanceScope ]
		)
		public metadata ^<Map[String, String]> = (
			^methodMirror metadata
		)
		public accessModifier ^<Symbol> = (
			^methodMirror accessModifier
		)
		public classDeclaration ^<ClassDeclarationMirror> = (
			^methodMirror definingMixin declaration
		)
		public methodModel ^<MethodModel | ClassModel> = (
			^model
		)
		public methodMirror ^<MethodMirror> = (
			^methodModel methodMirror
		)
		public enclosingInstanceScope ^<ObjectMirror | Nil> = (
			| mirror <ObjectMirror | Nil> = methodModel exemplar. |
			mirror isNil ifFalse: [ ^mirror ].
			
			(* If no exemplar known, use the exemplar of the enclosing class *)
			^computeExemplarFor: classDeclaration enclosing: nil
		)
		public processExemplar: e <String> ^<ThreadMirror>
		(* :exemplar1: processExemplar: 'definition' *)
		 = (
			| ast = (compiler parser parseExpression: e) statements first. selector = ast message selector. hasSelector = selector = methodMirror name. args <List[Object]> = ast message arguments collect: [:a <ExprAST> |
					| argThread <ThreadMirror> = enclosingScope evaluate: (e copyFrom: a start
							to: a end). |
					argThread isBroken ifTrue: [
							currentWindow enterSubject: (ide debugging ThreadSubject onModel: argThread)
						].
					argThread result reflectee
				]. thread <ThreadMirror> = selector = methodMirror name ifTrue: [
					enclosingScope sendSuspended: selector with: args
				]
				ifFalse: [ enclosingScope evaluate: e ]. |
			thread isBroken ifTrue: [
					currentWindow enterSubject: (ide debugging ThreadSubject onModel: thread)
				].
			^thread
		)
		computeExemplars ^<List[String]> = (
			| keys <Collection[String]> = metadata keys select: [:k <String> |
					k startsWith: 'exemplar'
				]. es <List[String]> = List new. |
			(isKindOfClassFactorySubject not and: [ model mirror isPrimitive ]) ifTrue: [
					^es
				].
			(metadata includesKey: 'no_exemplars') ifTrue: [ ^es ].
			keys do: [:k <String> | es add: (metadata at: k) ].
			exemplar:: es isEmpty ifTrue: [
					(Utilities isInstantiableUnarySelector: name) ifTrue: [ es add: name ]
				]
				ifFalse: [ es first ].
			^es
		)
		public enclosingClassScope ^<ObjectMirror | Nil> = (
			| mirror <ObjectMirror | Nil> = methodModel exemplar. |
			mirror isNil ifFalse: [ ^classObjectScopeFor: mirror ].
			
			(* If no exemplar known, use the class object of the exemplar of the enclosing class, if any *)
			^[
				classObjectScopeFor: (computeExemplarFor: classDeclaration enclosing: nil)
			] on: Error
				do: [:e |
					('Noclass exemplar for method ' , name , ' in class ' , classDeclaration name , ' ' , e printString) out.
					^nil
				]
		)
		classObjectScopeFor: mirror <ObjectMirror> ^<ObjectMirror> = (
			(* The receiver to use as a live 'self' for a CLASS-SIDE method, given an exemplar [mirror].
     Normally [mirror] is an instance of the presented class, so the class object is its #class.
     But when a class object is being inspected, [mirror] is already that class object itself;
     sending it #class would over-climb into the metaclass (whose own class is Metaclass),
     searching the wrong holder for the class-side method. In that case the class object IS the
     receiver, so use it directly. *)
			
			mirror getClass isMeta ifTrue: [ ^mirror ].
			^(mirror evaluate: #class) result
		)
	) : (
		public onModel: m <MethodMirror | ClassDeclarationMirror> = (
			^onMethodModel: (MethodModel method: m exemplar: nil)
		)
		public fromModel: mm <MethodModel> ^<Instance> = (
			^onMethodModel: mm
		)
	)
	class MirrorGroupPresenter onSubject: s <Subject> = DefinitionListPresenter onSubject: s (
	) (
		createPresenterForSubject: aSubject <Subject> ^<ProgrammingPresenter> = (
			(* Let the subject create its default unless elementPresenterClass is set to specify our preference. *)
			
			nil = elementPresenterClass ifTrue: [ ^aSubject presenter ].
			^elementPresenterClass onSubject: aSubject
		)
		definitionListMenu = (
			^menuWithLabelsAndActions: {{'Inspect Presenter'. [
					respondToInspectPresenter
				]. }. }
		)
		elementPresenterClass ^<ProgrammingPresenter class> = (
			(* A subclass must redefine this to define the class of presenter it will be using. *)
			
			subclassResponsibility
		)
		contentPresenters ^<Collection[ProgrammingPresenter]> = (
			^(subject elements collect: [:each <Subject> |
					createPresenterForSubject: each
				]) sort: [:p1 <ProgrammingPresenter> :p2 <ProgrammingPresenter> |
					lexicallyLessOrEqual: p1 subject name than: p2 subject name
				]
		)
	) : ()
	public class MethodHistorySubject onModel: m <MethodHistoryModel> = ProgrammingSubject onModel: m (
		(* Subject for browsing prior versions of a method as recorded in a
   particular source repository. Implements the MemberHistorySubject
   informal protocol consumed by MemberHistoryPresenter:
     repo, draftPath, liveSource, installHistoricalSource:, title,
     memberKindLabel. *)
		
	) (
		public createPresenter ^<Presenter> = (
			^MemberHistoryPresenter onSubject: self
		)
		public methodModel ^<MethodModel> = (
			^model methodModel
		)
		public methodMirror ^<MethodMirror> = (
			^methodModel methodMirror
		)
		public memberMirror = (
			(* The mirror EntrySubjects need to drive kind dispatch + install. *)
			
			^methodMirror
		)
		public repo = (
			^model repo
		)
		public draftPath ^<String> = (
			^ide draftPathForMethodMirror: methodMirror
		)
		public liveSource ^<String> = (
			^methodMirror source
		)
		public installHistoricalSource: src <String> = (
			(* Same shape as MethodSubject>>compileSource:ifSuccess:ifFailure:'s
     builder dance, but reused as the revert-as-edit path: the supplied
     text becomes the new live method source via installFromBuilders:. *)
			
			| builder |
			builder:: methodMirror definingMixin asBuilder.
			builder methods addFromSource: src.
			ide installFromBuilders: {builder declaration. }
		)
		public memberKindLabel ^<String> = (
			^'method'
		)
		public title ^<String> = (
			^'History: ' , (memberPathName: methodMirror definingMixin declaration) , ' >> ' , methodMirror name asString
		)
		public isKindOfMethodHistorySubject ^<Boolean> = (
			^true
		)
		isMyKind: f <Subject> ^<Boolean> = (
			^f isKindOfMethodHistorySubject
		)
		memberPathName: cd ^<String> = (
			| names path c |
			names:: List new.
			c:: cd.
			[ c isNil ] whileFalse: [
					names add: c simpleName asString.
					c:: c enclosingClass
				].
			path:: ''.
			names size to: 1
				by: -1
				do: [:i |
					path:: path , (names at: i).
					i > 1 ifTrue: [ path:: path , '.' ]
				].
			^path
		)
	) : ()
	public class LazySlotHistorySubject onModel: m <LazySlotHistoryModel> = ProgrammingSubject onModel: m (
		(* Per-lazy-slot history. Implements the MemberHistorySubject protocol. *)
		
	) (
		public createPresenter ^<Presenter> = (
			^MemberHistoryPresenter onSubject: self
		)
		public lazySlotModel = (
			^model lazySlotModel
		)
		public slotMirror = (
			^lazySlotModel slotMirror
		)
		public memberMirror = (
			^slotMirror
		)
		public repo = (
			^model repo
		)
		public draftPath ^<String> = (
			^ide draftPathForLazySlotMirror: slotMirror
		)
		public liveSource ^<String> = (
			^slotMirror source
		)
		public installHistoricalSource: src <String> = (
			| builder |
			builder:: slotMirror definingMixin asBuilder.
			builder lazySlots addFromSource: src.
			ide installFromBuilders: {builder declaration. }
		)
		public memberKindLabel ^<String> = (
			^'lazy slot'
		)
		public title ^<String> = (
			^'History: ' , (memberPathName: slotMirror definingMixin declaration) , ' >> ' , slotMirror name asString
		)
		public isKindOfLazySlotHistorySubject ^<Boolean> = (
			^true
		)
		isMyKind: f <Subject> ^<Boolean> = (
			^f isKindOfLazySlotHistorySubject
		)
		memberPathName: cd ^<String> = (
			| names path c |
			names:: List new.
			c:: cd.
			[ c isNil ] whileFalse: [
					names add: c simpleName asString.
					c:: c enclosingClass
				].
			path:: ''.
			names size to: 1
				by: -1
				do: [:i |
					path:: path , (names at: i).
					i > 1 ifTrue: [ path:: path , '.' ]
				].
			^path
		)
	) : ()
	public class ClassHeaderHistorySubject onModel: m <ClassHeaderHistoryModel> = ProgrammingSubject onModel: m (
		(* Per-class-header history. Implements the MemberHistorySubject protocol.
   The "live source" is the class header text (factory params, slot
   block, superclass clause); install routes through builder header
   source: and installFromBuilders: {b}. *)
		
	) (
		public createPresenter ^<Presenter> = (
			^MemberHistoryPresenter onSubject: self
		)
		public classMirror = (
			^model classMirror
		)
		public memberMirror = (
			^classMirror
		)
		public repo = (
			^model repo
		)
		public draftPath ^<String> = (
			^ide draftPathForClassDeclaration: classMirror
		)
		public liveSource ^<String> = (
			^classMirror header source
		)
		public installHistoricalSource: src <String> = (
			| b |
			b:: classMirror asBuilder.
			b header source: src.
			ide installFromBuilders: {b. }
		)
		public memberKindLabel ^<String> = (
			^'class header'
		)
		public title ^<String> = (
			^'History: ' , (memberPathName: classMirror) , ' header'
		)
		public isKindOfClassHeaderHistorySubject ^<Boolean> = (
			^true
		)
		isMyKind: f <Subject> ^<Boolean> = (
			^f isKindOfClassHeaderHistorySubject
		)
		memberPathName: cd ^<String> = (
			| names path c |
			names:: List new.
			c:: cd.
			[ c isNil ] whileFalse: [
					names add: c simpleName asString.
					c:: c enclosingClass
				].
			path:: ''.
			names size to: 1
				by: -1
				do: [:i |
					path:: path , (names at: i).
					i > 1 ifTrue: [ path:: path , '.' ]
				].
			^path
		)
	) : ()
	public class MemberRepoHistorySubject onModel: m <MemberRepoHistoryModel> = ProgrammingSubject onModel: m (
		(* Multi-repo wrapper around a single member's history. Holds the
   repo-agnostic identity (kind + target via the model); the
   presenter walks ide drafts (always) plus every Repository in Root
   whose namespace currently contains the member's defining class
   (`trackingRepos`), and stacks a collapsible per-repo
   ToggleComposer per repo. Order is permanent-first / drafts-last
   so time flows downward toward the live version.
   Historical-only repos (have commits but don't currently track the
   class) are not yet surfaced -- Phase-2 follow-up. *)
		
	) (
		public createPresenter ^<Presenter> = (
			^MemberRepoHistoryPresenter onSubject: self
		)
		public kind ^<Symbol> = (
			^model kind
		)
		public target = (
			^model target
		)
		public draftsRepo = (
			^ide drafts
		)
		public memberKindLabel ^<String> = (
			model kind = #method ifTrue: [ ^'method' ].
			model kind = #lazySlot ifTrue: [ ^'lazy slot' ].
			model kind = #classHeader ifTrue: [ ^'class header' ].
			^'member'
		)
		public definingClass ^<ClassDeclarationMirror> = (
			(* The live ClassDeclarationMirror that owns this member -- used to
     decide which Repositories track the member. Methods / slots reach
     through their definingMixin; class headers ARE the class. *)
			
			model kind = #method ifTrue: [
					^model target methodMirror definingMixin declaration
				].
			model kind = #lazySlot ifTrue: [
					^model target slotMirror definingMixin declaration
				].
			^model target
			(* classMirror *)
			
		)
		public memberName ^<Symbol | Nil> = (
			(* The selector / slot name we'd filter by inside a multi-member
     repo file. Nil for class headers (they're the whole declaration
     and any commit touching the file is relevant). *)
			
			model kind = #method ifTrue: [ ^model target methodMirror name ].
			model kind = #lazySlot ifTrue: [ ^model target slotMirror name ].
			^nil
		)
		public title ^<String> = (
			| cd kind nameStr classPath |
			cd:: definingClass.
			kind:: memberKindLabel.
			nameStr:: memberName isNil ifTrue: [ '' ]
				ifFalse: [ ' >> ' , memberName asString ].
			classPath:: qualifiedNameOf: cd.
			^'History: ' , classPath , nameStr , ' (' , kind , ')'
		)
		qualifiedNameOf: cd ^<String> = (
			(* Dotted enclosing-class chain, e.g. "MirrorsForJS.MixinBuilder".
     Mirrors the helper of the same name in AI_IDE_Support and the
     existing per-kind HistorySubjects so the outer banner matches
     what the inner presenter would have shown. *)
			
			| names path c |
			names:: List new.
			c:: cd.
			[ c isNil ] whileFalse: [
					names add: c simpleName asString.
					c:: c enclosingClass
				].
			path:: ''.
			names size to: 1
				by: -1
				do: [:i |
					path:: path , (names at: i).
					i > 1 ifTrue: [ path:: path , '.' ]
				].
			^path
		)
		public trackingRepos ^<List[Repository]> = (
			(* Permanent repos in Root whose namespace currently contains the
     defining class. drafts is NOT included here -- the presenter
     always shows drafts separately. *)
			
			| className result |
			className:: definingClass simpleName.
			result:: List new.
			ide namespacing Root keysAndValuesDo: [:key :value |
					(value isKindOfRepository and: [
							(value namespace at: className ifAbsent: [ nil ]) isNil not
						]) ifTrue: [ result add: value ]
				].
			^result
		)
		public historyModelFor: repo = (
			(* Build the appropriate per-repo *HistoryModel for this member,
     so we can hand it to the per-repo *HistorySubject + MemberHistory-
     Presenter. *)
			
			model kind = #method ifTrue: [
					^MethodHistoryModel methodModel: model target repo: repo
				].
			model kind = #lazySlot ifTrue: [
					^LazySlotHistoryModel lazySlotModel: model target repo: repo
				].
			^ClassHeaderHistoryModel classMirror: model target repo: repo
		)
		public historySubjectFor: repo = (
			| hm |
			hm:: historyModelFor: repo.
			model kind = #method ifTrue: [ ^MethodHistorySubject onModel: hm ].
			model kind = #lazySlot ifTrue: [ ^LazySlotHistorySubject onModel: hm ].
			^ClassHeaderHistorySubject onModel: hm
		)
		public isKindOfMemberRepoHistorySubject ^<Boolean> = (
			^true
		)
		isMyKind: f <Subject> ^<Boolean> = (
			^f isKindOfMemberRepoHistorySubject
		)
	) : ()
	public class MemberRepoHistoryPresenter onSubject: s = ProgrammingPresenter onSubject: s (
		(* Multi-repo history surface. The outer banner identifies the member
   (with full dotted class path). Below it, each repo gets a
   collapsible ToggleComposer:
     - Collapsed: "Repository: <name>" row.
     - Expanded: an embedded MemberHistoryPresenter rendering its
       own slim toolbar (expand/collapse-all/refresh/help/menu
       scoped to the version list) + the version list itself.
   The outer toolbar (expand/collapse-all + help + menu) operates on
   the per-repo toggles -- expandAll expands every repo, collapseAll
   closes them. Per-repo expand/collapse-all is delegated downwards
   to the embedded MemberHistoryPresenter.
   Repos are listed oldest-first: permanent (committed) repos at top,
   drafts at the bottom -- time flows downward toward the live
   version. *)
		
		(* Cached taggedColumn of the per-repo ToggleComposers so expandAll /
   collapseAll can iterate via childrenDo:, mirroring MemberHistory-
   Presenter>>contentListSlot. Recomputed on each definition pass;
   that's fine since the toggles' own state (expanded vs collapsed)
   is held inside taggedColumn's updateVisualsFromSameKind: dance. *)
		
		|
			repoTogglesSlot
		|
	) (
		public isKindOfMemberRepoHistoryPresenter ^<Boolean> = (
			^true
		)
		isMyKind: f <Fragment> ^<Boolean> = (
			^f isKindOfMemberRepoHistoryPresenter
		)
		definition = (
			| permanent toggles |
			permanent:: subject trackingRepos.
			toggles:: List new.
			
			(* Permanent (committed) repos start collapsed -- they're context
     the user opens deliberately. Drafts starts expanded since it's
     the always-present, always-edited repo and is what most users
     are coming here to look at. Once the user collapses or expands
     a toggle, the new state is carried across rebuilds via
     ToggleComposer>>updateVisualsFromSameKind:; the initiallyExpanded:
     value only takes effect on a fresh visit to the subject. *)
			permanent do: [:r | toggles add: (repoToggleFor: r initiallyExpanded: false) ].
			toggles add: (repoToggleFor: subject draftsRepo initiallyExpanded: true).
			repoTogglesSlot:: taggedColumn: toggles.
			^column: {helpSection. majorHeadingBlock: (row: {(label: subject title) bold. filler. expandButtonWithAction: [
								expandAll
							]. defaultBlank. collapseButtonWithAction: [ collapseAll ]. defaultBlank. helpButton. defaultBlank. dropDownMenu: [
								historyMenu
							]. }). mediumBlank. repoTogglesSlot. }
		)
		repoToggleFor: repo initiallyExpanded: open <Boolean> = (
			(* One collapsible block per repo. Tag is the repo name so the
     taggedColumn can match toggles across rebuilds. The expanded
     body is a fresh-per-render embedded MemberHistoryPresenter; its
     own toolbar carries the per-repo affordances. Across rebuilds
     the inner reconciles via MemberHistoryPresenter>>
     updateVisualsFromSameKind: which transfers loadStarted_slot and
     the entrySubject Map -- preventing a redundant historyOf:
     refetch per render. *)
			
			| repoName toggle |
			repoName:: repo name asString.
			toggle:: collapsed: [
					row: {(label: 'Repository: ') italic. (link: repoName
							action: [ toggle expand ]) color: actionLinkColor. filler. }
				]
				expanded: [
					column: {row: {(label: 'Repository: ') italic. (link: repoName
								action: [ toggle collapse ]) color: actionLinkColor. filler. }. smallBlank. (subject historySubjectFor: repo) createPresenter embedded: true;
							yourself. }
				]
				initiallyExpanded: open
				tag: repoName.
			^toggle
		)
		public expandAll = (
			repoTogglesSlot isNil ifFalse: [
					repoTogglesSlot childrenDo: [:t <ToggleComposer> | t expand ]
				]
		)
		public collapseAll = (
			repoTogglesSlot isNil ifFalse: [
					repoTogglesSlot childrenDo: [:t <ToggleComposer> | t collapse ]
				]
		)
		historyMenu = (
			^menuWithLabelsAndActions: {{'Inspect Presenter'. [
					respondToInspectPresenter
				]. }. }
		)
		helpText = (
			| mapping = Map new. |
			mapping at: #hopscotchHelpButton put: helpButton;
				at: #hopscotchExpandAllButton put: (expandButtonWithAction: [ expandAll ]);
				at: #hopscotchCollapseAllButton
					put: (collapseButtonWithAction: [ collapseAll ]);
				at: #hopscotchMenu put: (dropDownMenu: [ historyMenu ]).
			^ampleforth: 'This is the multi-repository history view for a single
' , subject memberKindLabel , '. It lists every repository in which the
defining class is currently tracked, oldest-first: permanent (committed)
repositories at the top, the in-IDE <em>drafts</em> store at the
bottom. Each entry is collapsible; expand a row to see that
repository''s history of this ' , subject memberKindLabel , ' in its own
panel, with its own expand-all / collapse-all / refresh / help /
Inspect Presenter affordances.
<br><br>
This bar provides the buttons below:
<ul>
<li> <div class="hopscotchHelpButton"> </div> Shows this help.</li>
<li> <div class="hopscotchExpandAllButton"> </div> Expand every
repository panel.</li>
<li> <div class="hopscotchCollapseAllButton"> </div> Collapse every
repository panel.</li>
<li> <div class="hopscotchMenu"> </div> Inspect this presenter.</li>
</ul>'
				mapping: mapping
		)
	) : ()
	public class MemberHistoryPresenter onSubject: s = ProgrammingPresenter onSubject: s (
		(* Generic history-list presenter shared by methods, lazy slots, and
   class headers. The subject -- one of MethodHistorySubject,
   LazySlotHistorySubject, ClassHeaderHistorySubject -- supplies the
   member-specific bits via this informal protocol:
     repo                     the source repository
     draftPath                file path within the repo
     liveSource               current live source of the member
     installHistoricalSource: install given source via installFromBuilders:
     title                    heading text
     memberKindLabel          'method' / 'lazy slot' / 'class header'

   Each row is a ToggleComposer: collapsed shows metadata (short SHA,
   date, commit subject, inlined member-change body); expanded embeds
   a CodeMirror initialized with the LIVE source then text-set to the
   HISTORICAL source, producing the standard pending-edit state. Accept
   routes through subject installHistoricalSource: -- the revert lands
   as a new append-only Accept commit in the repo. Cancel resets the
   editor and collapses the row.

   Two display modes:
     * Standalone (embeddedSlot=false): full helpSection +
       majorHeadingBlock title row + body.
     * Embedded (embeddedSlot=true): used inside
       MemberRepoHistoryPresenter -- the outer banner owns the
       title, so we render only a slim per-repo toolbar (label +
       expand-all / collapse-all / refresh / help / Inspect) and
       the body.

   Data flow:
     * History list: synchronous cachedHistoryOf: check first. Hit ->
       render. Miss -> render 'Loading...' AND kick off historyOf:
       which populates the cache, then updateGUI: rebuilds; the fresh
       presenter hits the cache. The startFetch trigger gates on
       repo.isReadyForHistory so we never call git.log on a still-
       cloning Repository (would hang on lightning-fs locks).
     * Source blobs: same pattern, per-(path, sha) cache on the repo.

   The "refresh repo history" button uses `refreshHistory`, NOT
   `refresh`, because Fragment>>refresh is the framework's visual-
   tree propagation method -- overriding it would turn every render
   into a cache-invalidate-plus-updateGUI loop. *)
		
		|
			loadStarted_slot <Boolean> ::= false.
			loadFailed_slot <String>
			
			(* Tracks whether the cache has ever been observed populated for
   this presenter. Set true in definition the first render that sees
   cached non-nil; carried across rebuilds via
   updateVisualsFromSameKind:. Used to detect cache-was-invalidated:
   if a later render sees cached=nil while cacheObservedSlot is
   true, an external commit (or refresh) cleared the cache between
   renders, so loadStarted_slot is stale and we need to re-fire
   startFetch -- otherwise the body sticks on "Loading..." forever
   (because loadStarted_slot is still true from the previous fetch
   even though no fetch is in flight). *)
			cacheObservedSlot <Boolean> ::= false.
			
			(* When true, skip helpSection + majorHeadingBlock title bar in
   definition. Set by MemberRepoHistoryPresenter so its single
   outer banner isn't duplicated by per-repo inner banners. *)
			embeddedSlot <Boolean> ::= false.
			
			(* Memoized taggedColumn of the per-entry toggles, populated once per
   presenter instance. Lets expandAll / collapseAll iterate the toggles
   via childrenDo:. *)
			contentListSlot
		|
	) (
		lazy public state <MemberHistoryPresenterState> ::= 
		(* Holds the sha-keyed MemberHistoryEntrySubjects so that their
   CodeMirror editors persist across presenter rebuilds and row
   collapse/expand. Transferred between presenter instances via
   updateVisualsFromSameKind:, mirroring DefinitionListPresenter
   (Browsing.ns:1198). *)
		MemberHistoryPresenterState new.
		updateVisualsFromSameKind: oldPresenter <Self> ^<Alien[Element]> = (
			(* Transfer the EntrySubjects (and thus their persistent editors)
     from the old presenter so user edits survive parent rebuilds.
     Also carry over the load-state slots so the new presenter knows
     a fetch is already in flight (or has failed) -- otherwise the
     fresh-presenter-per-render cycle from updateGUI: kicks off a
     fresh historyOf: every render. cacheObservedSlot is part of
     this transfer: definition uses (cacheObserved AND cached=nil)
     to detect a between-renders cache invalidation and re-fire. *)
			
			state:: oldPresenter state.
			loadStarted_slot:: oldPresenter loadStarted.
			loadFailed_slot:: oldPresenter loadFailed.
			cacheObservedSlot:: oldPresenter cacheObserved.
			^super updateVisualsFromSameKind: oldPresenter
		)
		public loadStarted ^<Boolean> = (
			^loadStarted_slot
		)
		public loadFailed ^<String | Nil> = (
			^loadFailed_slot
		)
		public cacheObserved ^<Boolean> = (
			^cacheObservedSlot
		)
		public isKindOfMemberHistoryPresenter ^<Boolean> = (
			^true
		)
		public embedded: flag <Boolean> = (
			embeddedSlot:: flag
		)
		isMyKind: f <Fragment> ^<Boolean> = (
			^f isKindOfMemberHistoryPresenter
		)
		definition = (
			| cached |
			cached:: subject repo cachedHistoryOf: subject draftPath.
			
			(* If we previously observed a populated cache but now see nil, an
     external event (a drafts commit, a refresh, or a permanent repo
     commit/pull) invalidated it. The fetch we initiated last time
     has long since resolved, so loadStarted_slot is stale -- reset
     the load state so the gate below fires a fresh fetch. Otherwise
     the body sticks on "Loading..." until the user manually clicks
     refresh. *)
			(cached isNil and: [ cacheObservedSlot ]) ifTrue: [
					loadStarted_slot:: false.
					loadFailed_slot:: nil.
					cacheObservedSlot:: false
				].
			cached isNil ifFalse: [ cacheObservedSlot:: true ].
			(cached isNil and: [
					loadStarted_slot not and: [ subject repo isReadyForHistory ]
				]) ifTrue: [
					loadStarted_slot:: true.
					startFetch
				].
			embeddedSlot ifTrue: [
					^
					(* Embedded mode: the enclosing MemberRepoHistoryPresenter owns
       the outer "History: ..." banner. We render a per-repo slim
       toolbar (expand/collapse-all + refresh + help + Inspect)
       scoped to this repo's version list. *)
					column: {row: {(label: 'Repository: ') italic. (label: repoName) bold. filler. expandButtonWithAction: [
									expandAll
								]. defaultBlank. collapseButtonWithAction: [ collapseAll ]. defaultBlank. refreshButtonWithAction: [
									refreshHistory
								]. defaultBlank. helpButton. defaultBlank. dropDownMenu: [ historyMenu ]. }. mediumBlank. bodyFor: cached. }
				].
			^column: {helpSection. majorHeadingBlock: (row: {(label: subject title) bold. filler. expandButtonWithAction: [
								expandAll
							]. defaultBlank. collapseButtonWithAction: [ collapseAll ]. defaultBlank. refreshButtonWithAction: [
								refreshHistory
							]. defaultBlank. helpButton. defaultBlank. dropDownMenu: [ historyMenu ]. }). mediumBlank. bodyFor: cached. }
		)
		public refreshHistory = (
			(* Drop the cached history for this repo and re-fetch. The current
     cache is repo-wide; that's coarser than per-path but fine -- any
     other open MemberHistoryPresenter on the same repo will simply
     re-fetch on its next render.
     NOT named `refresh` because Fragment>>refresh is the framework's
     visual-tree propagation method (HopscotchForHTML5.ns:1642) -- it
     fires automatically on every noticeExposure via HolderComposer
     and other propagating fragments. Overriding `refresh` here would
     turn every render into a cache-invalidate + updateGUI: loop. *)
			
			subject repo invalidateHistoryCache.
			loadStarted_slot:: false.
			loadFailed_slot:: nil.
			updateGUI: [ ]
		)
		bodyFor: cached = (
			(* Distinguish four states explicitly:
       1. failed     -> show error.
       2. not ready  -> repo isn't cloned/local-only yet; tell the user
                        rather than spinning a misleading "Loading..."
                        on a repo we deliberately can't fetch from.
       3. loading    -> fetch in flight.
       4. empty      -> fetched, but git.log returned no commits
                        touching this member's file -- the "no changes
                        in a repo" case the user flagged.
     Otherwise render the content list. *)
			
			cached isNil ifTrue: [
					loadFailed_slot isNil ifFalse: [
							^label: 'Failed to load history from ' , repoName , ': ' , loadFailed_slot
						].
					subject repo isReadyForHistory ifFalse: [
							^label: 'Repository ' , repoName , ' is not ready (clone in progress or unconfigured); no history available yet.'
						].
					^label: 'Loading history from ' , repoName , '...'
				].
			(cached at: 'length') = 0 ifTrue: [
					^label: 'No prior versions of this ' , subject memberKindLabel , ' in ' , repoName , '.'
				].
			^contentListFor: cached
		)
		repoName = (
			(* The Repository protocol now exposes `name` polymorphically:
     DraftsRepo returns #drafts; user-visible Repositories return
     their registered Symbol name. *)
			
			^subject repo name asString
		)
		contentListFor: entries = (
			(* Build a taggedColumn of toggles once per presenter instance and
     stash it in contentListSlot so expandAll / collapseAll can iterate
     it. The taggedColumn handles updateVisualsFromSameKind: for the
     children across refreshes. Zebra-striped for readability,
     matching the namespace / method-list presentation.

     Iterate from last index down to 0 so the oldest commit lands on
     top and time flows downward toward the live version below. The
     entries array comes from isomorphic-git which returns newest-
     first; this reversal matches the MemberRepoHistoryPresenter
     "time moves downward from top to present" convention. *)
			
			| toggles last |
			toggles:: List new.
			last:: (entries at: 'length') - 1.
			last to: 0 by: -1 do: [:i | toggles add: (toggleFor: (entries at: i)) ].
			contentListSlot:: zebra: (taggedColumn: toggles).
			^contentListSlot
		)
		public contentList = (
			^contentListSlot
		)
		public expandAll = (
			contentListSlot isNil ifFalse: [
					contentListSlot childrenDo: [:each <ToggleComposer> | each expand ]
				]
		)
		public collapseAll = (
			contentListSlot isNil ifFalse: [
					contentListSlot childrenDo: [:each <ToggleComposer> | each collapse ]
				]
		)
		historyMenu = (
			^menuWithLabelsAndActions: {{'Inspect Presenter'. [
					respondToInspectPresenter
				]. }. }
		)
		helpText = (
			| mapping = Map new. kind = subject memberKindLabel. |
			mapping at: #hopscotchHelpButton put: helpButton;
				at: #hopscotchExpandAllButton put: (expandButtonWithAction: [ expandAll ]);
				at: #hopscotchCollapseAllButton
					put: (collapseButtonWithAction: [ collapseAll ]);
				at: #hopscotchRefreshButton
					put: (refreshButtonWithAction: [ refreshHistory ]);
				at: #hopscotchMenu put: (dropDownMenu: [ historyMenu ]).
			^ampleforth: 'This is the history presenter for a single ' , kind , ' as
recorded in one source repository -- ' , repoName , ', in this instance. It lists
every commit in that repository that touched this ' , kind , '''s file, oldest
on top so time flows downward toward the live version at the bottom. Each
row shows the short commit SHA (click to expand), the commit date, the
commit''s subject line, and an inline summary of which members were added (+),
modified (~), or removed (-).
<br><br>
Expanding a row reveals an editor pre-loaded with the historical version of the
' , kind , ' as a <em>pending edit</em> against the live source (yellow background,
accept/cancel). Accept installs the historical text through the normal install
path; the revert is recorded as a new Accept commit, so history stays
append-only. Cancel resets the editor to the live source and collapses the row.
You can also further edit the historical text before accepting, in which case
the Accept records exactly what you typed -- the historical version is just a
starting point.
<br><br>
Each MemberHistoryPresenter is scoped to a single repository. Two flavours
of repository are wired up:
<ul>
<li><em>drafts</em> -- the browser-local (IndexedDB) repository that the
IDE auto-commits to on every Accept. Always available.</li>
<li>Any user-visible <em>Repository</em> in Root whose namespace currently
contains the defining class.</li>
</ul>
The full list (drafts + any tracking Repository) is the multi-repository view
above, MemberRepoHistoryPresenter, which stacks one of these per repo as a
collapsible toggle.
<br><br>
The body shows one of four states depending on the underlying fetch:
<ul>
<li><em>Loading history from &lt;repo&gt;...</em> while git.log is in
flight.</li>
<li><em>Repository &lt;repo&gt; is not ready</em> when the repo is still
cloning or the clone failed -- we deliberately don''t fire git.log on a
partial working dir (lightning-fs takes a lock that would hang the IDE).</li>
<li><em>Failed to load history from &lt;repo&gt;: &lt;err&gt;</em> on
git.log rejection.</li>
<li><em>No prior versions of this ' , kind , ' in &lt;repo&gt;</em> when no
commit in this repo changed this specific ' , kind , '''s source. The
filter is precise even for permanent (per-top-level-class) repos:
git.log finds candidate commits by class file, then each candidate''s
' , kind , ' source is compared to the parent commit''s and only
differing ones survive.</li>
</ul>
<br>
Controls in the header bar (or, in the multi-repo view, in this repo''s
slim per-repo toolbar), from left to right after the title:
<ul>
<li><div class="hopscotchExpandAllButton"></div> Expand every row.</li>
<li><div class="hopscotchCollapseAllButton"></div> Collapse every row.</li>
<li><div class="hopscotchRefreshButton"></div> Re-fetch the history. Drops the
repo-wide history cache and re-runs git.log -- useful after an external
commit / pull (in-IDE Accepts already invalidate the cache automatically).</li>
<li><div class="hopscotchHelpButton"></div> Show this help message.</li>
<li><div class="hopscotchMenu"></div> A menu of additional operations; currently
just <em>Inspect Presenter</em>, which opens an object inspector on this presenter
so you can see the code driving the UI.</li>
</ul>
'
				mapping: mapping
		)
		toggleFor: entry = (
			| toggle |
			toggle:: collapsed: [ collapsedFor: entry toggle: toggle ]
				expanded: [ expandedFor: entry toggle: toggle ]
				initiallyExpanded: false
				tag: (entry at: 'oid').
			^toggle
		)
		collapsedFor: entry toggle: toggle = (
			| sha shortSha message firstLine inlineBody timestamp dateStr |
			sha:: entry at: 'oid'.
			shortSha:: sha copyFrom: 1 to: 7.
			message:: (entry at: 'commit') at: 'message'.
			firstLine:: firstLineOf: message.
			inlineBody:: oneLineBodyOf: message.
			timestamp:: ((entry at: 'commit') at: 'author') at: 'timestamp'.
			dateStr:: formatTimestamp: timestamp.
			^row: {(link: shortSha action: [ toggle expand ]) color: actionLinkColor. smallBlank. label: dateStr. smallBlank. label: firstLine. smallBlank. label: inlineBody. }
		)
		expandedFor: entry toggle: toggle = (
			| sha shortSha message firstLine inlineBody timestamp dateStr path entrySubject |
			sha:: entry at: 'oid'.
			shortSha:: sha copyFrom: 1 to: 7.
			message:: (entry at: 'commit') at: 'message'.
			firstLine:: firstLineOf: message.
			inlineBody:: oneLineBodyOf: message.
			timestamp:: ((entry at: 'commit') at: 'author') at: 'timestamp'.
			dateStr:: formatTimestamp: timestamp.
			path:: subject draftPath.
			entrySubject:: state subjectFor: entry
				path: path
				memberMirror: subject memberMirror.
			ensureVersionSourceFor: entrySubject path: path sha: sha.
			^column: {row: {(link: shortSha action: [ toggle collapse ]) color: actionLinkColor. smallBlank. label: dateStr. smallBlank. label: firstLine. smallBlank. label: inlineBody. }. mediumBlank. entrySubject createPresenter. }
		)
		ensureVersionSourceFor: entrySubject path: path sha: sha = (
			(* If the entry subject doesn't yet have its versionSource set,
     check the repo's sync cache first; on miss kick off the async
     fetch which on resolve sets the source and triggers updateGUI:
     so a fresh definition pass renders the EntryPresenter with
     source available.
     memberSourceAt:in: is polymorphic over the repo: DraftsRepo
     reads the per-member blob directly; user-visible Repositories
     project to the top-level class file, parse it, and extract the
     named member's source. The presenter doesn't care which.
     The fetchStarted guard is critical: each then: calls updateGUI:
     synchronously, which re-renders the whole content list, which
     re-iterates entries -- and without the guard, every entry whose
     promise hasn't yet resolved would refire its memberSourceAt:.
     With N rows that becomes an O(N^2) updateGUI: cascade that
     wedges the IDE. Set the flag before launching so subsequent
     renders skip it; the eventually-resolved then: writes the
     versionSource, after which the isNil early-exit takes over. *)
			
			| cached |
			entrySubject versionSource isNil ifFalse: [ ^self ].
			entrySubject versionSourceFetchStarted ifTrue: [ ^self ].
			cached:: subject repo cachedMemberSourceAt: path in: sha.
			cached isNil ifFalse: [ ^entrySubject versionSource: cached ].
			entrySubject beginVersionSourceFetch.
			(subject repo memberSourceAt: path in: sha) then: [:src |
					entrySubject versionSource: src.
					updateGUI: [ ].
					nil
				]
				onRejected: [:err |
					('MemberHistoryPresenter: member-source fetch failed for ' , path , ' @ ' , sha , ': ' , err printString) out.
					updateGUI: [ ].
					nil
				]
		)
		firstLineOf: msg <String> ^<String> = (
			| lf idx |
			lf:: String fromRunes: {10. }.
			idx:: msg indexOf: lf.
			^idx = 0 ifTrue: [ msg ] ifFalse: [ msg copyFrom: 1 to: idx - 1 ]
		)
		bodyOf: msg <String> ^<String> = (
			(* Everything after the subject line and the conventional blank
     separator. Empty if there's no body. *)
			
			| lf idx bodyStart |
			lf:: String fromRunes: {10. }.
			idx:: msg indexOf: lf.
			idx = 0 ifTrue: [ ^'' ].
			bodyStart:: idx + 1.
			(bodyStart <= msg size and: [ (msg copyFrom: bodyStart to: bodyStart) = lf ]) ifTrue: [
					bodyStart:: bodyStart + 1
				].
			bodyStart > msg size ifTrue: [ ^'' ].
			^msg copyFrom: bodyStart to: msg size
		)
		oneLineBodyOf: msg <String> ^<String> = (
			(* Collapse the multi-line body into a single line: split on LF, trim
     each line's leading spaces, drop blanks, join with ' . '. Used
     to put the per-member change list on the same row as the heading. *)
			
			| body lf sb start idx pieces |
			body:: bodyOf: msg.
			body isEmpty ifTrue: [ ^'' ].
			lf:: String fromRunes: {10. }.
			pieces:: List new.
			start:: 1.
			idx:: body indexOf: lf startingAt: start.
			[ idx > 0 ] whileTrue: [
					pieces add: (trimLeadingSpaces: (body copyFrom: start to: idx - 1)).
					start:: idx + 1.
					idx:: body indexOf: lf startingAt: start
				].
			pieces add: (trimLeadingSpaces: (body copyFrom: start to: body size)).
			sb:: StringBuilder new.
			pieces do: [:p |
					p isEmpty ifFalse: [
							sb size = 0 ifFalse: [ sb add: ' . ' ].
							sb add: p
						]
				].
			^sb asString
		)
		trimLeadingSpaces: s <String> ^<String> = (
			| i |
			i:: 1.
			[ i <= s size and: [ (s copyFrom: i to: i) = ' ' ] ] whileTrue: [ i:: i + 1 ].
			^s copyFrom: i to: s size
		)
		formatTimestamp: tsSeconds = (
			(* git timestamps are seconds since epoch. The alien bridge truncates
     Newspeak Integer to 32 bits when handing it to JS, which silently
     loses the high bits of milliseconds-since-epoch timestamps. Force
     Float arithmetic via asFloat so the value reaches JS as a double. *)
			
			^(Date new: tsSeconds asFloat * 1000) toLocaleString
		)
		startFetch = (
			(* historyOf: caches into subject.repo on resolve; updateGUI:
     triggers a parent re-render. The fresh MethodHistoryPresenter
     produced by that re-render will see the cached entries on its
     synchronous definition pass. *)
			
			(subject repo historyOf: subject draftPath) then: [:log |
					updateGUI: [ ].
					nil
				]
				onRejected: [:err |
					updateGUI: [ loadFailed_slot:: err printString ].
					nil
				]
		)
	) : ()
	public class MemberHistoryEntrySubject onModel: m <MemberHistoryEntryModel> = ProgrammingSubject onModel: m (
		(* Subject for a single historical version of a member. Lives in
   MemberHistoryPresenterState (keyed by sha), so it persists across
   row collapse/expand and across parent presenter rebuilds. Holds the
   editor CodeMirrorFragment lazily; the fragment is created once by
   the EntryPresenter and stashed here, then reused on every render
   for cursor / selection / undo persistence. *)
		
		|
			editor_slot
			versionSource_slot
			
			(* Per-entry "fetch in flight" guard. Without this every render of
   the rows section re-fires memberSourceAt: for every entry whose
   versionSource_slot hasn't been written yet, and each resolve
   calls updateGUI: synchronously -- an O(N^2) updateGUI cascade
   that wedges the IDE. Set true on the first call to
   beginVersionSourceFetch; never reset (each entry is fetched at
   most once per session). *)
			versionSourceFetchStarted_slot ::= false.
			
			(* True when the user has hit "Compare to live" on this entry's
   editor. The diff marks are re-applied on every noticeExposure by
   a CompareToLiveDecorator fragment sibling of the editor; the
   slot is the only source of truth. Persisted on the subject
   (not on the presenter) so the state survives presenter rebuilds.
   See CompareToLiveDecorator's docstring for the wipe-and-re-apply
   protocol that motivates the decorator. *)
			compareLiveActive_slot <Boolean> ::= false.
			
			(* True for entries synthesised by `forChangesetVersionSource:`
   (changeset HEAD vs live rows). Those rows already render a
   side-by-side diff via DiffSideBySideTrigger; adding the live
   compare affordance on top would be redundant on the "Live"
   side and confusing on the "HEAD" side. The presenter omits
   the compareToLive button when this is true. *)
			isChangesetEntry_slot <Boolean> ::= false.
			messages_slot
			messagesComputed_slot ::= false.
		|
	) (
		public createPresenter ^<Presenter> = (
			^MemberHistoryEntryPresenter onSubject: self
		)
		public memberMirror = (
			^model memberMirror
		)
		public entry = (
			^model entry
		)
		public versionSourceFetchStarted ^<Boolean> = (
			^versionSourceFetchStarted_slot
		)
		public beginVersionSourceFetch = (
			versionSourceFetchStarted_slot:: true
		)
		public path = (
			^model path
		)
		public sha = (
			^entry at: 'oid'
		)
		public shortSha ^<String> = (
			(* Bound the upper index by sha size. The live history flow always
     hands us a full 40-char git oid; the changeset flow synthesises
     a shorter pseudo-oid (e.g. 'HEAD'). primordialsoup's String>>
     copyFrom:to: raises ArgumentError when `to > size`. *)
			
			^sha copyFrom: 1 to: (7 min: sha size)
		)
		public commitMessage ^<String> = (
			^(entry at: 'commit') at: 'message'
		)
		public commitTimestamp = (
			^((entry at: 'commit') at: 'author') at: 'timestamp'
		)
		public versionSource ^<String | Nil> = (
			^versionSource_slot
		)
		public versionSource: src <String> = (
			versionSource_slot:: src
		)
		public editor = (
			^editor_slot
		)
		public editor: cm = (
			editor_slot:: cm
		)
		public compareLiveActive ^<Boolean> = (
			^compareLiveActive_slot
		)
		public compareLiveActive: b <Boolean> = (
			compareLiveActive_slot:: b
		)
		public isChangesetEntry ^<Boolean> = (
			^isChangesetEntry_slot
		)
		public isChangesetEntry: b <Boolean> = (
			isChangesetEntry_slot:: b
		)
		public liveSource ^<String | Nil> = (
			(* Source of the LIVE version of this member, for the "Compare to
     live" diff. Dispatches on memberMirror kind: methods and lazy
     slots expose source directly, class declarations expose header
     source. Returns nil for memberMirrors that don't resolve to a
     live mirror (e.g. SourceMirror-flavoured stand-ins used in the
     changeset flow) -- the presenter checks and disables the
     compare button in that case. *)
			
			| m |
			m:: memberMirror.
			m isKindOfClassDeclarationMirror ifTrue: [
					^[ m header source ] on: Exception do: [:e | nil ]
				].
			(m isKindOfMethodMirror or: [ m isKindOfLazySlotMirror ]) ifTrue: [
					^[ m source ] on: Exception do: [:e | nil ]
				].
			^nil
		)
		public installEdits: text <String> = (
			(* Install `text` as the new live source of the member this entry
     is a version of. Dispatches on memberMirror's kind: methods and
     lazy slots install through the defining mixin's builder; class
     declarations install through the declaration's own builder
     mutating its header source. Mirrors the old parent-delegated
     installHistoricalSource: paths (MethodHistorySubject,
     LazySlotHistorySubject, ClassHeaderHistorySubject) -- moved here
     once the parent disappeared. *)
			
			| mirror |
			mirror:: memberMirror.
			mirror isKindOfMethodMirror ifTrue: [
					| builder |
					builder:: mirror definingMixin asBuilder.
					builder methods addFromSource: text.
					^ide installFromBuilders: {builder declaration. }
				].
			mirror isKindOfLazySlotMirror ifTrue: [
					| builder |
					builder:: mirror definingMixin asBuilder.
					builder lazySlots addFromSource: text.
					^ide installFromBuilders: {builder declaration. }
				].
			mirror isKindOfClassDeclarationMirror ifTrue: [
					| b |
					b:: mirror asBuilder.
					b header source: text.
					^ide installFromBuilders: {b. }
				].
			Error signal: 'MemberHistoryEntrySubject>>installEdits: unrecognized memberMirror kind'
		)
		public messages ^<List[Symbol] | Nil> = (
			(* Lazily compiles versionSource against the live defining mixin and
     walks the resulting bytecode for sent selectors. Returns nil when
     compilation fails (e.g. the source predates a syntax change) or
     when there's no source yet. nil is the "menu shows a disabled
     entry" signal; an empty list is "compiled fine but no sends". *)
			
			messagesComputed_slot ifTrue: [ ^messages_slot ].
			versionSource_slot isNil ifTrue: [ ^nil ].
			messagesComputed_slot:: true.
			messages_slot:: [ computeMessages ] on: Error do: [:e | nil ].
			^messages_slot
		)
		computeMessages ^<List[Symbol] | Nil> = (
			| mirror |
			mirror:: memberMirror.
			mirror isKindOfMethodMirror ifTrue: [
					| imeth |
					imeth:: compiler compileMethodSource: versionSource_slot
						within: mirror definingMixin.
					^selectorsInBytes: imeth bytes literals: imeth literals
				].
			mirror isKindOfLazySlotMirror ifTrue: [
					| islot init |
					islot:: compiler compileLazySlotSource: versionSource_slot
						within: mirror definingMixin.
					init:: islot intermediateInitMethod.
					^selectorsInBytes: init bytes literals: init literals
				].
			mirror isKindOfClassDeclarationMirror ifTrue: [ ^computeHeaderMessages ].
			^nil
		)
		computeHeaderMessages ^<List[Symbol]> = (
			(* Mirrors the live ClassFactoryPresenter>>messages at
     Browsing.ns:685: explicit slot names (and setters for mutable
     slots) plus the bytecode-walked selectors of the synthetic class-
     declaration initializer, with backtick-mangled internal selectors
     dropped. We deliberately do NOT walk the factory -- the live menu
     doesn't either, so basicNew etc. would just be noise. `within:`
     is nil; Newspeak's late binding means selector extraction does
     not need an enclosing-scope lookup. *)
			
			| icd accum initSelectors |
			icd:: compiler compileClassHeader2: versionSource_slot within: nil.
			accum:: List new.
			icd instanceSide slots do: [:slot |
					accum add: slot name.
					slot isMutable ifTrue: [ accum add: slot name , ':' ]
				].
			icd initializers isNil ifFalse: [
					icd initializers do: [:imeth |
							initSelectors:: (selectorsInBytes: imeth bytes literals: imeth literals) removeAllSuchThat: [:s |
									(s indexOf: '`') > 0
								].
							initSelectors do: [:s | (accum indexOf: s) = 0 ifTrue: [ accum add: s ] ]
						]
				].
			^accum
		)
		selectorsInBytes: bytes literals: literals ^<List[Symbol]> = (
			(* Bytecode walker. Mirrors MethodMirror>>selectors in
     out/MirrorsForPrimordialSoup.ns:1090 -- common sends, ordinary
     sends, and the extension-byte forms for implicit-receiver / super
     / self / outer sends. Selectors are accumulated from the literal
     pool. *)
			
			| pc extA result |
			pc:: 1.
			extA:: 0.
			result:: Set new.
			[ pc > bytes size ] whileFalse: [
					| instruction |
					instruction:: bytes at: pc.
					(instruction > 79 and: [ instruction <= 111 ]) ifTrue: [
							result add: (commonSendSelector: instruction - 79)
						].
					(instruction > 112 and: [ instruction <= 175 ]) ifTrue: [
							| index |
							index:: 1 + (instruction bitAnd: 15).
							result add: (literals at: index)
						].
					instruction = 224 ifTrue: [
							| byte2 |
							byte2:: bytes at: pc + 1.
							extA:: extA << 8 + byte2
						].
					({227. 228. 253. } indexOf: instruction) > 0 ifTrue: [ extA:: 0 ].
					({238. 240. 241. 245. 254. } indexOf: instruction) > 0 ifTrue: [
							| byte2 index |
							byte2:: bytes at: pc + 1.
							index:: 1 + (extA << 5) + (byte2 >> 3).
							extA:: 0.
							result add: (literals at: index)
						].
					pc:: pc + (bytecodeSize: instruction)
				].
			^List withAll: result asArray
		)
		bytecodeSize: instruction = (
			instruction <= 223 ifTrue: [ ^1 ].
			instruction <= 248 ifTrue: [ ^2 ].
			^3
		)
		commonSendSelector: offset = (
			^{#+. #-. #<. #>. #<=. #>=. #=. #~=. #*. #/. #\\. #@. #bitShift:. #//. #bitAnd:. #bitOr:. #at:. #at:put:. #size. #next. #nextPut:. #atEnd. #==. #class. #blockCopy:. #value. #value:. #do:. #new. #new:. #x. #y. } at: offset
		)
		public isKindOfMemberHistoryEntrySubject ^<Boolean> = (
			^true
		)
		isMyKind: f <Subject> ^<Boolean> = (
			^f isKindOfMemberHistoryEntrySubject
		)
	) : (
		public forChangesetVersionSource: src <String> memberMirror: mm path: path <String> commitOid: oid <String> commitMessage: msg <String> commitTimestamp: ts <Integer> ^<MemberHistoryEntrySubject> = (
			(* Build an EntrySubject for a changeset (HEAD vs live) row, where
     no real isomorphic-git log entry exists. Synthesizes the
     {oid, commit/message, commit/author/timestamp} Map the EntrySubject
     reads, pre-seats versionSource, and hands back the subject ready
     to drive a MemberHistoryEntryPresenter. *)
			
			| entry commit author subject |
			entry:: Map new.
			entry at: 'oid' put: oid.
			commit:: Map new.
			commit at: 'message' put: msg.
			author:: Map new.
			author at: 'timestamp' put: ts.
			commit at: 'author' put: author.
			entry at: 'commit' put: commit.
			subject:: self onModel: (MemberHistoryEntryModel entry: entry
					memberMirror: mm
					path: path).
			subject versionSource: src.
			subject isChangesetEntry: true.
			^subject
		)
	)
	public class MemberHistoryEntryPresenter onSubject: s <MemberHistoryEntrySubject> = ProgrammingPresenter onSubject: s (
		(* Renders ONE historical version. Drops live-only affordances
   (exemplar / debug). Editor is the subject's persistent
   CodeMirrorFragment, created lazily on first render and reused
   thereafter -- this is the load-bearing piece for edit persistence
   across collapse and refresh.

   Make Live button is always visible: it installs whatever's in the
   editor (edited or original) through the parent subject's
   installHistoricalSource:. CodeMirror's standard accept does the
   same when edits are pending. Cancel (CodeMirror's red button) is
   only visible with edits and resets the editor to the version's
   original source.

   References menu and AI brain reuse the live affordances, scoped to
   this historical version. The brain installs a historical focus on
   ide aiSupport so the shared chat picks up the version's sha and
   source through current_focus; source-reading tools fan out to the
   historical blob when the request matches. Writes still install to
   live (Make Live semantic), matching the button next to them.

   Colorization dispatches on the entry's memberMirror.isKindOf*. *)
		
	) (
		public isKindOfMemberHistoryEntryPresenter ^<Boolean> = (
			^true
		)
		isMyKind: f <Fragment> ^<Boolean> = (
			^f isKindOfMemberHistoryEntryPresenter
		)
		definition = (
			subject versionSource isNil ifTrue: [ ^label: 'Loading source...' ].
			^column: {helpSection. ensureEditor. mediumBlank. actionRow. chatSection. 
				(* Decorator must come AFTER the editor: its noticeExposure
       re-applies the diff each round-trip (Hopscotch's CodeMirror
       reconciliation calls editor setValue, which clears marks),
       and the editor has to exist at noticeExposure time. *)
				CompareToLiveDecorator onEntry: subject. }
		)
		actionRow = (
			(* compareToLive only appears when the diff is meaningful:
     never on a changeset HEAD/live row (those already render a
     side-by-side diff via DiffSideBySideTrigger), and never when
     the member has no live counterpart (deleted member, phantom
     SourceMirror in #added rows). Showing-it-greyed-out was
     reported as ambiguous, so the affordance is removed entirely
     in those cases rather than dimmed. *)
			
			| items |
			items:: List new.
			items add: mediumBlank.
			items add: (button: 'Make Live' action: [ installCurrentEditorText ]).
			items add: smallBlank.
			showCompareToLive ifTrue: [
					items add: compareToLiveButton.
					items add: smallBlank
				].
			items add: (dropDownMenu: [ messagesMenu ]
					image: ide images itemReferencesImage).
			items add: smallBlank.
			items add: (aiChatButton: [ installHistoryFocusAction ]
					ifFocused: [
						ide aiSupport isFocusedOnHistory: subject memberMirror sha: subject sha
					]).
			items add: smallBlank.
			items add: helpButton.
			items add: smallBlank.
			items add: (dropDownMenu: [ entryMenu ]).
			items add: filler.
			^row: items
		)
		showCompareToLive ^<Boolean> = (
			subject isChangesetEntry ifTrue: [ ^false ].
			^subject liveSource isNil not
		)
		entryMenu = (
			^menuWithLabelsAndActions: {{'Inspect Presenter'. [
					respondToInspectPresenter
				]. }. }
		)
		helpText = (
			| mapping = Map new. kind |
			kind:: memberKindLabel.
			mapping at: #hopscotchHelpButton put: helpButton;
				at: #hopscotchReferencesButton
					put: (dropDownMenu: [ messagesMenu ] image: ide images itemReferencesImage);
				at: #hopscotchMenu put: (dropDownMenu: [ entryMenu ]).
			^ampleforth: 'This is an entry presenter for one version of a ' , kind , '.
The editor below shows the source for that version. Editing the text
puts the editor into pending-edit mode (accept / cancel appear).
<br><br>
<b>Make Live</b> installs whatever''s currently in the editor as the
new live source for this ' , kind , ' -- the same install path used
elsewhere in the IDE. Cancel resets the editor to the version''s
original source.
<br><br>
Controls in the row below the editor, from left to right:
<ul>
<li><b>Make Live</b> -- install editor text as the new live ' , kind , '.</li>
<li><b>Compare to live</b> (when present) -- tints lines and character
spans in this historical view that are <em>no longer in</em> the
current live source. Content that was <em>added</em> in live since
this version is not shown here -- only one editor pane is available,
so the diff is one-sided by design. Click again to clear. Absent on
changeset rows (those already render a side-by-side diff) and on
entries whose member no longer exists live.</li>
<li><div class="hopscotchReferencesButton"></div> -- menu of selectors
sent from this version, each navigable.</li>
<li>AI chat button -- focus the IDE chat on this historical version
(its sha + source). Source-reading tools fan out to the version''s
blob; writes still install live, matching <b>Make Live</b>.</li>
<li><div class="hopscotchHelpButton"></div> -- show this help message.</li>
<li><div class="hopscotchMenu"></div> -- additional operations
(<em>Inspect Presenter</em>).</li>
</ul>
'
				mapping: mapping
		)
		memberKindLabel = (
			(* Dispatched off the entry's memberMirror so we can describe what
     kind of thing this entry is in the help text. *)
			
			| mirror |
			mirror:: subject memberMirror.
			mirror isKindOfMethodMirror ifTrue: [ ^'method' ].
			mirror isKindOfLazySlotMirror ifTrue: [ ^'lazy slot' ].
			mirror isKindOfClassDeclarationMirror ifTrue: [ ^'class header' ].
			^'member'
		)
		installHistoryFocusAction = (
			ide aiSupport setHistoryFocusOnEntry: subject
		)
		messagesMenu = (
			(* If compilation fell over (syntax change since the commit), show a
     single disabled placeholder. Otherwise build the same item set the
     live MethodPresenter uses, dropping selectors that contain spaces
     (the existing string-heuristic for "not a real selector") and
     skipping the entry's own selector when it matches one. *)
			
			| msgs items |
			msgs:: subject messages.
			msgs isNil ifTrue: [
					^menuWithLabelsAndActions: {{'(source predates a syntax change)'. [ ]. }. }
				].
			items:: referencesMenuMessageItems: msgs.
			items isEmpty ifTrue: [
					^menuWithLabelsAndActions: {{'(no references in this version)'. [ ]. }. }
				].
			^menuWithLabelsAndActions: items
		)
		referencesMenuMessageItems: msgs <List[Symbol]> ^<List> = (
			(* Same shape as the live MethodPresenter's referencesMenuMessageItems
     at Browsing.ns:2744 -- filter, sort lexically, emit
     {label. [browseSelector: selector]}. *)
			
			| items likely sorted name |
			items:: List new.
			name:: parentMemberName.
			likely:: msgs select: [:s <String> | 0 = (s indexOf: ' ') ].
			sorted:: likely sort: [:m1 :m2 | lexicallyLessOrEqual: m1 than: m2 ].
			sorted do: [:selector |
					selector == name ifFalse: [
							items add: {selector copyFrom: 1 to: (64 min: selector size). [
									browseSelector: selector
								]. }
						]
				].
			^items
		)
		parentMemberName = (
			(* Skip the entry's own name when listing its sends, so we don't
     suggest "find senders of foo" from inside foo. Class-header
     entries don't have a single member name to skip; nil. *)
			
			| mirror |
			mirror:: subject memberMirror.
			mirror isKindOfMethodMirror ifTrue: [ ^mirror name ].
			mirror isKindOfLazySlotMirror ifTrue: [ ^mirror name ].
			^nil
		)
		ensureEditor ^<CodeMirrorFragment> = (
			(* Lazy-init the CodeMirror once; subsequent renders return the same
     Fragment instance, preserving text, cursor, undo. *)
			
			subject editor isNil ifTrue: [
					| src cm |
					src:: crToLf: subject versionSource.
					cm:: codeMirror: src.
					cm changeResponse: [:ed :ev |
							colorizeSource: (crToLf: ed textBeingAccepted) withEditor: ed
						];
						cancelResponse: [:ed |
								ed text: src.
								colorizeSource: src withEditor: ed.
								ed leaveEditState
							];
						acceptResponse: [:ed :ev | installAndResetEditor: ed ].
					colorizeSource: src withEditor: cm.
					subject editor: cm
				].
			^subject editor
		)
		colorizeSource: src <String> withEditor: cm <CodeMirrorFragment> = (
			(* Colorization is presentation; kind-dispatch on the entry's
     memberMirror. *)
			
			| mirror |
			mirror:: subject memberMirror.
			mirror isKindOfMethodMirror ifTrue: [
					^ide colorizer colorizeMethod: src
						fromClass: mirror definingMixin declaration
						via: (colorizingBlockFor: cm)
				].
			mirror isKindOfLazySlotMirror ifTrue: [
					^ide colorizer colorizeLazySlot: src
						fromClass: mirror definingMixin declaration
						via: (colorizingBlockFor: cm)
				].
			mirror isKindOfClassDeclarationMirror ifTrue: [
					^ide colorizer colorizeHeader: src
						fromClass: mirror
						via: (colorizingBlockFor: cm)
				]
		)
		installAndResetEditor: ed <CodeMirrorFragment> = (
			(* CodeMirror's accept path: install edited text, reset editor to
     the version's original. *)
			
			updateGUI: [
					[
						subject installEdits: ed textBeingAccepted.
						resetEditor: ed
					] on: Error do: [:ex <Exception> | ed showMessage: ex printString ]
				].
			ed editor focus
		)
		installCurrentEditorText = (
			(* Make Live button: always available. Installs whatever's currently
     in the editor (edited or not), then resets to the version's
     original. *)
			
			| cm |
			cm:: subject editor.
			cm isNil ifTrue: [ ^self ].
			updateGUI: [
					[
						subject installEdits: cm textBeingAccepted.
						resetEditor: cm
					] on: Error do: [:ex <Exception> | cm showMessage: ex printString ]
				]
		)
		resetEditor: cm <CodeMirrorFragment> = (
			| src |
			src:: crToLf: subject versionSource.
			cm text: src.
			colorizeSource: src withEditor: cm.
			cm leaveEditState
		)
		compareToLiveButton = (
			(* Button label flips between "Compare to live" and "Clear compare"
     based on the subject's persisted state. Only rendered when
     showCompareToLive is true (live source exists, not a changeset
     entry) -- the gating happens in actionRow. *)
			
			^button: (subject compareLiveActive ifTrue: [ 'Clear compare' ]
					ifFalse: [ 'Compare to live' ])
				action: [ toggleCompareToLive ]
		)
		toggleCompareToLive = (
			(* Flip the persisted flag and refresh. The actual diff machinery
     lives in CompareToLiveDecorator's noticeExposure: re-applying
     marks after the reconciliation's setValue has wiped them is
     the only thing that makes the decorations visible across
     updateGUI: round-trips. *)
			
			subject compareLiveActive: subject compareLiveActive not.
			updateGUI: [ ]
		)
	) : ()
	public class SideBySideDiff onOld: ot <String> new: nt <String> = Object new (
		(* Computes a textual diff between two source strings using google's
   diff-match-patch (vendored at out/vendor/diff_match_patch-2019-07.js;
   loaded via primordialsoup.html as window.diff_match_patch) and
   exposes the result as two lists of CodeMirror decoration ops -- one
   for the old-side editor, one for the new-side. Each op is a Map:
     #kind       -> #line | #span
     #line       -> line index (when kind = #line)
     #className  -> CSS class to apply
     #fromLine, #fromCol, #toLine, #toCol  (when kind = #span)

   Used by ChangesetPresenter's #changed-member rows
   (Repositories.ns: changedMemberToggleFor:, changedHeaderSectionFor:)
   to tint the two side-by-side editors with line + intra-line
   character marks. Decoration colors are defined inline in
   primordialsoup.html (cm-diff-removed-line / cm-diff-added-line /
   cm-diff-removed-span / cm-diff-added-span).

   Computation runs eagerly in the initializer -- the line+character
   diff is microsecond-scale for typical member-source sizes; we
   intentionally avoid memoization since the inputs are immutable
   strings and instances are short-lived. *)
		
		|
			oldText = ot.
			newText = nt.
			leftOps_slot <List>
			rightOps_slot <List>
		|
		compute.
	) (
		public leftOps ^<List> = (
			^leftOps_slot
		)
		public rightOps ^<List> = (
			^rightOps_slot
		)
		compute = (
			(* Run diff_main on the raw strings (character-level diff), then
     iterate the ops tracking (line, col) cursors in old and new
     independently. EQUAL advances both; DELETE emits decorations on
     the old side and advances old; INSERT does the same on new.
     Cursors are 0-based to match CodeMirror's API directly. *)
			
			| dmp diffs n leftLine leftCol rightLine rightCol |
			dmp:: (cachedPlatform js global at: 'diff_match_patch') new.
			diffs:: dmp diff_main: oldText _: newText.
			dmp diff_cleanupSemantic: diffs.
			leftOps_slot:: List new.
			rightOps_slot:: List new.
			leftLine:: 0.
			leftCol:: 0.
			rightLine:: 0.
			rightCol:: 0.
			n:: diffs at: 'length'.
			0 to: n - 1
				do: [:idx |
					| entry op text adv |
					entry:: diffs at: idx.
					op:: entry at: 0.
					text:: entry at: 1.
					op = 0 ifTrue: [
							adv:: advanceLine: leftLine col: leftCol byText: text.
							leftLine:: adv at: 1.
							leftCol:: adv at: 2.
							adv:: advanceLine: rightLine col: rightCol byText: text.
							rightLine:: adv at: 1.
							rightCol:: adv at: 2
						].
					op = -1 ifTrue: [
							| sl sc |
							sl:: leftLine.
							sc:: leftCol.
							adv:: advanceLine: leftLine col: leftCol byText: text.
							leftLine:: adv at: 1.
							leftCol:: adv at: 2.
							emitDecorationsInto: leftOps_slot
								startLine: sl
								startCol: sc
								endLine: leftLine
								endCol: leftCol
								lineClass: 'cm-diff-removed-line'
								spanClass: 'cm-diff-removed-span'
						].
					op = 1 ifTrue: [
							| sl sc |
							sl:: rightLine.
							sc:: rightCol.
							adv:: advanceLine: rightLine col: rightCol byText: text.
							rightLine:: adv at: 1.
							rightCol:: adv at: 2.
							emitDecorationsInto: rightOps_slot
								startLine: sl
								startCol: sc
								endLine: rightLine
								endCol: rightCol
								lineClass: 'cm-diff-added-line'
								spanClass: 'cm-diff-added-span'
						]
				]
		)
		advanceLine: line col: col byText: text ^<Array> = (
			(* Returns {newLine. newCol} -- the caller destructures via
     `at: 1` / `at: 2` to dodge the no-multiple-return-values rule.
     Walks the rune sequence directly: rune 10 (LF) drops to the
     next line, anything else advances the column. Works uniformly
     on Newspeak Strings and on alien JS strings; both respond to
     `at: i` with the integer rune at position i.

     Earlier revisions used `text indexOf: newlineStr startingAt: ...`
     for a bulk-newline scan, with `newlineStr:: String fromRunes:
     { 10 }`. That construction returned an empty string in this
     code's runtime, so the loop never advanced; the rune walk here
     is both simpler and runtime-agnostic. For typical method-body
     sizes the per-character cost is negligible. *)
			
			| sz line2 col2 i ch |
			sz:: text size.
			line2:: line.
			col2:: col.
			i:: 1.
			[ i <= sz ] whileTrue: [
					ch:: text at: i.
					ch = 10 ifTrue: [
							line2:: line2 + 1.
							col2:: 0
						]
						ifFalse: [ col2:: col2 + 1 ].
					i:: i + 1
				].
			^{line2. col2. }
		)
		emitDecorationsInto: ops startLine: sl startCol: sc endLine: el endCol: ec lineClass: lc spanClass: spc = (
			(* Emit one span op covering (sl,sc)..(el,ec) plus one line op per
     line that the span touches. If ec = 0 the span ends right at the
     start of `el`, so `el` itself wasn't actually touched -- exclude
     it from the line-op range. Without this guard, a single inserted
     '\n' would tint the line after the newline as "added" even
     though no character on it actually changed. *)
			
			| loopEnd |
			ops add: (Map new at: #kind put: #span;
					at: #fromLine put: sl;
					at: #fromCol put: sc;
					at: #toLine put: el;
					at: #toCol put: ec;
					at: #className put: spc;
					yourself).
			loopEnd:: ec = 0 ifTrue: [ el - 1 ] ifFalse: [ el ].
			sl to: loopEnd
				do: [:lineIdx |
					ops add: (Map new at: #kind put: #line;
							at: #line put: lineIdx;
							at: #className put: lc;
							yourself)
				]
		)
		public applyTo: cm <Alien> usingOps: ops <List> = (
			(* Apply this side's ops to a CodeMirror instance. Line ops use
     addLineClass with the 'background' wrap so the tint covers the
     whole row including the gutter. Span ops use markText with the
     className option for the intra-line character mark. *)
			
			ops do: [:op |
					(op at: #kind) = #line ifTrue: [
							cm addLineClass: (op at: #line) _: 'background' _: (op at: #className)
						].
					(op at: #kind) = #span ifTrue: [
							| fromObj toObj optsObj |
							fromObj:: JSObject new.
							fromObj at: 'line' put: (op at: #fromLine).
							fromObj at: 'ch' put: (op at: #fromCol).
							toObj:: JSObject new.
							toObj at: 'line' put: (op at: #toLine).
							toObj at: 'ch' put: (op at: #toCol).
							optsObj:: JSObject new.
							optsObj at: 'className' put: (op at: #className).
							cm markText: fromObj _: toObj _: optsObj
						]
				]
		)
		public applyToOldEditor: cm <Alien> = (
			^applyTo: cm usingOps: leftOps_slot
		)
		public applyToNewEditor: cm <Alien> = (
			^applyTo: cm usingOps: rightOps_slot
		)
	) : ()
	public class DiffSideBySideTrigger onOldEntry: oe <MemberHistoryEntrySubject> newEntry: ne <MemberHistoryEntrySubject> = Fragment new (
		(* Invisible fragment placed last in the column of a #changed-member
   side-by-side row. On the first noticeExposure -- which fires top-
   down after the whole subtree has been mounted (createVisual done,
   editor slots populated) -- it reads both editors' current text,
   computes a SideBySideDiff, and applies the decorations to each
   side.

   Why a noticeExposure trigger instead of e.g. wiring into
   MemberHistoryEntryPresenter's substance computation: the diff
   needs BOTH JS CodeMirror instances to exist, and they only exist
   after each CodeMirrorFragment's createVisual runs. noticeExposure
   is the first hook the framework guarantees AFTER the visual tree
   is mounted, so it's the simplest correct hook.

   We guard with applied_slot so a second noticeExposure (e.g. from
   refresh propagation through helpHolder, or a re-expose after
   tab-switching) doesn't re-apply over the existing decorations.
   This is a v1 trade-off: if the user edits a side, the decorations
   become stale -- a v2 follow-up could clear and re-compute on edit.

   Note that the entrySubject's `editor` is the CodeMirrorFragment;
   the fragment's `editor` is the JS CM5 alien. The path
   `entrySubject editor editor` therefore reads as
   `subject.fragment.cmInstance`. *)
		
		|
			private oldEntry = oe.
			private newEntry = ne.
			applied_slot <Boolean> ::= false.
		|
	) (
		public createVisual = (
			| div |
			div:: document createElement: 'div'.
			(div at: 'style') at: 'display' put: 'none'.
			^div
		)
		public childrenDo: aBlock <[:Fragment | Object]> = (
			(* No children -- the trigger is a leaf with a side-effecting
     noticeExposure, not a container. *)
			
		)
		public isKindOfDiffSideBySideTrigger ^<Boolean> = (
			^true
		)
		isMyKind: f <Fragment> ^<Boolean> = (
			^f isKindOfDiffSideBySideTrigger
		)
		public applied ^<Boolean> = (
			^applied_slot
		)
		updateVisualsFromSameKind: oldFragment ^<Alien[Element]> = (
			(* Carry forward applied_slot so the reconciled trigger doesn't
     re-run applyDiffIfReady against editors that already hold our
     decorations. addLineClass is idempotent, but markText is not --
     repeated calls layer fresh TextMarks on top of one another and
     visually accumulate the class. *)
			
			applied_slot:: oldFragment applied.
			^oldFragment visual
		)
		public noticeExposure = (
			super noticeExposure.
			applied_slot ifTrue: [ ^self ].
			applied_slot:: applyDiffIfReady
		)
		applyDiffIfReady ^<Boolean> = (
			(* Returns true if the diff actually got applied; false if either
     editor wasn't mounted yet (caller leaves applied_slot false so
     a later noticeExposure can retry). The framework calls
     noticeExposure at least once after the tree is mounted, but we
     guard defensively against early invocation. *)
			
			| leftCM rightCM leftAlien rightAlien diff |
			leftCM:: oldEntry editor.
			rightCM:: newEntry editor.
			(leftCM isNil or: [ rightCM isNil ]) ifTrue: [ ^false ].
			leftAlien:: leftCM editor.
			rightAlien:: rightCM editor.
			(leftAlien isNil or: [ rightAlien isNil ]) ifTrue: [ ^false ].
			diff:: SideBySideDiff onOld: leftAlien getValue new: rightAlien getValue.
			diff applyToOldEditor: leftAlien.
			diff applyToNewEditor: rightAlien.
			^true
		)
	) : ()
	public class CompareToLiveDecorator onEntry: e <MemberHistoryEntrySubject> = Fragment new (
		(* Invisible fragment that lives last in the column of a
   MemberHistoryEntryPresenter. On every noticeExposure it consults
   the entry's compareLiveActive flag and either applies a fresh
   SideBySideDiff(historical, live) to the entry's CodeMirror or
   leaves the editor alone.

   Re-applying on every exposure (rather than once-and-cache like
   DiffSideBySideTrigger does) is load-bearing: HopscotchForHTML5
   CodeMirrorFragment>>updateVisualsFromSameKind: invokes
   editor setValue: textSlot whenever the fragment is not in edit
   state, and CodeMirror's setValue clears every TextMark and
   line-class on the editor. So each updateGUI: round-trip wipes
   the decorations; the decorator's job is to put them back on the
   same trip. The framework calls noticeExposure top-down AFTER
   updateVisualsFromSameKind: has finished, so by the time apply
   runs the editor is in its post-setValue clean state.

   This wipe-then-re-apply protocol makes the "Clear compare"
   path trivial: flipping compareLiveActive to false and calling
   updateGUI: produces a refresh in which setValue wipes the
   previous marks and the decorator declines to re-apply -- no
   explicit removeLineClass / TextMark.clear is needed. *)
		
		|
			private entry = e.
		|
	) (
		public createVisual = (
			| div |
			div:: document createElement: 'div'.
			(div at: 'style') at: 'display' put: 'none'.
			^div
		)
		public childrenDo: aBlock <[:Fragment | Object]> = (
			(* Leaf with a side-effecting noticeExposure, not a container. *)
			
		)
		public isKindOfCompareToLiveDecorator ^<Boolean> = (
			^true
		)
		isMyKind: f <Fragment> ^<Boolean> = (
			^f isKindOfCompareToLiveDecorator
		)
		updateVisualsFromSameKind: oldFragment ^<Alien[Element]> = (
			(* No transferable state -- entry is captured at construction and
     the diff is recomputed from CodeMirror's current text on every
     noticeExposure. Just hand the previous (hidden) <div> back so
     Hopscotch's reconciliation completes without unwinding the
     subtree. Forgetting this override raises subclassResponsibility
     mid-reconciliation; the unwind collapses the parent toggle row. *)
			
			^oldFragment visual
		)
		public noticeExposure = (
			super noticeExposure.
			entry compareLiveActive ifFalse: [ ^self ].
			applyDiff
		)
		applyDiff = (
			(* Bail silently when the editor isn't mounted or live source is
     unavailable. The action row would normally have hidden the
     button in those cases, but the decorator stays mounted and
     defensive against transient null states. *)
			
			| cm cmAlien histSrc liveSrc diff |
			cm:: entry editor.
			cm isNil ifTrue: [ ^self ].
			cmAlien:: cm editor.
			cmAlien isNil ifTrue: [ ^self ].
			liveSrc:: entry liveSource.
			liveSrc isNil ifTrue: [ ^self ].
			histSrc:: cmAlien getValue.
			diff:: SideBySideDiff onOld: histSrc new: liveSrc.
			diff applyToOldEditor: cmAlien
		)
	) : ()
	public class MemberHistoryPresenterState new = Object new (
		(* Per-MemberHistoryPresenter-instance state. Holds the
   sha-keyed EntrySubjects so they survive parent rebuilds and row
   collapse/expand. Transferred between presenter instances via
   MemberHistoryPresenter>>updateVisualsFromSameKind:, exactly the
   way DefinitionListPresenterState (Browsing.ns:1274) is transferred. *)
		
	) (
		lazy entries = Map new.
		public subjectFor: entry path: path <String> memberMirror: mm ^<MemberHistoryEntrySubject> = (
			| sha |
			sha:: entry at: 'oid'.
			^entries at: sha
				ifAbsentPut: [
					MemberHistoryEntrySubject onModel: (MemberHistoryEntryModel entry: entry
							memberMirror: mm
							path: path)
				]
		)
		public isKindOfMemberHistoryPresenterState ^<Boolean> = (
			^true
		)
	) : ()
	class MirrorGroupSubject onModel: m <MirrorGroupModel> = ProgrammingSubject onModel: m (
		|
			elements_slot <Collection[Subject]>
		|
	) (
		public exemplar = (
			^model exemplar
		)
		public definingMixin ^<MixinMirror> = (
			^model definingMixin
		)
		elementSubjectClass = (
			(* Answer the class of the subjects we create on individual elements of our subject group. *)
			
			subclassResponsibility
		)
		public isKindOfMirrorGroupSubject ^<Boolean> = (
			^true
		)
		public mirrorGroup ^<MirrorGroup> = (
			^model mirrorGroup
		)
		modelMirrorCollection ^<Collection[Mirror]> = (
			^subclassResponsibility
		)
		elementModelClass = (
			(* Answer the class of the models we create for individual elements of our subject group. *)
			
			subclassResponsibility
		)
		public elements ^<Collection[Subject]> = (
			(* Answer a collection of subjects on individual elements of the group which is our subject. *)
			
			elements_slot isNil ifTrue: [
					elements_slot:: modelMirrorCollection collect: [:each |
							elementSubjectClass fromModel: (elementFor: each)
						].
					^elements_slot
				].
			updateElements.
			^elements_slot
		)
		elementFor: m <Mirror> = (
			^subclassResponsibility
		)
		updateElements = (
			| subjectMirrors <List[Mirror]> = elements_slot collect: [:e <Subject> |
					e model mirror
				]. obsoleteSubjects <List[Subject]> = List new. |
			elements_slot do: [:s <Subject> |
					(modelMirrorCollection includes: s model mirror) ifFalse: [
							obsoleteSubjects add: s
						]
				].
			obsoleteSubjects do: [:s <Subject> | elements_slot remove: s ].
			modelMirrorCollection do: [:m <Mirror> |
					(subjectMirrors includes: m) ifFalse: [
							elements_slot add: (elementSubjectClass fromModel: (elementFor: m))
						]
				]
		)
	) : ()
	class NamespacePresenter onSubject: s = DefinitionListPresenter onSubject: s (
	) (
		class ClassEntryPresenter onSubject: s <ClassSubject> = outer Browsing ClassEntryPresenter onSubject: s (
		) (
			accessIndicator = (
				^nothing
			)
			public tag = (
				^subject name
			)
			helpText = (
				| mapping = Map new. menuImage = Utilities uriForIconNamed: #dropDownImage. referenceImage = Utilities uriForIconNamed: #itemReferencesImage. goldenIcon = Utilities uriForIconNamed: #classImage. |
				mapping at: #hopscotchToggleEntry
					put: (collapsed: [ defaultBlank ] expanded: [ expandedDefinition ]);
					at: #className put: (link: tag action: [ enterSubject:: subject ]);
					at: #hopscotchEntryMenuButton
						put: (dropDownMenu: [ entryActionsMenuFor: tag ]);
					at: #hopscotchMethodReferencesButton
						put: (dropDownMenu: [ messagesMenu ] image: ide images itemReferencesImage);
					at: #hopscotchHelpButton put: helpButton.
				^ampleforth: 'This is a class entry presenter, representing a class within an enclosing namespace. Below, you see, from left to right: 
  <ul>
  <li><img src=''' , goldenIcon , ''' alt="" width="25"> The icon identifying this entry as a class.
  <li>The class name <div class="className"> </div> If you click on it, the system will open a presenter on the class. This will be either a class presenter, or an object presenter on an exemplar of the class (if the system can find one). You can also expand a presenter on the class in place using the toggle <div class="hopscotchToggleEntry"> </div>  at the top left of this entry.</li>
  <li>A summary of their class comment, if any. </li>
   <li><div class="hopscotchHelpButton"> </div> Shows this help message.</li>
  <li><br>If a class is a test configuration, its entry will have links marked [run tests] and [show tests]. The former runs its tests, and the latter opens the test suite without running it. <br>If a class is an application, its entry will have the following links: <ul><li>[deploy] Deploy the application. This will allow you to deploy the app using one of the existing configurations</li><li>[configurations] Open the configuration manager for this application</li><li>[run] Run the application<li>[debug] Debug the application</ul>The above options will also be available when you open the class presenter for the class.</li>

  <li><div class="hopscotchEntryMenuButton"> </div> Opens a menu of additional operations, such as removing this class from the enclosing namespace or inspecting this presenter.</li>
  </ul>
  '
					mapping: mapping
			)
			entryActionsMenu = (
				^dropDownMenu: [ entryActionsMenuFor: subject name ]
			)
		) : ()
		class NamespaceEntryPresenter onSubject: s = EntryPresenter onSubject: s (
		) (
			expandedDefinition = (
				^subject presenter
			)
			public tag ^<String> = (
				^subject key
			)
			collapsedDefinition = (
				^column: {helpSection. row1: {defaultBlank. (image: ide images classPresenterImage) height: styleButtonSize. defaultBlank. row: {link: subject key
								action: [
									
									(* ide defaultPopularityRecord
			rememberNamespaceVisit: subject key. (* Should be the namespace itself, but non-strings break the home page. *) *)
									enterSubject:: subject refreshmentSubject
								]. }. }
						row2: {(label: subject summaryText) smallFont;
							compressibility: 1;
							color: secondaryTextColor. filler compressibility: 0. mediumBlank. helpButton. mediumBlank. dropDownMenu: [
								entryActionsMenuFor: subject key
							]. }. }
			)
			helpText = (
				| mapping = Map new. menuImage = Utilities uriForIconNamed: #dropDownImage. greenIcon = Utilities uriForIconNamed: #classPresenterImage. |
				mapping at: #hopscotchToggleEntry
					put: (collapsed: [ defaultBlank ] expanded: [ expandedDefinition ]);
					at: #entryName put: (link: tag action: [ enterSubject:: subject ]);
					at: #hopscotchEntryMenuButton
						put: (dropDownMenu: [ entryActionsMenuFor: tag ]);
					at: #hopscotchHelpButton put: helpButton.
				^ampleforth: 'This is a namespace entry presenter, representing a nested namespace within another  namespace. Below, you see, from left to right: 
  <ul>
  <li><img src=''' , greenIcon , ''' alt="" width="25"> The icon identifying this entry as a namespace.
  <li>The namespace''s name <div class="entryName"> </div> If you click on it, the system will open a namespace presenter on the nested namespace. You can also expand a presenter on the namespace in place using the toggle <div class="hopscotchToggleEntry"> </div>  at the top left of this entry.</li>
  <li>A summary of the namespace''s contents: ' , subject summaryText , '</li>
  <li><div class="hopscotchHelpButton"> </div> Shows this help message.</li>
  <li><div class="hopscotchEntryMenuButton"> </div> Opens a menu of additional operations, such as removing this namespace from the enclosing namespace or inspecting this presenter.</li>
  </ul>
  '
					mapping: mapping
			)
		) : ()
		class ValueEntryPresenter onSubject: s = EntryPresenter onSubject: s (
			|
				public key
			|
		) (
			definition = (
				(* Should provide someway to edit the value. Possibly like the slots experiment with the inspectors. Evaluate in the context of a workspace. *)
				
				^collapsed: [ collapsedDefinition ]
					expanded: [ subject presenter selfCaption: key ]
			)
			expandedDefinition = (
				(* Should provide someway to edit the value. Possibly like the slots experiment with the inspectors. Evaluate in the context of a workspace. *)
				
				^subject presenter selfCaption: key
			)
			public isKindOfValueEntryPresenter ^<Boolean> = (
				^true
			)
			isMyKind: f <Fragment> ^<Boolean> = (
				^f isKindOfValueEntryPresenter
			)
			public tag ^<String> = (
				^key
			)
			collapsedDefinition = (
				^column: {helpSection. row1: {defaultBlank. (image: ide images classUnknownImage) height: styleButtonSize. defaultBlank. link: key
							action: [ enterSubject:: subject ]. }
						row2: {(label: subject title) smallFont;
							compressibility: 1;
							color: secondaryTextColor. filler compressibility: 0. mediumBlank. helpButton. mediumBlank. dropDownMenu: [
								entryActionsMenuFor: key
							]. }. }
			)
			helpText = (
				| mapping = Map new. menuImage = Utilities uriForIconNamed: #dropDownImage. greyIcon = Utilities uriForIconNamed: #classUnknownImage. |
				mapping at: #hopscotchToggleEntry
					put: (collapsed: [ defaultBlank ] expanded: [ expandedDefinition ]);
					at: #entryName put: (link: tag action: [ enterSubject:: subject ]);
					at: #hopscotchEntryMenuButton
						put: (dropDownMenu: [ entryActionsMenuFor: tag ]);
					at: #hopscotchHelpButton put: helpButton.
				^ampleforth: 'This is a value entry presenter, representing an arbitrary object within a namespace. Below, you see, from left to right: 
  <ul>
  <li><img src=''' , greyIcon , ''' alt="" width="25"> The icon identifying this entry as an arbitrary object (as opposed to a class, document, namespace or other specific kind of object commonly placed in namespaces).
  <li>The key under which the object is stored in the enclosing namespace.<div class="entryName"> </div> If you click on it, the system will open an object presenter on the object. You can also expand a presenter on the object in place using the toggle <div class="hopscotchToggleEntry"> </div>  at the top left of this entry.</li>
  <li>A description of the object: ' , subject title , ' . </li>
  <li><div class="hopscotchHelpButton"> </div> Shows this help message.</li>
  <li><div class="hopscotchEntryMenuButton"> </div> Opens a menu of additional operations, such as removing this object from the namespace or inspecting this presenter.</li>
  </ul>
  '
					mapping: mapping
			)
		) : ()
		class DocumentEntryPresenter onSubject: s <ObjectSubject> = EntryPresenter onSubject: s (
		) (
			public isKindOfDocumentEntryPresenter ^<Boolean> = (
				^true
			)
			isMyKind: other ^<Boolean> = (
				^other isKindOfDocumentEntryPresenter
			)
			public tag ^<String> = (
				^(subject evaluate: #name) result reflectee
			)
			documentSubject = (
				(* should be cached *)
				
				^ide documents DocumentSubject onModel: subject objectMirror reflectee
			)
			expandedDefinition = (
				^subject presenter
			)
			collapsedDefinition = (
				^column: {helpSection. row1: {defaultBlank. (image: ide images ampleforthDocument) height: styleButtonSize. defaultBlank. link: tag
							action: [ enterSubject:: subject ]. }
						row2: {filler compressibility: 0. mediumBlank. helpButton. mediumBlank. dropDownMenu: [
								entryActionsMenuFor: tag
							]. }. }
			)
			helpText = (
				| mapping = Map new. menuImage = Utilities uriForIconNamed: #dropDownImage. referenceImage = Utilities uriForIconNamed: #itemReferencesImage. documentIcon = Utilities uriForIconNamed: #ampleforthDocument. |
				mapping at: #hopscotchToggleEntry
					put: (collapsed: [ defaultBlank ] expanded: [ expandedDefinition ]);
					at: #docName put: (link: tag action: [ enterSubject:: subject ]);
					at: #hopscotchEntryMenuButton
						put: (dropDownMenu: [ entryActionsMenuFor: tag ]);
					at: #hopscotchHelpButton put: helpButton.
				^ampleforth: 'This is a document entry presenter, representing an Ampleforth document in a namespace. Below, you see, from left to right: 
  <ul>
  <li><img src=''' , documentIcon , ''' alt="" width="15"> The icon identifying this entry as a document.
  <li>The document name <div class="docName"> </div> If you click on it, the system will open an object presenter on the document. You can also expand an object presenter on the document in place using the toggle <div class="hopscotchToggleEntry"> </div>  at the top left of this entry.</li>
  <li><div class="hopscotchHelpButton"> </div> Shows this help message.</li>
  <li><div class="hopscotchEntryMenuButton"> </div> Opens a menu of additional operations, such as removing this document from the namespace or inspecting this presenter.</li>
  </ul>
  '
					mapping: mapping
			)
		) : ()
		acceptNewClassDefinitionFrom: aTemplate = (
			| prefixState <DefinitionListPresenterState> = state. |
			subject addClassFromDefinition: aTemplate text
				ifSuccess: [ updateGUI: [ prefixState removePrefix: aTemplate ] ]
				ifFailure: [:msg | aTemplate editor showMessage: msg ]
		)
		addButton = (
			^
			(* subject namespace isKindOfCategoryNamespace
				ifTrue: [ *)
			addButtonWithMenu: [ addCategoryMenu ]
			(* ]
				ifFalse: [addButtonWithAction: [respondToAddForRoot]] *)
			
		)
		contentList ^<PresenterList> = (
			^zebra: super contentList
		)
		contentPresenters ^<List[Presenter]> = (
			| lexicalOrder <[:Symbol :Symbol | Boolean]> |
			lexicalOrder:: [:a <Symbol> :b <Symbol> | lexicallyLessOrEqual: a than: b ].
			^(subject namespace keys asArray sort: lexicalOrder) collect: [:key |
					presenterForEntryAt: key
				]
		)
		definitionListMenu = (
			^namespaceMenu
		)
		public isKindOfNamespacePresenter ^<Boolean> = (
			^true
		)
		isMyKind: f <Fragment> ^<Boolean> = (
			^f isKindOfNamespacePresenter
		)
		respondToAddForRoot = (
			openMenuWithLabelsAndActions: {{'Add Namespace'. [ addNamespaceTemplate ]. }. }
		)
		respondToAddImage = (
			| fileRequester |
			fileRequester:: request File new.
			fileRequester allowedFileTypes: {'Image files (*.png)' -> '*.png'. }.
			fileRequester initialDirectory: FileDirectory default fullName.
			fileRequester openModal ifNotNil: [:fn |
					| key form |
					key:: (FileDirectory on: fn) localName allButLast: 4.
					key:: key select: [:letter | letter isAlphaNumeric ].
					form:: PNGReadWriter formFromFileNamed: fn.
					subject namespace at: key asSymbol put: form
				]
		)
		respondToAddText = (
			| fileRequester |
			fileRequester:: request File new.
			fileRequester allowedFileTypes: {'Text files (*.txt)' -> '*.txt'. }.
			fileRequester initialDirectory: FileDirectory default fullName.
			fileRequester openModal ifNotNil: [:fn |
					| key text |
					key:: (FileDirectory on: fn) localName allButLast: 4.
					key:: key select: [:letter | letter isAlphaNumeric ].
					text:: ((MultiByteFileStream oldFileNamed: fn) converter: (TextConverter newForEncoding: 'utf8')) contents.
					subject namespace at: key asSymbol put: text
				]
		)
		public tag ^<String> = (
			^title
		)
		public title = (
			^subject key
			(* asText allBold *)
			
		)
		respondToCompileFiles = (
			multipleFileChooser chooseFileList: [:fl |
					subject compileFiles: fl
						ifSuccess: [ updateGUI: [ ] ]
						ifFailure: [:msg |
							alert: msg.
							nil
						]
				]
		)
		addClassTemplate = (
			| prefixState <DefinitionListPresenterState> = state. |
			updateGUI: [
					prefixState addPrefix: (DefinitionTemplate caption: 'Defining a new class:'
							initialText: subject classTemplateText
							colorizerBlock: [:text <String> :cm <CodeMirrorFragment> |
								subject colorizeClassSource: text editor: cm
							]
							acceptResponse: [:template | acceptNewClassDefinitionFrom: template ]
							cancelResponse: [:template |
								updateGUI: [ prefixState removePrefix: template ]
							])
				]
		)
		addNamespaceTemplate = (
			| prefixState <DefinitionListPresenterState> = state. |
			updateGUI: [
					prefixState addPrefix: (DefinitionTemplate caption: 'Defining a new namespace:'
							initialText: 'NewNamespace'
							colorizerBlock: [:text <String> :cm <CodeMirrorFragment> | ]
							acceptResponse: [:template | acceptNewNamespaceDefinitionFrom: template ]
							cancelResponse: [:template |
								updateGUI: [ prefixState removePrefix: template ]
							])
				]
		)
		addDocumentTemplate = (
			| prefixState <DefinitionListPresenterState> = state. |
			updateGUI: [
					prefixState addPrefix: (DefinitionTemplate caption: 'Defining a new document named:'
							initialText: 'MyDocument'
							colorizerBlock: [:text <String> :cm <CodeMirrorFragment> | ]
							acceptResponse: [:template | acceptNewDocumentDefinitionFrom: template ]
							cancelResponse: [:template |
								updateGUI: [ prefixState removePrefix: template ]
							])
				]
		)
		addCategoryMenu = (
			^{{'Add Class'. [ addClassTemplate ]. }. {'Add Namespace'. [
				addNamespaceTemplate
			]. }. {'Add Document'. [ addDocumentTemplate ]. }. {'Add Repository'. [
				addRepositoryForCurrentNamespace
			]. }. (* {'Add Image From File'. [respondToAddImage].}.
		{'Add Text From File'. [respondToAddText]}.
		 'Add Value' -> [Error signal: 'Unimplemented']. *) }
		)
		addRepositoryForCurrentNamespace = (
			(* Open the Repository setup form pre-filled with the current
	   namespace's key. The user adjusts name / remote URL / branch /
	   CORS proxy and confirms; the new Repository is registered in
	   Root and bound to this namespace. *)
			
			| setup |
			setup:: ide repositories setup.
			setup namespaceKey: subject key asString.
			setup createNewNamespace: false.
			enterSubject:: setup
		)
		presenterForEntryAt: key <Symbol> ^<EntryPresenter> = (
			| entry = subject namespace at: key. s <Subject> = subject namespaceSubjects at: key. |
			entry isKindOfBehavior ifTrue: [ ^ClassEntryPresenter onSubject: s ].
			entry isKindOfNamespace ifTrue: [ ^NamespaceEntryPresenter onSubject: s ].
			entry isKindOfDocument ifTrue: [ ^DocumentEntryPresenter onSubject: s ].
			^(ValueEntryPresenter onSubject: s) key: key
		)
		acceptNewDocumentDefinitionFrom: aTemplate = (
			| prefixState <DefinitionListPresenterState> = state. |
			subject addDocumentNamed: aTemplate text
				ifSuccess: [ updateGUI: [ prefixState removePrefix: aTemplate ] ]
				ifFailure: [:msg | aTemplate editor showMessage: msg ]
		)
		acceptNewNamespaceDefinitionFrom: aTemplate = (
			| prefixState <DefinitionListPresenterState> = state. |
			subject addNamespaceFromDefinition: aTemplate text
				ifSuccess: [ updateGUI: [ prefixState removePrefix: aTemplate ] ]
				ifFailure: [:msg | aTemplate editor showMessage: msg ]
		)
		respondToLoadDocuments = (
			multipleFileChooser chooseFileList: [:fl |
					subject loadDocuments: fl
						ifSuccess: [ updateGUI: [ ] ]
						ifFailure: [:msg |
							updateGUI: [ ].
							alert: msg
						]
				]
		)
		elementDescription ^<String> = (
			^'names at either the IDE top level (Root) namespace or of an enclosed namespace. These will  usually be either Newspeak classes, Ampleforth documents, or nested namespaces'
		)
		menuOperationsHelp ^<String> = (
			^'which includes compiling Newspeak code, loading Ampleforth documents and  ' , super menuOperationsHelp , '. You can select one or more files to compile/load. Newspeak code files should contain a valid top level class; they usually have a .ns suffix. Ampleforth documents are zip files produced by saving an Ampleforth document in the IDE. If any of the files fails to compile/load, none of the files will be loaded'
		)
		specificHelp ^<String> = (
			| goldenIcon = Utilities uriForIconNamed: #classImage. documentIcon = Utilities uriForIconNamed: #ampleforthDocument. greenIcon = Utilities uriForIconNamed: #classPresenterImage. greyIcon = Utilities uriForIconNamed: #classUnknownImage. |
			^'Different kinds of elements in the namespace are marked with distinct icons. The <img src=''' , goldenIcon , ''' alt="" width="25"> icons represent Newspeak classes. The <img src=''' , documentIcon , ''' alt="" width="15"> icons represent Ampleforth documents. The <img src=''' , greenIcon , ''' alt="" width="25"> icons represent nested namespaces.  The <img src=''' , greyIcon , ''' alt="" width="25"> icons represent arbitrary objects.  <br>Each entry has its own menu on the far right.'
		)
		listDescription ^<String> = (
			^'namespace list'
		)
		namespaceMenu = (
			^menuWithLabelsAndActions: {{'Inspect Presenter'. [
					respondToInspectPresenter
				]. }. #separator. {'Typecheck Namespace'. [
					enterSubject:: subject typecheckReportSubject
				]. }. #separator. {'Compile File(s)'. [ respondToCompileFiles ]. }. {'Load Document(s)'. [
					respondToLoadDocuments
				]. }. {'Load App'. [ respondToLoadApp ]. }. }
		)
		respondToLoadApp = (
			fileChooser chooseSingleFile: [:f |
					subject loadAppFromNSO: f
						ifFail: [:msg |
							alert: msg.
							nil
						]
				]
		)
		definition ^<Fragment> = (
			(* Override to render a "Repository:" link row above the standard
	   namespace list when one or more user-visible Repositories target
	   this namespace. The reverse lookup is on
	   `ide repositories repositoriesForNamespaceKey:`. *)
			
			| linkedRepos baseDefn |
			linkedRepos:: ide repositories repositoriesForNamespaceKey: subject key asString.
			baseDefn:: super definition.
			linkedRepos isEmpty ifTrue: [ ^baseDefn ].
			^column: {repositoriesLinkRow: linkedRepos. baseDefn. }
		)
		repositoriesLinkRow: linkedRepos <List> = (
			| parts first lbl |
			parts:: List new.
			lbl:: linkedRepos size = 1 ifTrue: [ 'Repository: ' ]
				ifFalse: [ 'Repositories: ' ].
			parts add: (label: lbl) bold.
			first:: true.
			linkedRepos do: [:repo |
					first ifFalse: [ parts add: (label: ', ') ].
					first:: false.
					parts add: (link: repo name asString
							action: [
								enterSubject:: ide repositories RepositorySubject onModel: repo
							])
				].
			parts add: filler.
			^row: parts asArray
		)
	) : ()
	public class NamespaceSubject onModel: m <Map[Symbol, Object]> key: k <Symbol> = ProgrammingSubject onModel: m (
		|
			public key = k.
			namespaceSubjects_slot
		|
		ide namespacing refreshCategoryNamespaces.
	) (
		public = other ^<Boolean> = (
			^other isKindOfNamespaceSubject and: [
					namespace = other namespace and: [ key = other key ]
				]
		)
		public classTemplateText ^<String> = (
			^'class ClassNameHere = (
	|
	slot1
	slot2
	|
) ()'
		)
		public colorizeClassSource: source <String> editor: cm <CodeMirrorFragment> = (
			^ide colorizer colorizeClassDeclaration: source
				fromClass: nil
				via: (colorizingBlockFor: cm)
		)
		public createPresenter ^<NamespacePresenter> = (
			^NamespacePresenter onSubject: self
		)
		public hash ^<Integer> = (
			^model hash bitXor: key hash
		)
		public isKindOfNamespaceSubject ^<Boolean> = (
			^true
		)
		isMyKind: s <Subject> ^<Boolean> = (
			^s isKindOfNamespaceSubject
		)
		public namespace ^<Map[Symbol, Object]> = (
			^self model
		)
		public refreshmentSubject = (
			^self class onModel: model key: key
		)
		public title ^<String> = (
			^key
		)
		public typecheckReportSubject ^<ClassTypecheckReportSubject> = (
			(* Typecheck every class in this namespace, each recursing into its nested
	   classes via ClassSubject>>collectTypecheckEntriesWith:into:prefix:, sharing
	   one typechecker across the whole sweep, and return an aggregated summary
	   report. Documents, forms, and nested namespaces are skipped (only
	   behaviors are typecheckable — same filter as the IDE's makeTypechecker).
	   Per-member banners are populated on the cached class subjects, so they
	   show when those classes are opened from this namespace. *)
			
			| tc <NewspeakTypechecker> = ide freshTypechecker. entries <List[TypecheckReportEntry]> = List new. subs <Map[Symbol, Subject]> = namespaceSubjects. |
			namespace keysAndValuesDo: [:k <Symbol> :v |
					v isKindOfBehavior ifTrue: [
							(subs at: k) collectTypecheckEntriesWith: tc into: entries prefix: ''
						]
				].
			^ClassTypecheckReportSubject onClassNamed: title entries: entries
		)
		public addClassFromDefinition: definition <String> ifSuccess: successBlock <[]> ifFailure: failureBlock <[:String | Object]> = (
			| builder <ClassDeclarationBuilder> klass |
			[ builder:: ClassDeclarationBuilder fromSource: definition ] on: Error
				do: [:ex | ^failureBlock value: ex printString ].
			(namespace includesKey: builder name) ifTrue: [
					^failureBlock value: 'A class named ' , builder name , ' already exists in this namespace'
				].
			klass:: (ide installFromBuilders: {builder. }) first declaration applyToObject.
			namespace at: klass mixin name put: klass reflectee.
			successBlock value
		)
		public namespaceSubjects ^<Map[Symbol, Subject]> = (
			namespaceSubjects_slot isNil ifTrue: [
					namespaceSubjects_slot:: Map new.
					namespace keysAndValuesDo: [:k :v |
							namespaceSubjects_slot at: k put: (subjectFor: v key: k)
						]
				].
			updateNamespace.
			^namespaceSubjects_slot
		)
		subjectFor: entry key: k <Symbol> ^<Subject> = (
			entry isKindOfBehavior ifTrue: [
					^ClassSubject onDeclaration: (ClassMirror reflecting: entry) mixin declaration
				].
			entry isKindOfNamespace ifTrue: [ ^NamespaceSubject onModel: entry key: k ].
			^presenter objectSubjectFor: entry
		)
		updateNamespace = (
			| obsoleteSubjectKeys <List[Symbol]> = List new. |
			namespaceSubjects_slot keys do: [:k <Symbol> |
					(namespace includesKey: k) ifFalse: [ obsoleteSubjectKeys add: k ]
				].
			obsoleteSubjectKeys do: [:k <Symbol> | namespaceSubjects_slot removeKey: k ].
			namespace keysAndValuesDo: [:k <Symbol> :v |
					(namespaceSubjects_slot includesKey: k) ifFalse: [
							namespaceSubjects_slot at: k put: (subjectFor: v key: k)
						]
				]
		)
		public addNamespaceFromDefinition: definition <String> ifSuccess: successBlock <[]> ifFailure: failureBlock <[:String | Object]> = (
			| selector <Symbol> = definition asSymbol. |
			
			(* model = ide namespacing Categories ifFalse: (* ? *)
		[Error signal: 'Not supported yet, only categories for now.']. *)
			(namespace includesKey: selector) ifTrue: [
					^failureBlock value: 'A class named ' , definition , ' already exists in this namespace'
				].
			
			(* ide namespacing categoryNamespace: selector. *)
			namespace at: selector put: ide namespacing freshNamespace.
			successBlock value
		)
		public addDocumentNamed: n <String> ifSuccess: successBlock <[]> ifFailure: failureBlock <[:String | Object]> = (
			| docName <Symbol> = n asSymbol. |
			(namespace includesKey: docName) ifTrue: [
					^failureBlock value: 'An entry named ' , n , ' already exists in this namespace'
				].
			[ namespace at: docName put: (ide documents freshDocumentNamed: docName) ] on: Error
				do: [:e |
					^failureBlock value: 'Document name must be a valid Newspeak identifier'
				].
			successBlock value
		)
		public compilePromises: ps <JSArray[JSPromise[String]]> ifSuccess: successBlock <[]> ifFailure: failureBlock <[:List[String] | Object]> = (
			(JSPromise all: ps) then: [:sources <JSArray[String]> |
					[
						| mixins <List[MixinMirror]> bs <List[ClassDeclarationBuilder]> = List new: (sources at: #length). |
						0 to: (sources at: #length) - 1
							do: [:i <Integer> |
								bs add: (ClassDeclarationBuilder fromUnitSource: (sources at: i))
							].
						mixins:: ide installFromBuilders: bs into: namespace.
						mixins do: [:m <MixinMirror> |
								namespace at: m name
									ifAbsent: [
										namespace at: m name put: m declaration applyToObject reflectee
									].
								[ ide typechecker invalidateNamespaceName: m name ] on: Error
									do: [:e <Exception> | ]
							].
						successBlock value
					] on: Error do: [:ex | failureBlock value: ex printString ]
				]
				onError: [:ex | failureBlock value: ex printString ]
		)
		public compileFiles: fs <List[Alien[File]]> ifSuccess: successBlock <[]> ifFailure: failureBlock <[:List[String] | Object]> = (
			| ps <List[Alien[Promise[[String]]]]> = JSArray new: fs size. |
			1 to: fs size do: [:i <Integer> | ps at: i - 1 put: (fs at: i) text ].
			compilePromises: ps ifSuccess: successBlock ifFailure: failureBlock
		)
		public loadDocuments: fs <List[Alien[File]]> ifSuccess: successBlock <[]> ifFailure: failureBlock <[:List[String] | Object]> = (
			| ps <List[Alien[Promise[[JSZip]]]]> = JSArray new: fs size. fns <Array[String]> = Array new: fs size. options <Alien> = JSObject new. updateCount ::= 
			(* Gross. To ensure that we only execute the success block once, we maintain a counter of the number of files to process, and only when it's 0 do we declare success. *)
			fs size. |
			1 to: fs size
				do: [:i <Integer> |
					| file <Alien[File]> = fs at: i. folder = ide webFiles Folder named: (file at: #name). |
					ps at: i - 1 put: (folder loadAsync: file options: options).
					fns at: i put: (file at: #name)
				].
			(JSPromise all: ps) then: [:zips <JSArray[JSZip]> |
					[
						0 to: fs size - 1
							do: [:i <Integer> |
								| fn = fns at: i + 1. |
								ide documents loadDocument: (zips at: i)
									named: (fn copyFrom: 1 to: (fn indexOf: '.') - 1)
									into: self
									ifSuccess: [
										updateCount:: updateCount - 1.
										updateCount = 0 ifTrue: [ successBlock value ]
									]
									ifFailure: [:ex |
										updateCount:: updateCount - 1.
										failureBlock value: ex
									].
								nil
							]
					] on: Error do: [:ex | failureBlock value: 'Failure: ' , ex printString ].
					nil
				]
				onError: [:ex |
					failureBlock value: 'Error: ' , ex printString.
					nil
				]
		)
		public summaryText = (
			| sb = StringBuilder new. s |
			namespace keys do: [:k | sb add: k ] separatedBy: [ sb add: ', ' ].
			s:: sb asString.
			s size > 20 ifTrue: [ ^(s copyFrom: 1 to: 20) , '...' ].
			^s
		)
		public loadAppFromNSO: f <Alien[File]> ifFail: blk <[String]> = (
			loadBytesFromNSO: f
				ifSuccess: [:bytes <Alien[Uint8Array]> |
					| app = Deserializer new deserialize: bytes. |
					app main: AppPlatform new args: {}.
					nil
				]
				ifFailure: [:msg | blk value: msg ]
		)
		loadBytesFromNSO: f <Alien[File]> ifSuccess: successBlock <[Alien[Uint8Array]]> ifFailure: failBlock <[String]> = (
			| promise <Alien[JSPromise[ArrayBuffer]]> = f arrayBuffer. |
			promise then: [:ab <Alien[ArrayBuffer]> |
					| jsArray = JSUint8Array new: ab. nsArray = Array new: (jsArray at: #length). |
					1 to: nsArray size do: [:i | nsArray at: i put: (jsArray at: i - 1) ].
					[ successBlock value: nsArray ] on: Error
						do: [:ex |
							failBlock value: 'Error loading app from file ' , (f at: #name) , ' :' , ex printString
						]
				]
				onError: [:ex |
					failBlock value: 'Error loading app from file ' , (f at: #name) , ' :' , ex printString.
					nil
				]
		)
	) : (
		public new = (
			#NAMESPACEBOGUS.
			^self onModel: ide namespacing Root key: 'Root'
		)
	)
	public class InteractionSubject onMessage: m <String> kind: k <Symbol> onAccept: aBlock <[:String | Object]> onCancel: cBlock <[]> returnTo: rs <Subject> = ProgrammingSubject onModel: nil (
		(* Reusable confirm / prompt Subject. Replaces JS-side modal alert /
   confirm / prompt calls with an in-IDE navigable view that obeys the
   Hopscotch back-stack. Two kinds:

     #confirm  message + Accept / Cancel buttons.
     #prompt   message + text input + Accept / Cancel buttons.

   onAccept is called with the input string (#prompt) or nil (#confirm)
   when the user accepts. onCancel is called when the user cancels.
   returnTo is the Subject the presenter navigates to after either
   button. There is no #notify variant: simple notifications go to the
   originating presenter's status banner, not to a navigable view. *)
		
		|
			public message <String> = m.
			public kind <Symbol> = k.
			onAccept_slot <[:String | Object]> = aBlock.
			onCancel_slot <[]> = cBlock.
			public returnTo <Subject> = rs.
			public acceptLabel <String> ::= 'OK'.
			public cancelLabel <String> ::= 'Cancel'.
			public input <String> ::= ''.
			titleText_slot <String>
		|
		titleText_slot:: kind = #prompt ifTrue: [ 'Input' ] ifFalse: [ 'Confirm' ].
	) (
		public createPresenter = (
			^InteractionPresenter onSubject: self
		)
		public title = (
			^titleText_slot
		)
		public title: t <String> = (
			titleText_slot:: t
		)
		public isKindOfInteractionSubject ^<Boolean> = (
			^true
		)
		isMyKind: s <Subject> ^<Boolean> = (
			^s isKindOfInteractionSubject
		)
		public accept = (
			kind = #prompt ifTrue: [ onAccept_slot value: input ]
				ifFalse: [ onAccept_slot value: nil ]
		)
		public cancel = (
			onCancel_slot value
		)
	) : (
		public confirm: m <String> yesLabel: yl <String> onYes: yesBlock <[]> returnTo: rs <Subject> ^<InteractionSubject> = (
			| s |
			s:: self onMessage: m
				kind: #confirm
				onAccept: [:i | yesBlock value ]
				onCancel: [ ]
				returnTo: rs.
			s acceptLabel: yl.
			^s
		)
		public confirm: m <String> yesLabel: yl <String> onYes: yesBlock <[]> noLabel: nl <String> onNo: noBlock <[]> returnTo: rs <Subject> ^<InteractionSubject> = (
			| s |
			s:: self onMessage: m
				kind: #confirm
				onAccept: [:i | yesBlock value ]
				onCancel: noBlock
				returnTo: rs.
			s acceptLabel: yl.
			s cancelLabel: nl.
			^s
		)
		public prompt: m <String> default: dft <String> onAccept: acceptBlock <[:String | Object]> returnTo: rs <Subject> ^<InteractionSubject> = (
			| s |
			s:: self onMessage: m
				kind: #prompt
				onAccept: acceptBlock
				onCancel: [ ]
				returnTo: rs.
			s input: dft.
			^s
		)
	)
	public class InteractionPresenter onSubject: s <InteractionSubject> = ProgrammingPresenter onSubject: s (
		|
			inputEditor
		|
	) (
		public isKindOfInteractionPresenter ^<Boolean> = (
			^true
		)
		isMyKind: f <Fragment> ^<Boolean> = (
			^f isKindOfInteractionPresenter
		)
		definition = (
			^column: {majorHeadingBlock: (row: {(label: subject title) bold. filler. }). mediumBlank. messageColumn. mediumBlank. subject kind = #prompt ifTrue: [
						inputArea
					]
					ifFalse: [ nothing ]. mediumBlank. buttonRow. }
		)
		messageColumn = (
			| labels lines start lf size text |
			text:: subject message.
			labels:: List new.
			lines:: List new.
			lf:: String fromRunes: {10. }.
			start:: 1.
			size:: text size.
			[ start <= size ] whileTrue: [
					| idx |
					idx:: text indexOf: lf startingAt: start.
					idx = 0 ifTrue: [
							lines add: (text copyFrom: start to: size).
							start:: size + 1
						]
						ifFalse: [
							lines add: (text copyFrom: start to: idx - 1).
							start:: idx + 1
						]
				].
			lines do: [:line | labels add: (label: line) ].
			^column: labels asArray
		)
		inputArea = (
			inputEditor:: codeMirror: subject input.
			inputEditor changeResponse: [:frag | subject input: frag textBeingAccepted ].
			^inputEditor
		)
		buttonRow = (
			^row: {filler. button: subject cancelLabel action: [ respondToCancel ]. smallBlank. button: subject acceptLabel
					action: [ respondToAccept ]. }
		)
		respondToAccept = (
			updateGUI: [
					inputEditor isNil ifFalse: [ subject input: inputEditor textBeingAccepted ].
					subject accept.
					enterSubject:: subject returnTo
				]
		)
		respondToCancel = (
			updateGUI: [
					subject cancel.
					enterSubject:: subject returnTo
				]
		)
	) : ()
	class NestedClassGroupPresenter onSubject: s <Subject> = MirrorGroupPresenter onSubject: s (
		(* Presents the subject, a NestedClassGroupSubject, as a column of presenters for the nested classes in the group. Automatically gets updated after the subject mirror group. Anything that has to do with adding, editing or deleting NS nested classes goes here. *)
		
	) (
		public deleteClassInPresenter: presenter <Presenter> ifSuccess: successResponse <[]> ifFailure: failureResponse <[]> = (
			subject deleteClassWithSubject: presenter subject.
			successResponse value
		)
		elementPresenterClass ^<ProgrammingPresenter class> = (
			^ClassEntryPresenter
		)
		public title = (
			^'Classes'
		)
		public addNewItemTemplate = (
			addNewItemTemplate: subject classTemplateText
		)
		public addNewItemTemplate: src <String> = (
			(* Handle a user's request to create a new nested class by displaying a new class template
      based on src. *)
			
			| prefixState <DefinitionListPresenterState> = state. |
			updateGUI: [
					prefixState addPrefix: (DefinitionTemplate caption: 'Defining a new class:'
							initialText: src
							colorizerBlock: [:text <String> :cm <CodeMirrorFragment> |
								subject colorizeClassSource: text editor: cm
							]
							acceptResponse: [:template | acceptNewClassDefinitionFrom: template ]
							cancelResponse: [:template |
								updateGUI: [ prefixState removePrefix: template ]
							])
				]
		)
		elementDescription ^<String> = (
			^'nested classes of the surrounding class'
		)
		acceptNewClassDefinitionFrom: aTemplate = (
			| prefixState <DefinitionListPresenterState> = state. |
			subject addClassFromDefinition: aTemplate text
				ifSuccess: [:newClass <ClassDeclarationMirror> |
					updateGUI: [ prefixState removePrefix: aTemplate ]
				]
				ifFailure: [:msg | aTemplate editor showMessage: msg ]
		)
		listDescription ^<String> = (
			^'nested class list'
		)
	) : ()
	public class NestedClassGroupSubject onModel: m <MirrorGroupModel[ClassDeclarationMirror]> = MirrorGroupSubject onModel: m (
		(* Represents the collection of nested classes of a Newspeak class. Holds onto the mirror group for the classes. *)
		
	) (
		elementFor: m <Mirror> = (
			^ClassModel declaration: m exemplar: nil enclosing: exemplar
		)
		public classTemplateText ^<String> = (
			^'class ClassNameHere = (
	|
	slot1
	slot2
	|
) ()'
		)
		public colorizeClassSource: source <String> editor: cm <CodeMirrorFragment> = (
			^ide colorizer colorizeClassDeclaration: source
				fromClass: definingMixin declaration
				via: (colorizingBlockFor: cm)
		)
		public createPresenter = (
			^NestedClassGroupPresenter onSubject: self
		)
		elementSubjectClass ^<ClassSubject class> = (
			^ClassSubject
		)
		public isKindOfNestedClassGroupSubject ^<Boolean> = (
			^true
		)
		isMyKind: s <Subject> ^<Boolean> = (
			^s isKindOfNestedClassGroupSubject
		)
		public addClassFromDefinition: source <String> ifSuccess: successBlock <[:ClassDeclarationMirror | Object]> ifFailure: failureBlock <[:String | Object]> = (
			[
				| builder <MixinBuilder> newBuilder <ClassDeclarationBuilder> newMirror <ClassDeclarationMirror> |
				builder:: definingMixin asBuilder.
				newBuilder:: builder nestedClasses addFromSource: source.
				ide installFromBuilders: {builder declaration. }.
				newMirror:: definingMixin nestedClasses findMirrorNamed: newBuilder name.
				successBlock value: newMirror
			] on: Error do: [:ex <Exception> | failureBlock value: ex printString ]
		)
		public deleteClassWithSubject: classSubject <ClassSubject> = (
			| builder <MixinBuilder> |
			builder:: definingMixin asBuilder.
			builder nestedClasses removeMirrorNamed: classSubject name.
			ide installFromBuilders: {builder declaration. }
		)
		modelMirrorCollection ^<Collection[Mirror]> = (
			^List withAll: definingMixin nestedClasses
		)
		elementModelClass ^<ClassModel class> = (
			^ClassModel
		)
	) : ()
	class ObjectPresenter onSubject: s = ProgrammingPresenter onSubject: s (
		|
			public selfCaption ::= 'self'.
			public openClass <Boolean> ::= false.
			classPresenter <ClassPresenter>
			
			(* We cache the views in map keyed by their class. The map is ordered, so that we can reflect the priority between views as defined in the code. The cache is used to update fresh presenters, to preserve the state of the views. Using classes as keys allows us to match up the correct corresponding views in the old and new object presenters (the order won't help here, as the applicable view classes may change. *)
			public viewCache <Map[Presenter class, Presenter]> = Map new.
		|
	) (
		captionBar: body = (
			^(padded: body with: {5. 5. styleHeaderPadRight. 5. }) color: captionColor
		)
		enclosingInfoLine = (
			^row: {(label: 'enclosingObject') width: 0 elasticity: 1. (link: subject enclosingObjectName
					action: [ navigateToEnclosingObject ]) width: 0 elasticity: detailAreaRatio. }
		)
		public isKindOfObjectPresenter ^<Boolean> = (
			^true
		)
		isMyKind: f <Fragment> ^<Boolean> = (
			^f isKindOfObjectPresenter
		)
		navigateToEnclosingObject = (
			inspectObjectMirror: subject classMirror enclosingObject
		)
		navigateToSelf = (
			enterSubject: subject
		)
		respondToInspectMirror = (
			inspectObject: subject objectMirror
		)
		public title = (
			^'Inspector on ' , subject title
		)
		selfInfoLine = (
			^row: {(label: selfCaption) bold width: 0 elasticity: 1. (row: {(link: subject title
						action: [ navigateToSelf ]) compressibility: 1. filler compressibility: 0. mediumBlank. helpButton. dropDownMenu: [
							actionsMenu
						]. }) width: 0 elasticity: detailAreaRatio. }
		)
		public definition = (
			^column: {helpSection. captionBar: (column: {selfInfoLine. enclosingInfoLine. classInfoLine. smallBlank. subject evaluator presenter. }). objectDetails. }
		)
		classInfoLine = (
			^row: {classExpansionLink. }
		)
		public instanceMethodsPresenter ^<MethodGroupPresenter> = (
			^classPresenter isNil ifFalse: [ classPresenter instanceMethodsPresenter ]
		)
		public classMethodsPresenter ^<MethodGroupPresenter> = (
			^classPresenter isNil ifFalse: [ classPresenter classMethodsPresenter ]
		)
		public lazySlotsPresenter ^<MethodGroupPresenter> = (
			^classPresenter isNil ifFalse: [ classPresenter lazySlotsPresenter ]
		)
		public nestedClassesPresenter ^<NestedClassGroupPresenter> = (
			^classPresenter isNil ifFalse: [ classPresenter nestedClassesPresenter ]
		)
		helpText ^<Fragment> = (
			| mapping = Map new. |
			mapping at: #classExpander put: classExpansionLink.
			^ampleforth: 'This is an object presenter (aka  inspector).  At the top you''ll see its description, a link to the object''s enclosing object, and an expandable link to its class: <div class="classExpander"> </div> Expanding it in place allows you to see the class in the context of the instance, which can be very handy.
  <br><br>
  You can enter and evaluate Newspeak expressions in the evaluator pane below the class link/expanded class. See the evaluator''s help section for details. Below the evaluator you will typically see the slots of the object listed; this the basic view of objects. Some objects, such as integers or strings, have customized views. An object can have multiple views (and you can define new views as well). If there are multiple views, tab links appear underneath the results list, and you can select between them.
'
				mapping: mapping
		)
		actionsMenu = (
			^menuWithLabelsAndActions: {{'Inspect Mirror'. [ respondToInspectMirror ]. }. {'Inspect Presenter'. [
					respondToInspectPresenter
				]. }. {'Make DoIt Button'. [
					subject evaluator presenter respondToMakeButton
				]. }. }
		)
		savedViews = (
			| latestViewClasses <List[Presenter class]> = availableViewClasses. |
			latestViewClasses do: [:vc <Presenter class> |
					viewCache at: vc ifAbsentPut: [ vc onSubject: subject ]
				].
			viewCache keys do: [:vc <Presenter class> |
					(latestViewClasses includes: vc) ifFalse: [ viewCache removeKey: vc ]
				].
			^viewCache
		)
		availableViewClasses ^<List[Presenter class]> = (
			(* Return a list of presenter classes that are available for the object we
are presenting. *)
			
			(* The list of available viewers we'll return *)
			
			| viewClasses <Set[Presenter class]> = List new. alreadySeen <Set[Presenter class]> = 
			(* A set of viewers already in the result, so we avoid duplicates *)
			Set new. |
			
			(* traverse all views, prioritizing by kind *)
			objectViews keysAndValuesDo: [:k <Symbol> :v <List[Presenter class]> |
					| supported <Boolean> = (subject evaluate: k) result reflectee. |
					
					(* if the object is of kind k, add the views for k *)
					supported ifTrue: [
							v do: [:vu <Presenter class> |
									
									(* eliminate duplicates before adding vu *)
									(alreadySeen includes: vu) ifFalse: [
											viewClasses add: vu.
											alreadySeen add: vu
										]
								]
						]
				].
			
			(* We always support the default view *)
			viewClasses addLast: BasicView.
			^viewClasses
		)
		updateVisualsFromSameKind: oldPresenter <Self> ^<Alien[Element]> = (
			(* Make sure we only update on presenters that reflect the same objects. Check equality on subjects, not presenters; using the presenter itself may not work as it may not be installed in a window yet *)
			
			subject = oldPresenter subject ifFalse: [
					ensureSubstance.
					^replaceVisual: oldPresenter visual with: substance visual
				].
			updateStateFrom: oldPresenter.
			
			(* nil out the substance, to be sure it gets (re)constructed based on the updated subject state; probably not needed; it should have been nil here anyway *)
			substanceSlot:: nil.
			ensureSubstance.
			^super updateVisualsFromSameKind: oldPresenter
		)
		updateStateFrom: oldPresenter <Self> = (
			(* Preserve the user's latest choice as to what view should be shown *)
			
			subject preferredViewName: oldPresenter subject preferredViewName.
			
			(* update views from old presenter *)
			savedViews keys do: [:vc <Presenter class> |
					updateViewClass: vc using: oldPresenter
				]
		)
		classExpansionLink = (
			| toggle |
			toggle:: (collapsed: [
					row: {(label: 'class') width: 0 elasticity: 1. (link: subject className
							action: [ toggle expand ]) width: 0 elasticity: detailAreaRatio. }
				]
				expanded: [
					column: {row: {filler. (label: 'class') bold. filler. }. classPresenter:: (ClassPresenter onSubject: subject classSubject) elasticity: detailAreaRatio. }
				]
				initiallyExpanded: openClass) width: 0 elasticity: detailAreaRatio.
			^toggle
		)
		updateViewClass: vc <Presenter class> using: oldPresenter <Self> = (
			(* prevent double update of current view. It will be updated as part of normal substance update *)
			
			viewCache size = 1 ifTrue: [ ^self ].
			vc name = subject preferredViewName ifTrue: [ ^self ].
			(viewCache at: vc) title = subject preferredViewName ifTrue: [ ^self ].
			(viewCache at: vc) updateVisualsFrom: (oldPresenter viewCache at: vc
					ifAbsent: [ ^self ])
		)
		objectDetails = (
			| views = savedViews values. currentView switchers |
			views size = 1 ifTrue: [ ^views first ].
			currentView:: holder: (subject preferredViewName isNil ifTrue: [
						subject preferredViewName: views first title.
						views first
					]
					ifFalse: [
						views detect: [:v | v title = subject preferredViewName ]
							ifNone: [ views first title ]
					]).
			switchers:: List new.
			views do: [:view |
					switchers add: mediumBlank.
					switchers add: ((link: '[' , view title , ']'
							action: [
								subject preferredViewName: view title.
								currentView content: view
							]) color: actionLinkColor)
				].
			^column: {row: switchers. currentView. }
		)
	) : ()
	public class ObjectSubject onModel: m <ObjectMirror> evaluator: e <EvaluationViewState>
	(* :exemplar: ObjectSubject onModel: (ObjectMirror reflecting: self) *)
	 = ProgrammingSubject onModel: m (
		|
			public evaluator <EvaluatorSubject> = EvaluatorSubject onModel: e.
			slotMap <Map[Symbol, SlotSubject]> ::= Map new.
			lazySlotMap <Map[Symbol, SlotSubject]> ::= Map new.
			public preferredViewName <String>
		|
	) (
		lazy public classSubject <ClassSubject> = ClassSubject onClassModel: (ClassModel declaration: classMirror mixin declaration
				exemplar: objectMirror).
		public = another <Object> ^<Boolean> = (
			^another isKindOfObjectSubject and: [ objectMirror = another objectMirror ]
		)
		public classMirror ^<ClassMirror> = (
			^model getClass
		)
		public className ^<String> = (
			^classMirror mixin name
		)
		computeSlots = (
			| newMap <Map[Symbol, SlotSubject]> = Map new. slotList <List[SlotSubject]> = classMirror slots collect: [:slot <SlotDeclarationMirror> |
					newMap at: slot name put: (slotSubjectFor: slot)
				]. |
			slotMap:: newMap.
			^slotList
		)
		public createPresenter = (
			^ObjectPresenter onSubject: self
		)
		public enclosingObjectName = (
			^classMirror enclosingObject reflectee printString
		)
		public evaluate: expression <String> ^<ThreadMirror> = (
			(* The IDE provides ambient access to the platform object during development. *)
			
			| scope <Map[Symbol, ObjectMirror]> = Map new. |
			scope at: #_ put: (ObjectMirror reflecting: cachedPlatform).
			^objectMirror evaluate: expression with: scope
		)
		public hash ^<Integer> = (
			^self class hash bitXor: objectMirror hash
		)
		public isKindOfObjectSubject = (
			^true
		)
		public isModelKindOfArray ^<Boolean> = (
			^classMirror = (ClassMirror reflecting: Array)
		)
		isMyKind: s <Subject> ^<Boolean> = (
			^s isKindOfObjectSubject
		)
		public objectMirror ^<ObjectMIrror> = (
			^model
		)
		public slots ^<Sequence[SlotSubject]> = (
			(* Arrays have slots that aren't defined by their class. *)
			
			(* :todo: Push this down to `ObjectMirror slots` because which classes this applies to is implementation specific. *)
			
			isModelKindOfArray ifTrue: [ ^computeArraySlots ].
			^computeSlots
		)
		public title = (
			^objectMirror reflectee printString
		)
		allMixinsOf: c <ClassMirror> ^<List[MixinMirror]> = (
			(* Return mirrors on all mixins of c, in superclass chain order,  subclasses first *)
			
			c isNil ifTrue: [ ^List new ].
			^(allMixinsOf: c superclass) addFirst: c mixin;
				yourself
		)
		kindOfSelectorsForMixin: mixinMirror <MixinMirror> ^<List[String]> = (
			(* Get the isKindOf selectors of mixinMirror. If there are several, make sure that one specific to the mixin,
    if defined,  is placed first in the result. *)
			
			| result = (mixinMirror methods select: [:m <MethodMirror> |
					1 = (m name indexOf: 'isKindOf')
				]) collect: [:m <MethodMirror> | m name ]. mostSpecific = 'isKindOf' , mixinMirror name. |
			result remove: mostSpecific ifAbsent: [ ].
			result addFirst: mostSpecific asSymbol.
			^result
		)
		public kindOfSelectors ^<List[String]> = (
			(* Produce a list of the isKindOf selectors of the class of the model's reflectee,
  in superclass chain order,  subclasses first. If any mixin in the chain has several,
  those are ordered among themselves by kindOfSelectorsForMixin. *)
			
			| result <List[String]> = List new. |
			(allMixinsOf: classMirror) do: [:m <MixinMirror> |
					(kindOfSelectorsForMixin: m) do: [:s <Symbol> |
							((Message selector: s arguments: {}) sendTo: objectMirror reflectee) ifTrue: [
									result add: s
								]
						]
				].
			^result
		)
		computeLazySlots = (
			| newMap <Map[Symbol, SlotSubject]> = Map new. slotList <List[SlotSubject]> = classMirror lazySlots collect: [:slot <LazySlotMirror> |
					newMap at: slot name put: (lazySlotSubjectFor: slot)
				]. |
			lazySlotMap:: newMap.
			^slotList
		)
		public lazySlots = (
			^computeLazySlots
		)
		arraySlotSubjectFor: index <Integer> ^<IndexSlotSubject> = (
			| name = index asString. entry <IndexSlotSubject> ::= slotMap at: name
				ifAbsent: [ IndexedSlotSubject index: index ofObject: objectMirror ]. |
			^entry
		)
		arraySlotSubjectFor: index <Integer> value: val <ObjectMirror> = (
			| name = index asString. entry <SlotSubject> ::= slotMap at: name
				ifAbsent: [ IndexedSlotSubject index: index ofObject: objectMirror ]. |
			val = entry slotValueMirror ifFalse: [
					entry:: IndexedSlotSubject index: index ofObject: objectMirror
				].
			^entry
		)
		computeArraySlots = (
			| array = objectMirror reflectee. variableLengthSlots = Array new: array size. newMap <Map[Symbol, IndexSlotSubject]> = Map new. |
			1 to: array size
				do: [:index |
					| slot <IndexSlotSubject> |
					slot:: arraySlotSubjectFor: index
						value: (ObjectMirror reflecting: (array at: index)).
					newMap at: slot name put: slot.
					variableLengthSlots at: index put: slot
				].
			slotMap:: newMap.
			^variableLengthSlots
		)
		slotSubjectFor: slot <SlotDeclarationMirror> ^<SlotSubject> = (
			| val <ObjectMirror> = objectMirror getSlot: slot name. entry <SlotSubject> ::= slotMap at: slot name
				ifAbsent: [ ObjectSlotSubject name: slot name ofObject: objectMirror ]. |
			val = entry objectMirror ifFalse: [
					entry:: ObjectSlotSubject name: slot name ofObject: objectMirror
				].
			^entry
		)
		public keysAndValues ^<Collection[SlotSubject]> = (
			| result |
			result:: List new: objectMirror reflectee size.
			objectMirror reflectee keysAndValuesDo: [:key :value |
					result add: (slotSubjectForKey: key withValue: value)
				].
			^result
		)
		slotSubjectForKey: k <Object> withValue: v <Object> ^<SlotSubject> = (
			| name = 'at: ' , k printString. val <ObjectMirror> = ObjectMirror reflecting: v. entry <SlotSubject> ::= slotMap at: k
				ifAbsentPut: [ KeyValueSlotSubject key: k ofObject: objectMirror ]. |
			val = entry objectMirror ifFalse: [
					entry:: slotMap at: k
						put: (KeyValueSlotSubject key: k ofObject: objectMirror)
				].
			^entry
		)
		lazySlotSubjectFor: slot <LazySlotMirror> ^<SlotSubject> = (
			| val <ObjectMirror> = objectMirror getLazySlot: slot name. entry <SlotSubject> ::= lazySlotMap at: slot name
				ifAbsent: [ LazyObjectSlotSubject name: slot name ofObject: objectMirror ]. |
			val = entry objectMirror ifFalse: [
					entry:: LazyObjectSlotSubject name: slot name ofObject: objectMirror
				].
			^entry
		)
	) : (
		public onModel: m = (
			^onModel: m evaluator: (EvaluationViewState onModel: m)
		)
		public onEvaluator: e <EvaluationViewState> = (
			^onModel: e mirror evaluator: e
		)
	)
	public class ProgrammingPresenter onSubject: s <Subject> = Presenter onSubject: s (
		(* Common superclass for presenters of programming constructs. *)
		
		|
			chatHolder = holder: nothing.
			focusAction_slot
		|
	) (
		lazy public regionChat ::= ide aiSupport ensureSharedChat.
		public chatSection = (
			(* A holder at the top of a presenter where the shared AI chat can be
	   installed. Populated by aiChatButton:. *)
			
			^chatHolder
		)
		aiChatButton: installFocusAction ifFocused: isFocusedPredicate = (
			(* Image button that, when clicked, runs installFocusAction (which is
	   expected to call one of ide aiSupport's setClassFocusOn:,
	   setMethodFocusOn:, setLazySlotFocusOn:, setClassHeaderFocusOn:
	   helpers — installing a structured focus with description block, owner,
	   and existence validator), and opens the shared AI chat just below
	   this presenter's header.

	   Setup short-circuit: if `ide aiSupport ensureSharedChat` returns a
	   chat setup subject (no API key configured yet), we install the
	   focus and navigate to setup directly, BEFORE the updateGUI: dance.
	   Routing setup through installAIChat's `^enterSubject:` inside an
	   updateGUI: block leaves the user staring at an unchanged page
	   with just the brain highlighted — the navigation happens but the
	   GUI-bump bookkeeping appears to clobber it.

	   isFocusedPredicate returns whether this presenter's entity is currently
	   focused (matched structurally — by class path + side + selector — not by
	   Subject object identity, since atomic install does not preserve
	   Subject identity across method replacement). *)
			
			| btn isFocused |
			isFocused:: isFocusedPredicate value.
			
			(* M2a: remember this brain's focus-action so the region's render path
		   (installAIChatExpanded:) can re-assert the focus when the user navigates
		   back to this page with the region already open — not only on a click. *)
			focusAction_slot:: installFocusAction.
			btn:: (imageButton: ide images brainImage
				action: [
					| stage <String> shared |
					stage:: 'start'.
					[
						shared:: regionChat.
						shared isKindOfIDEChatSetupSubject ifTrue: [
								
								(* No key yet — install the focus (so the brain shows
					   amber on the next visit) and head to the setup
					   screen. Skip the updateGUI:/installAIChat cycle
					   entirely. *)
								installFocusAction value.
								enterSubject: shared
							]
							ifFalse: [
								updateGUI: [
										| previousChatHolder previousPage currentPage |
										
										(* Auto-close a previously-active chat region only when
						   it's on the SAME page. If the user opened chat on A,
						   navigated to B, opened chat there, and is now coming
						   back to A — we want A's chat region preserved.
						   Same-page test: the page subject the chat was opened
						   on equals the page subject the IDE is currently
						   rendering. *)
										stage:: 'read activeChatHolder'.
										previousChatHolder:: ide aiSupport activeChatHolder.
										stage:: 'read activeChatHolderPage'.
										previousPage:: ide aiSupport activeChatHolderPage.
										stage:: 'read currentPageSubject'.
										currentPage:: ide browsing currentPageSubject.
										stage:: 'close previous chat'.
										(previousChatHolder isNil not and: [
												previousChatHolder ~= chatHolder and: [ previousPage = currentPage ]
											]) ifTrue: [ previousChatHolder content: nothing ].
										stage:: 'install focus'.
										installFocusAction value.
										stage:: 'install AI chat'.
										installAIChat.
										stage:: 'capture focus into region chat'.
										
										(* M2a: snapshot the just-installed focus into THIS region's chat. *)
										ide aiSupport captureFocusInto: regionChat.
										stage:: 'record active chat'.
										ide aiSupport activeChatHolder: chatHolder page: currentPage
									]
							]
					] on: Error
						do: [:e |
							| desc |
							
							(* messageText is often nil for exceptions raised without a
				   message; concatenating with nil raises ArgumentError, so
				   the bare 'AI chat error: ', e messageText crashes the
				   handler itself. Defensive extraction: try messageText, fall
				   back to the exception's class name, then printString, then
				   a literal. Class name is the most useful 'no-message'
				   diagnostic — at least we see what kind of error fired.
				   stage indicates where in the handler we were when the
				   exception fired, so the user can tell us which substep
				   to investigate. *)
							desc:: [
								| mt |
								mt:: [ e messageText ] on: Exception do: [:e2 | nil ].
								mt isNil ifTrue: [
										[ e class name printString ] on: Exception
											do: [:e2 |
												[ e printString ] on: Exception do: [:e3 | '<unprintable>' ]
											]
									]
									ifFalse: [ mt ]
							] on: Exception do: [:e4 | '<unprintable>' ].
							alert: 'AI chat error at "' , stage , '": ' , desc
						]
				]
				size: styleButtonSize) toolTip: (isFocused ifTrue: [
						'AI chat focused on this'
					]
					ifFalse: [ 'AI chat about this' ]).
			
			(* Always pad so the focused/unfocused states occupy the same space, and
	   always pass a color so PaddedFrameComposer's update path clears any
	   previous background (transitioning from highlight back to transparent). *)
			^(padded: btn with: {3. 3. 3. 3. }) color: (isFocused ifTrue: [
						Color r: 1.0 g: 0.85 b: 0.3
					]
					ifFalse: [ Color scaledR: 0 g: 0 b: 0 a: 0 ])
		)
		installAIChat = (
			installAIChatExpanded: true
		)
		installAIChatExpanded: wasExpanded = (
			| shared toggle |
			shared:: regionChat.
			shared isKindOfIDEChatSetupSubject ifTrue: [ ^enterSubject: shared ].
			toggle:: collapsed: [ aiChatCollapsedRow: toggle ]
				expanded: [ aiChatExpandedColumn: toggle ]
				initiallyExpanded: wasExpanded.
			chatHolder content: toggle
		)
		aiChatCollapsedRow: toggle = (
			^row: {(link: 'AI Chat (click to expand)' action: [ toggle expand ]) color: actionLinkColor. filler. }
		)
		aiChatExpandedColumn: toggle = (
			(* Look up the shared chat subject fresh at render time, not at install time,
	   so the embedded chat always shows the current conversation. *)
			
			| shared |
			shared:: regionChat.
			^column: {row: {(label: 'AI Chat') bold. filler. (imageButton: ide images collapseImage
						action: [ toggle collapse ]
						size: styleButtonSize) toolTip: 'Hide AI chat'. }. shared isKindOfIDEChatSetupSubject ifTrue: [
						textDisplay: 'No API key configured. Open the chat from the toolbar to set up.'
					]
					ifFalse: [
						| cp |
						cp:: shared createPresenter.
						
						(* Region-local switching: the embedded chat's switcher retargets
						   THIS region's regionChat and refreshes only this presenter,
						   instead of moving the global current (which every brain region
						   reads). Re-injected on every render, so it needn't survive the
						   chat presenter's own regeneration. *)
						cp onSwitchHandler: [:doc <Document> |
								regionChat: (ide aiSupport chatSubjectFor: doc).
								updateGUI: [ ]
							].
						cp
					]. }
		)
		updateVisualsFromSameKind: oldPresenter <Self> ^<Alien[Element]> = (
			(* Reinstall a fresh chat-toggle on refresh, preserving the user's
	   collapsed/expanded choice. The fresh toggle's expandedDefinition is
	   re-evaluated, creating a fresh ChatPresenter whose substance reflects
	   the current conversation. Moving the old toggle does NOT work because
	   its expandedPresenter is cached, and the cached presenter's substance
	   never re-renders against new messages.
	   The input draft survives recreation because ChatPresenter syncs the
	   draft into the subject on every keystroke. *)
			
			| oldChat |
			oldChat:: oldPresenter chatSection content.
			oldChat isKindOfBlankFragment ifFalse: [
					
					(* Carry the region's chosen chat forward so a refresh doesn't reset it
				   to the global default. Guarded by "a region was open" (oldChat not
				   blank), which is exactly when regionChat was computed — so we never
				   force ensureSharedChat for presenters that never opened a chat. *)
					regionChat: oldPresenter regionChat.
					installAIChatExpanded: oldChat isExpanded
				].
			^super updateVisualsFromSameKind: oldPresenter
		)
		public noticeExposure = (
			(* M2a: when this page is EXPOSED (navigated-to / shown — the shell sends
		   noticeExposure post-navigation), if its brain chat region is open,
		   re-assert this page's focus and snapshot it into the region's chat. This
		   fires on exposure, NOT on repaint, so a live background pane (e.g. a
		   workspace evaluator) that repaints constantly does not dominate the
		   focus — only the page the user actually navigates to updates it.
		   focusAction is side-effect-free (sets module focus state, no re-render). *)
			
			super noticeExposure.
			([ chatHolder content isKindOfBlankFragment not ] on: Exception
				do: [:e | false ]) ifTrue: [
					focusAction_slot isNil ifFalse: [ focusAction_slot value ].
					ide aiSupport captureFocusInto: regionChat
				]
		)
		actionLinkColor = (
			^Color black
		)
		addButtonWithAction: aBlock = (
			^(imageButton: ide images addImage action: aBlock) height: styleButtonSize
		)
		addButtonWithMenu: menu = (
			^dropDownMenu: menu image: ide images addImage
		)
		browseSelector: selector = (
			enterSubject: (SelectorSubject onModel: selector)
		)
		collapseButtonWithAction: aBlock = (
			^(imageButton: ide images collapseImage action: aBlock) height: styleButtonSize
		)
		expandButtonWithAction: aBlock = (
			^(imageButton: ide images expandImage action: aBlock) height: styleButtonSize
		)
		refreshButtonWithAction: aBlock = (
			(* Variant of refreshButton with a caller-supplied action -- the
	   default refreshButton rebuilds the whole shell. *)
			
			^(imageButton: ide images refreshImage action: aBlock) height: styleButtonSize;
				toolTip: #refresh
		)
		indentedBlock: body = (
			^column: {mediumBlank. row: {mediumBlank. elastic: body. }. mediumBlank. }
		)
		inspectObject: object <Object> = (
			enterSubject:: ObjectSubject onModel: (ObjectMirror reflecting: object)
		)
		inspectObjectMirror: object <ObjectMirror> = (
			enterSubject:: ObjectSubject onModel: object
		)
		itemReferencesButtonWithAction: aBlock = (
			^(imageButton: ide images itemReferencesImage action: aBlock) height: styleButtonSize
		)
		saveButtonWithAction: aBlock = (
			^(imageButton: ide images downloadImage action: aBlock) height: styleButtonSize
		)
		defaultBlank = (
			^blank: 3
		)
		largeBlank = (
			^blank: 20
		)
		majorHeadingBlock: body = (
			^(padded: body with: {10. 10. styleHeaderPadRight. 10. }) color: majorHeadingColor
		)
		majorHeadingColor = (
			(* This color is used for major definitions such as class headings. *)
			
			^Gradient from: (Color h: 240 s: 0.05 v: 0.92)
				to: (Color h: 240 s: 0.05 v: 0.86)
		)
		minorHeadingBlock: body = (
			^(padded: body with: {10. 5. styleHeaderPadRight. 5. }) color: minorHeadingColor
		)
		minorHeadingColor = (
			^Gradient from: (Color h: 240 s: 0.02 v: 0.94)
				to: (Color h: 240 s: 0.02 v: 0.9)
		)
		public objectSubjectFor: anObject = (
			^objectSubjectForMirror: (ObjectMirror reflecting: anObject)
		)
		objectSubjectForMirror: objectMirror <ObjectMirror> = (
			^ObjectSubject onModel: objectMirror
		)
		respondToInspectPresenter = (
			inspectObject: self
		)
		secondaryTextColor ^<Color> = (
			^Color gray: 0.6
		)
		tertiaryTextColor = (
			^Color gray: 0.8
		)
		linkToBrowseSelector: selector = (
			^row: {defaultBlank. link: selector action: [ browseSelector: selector ]. }
		)
		linkToBrowseNamespace: ns key: key = (
			^row: {defaultBlank. (image: ide images classPresenterImage) height: styleButtonSize. defaultBlank. link: key
					action: [ enterSubject:: NamespaceSubject onModel: ns key: key ]. }
		)
		linkToBrowseClass: aClass = (
			^row: {defaultBlank. link: aClass name action: [ browseClass: aClass ]. }
		)
		accessIndicator: am <String> ^<StaticImageFragment> = (
			^(image: (iconForAccessModifier: am)) height: styleButtonSize
		)
		iconForAccessModifier: am <String> ^<Alien[Image]> = (
			#private = am ifTrue: [ ^ide images privateAccessImage ].
			#protected = am ifTrue: [ ^ide images protectedAccessImage ].
			^ide images publicAccessImage
		)
		accessIndicator ^<StaticImageFragment> = (
			^accessIndicator: subject accessModifier
		)
		browseClass: klass <Behavior | ClassDeclarationMirror> = (
			| decl <ClassDeclarationMirror> = klass isKindOfClassDeclarationMirror ifTrue: [
					klass
				]
				ifFalse: [ (ClassMirror reflecting: klass) mixin declaration ]. |
			enterSubject:: ClassSubject onDeclaration: decl
		)
		browseMixinMirror: mixin <MixinMirror> = (
			enterSubject:: ClassSubject onDeclaration: mixin declaration
		)
		browseDocument: doc <Document | ObjectMirror> = (
			| m <ObjectMirror> = doc isKindOfObjectMirror ifTrue: [ doc ]
				ifFalse: [ ObjectMirror reflecting: doc ]. |
			enterSubject:: ObjectSubject onModel: m
		)
		refreshButton = (
			^(imageButton: ide images refreshImage action: [ shell refresh ]) height: styleButtonSize;
				toolTip: #refresh
		)
	) : ()
	public class SelectorPresenter onSubject: s = ProgrammingPresenter onSubject: s (
	) (
		definition = (
			^column: {implementorsPart. sendersPart. }
		)
		public isKindOfSelectorPresenter ^<Boolean> = (
			^true
		)
		isMyKind: other <Subject> ^<Boolean> = (
			^other isKindOfSelectorPresenter
		)
		implementorsPart = (
			^partNamed: 'implementors' model: subject implementorList presenter
		)
		partNamed: t <String> model: m ^<AssortedMethodListPresenter> = (
			^column: {majorHeadingBlock: (row: {label: subject selector. smallBlank. label: t. }). mediumBlank. row: {mediumBlank. elastic: m. }. mediumBlank. }
		)
		sendersPart = (
			^partNamed: 'senders' model: subject senderList presenter
		)
	) : ()
	public class SelectorSubject onModel: m = Subject onModel: m asSymbol (
		(* Holds onto a selector (a Symbol) and retrieves its senders and implementors. *)
		
		|
			implementorList_slot <AssortedMethodsSubject>
			senderList_slot <AssortedMethodsSubject>
		|
	) (
		public createPresenter = (
			^SelectorPresenter onSubject: self
		)
		public isKindOfSelectorSubject ^<Boolean> = (
			^true
		)
		isMyKind: other <Subject> ^<Boolean> = (
			^other isKindOfSelectorSubject
		)
		public selector = (
			^model
		)
		public title = (
			^selector printString
		)
		public senderList ^<AssortedMethodsSubject> = (
			senderList_slot isNil ifTrue: [
					senderList_slot:: AssortedMethodsSubject onModel: senderSubjects
				].
			updateSenders.
			^senderList_slot
		)
		public implementorList ^<AssortedMethodsSubject> = (
			implementorList_slot isNil ifTrue: [
					implementorList_slot:: AssortedMethodsSubject onModel: implementorSubjects
				].
			updateImplementors.
			^implementorList_slot
		)
		elementSubjectForModel: m <MethodModel | ClassModel> ^<MethodSubject | LazySlotSubject | ClassFactorySubject> = (
			^m isKindOfMethodModel ifTrue: [ MethodSubject onMethodModel: m ]
				ifFalse: [
					m isKindOfClassModel ifTrue: [ ClassFactorySubject onClassModel: m ]
						ifFalse: [ LazySlotSubject onLazySlotModel: m ]
				]
		)
		public senderSubjects ^<Collection[MethodSubject | LazySlotSubject | ClassFactorySubject]> = (
			(* Answer a collection of senders of our subject, as MethodSubjects. *)
			
			^senders collect: [:each <MethodModel | LazySlotModel | ClassModel> |
					elementSubjectForModel: each
				]
		)
		implementors ^<List[MethodModel | LazySlotModel | ClassModel]> = (
			(* Answer a collection of implementors of our selector (as MethodReferences). *)
			
			| results <List[MethodModel | LazySlotModel | ClassModel]> = List new. |
			systemScope implementorsOf: selector
				do: [:mirror <MethodMirror | LazySlotMirror | ClassDeclarationMirror> |
					results add: (mirror isKindOfMethodMirror ifTrue: [
								MethodModel method: mirror exemplar: nil
							]
							ifFalse: [
								mirror isKindOfClassDeclarationMirror ifTrue: [
										ClassModel declaration: mirror exemplar: nil
									]
									ifFalse: [ LazySlotModel slot: mirror exemplar: nil ]
							])
				].
			^results
		)
		senders ^<List[MethodModel | LazySlotModel | ClassModel]> = (
			(* Answer a collection of senders of our selector (as MethodReferences). *)
			
			| results <List[MethodModel | LazySlotModel | ClassModel]> = List new. |
			systemScope sendersOf: selector
				do: [:mirror <MethodMirror | LazySlotMirror | ClassDeclarationMirror> |
					results add: (mirror isKindOfMethodMirror ifTrue: [
								MethodModel method: mirror exemplar: nil
							]
							ifFalse: [
								mirror isKindOfClassDeclarationMirror ifTrue: [
										ClassModel declaration: mirror exemplar: nil
									]
									ifFalse: [ LazySlotModel slot: mirror exemplar: nil ]
							])
				].
			^results
		)
		public implementorSubjects ^<Collection[MethodSubject | LazySlotSubject | ClassFactorySubject]> = (
			(* Answer a collection of senders of our subject, as MethodSubjects. *)
			
			^implementors collect: [:each <MethodModel | LazySlotModel | ClassModel> |
					elementSubjectForModel: each
				]
		)
		updateImplementors = (
			| subjectModels <List[MethodModel | ClassModel]> = implementorList_slot model collect: [:e <MethodSubject | LazySlotSubject | ClassFactorySubject> |
					e model
				]. obsoleteSubjects <List[MethodSubject | ClassFactorySubject]> = List new. |
			implementorList_slot model do: [:s <Subject> |
					(implementors includes: s model) ifFalse: [ obsoleteSubjects add: s ]
				].
			obsoleteSubjects do: [:s <MethodSubject | LazySlotSubject | ClassFactorySubject> |
					implementorList_slot model remove: s
				].
			implementors do: [:m <MethodModel | LazySlotModel | ClassModel> |
					(subjectModels includes: m) ifFalse: [
							implementorList_slot model add: (elementSubjectForModel: m)
						]
				]
		)
		updateSenders = (
			| subjectModels <List[MethodModel | ClassModel]> = senderList_slot model collect: [:e <MethodSubject | LazySlotSubject | ClassFactorySubject> |
					e model
				]. obsoleteSubjects <List[MethodSubject | ClassFactorySubject]> = List new. |
			senderList_slot model do: [:s <Subject> |
					(senders includes: s model) ifFalse: [ obsoleteSubjects add: s ]
				].
			obsoleteSubjects do: [:s <MethodSubject | LazySlotSubject | ClassFactorySubject> |
					senderList_slot model remove: s
				].
			senders do: [:m <MethodModel | LazySlotModel | ClassModel> |
					(subjectModels includes: m) ifFalse: [
							senderList_slot model add: (elementSubjectForModel: m)
						]
				]
		)
	) : ()
	public class SlotPresenter onSubject: s <SlotSubject> = ProgrammingPresenter onSubject: s (
		|
			editorFragment
		|
	) (
		public isKindOfSlotPresenter ^<Boolean> = (
			^true
		)
		isMyKind: f <Fragment> ^<Boolean> = (
			^f isKindOfSlotPresenter
		)
		public setValue: expression <String> ifFail: failBlock = (
			subject setValue: expression
				ifCompilerError: failBlock
				ifError: failBlock value.
			refresh
		)
		public refresh = (
			details refresh.
			super refresh
		)
		details ^<Fragment> = (
			^subject slotValueSubject presenter selfCaption: subject name
		)
		setValue: expression <String> = (
			subject setValue: expression
				ifCompilerError: [:msg | ^editorFragment editor showMessage: msg ]
				ifError: [:thread <ThreadMirror> |
					enterSubject:: ide debugging ThreadSubject onModel: thread
				].
			editorFragment editor leaveEditState
		)
		public tag ^<Symbol> = (
			^subject name
		)
		caption ^<Fragment> = (
			^row: {(link: subject name action: [ substance toggle ]) width: 0
					elasticity: 1;
					color: actionLinkColor. smallBlank. (link: subject reflecteePrintString
					action: [ inspectObjectMirror: subject slotValueMirror ]) width: 0
					elasticity: detailAreaRatio. smallBlank. helpButton. }
		)
		public definition ^<Fragment> = (
			^column: {helpSection. collapsed: [ caption ]
					expanded: [ expandedDefinition ]. }
		)
		helpText = (
			| mapping = Map new. |
			mapping at: #hopscotchHelpButton put: helpButton.
			^ampleforth: 'This is a slot presenter. It may be either collapsed or expanded. When collapsed, it shows the name of the slot on the left, and a link with a description the slot value, followed by the help button, <div class="hopscotchHelpButton"> </div>, which shows this help message. When expanded, an input field is shown, where you can enter an expression that will be evaluated to produce a new value for the slot. The help button appears to its right. Below the input field you will find an object presenter for the value of the slot.'
				mapping: mapping
		)
		expandedDefinition ^<Fragment> = (
			editorFragment:: (DefinitionTemplate caption: 'Set value for slot ' , subject name
				initialText: 'new value for ' , subject name
				colorizerBlock: [:text <String> :cm <CodeMirrorFragment> | ]
				acceptResponse: [:t |
					updateGUI: [ setValue: t text asString ].
					refresh
				]
				cancelResponse: [:t | t editor defaultCancelResponse ]) initiallyInEditState: false.
			^column: {row: {editorFragment. smallBlank. helpButton. }. details. }
		)
	) : ()
	public class SlotSubject name: n ofObject: o = Subject onModel: (SlotModel name: n
			ofObject: o) (
		(* SlotSubject is the superclass of a number of subject classes for various kinds of slots in the IDE.  These include regular object slots (ObjectSlotSubject), lazy slots (LazyObjectSlotSubject),  individual array entries (IndexedSlotSubject), list and map entries (KeyValueSlotSubject), local variables in activations (ActivationSlotSubject) and the results of a thread (ThreadResultSubject). It is NOT tied to the management of lazy slots, which have a distinct implementation in the IDE. *)
		
	) (
		public createPresenter = (
			^SlotPresenter onSubject: self
		)
		public isKindOfSlotSubject ^<Boolean> = (
			^true
		)
		isMyKind: s <Subject> ^<Boolean> = (
			^s isKindOfSlotSubject
		)
		public setValue: expression <String> ifCompilerError: compileFailBlock ifError: failBlock = (
			| evalThread <ThreadMirror> |
			evalThread:: [ objectMirror evaluate: expression with: Map new ] on: Error
				do: [:ce | compileFailBlock value: ce printString ].
			
			(* object scope? debugger? *)
			evalThread isBroken ifTrue: 
				(* so for runtime errors, the block should take a thread so it can open a debugger on it *)
				[ failBlock value: thread ]
				ifFalse: [ objectMirror setSlot: name to: evalThread result ]
		)
		public reflecteePrintString = (
			^slotValueMirror reflectee printString
		)
		public objectSubject ^<ObjectSubject> = (
			^ObjectSubject onModel: slotValueMirror
		)
		public objectMirror ^<ObjectMirror> = (
			^model objectMirror
		)
		public name ^<String> = (
			^model name
		)
		public slotValueMirror ^<ObjectMirror> = (
			^objectMirror getSlot: name
		)
		public slotValueSubject ^<ObjectSubject> = (
			^ObjectSubject onModel: slotValueMirror
		)
		public tag ^<Symbol> = (
			^name
		)
	) : ()
	class StringView onSubject: s = ProgrammingPresenter onSubject: s (
	) (
		public definition = (
			| cm |
			cm:: codeMirror: subject objectMirror reflectee.
			cm readOnly: true.
			^column: {cm. }
		)
		public isKindOfStringView ^<Boolean> = (
			^true
		)
		isMyKind: other <Fragment> ^<Boolean> = (
			^other isKindOfStringView
		)
	) : ()
	public class EvaluatorPresenter onSubject: s <ObjectSubject | ActivationSubject> = ProgrammingPresenter onSubject: s (
		|
			cm <CodeMirrorFragment>
			results_slot <List[TaggedHolderComposer]>
		|
	) (
		public editorText ^<String | Nil> = (
			(* The current text in the embedded CodeMirror. Returns nil when the
       editor hasn't been rendered yet (cm not yet assigned). *)
			
			^cm isNil ifTrue: [ nil ] ifFalse: [ cm textBeingAccepted ]
		)
		deadChangeResponse = (
			^[:editor <CodeMirrorFragment> |
				| src <String> = editor textBeingAccepted. |
				ide colorizer colorizeDoIt: src
					fromClass: nil
					via: (colorizingBlockFor: editor).
				editor isInEditState: true.
				editor editor focus
			]
		)
		linkForThread: thread <ThreadMirror> ^<Fragment> = (
			thread isFulfilled ifTrue: [ ^linkForResult: thread ].
			thread isBroken ifTrue: [ ^linkForError: thread ].
			^nothing
		)
		public isKindOfEvaluatorPresenter ^<Boolean> = (
			^true
		)
		isMyKind: f <Fragment> ^<Boolean> = (
			^f isKindOfEvaluatorPresenter
		)
		changeResponse = (
			^subject isLive ifTrue: [ liveChangeResponse ]
				ifFalse: [ deadChangeResponse ]
		)
		editorDefinition ^<CodeMirrorFragment> = (
			| initialSource |
			initialSource:: subject initialSource.
			cm:: (codeMirror: initialSource) changeResponse: changeResponse;
				evaluateResponse: evaluateResponse;
				useEditControls: false.
			
			(* ide colorizer colorizeDoIt: initialSource fromClass: nil via: (colorizingBlockFor: cm). *)
			^cm
		)
		public invertEvalStatusButton ^<ButtonFragment> = (
			^subject isLive ifTrue: [
					button: 'Suspend Live Evaluation'
						action: [ updateGUI: [ subject isLive: false ] ]
				]
				ifFalse: [
					button: 'Start Live Evaluation'
						action: [ updateGUI: [ subject isLive: true ] ]
				]
		)
		public makeDoItButton ^<ButtonFragment> = (
			^button: 'Make DoIt Button' action: [ respondToMakeButton ]
		)
		helpText = (
			| mapping = Map new. |
			mapping at: #evaluateSelectionButton put: evaluateSelectionButton;
				at: #invertEvalStatusButton put: invertEvalStatusButton;
				at: #MakeSelectionADoItButton put: makeDoItButton.
			^ampleforth: 'This is an evaluator.  You can enter and evaluate Newspeak expressions in the pane below. The expressions are evaluated in a <i>scope</i>. If this evaluator is immediately contained in an object presenter, the scope is that of the object being presented.  If the evaluator is a part of an activation presenter, the scope is that of the activation; if it is part of a method presenter, the scope is that of the an activation of the method''s exemplar. <br><br>
 Shift-Return evaluates the currently selected text; if no text is selected, the current line (i.e., the line where the cursor is) is evaluated. You can also initiate evaluation of any selected text by pressing: <div class = "evaluateSelectionButton"></div> which is located above the editor on the left. 
  <br><br>
The editor can also evaluate at every keystroke; you can toggle this behavior using <div class = "invertEvalStatusButton"></div>
also located above the editor (note: this doesn''t work in methods yet).
<br><br>
Evaluation results, if any, are displayed below the editor pane. Each result is a link; clicking on it takes you an object inspector on the result.  You can clear the results list by pressing the clear button to its right: <div class="hopscotchClearResultsButton"> </div>
<br>
If  there are no results to display, the  results list area is blank.<br><br>
If you find you want to repeatedly re-evaluate some code, and selecting it or using the keyboard prove too burdensome, you can convert the code into a button.
Simply select the code in question, and then press <div class="MakeSelectionADoItButton"> </div> which will be the rightmost button above the evaluator.'
				mapping: mapping
		)
		evaluateResponse ^<[:CodeMirrorFragment | Object]> = (
			^[:ed <CodeMirrorFragment> |
				| src <String> ::= ed editor getSelection. |
				src isEmpty ifTrue: [ src:: ed currentLine ].
				src isEmpty ifFalse: [
						updateGUI: [ subject evaluate: src withoutNbsp ].
						ed visual focus
					]
			]
		)
		public evaluateSelectionButton ^<ButtonFragment> = (
			^button: 'Evaluate Selection'
				action: [
					updateGUI: [ subject evaluate: cm editor getSelection withoutNbsp ]
				]
		)
		liveChangeResponse = (
			^[:editor <CodeMirrorFragment> |
				| src <String> = editor textBeingAccepted. |
				updateGUI: [
						subject evaluateLive: src withoutNbsp.
						ide colorizer colorizeDoIt: src
							fromClass: nil
							via: (colorizingBlockFor: editor).
						editor isInEditState: true
					].
				editor editor focus
			]
		)
		public respondToMakeButton = (
			| src <String> ::= cm editor getSelection. defaultTitle <String> ::= 'Do it!'. title <String> |
			
			(* title:: prompt: 'Enter the button title' input: defaultTitle.
        title isEmpty ifTrue: [ title:: defaultTitle ]. *)
			src isEmpty ifTrue: [
					| line = cm currentLine. lineNumber = cm currentLineNumber. start = JSObject new. end = JSObject new. |
					src:: line.
					start at: 'line' put: lineNumber;
						at: 'ch' put: 0.
					end at: 'line' put: lineNumber;
						at: 'ch' put: src size.
					cm editor setSelection: start end: end
				].
			src isEmpty ifFalse: [
					| button <ButtonFragment> = button: src
						action: [ updateGUI: [ subject evaluate: src withoutNbsp ] ]. |
					cm replace: button.
					cm editor focus
				]
		)
		actionsMenu = (
			^menuWithLabelsAndActions: {{'Pretty Print Selection'. [
					respondToPrettyPrintSelection
				]. }. #separator. {'Inspect Presenter'. [ respondToInspectPresenter ]. }. }
		)
		respondToPrettyPrintSelection = (
			(* Pretty-print the current selection (or the whole buffer if
       nothing is selected — actually no: show a message and bail).
       Replaces the selection in place via CodeMirror's
       replaceSelection. Does NOT trigger evaluate. *)
			
			| source formatted |
			cm isNil ifTrue: [ ^self ].
			source:: cm editor getSelection.
			(source isNil or: [ source isEmpty ]) ifTrue: [
					cm showMessage: 'Pretty Print Selection: nothing selected.'.
					^self
				].
			formatted:: [ ide prettyPrinter prettyPrintExpression: source ] on: Exception
				do: [:e |
					cm showMessage: 'Pretty print failed: ' , e printString.
					^self
				].
			cm editor replaceSelection: formatted.
			cm editor focus
		)
		linkForEvaluation: r <ThreadMirror | Error> ^<Fragment> = (
			r isKindOfError ifTrue: [:e <Error> | ^linkForCompileError: e ].
			r isFulfilled ifTrue: [ ^linkForResult: r ].
			r isBroken ifTrue: [ ^linkForError: r ].
			'result is neither error nor fulfilled nor broken!' out
		)
		linkForResult: r <ThreadMirror> ^<Fragment> = (
			^link: r result reflectee printString
				action: [ enterSubject:: ObjectSubject onModel: r result ]
		)
		linkForError: thread <ThreadMirror> = (
			^(link: thread result reflectee printString
				action: [ enterSubject:: ide debugging ThreadSubject onModel: thread ]) color: (Color r: 1
					g: 0
					b: 0)
		)
		linkForCompileError: error <Exception> = (
			^(link: error printString
				action: [ inspectObjectMirror: (ObjectMirror reflecting: error) ]) color: (Color r: 1
					g: 0
					b: 0)
		)
		updateStateFrom: oldPresenter <Self> = (
			(* Set cached state (result list, last expression computed, liveness, ...) based on the old presenter's cached state *)
			
			| oldSubject = oldPresenter subject. |
			results_slot:: nil.
			subject model lastEvalWasLive: oldSubject model lastEvalWasLive.
			subject results: oldSubject results.
			
			(* oldSubject results isEmpty ifTrue: ['empty results' out] ifFalse: ['non-empty results' out]. *)
			subject lastExpression: oldSubject lastExpression.
			subject isLive: oldSubject isLive.
			
			(* is this even used? *)
			subject initialSource: oldSubject initialSource
		)
		public results ^<List[TaggedHolderComposer]> = (
			| i <Integer> ::= 0. |
			results_slot isNil ifTrue: [
					
					(* 'recomputing results slot' out. *)
					results_slot:: subject results collect: [:r <ThreadMirror | Error> |
							i:: i + 1.
							holder: (r isKindOfThreadMirror ifTrue: [ linkForThread: r ]
									ifFalse: [ linkForCompileError: r ])
								tag: i printString
						]
				].
			^results_slot
		)
		definition ^<Fragment> = (
			| items <List[Fragment]> = results. |
			^column: {helpSection. row: {evaluateSelectionButton. mediumBlank. invertEvalStatusButton. mediumBlank. makeDoItButton. mediumBlank. aiChatButton: [
							ide aiSupport setEvaluatorFocusOnSubject: subject
						]
						ifFocused: [
							ide aiSupport isFocusedOnEvaluatorMirror: subject model mirror
						]. mediumBlank. helpButton. dropDownMenu: [ actionsMenu ]. }. chatSection. editorDefinition. row: {(taggedColumn: items) elasticity: 1. items isEmpty ifTrue: [
							smallBlank
						]
						ifFalse: [ clearResultsButton ]. }. }
		)
		updateVisualsFromSameKind: oldPresenter <Self> = (
			(* Make sure we only update on presenters that reflect the same objects. Check equality on subjects, not presenters; using the presenter itself may not work as it may not be installed in a window yet *)
			
			subject = oldPresenter subject ifFalse: [
					ensureSubstance.
					^replaceVisual: oldPresenter visual with: substance visual
				].
			updateStateFrom: oldPresenter.
			
			(* nil out the substance, to be sure it gets (re)constructed based on the updated subject state; probably not needed; it should have been nil here anyway *)
			substanceSlot:: nil.
			ensureSubstance.
			^super updateVisualsFromSameKind: oldPresenter
		)
		public clearResultsButton ^<ButtonFragment> = (
			^(imageButton: ide images clearImage
				action: [
					updateGUI: [
							subject clear.
							results_slot:: nil
						]
				]) height: styleButtonSize
		)
	) : ()
	public class SearchResultsSubject onModel: searchTerm <String> = ProgrammingSubject onModel: searchTerm (
		|
			includeSynthetics <Boolean> = (searchTerm indexOf: "`") isNil not.
			public searchSuggestions <List[Symbol]> = Set new.
			
			(* hack *)
			selectorSubjects_slot <List[SelectorSubject]>
			classSubjects_slot <List[ClassSubject]>
		|
	) (
		public createPresenter = (
			^SearchResultsPresenter onSubject: self
		)
		public title = (
			^'Search for "' , model , '"'
		)
		properlySorted: selectors <Collection[String]> = (
			| lower <List[String]> upper <List[String]> |
			lower:: List new: selectors size.
			upper:: List new: selectors size // 2.
			selectors do: [:each <String> |
					each first isUppercase ifTrue: [ upper add: each ]
						ifFalse: [ lower add: each ]
				].
			lower sort: [:a :b | a key < b key ].
			upper sort: [:a :b | a key < b key ].
			^lower asArray , upper
		)
		public isKindOfSearchResultsSubject ^<Boolean> = (
			^true
		)
		createSuggestions = (
			| foundNoResults <Boolean> names <Set[String]> |
			foundNoResults:: true.
			classMatches isEmpty ifFalse: [ foundNoResults:: false ].
			selectorMatches isEmpty ifFalse: [ foundNoResults:: false ].
			namespaceMatches isEmpty ifFalse: [ foundNoResults:: false ].
			foundNoResults ifFalse: [
					searchSuggestions:: Set new.
					^self
				].
			searchSuggestions:: Set new.
			^self
			(* hack *)
			
			(* names:: Set new: 200.
	systemScope allClassesDo: [:each <ClassDeclarationMirror> | 
      names add: (each simpleName)
      ].
	searchSuggestions:: (model correctAgainst: names). *)
			
		)
		addMatchesOfPatterns: ps <Array[String]> inNamespace: ns <Namespace> to: collected <Set[Association[String, Namespace]]> = (
			ns keysAndValuesDo: [:k :v |
					v isKindOfNamespace ifTrue: [
							addMatchesOfPatterns: ps inNamespace: v to: collected.
							ps do: [:pattern <String> |
									(pattern: pattern match: k) ifTrue: [ collected add: {k. v. } ]
								]
						]
				]
		)
		findWildcardsIn: p <String> ^<List[Integer]> = (
			(* Return an ordered list of indices in p where the wildcard indicator, *, appears. *)
			
			| index <Integer> ::= 1. wildcardIndices = List new. nextIndex |
			p isEmpty ifTrue: [ ^wildcardIndices ].
			[ index <= p size ] whileTrue: [
					
					(* if not found, we get 0 *)
					nextIndex:: p indexOf: '*' startingAt: index.
					
					(* If no wildcard found, set index so we exist the loop; otherwise, add the position we found
         (nextIndex) and increment index so we continue looking at the rest the the pattern p *)
					index:: nextIndex = 0 ifFalse: [
							wildcardIndices add: nextIndex.
							nextIndex + 1
						]
						ifTrue: [ p size + 1 ]
				].
			^wildcardIndices
		)
		prepareSegments: p <String> ^<List[Integer]> = (
			(* Return a list of segment markers in p, i.e., indices that immediately precede or follow
    wildcard-free substrings p. This amounts to the position of wildcards,
    plus markers for imaginary wildcards before and after p. *)
			
			| wildcardIndices <List[Integer]> = findWildcardsIn: p. |
			wildcardIndices isEmpty ifTrue: [ ^List withAll: {0. p size + 1. } ].
			
			(* no wildcards found *)
			wildcardIndices first = 1 ifFalse: [ wildcardIndices addFirst: 0 ].
			wildcardIndices last = p size ifFalse: [ wildcardIndices add: p size + 1 ].
			^wildcardIndices
		)
		pattern: p <String> match: s <String> ^<Boolean> = (
			| index <Integer> ::= 1. nextIndex segmentMarkers = prepareSegments: p. segments <List[String]> ::= List new. isFirst <Boolean> ::= true. res |
			
			(* collect the wild-card free strings - those prior to, between, or after wildcards *)
			segmentMarkers reduce: [:i <Integer> :j <Integer> |
					segments add: (p copyStringFrom: i + 1 to: j - 1).
					j
				].
			
			(* eliminate effects of adjacent wildcards *)
			segments:: segments select: [:seg | seg isEmpty not ].
			segments do: [:seg <String> |
					nextIndex:: s indexOf: seg startingAt: index.
					nextIndex = 0 ifTrue: [ ^false ].
					isFirst ifTrue: [
							isFirst:: false.
							
							(* unless there's a wildcard at the start of the pattern, 
      the first segment needs to start at the beginning of s *)
							(nextIndex = 1 or: [ segmentMarkers first = 1 ]) ifFalse: [ ^false ]
						].
					index:: nextIndex + seg size
				].
			
			(* If the last segment doesn't extend to the end of s, the pattern must end with a wildcard *)
			^index > s size or: [ segmentMarkers last = p size ]
		)
		isMyKind: s <Subject> ^<Boolean> = (
			^s isKindOfSearchResultsSubject
		)
		public selectorMatches ^<Array[String]> = (
			| collected <Set[String]> patterns <Array[String]> |
			collected:: Set new: 20.
			patterns:: searchPatterns.
			
			(* compute once *)
			systemScope allSelectorsDo: [:sel <String> |
					patterns do: [:each <String> |
							(pattern: each match: sel) ifTrue: [ collected add: sel ]
						]
				].
			includeSynthetics ifFalse: [
					collected removeAllSuchThat: [:each | (each indexOf: "`") ~= 0 ].
					collected removeAllSuchThat: [:each | (each indexOf: " ") ~= 0 ]
				].
			^collected asArray sort: [:a :b | lexicallyLessOrEqual: a than: b ]
		)
		public namespaceMatches ^<Array[Association[String, Namespace]]> = (
			| collected <Set[Association[String, Namespace]]> = Set new: 20. patterns <Array[String]> = searchPatterns. root = ide namespacing Root. |
			addMatchesOfPatterns: patterns inNamespace: root to: collected.
			^collected asArray sort: [:a :b |
					lexicallyLessOrEqual: a first than: b first
				]
		)
		public classMatches ^<Array[ClassDeclarationMirror]> = (
			| collected <Set[ClassDeclarationMirror]> patterns <Array[String]> |
			collected:: Set new: 20.
			patterns:: searchPatterns.
			
			(* compute once *)
			systemScope allClassesDo: [:cls <ClassDeclarationMirror> |
					patterns do: [:pattern |
							(pattern: pattern match: cls simpleName) ifTrue: [ collected add: cls ]
						]
				].
			^collected asArray sort: [:a :b |
					lexicallyLessOrEqual: a simpleName than: b simpleName
				]
		)
		public selectorSubjects ^<List[SelectorSubject]> = (
			(* Answer a collection of subjects on individual selectors the search has found. *)
			
			selectorSubjects_slot isNil ifTrue: [
					selectorSubjects_slot:: List withAll: (selectorMatches collect: [:each <Symbol> |
								SelectorSubject onModel: each
							]).
					^selectorSubjects_slot
				].
			updateSelectors.
			^selectorSubjects_slot
		)
		updateSelectors = (
			| subjectNames <List[Symbol]> = selectorSubjects_slot collect: [:e <SelectorSubject> |
					e model
				]. matches <Array[Symbol]> = selectorMatches. obsoleteSubjects <List[SelectorSubject]> = List new. |
			selectorSubjects_slot do: [:s <SelectorSubject> |
					(matches includes: s model) ifFalse: [ obsoleteSubjects add: s ]
				].
			obsoleteSubjects do: [:s <SelectorSubject> | selectorSubjects_slot remove: s ].
			matches do: [:m <Symbol> |
					(subjectNames includes: m) ifFalse: [
							selectorSubjects_slot add: (SelectorSubject onModel: m)
						]
				]
		)
		public classSubjects ^<List[ClassSubject]> = (
			(* Answer a collection of subjects on individual classes the search has found. *)
			
			classSubjects_slot isNil ifTrue: [
					classSubjects_slot:: List withAll: (classMatches collect: [:each <ClassDeclarationMirror> |
								ClassSubject onDeclaration: each
							]).
					^classSubjects_slot
				].
			updateClasses.
			^classSubjects_slot
		)
		updateClasses = (
			| subjectMirrors <List[ClassDeclarationMirror]> = classSubjects_slot collect: [:e <ClassSubject> |
					e model
				]. matches <Array[ClassDeclarationMirror]> = classMatches. obsoleteSubjects <List[ClassSubject]> = List new. |
			classSubjects_slot do: [:s <ClassSubject> |
					(matches includes: s model) ifFalse: [ obsoleteSubjects add: s ]
				].
			obsoleteSubjects do: [:s <ClassSubject> | classSubjects_slot remove: s ].
			matches do: [:m <ClassDeclarationMirror> |
					(subjectMirrors includes: m) ifFalse: [
							classSubjects_slot add: (ClassSubject onDeclaration: m)
						]
				]
		)
		public selectorSubjectsFor: names <List[Symbol]> ^<List[SelectorSubject]> = (
			(* Answer a collection of subjects on individual selectors in #names *)
			
			names collect: [:each <Symbol> | SelectorSubject onModel: each ]
		)
		searchPatterns ^<Array[String]> = (
			(* Produce a collection of the specific search pattern to use. The model is the raw input provided by the user and may include multiple patterns. *)
			
			| parts <Array[String]> |
			parts:: model findTokens: ';'.
			parts:: parts collect: [:each <String> | each withBlanksTrimmed ].
			parts:: parts select: [:each <String> | each isEmpty not ].
			
			(* parts:: parts collect:
		[:each <String> |
		((each indexOf: "*") ~= 0 or: [(each indexOf: "#") ~= 0])
			ifTrue: [each]
			ifFalse: [(pattern: '"*"' match: each)
					ifTrue: [each copyFrom: 2 to: each size - 1]
					ifFalse: ['*', each, '*']]]. *)
			^parts
		)
	) : ()
	class SearchResultsPresenter onSubject: s = ProgrammingPresenter onSubject: s (
	) (
		class ClassSectionPresenter onSubject: s = ProgrammingPresenter onSubject: s (
		) (
			public isKindOfClassSectionPresenter ^<Boolean> = (
				^true
			)
			classSectionResultsMenu = (
				^menuWithLabelsAndActions: {{'Inspect Presenter'. [
						respondToInspectPresenter
					]. }. }
			)
			definition = (
				^column: {helpSection. minorHeadingBlock: (row: {label: 'Classes'. filler. refreshButton. smallBlank. helpButton. smallBlank. dropDownMenu: [
									classSectionResultsMenu
								]. }). indentedBlock: (column: classSearchResults). }
			)
			helpText = (
				| menuImage = Utilities uriForIconNamed: #dropDownImage. mapping = Map new. |
				mapping at: #classSectionMenuButton
					put: (dropDownMenu: [ classSectionResultsMenu ]);
					at: #hopscotchHelpButton put: helpButton;
					at: #hopscotchRefreshButton put: refreshButton.
				^ampleforth: 'This section shows the classes found by the enclosing search presenter. For each class found, a toggle is displayed. Initially, the toggle is collapsed, and only shows a link to the class. The toogle can be expanded to show the class in place.
  <ul>
    <li><div class="hopscotchRefreshButton"> </div> Refreshes the display of the classes.</li>  
    <li><div class="hopscotchHelpButton"> </div> Shows this help message.</li>
   <li> <div class="classSectionMenuButton"> </div> Opens a menu of additional operations, such as inspecting this presenter.
   </ul> <br>'
					mapping: mapping
			)
		) : (
			public new = (
				^onSubject: nil
			)
		)
		class NamespaceSectionPresenter onSubject: s = ProgrammingPresenter onSubject: s (
		) (
			public isKindOfNamespaceSectionPresenter ^<Boolean> = (
				^true
			)
			namespaceSectionResultsMenu = (
				^menuWithLabelsAndActions: {{'Inspect Presenter'. [
						respondToInspectPresenter
					]. }. }
			)
			definition = (
				^column: {helpSection. minorHeadingBlock: (row: {label: 'Namespaces'. filler. refreshButton. smallBlank. helpButton. smallBlank. dropDownMenu: [
									namespaceSectionResultsMenu
								]. }). indentedBlock: (column: namespaceSearchResults). }
			)
			helpText = (
				| menuImage = Utilities uriForIconNamed: #dropDownImage. mapping = Map new. |
				mapping at: #namespaceSectionMenuButton
					put: (dropDownMenu: [ classSectionResultsMenu ]);
					at: #hopscotchHelpButton put: helpButton;
					at: #hopscotchRefreshButton put: refreshButton.
				^ampleforth: 'This section shows the namespaces found by the enclosing search presenter. Each listed entry is a link to the actual namespace.
  <ul>
    <li><div class="hopscotchRefreshButton"> </div> Refreshes the display of the namespaces.</li>  
    <li><div class="hopscotchHelpButton"> </div> Shows this help message.</li>
   <li> <div class="namespaceSectionMenuButton"> </div> Opens a menu of additional operations, such as inspecting this presenter.
   </ul> <br>'
					mapping: mapping
			)
		) : (
			public new = (
				^onSubject: nil
			)
		)
		class SelectorSectionPresenter onSubject: s = ProgrammingPresenter onSubject: s (
		) (
			public isKindOfSelectorSectionPresenter ^<Boolean> = (
				^true
			)
			selectorSectionResultsMenu = (
				^menuWithLabelsAndActions: {{'Inspect Presenter'. [
						respondToInspectPresenter
					]. }. }
			)
			definition = (
				^column: {helpSection. minorHeadingBlock: (row: {label: 'Selectors'. filler. refreshButton. smallBlank. helpButton. smallBlank. dropDownMenu: [
									selectorSectionResultsMenu
								]. }). indentedBlock: (column: selectorSearchResults). }
			)
			helpText = (
				| menuImage = Utilities uriForIconNamed: #dropDownImage. mapping = Map new. |
				mapping at: #selectorSectionMenuButton
					put: (dropDownMenu: [ classSectionResultsMenu ]);
					at: #hopscotchHelpButton put: helpButton;
					at: #hopscotchRefreshButton put: refreshButton.
				^ampleforth: 'This section shows the selectors found by the enclosing search presenter. For each selector found, a toggle is displayed. Initially, the toggle is collapsed, and only shows the selector. The toggle expands to show two sections: one listing implementers of the selector, and one listing senders of the selector.
  <ul>
    <li><div class="hopscotchRefreshButton"> </div> Refreshes the display of the selectors.</li>  
    <li><div class="hopscotchHelpButton"> </div> Shows this help message.</li>
   <li> <div class="selectorSectionMenuButton"> </div> Opens a menu of additional operations, such as inspecting this presenter.
   </ul> <br>'
					mapping: mapping
			)
		) : (
			public new = (
				^onSubject: nil
			)
		)
		searchSuggestions = (
			^incrementalList: [:s |
					subject searchSuggestions do: [:suggestion |
							s nextPut: (link: suggestion
									action: [ enterSubject: (SearchResultsSubject onModel: suggestion) ])
						]
				]
		)
		isMyKind: f <Fragment> ^<Boolean> = (
			^f isKindOfSearchResultsPresenter
		)
		public isKindOfSearchResultsPresenter ^<Boolean> = (
			^true
		)
		searchResultsMenu = (
			^menuWithLabelsAndActions: {{'Inspect Presenter'. [
					respondToInspectPresenter
				]. }. }
		)
		sectionWithHeader: theHeader andContents: theContents = (
			^column: {minorHeadingBlock: (label: theHeader). indentedBlock: (column: theContents). }
		)
		namespaceSearchResults ^<Array[Fragment]> = (
			^subject namespaceMatches collect: [:assoc <{String. Namespace}> |
					linkToBrowseNamespace: assoc last key: assoc first
				]
		)
		searchFeedback = (
			subject searchSuggestions isEmpty ifTrue: [ ^nothing ]
				ifFalse: [
					^sectionWithHeader: 'Did you mean?' andContents: searchSuggestions
				]
		)
		definition = (
			^column: {helpSection. row: {filler. helpButton. mediumBlank. dropDownMenu: [
							searchResultsMenu
						]. }. deferred: [ searchFeedback ]. initially: (label: 'Searching namespaces')
					deferred: [ namespacesSection ]. initially: (label: 'Searching classes')
					deferred: [ classesSection ]. initially: (label: 'Searching selectors')
					deferred: [ selectorsSection ]. }
		)
		selectorSearchResults ^<Array[Fragment]> = (
			^subject selectorSubjects collect: [:each <SelectorSubject> |
					collapsed: (linkToBrowseSelector: each model) expanded: [ each presenter ]
				]
		)
		classSearchResults ^<Array[Fragment]> = (
			^subject classSubjects collect: [:each <ClassSubject> |
					collapsed: (linkToBrowseClass: each model klass)
						expanded: [ each presenter ]
				]
		)
		helpText = (
			| menuImage = Utilities uriForIconNamed: #dropDownImage. mapping = Map new. |
			mapping at: #searchResultsMenuButton
				put: (dropDownMenu: [ searchResultsMenu ]);
				at: #hopscotchHelpButton put: helpButton;
				at: #hopscotchRefreshButton put: refreshButton.
			^ampleforth: 'This is a search results presenter.  It shows occurrences of a search pattern in the code loaded into the IDE. Results will be grouped into separate sections for classes, namespaces and selectors. Sections are only displayed if they contain results. If there are no results at all, the area below will be blank.
  <ul>
    <li>div class="hopscotchRefreshButton"> </div> Refreshes the display.</li>
    <li><div class="hopscotchHelpButton"> </div> Shows this help message.</li>
   <li> <div class="searchResultsMenuButton"> </div> Opens a menu of additional operations, such as inspecting this presenter.
   </ul> <br>'
				mapping: mapping
		)
		classesSection = (
			^subject classSubjects isEmpty ifTrue: [ nothing ]
				ifFalse: [ ClassSectionPresenter new ]
		)
		selectorsSection = (
			^subject selectorSubjects isEmpty ifTrue: [ nothing ]
				ifFalse: [ SelectorSectionPresenter new ]
		)
		namespacesSection = (
			^subject namespaceMatches isEmpty ifTrue: [ nothing ]
				ifFalse: [ NamespaceSectionPresenter new ]
		)
	) : ()
	public class EvaluatorSubject onModel: e <EvaluationViewState> = Subject onModel: e (
