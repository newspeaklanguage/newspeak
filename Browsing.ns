	public class IDEWindow into: b openSubject: s <Subject>
	(* :exemplar: currentWindow *)
	 = Window into: b openSubject: s (
	) (
		class ToolbarPresenter new = super ToolbarPresenter new (
			|
				textView <SearchFieldFragment>
			|
		) (
			find = (
				find: textView textBeingAccepted
			)
			find: s <String> = (
				enterSubject: (SearchResultsSubject onModel: s)
			)
			searchField ^<Fragment> = (
				textView:: SearchFieldFragment new.
				textView acceptResponse: [:editor | find: editor textBeingAccepted ].
				^textView
			)
			saveAll = (
				^imageButton: ide images saveImage
					action: [ saveSources ]
					size: styleButtonSize
			)
			aiChatButton = (
				^(imageButton: ide images brainImage
					action: [ enterSubject: ide aiSupport chatLauncher ]
					size: styleButtonSize) toolTip: 'AI Chat'
			)
			toolbarItems ^<Array[Fragment]> = (
				^super toolbarItems , {saveAll. smallBlank. aiChatButton. smallBlank. searchField. }
			)
			helpText = (
				| findImage = Utilities uriForIconNamed: #findImage. mapping = Map new. |
				mapping at: #hopscotchSearchBar put: searchField;
					at: #hopscotchHistoryButton put: historyButton;
					at: #hopscotchHomeButton put: homeButton;
					at: #hopscotchRefreshButton put: refreshButton;
					at: #hopscotchHelpButton put: helpButton;
					at: #hopscotchCloseHelpButton put: closeHelpButton;
					at: #hopscotchSaveAllButton put: saveAll;
					at: #hopscotchAiChatButton put: aiChatButton.
				^ampleforth: 'You are running the Newspeak Web IDE.  You can learn all about it from within the IDE, using the help buttons of the various parts of the system. Newspeak is a live system. You can modify it within itself. <br>The IDE uses a navigation paradigm similar to web browsers and mobile devices. It runs locally in your browser, or as a PWA; it makes no use of the server after the page has opened, unless you are using  the collaborative version.<br>
 To learn about the language, go to <a href="https://newspeaklanguage.org">the Newspeak programming language website</a>.<br>
 The help button you opened just now is located in the IDE toolbar, which is always visible at the top  of the page/window.
 The elements of the toolbar are all described below:
  <br>
  <ul>
  <li><div class="hopscotchHistoryButton"> </div>
  <br>The history button shows you a list of all the presenters (''pages'') visited in the current session.  Alternatively, to navigate back and forth between visited presenters, you can use the viewer specific controls - see the ''Navigation'' section below.</li>
  <li><div class="hopscotchHomeButton"> </div>The home button takes you to the home page.</li>  
  <li><div class="hopscotchRefreshButton"> </div> Refreshes the display. The same icon is used for refreshing individual presenters everywhere in the system.</li> 
  <li><div class="hopscotchHelpButton"> </div> Shows this help message. This icon is used by presenters throughout the system to show help.</li>    
  <li><div class="hopscotchSaveAllButton"> </div> Saves the current IDE contents to a file. <b>Beware! The button in the help is live!</b></li>
  <li><div class="hopscotchAiChatButton"> </div> Opens an AI chat. If you have already provided an API key in this browser, the chat opens directly; otherwise a setup page lets you enter your API key and choose a model. From the chat, the AI can query the IDE (e.g. ask for class or method source, find senders and implementors).</li>
  <li><div class="hopscotchSearchBar"> </div> The search bar allow you to search for classes, methods and namespaces defined in the system. You can use wildcards in search terms. Pressing return or clicking on the search icon (<img src=''' , findImage , ''' alt="" width="18" height="30">) triggers the search.</li>
  </ul>
  <p><strong>Navigation</strong></p>
  Back and forth navigation between presenters (''pages'') differs depending on the viever:
  <ul>
    <li>In the web browser, use the browser''s navigation back and forward controls.</li>
    <li>In the Progressive Web App (PWA), use the standard keyboard shortcuts.
      <ul>
        <li>In Chrome and Chromium on Linux and Windows: To navigate back, use Alt + left arrow. To navigate forward, use Alt + right arrow.</li>
        <li>In Chrome and Chromium on Mac and iOS: To navigate back, use MacCmd + left arrow. To navigate forward, use MacCmd + right arrow.</li>
      </ul>
    </li>
  </ul>

  <br><br>
      You can close the help section by pressing <div class = "hopscotchCloseHelpButton"></div>, a convention used in all help sections.
  '
					mapping: mapping
			)
		) : ()
		public isKindOfIDEWindow ^<Boolean> = (
			^true
		)
		public runCurrentProgram = (
			(* Are we looking at an app we can run? *)
			
			(* Bogus: We could be in an object presenter for such a class, and need to handle that case as well *)
			
			(currentPresenter isKindOfClassPresenter and: [
					currentPresenter subject isApplicationConfiguration
				]) ifTrue: 
				(* If so, run it *)
				[ currentPresenter subject respondToRunApp: false ]
				ifFalse: 
				(* else, give an error message saying there is no runnable program *)
				[ 'You must be browsing an application class to run it.' out ]
		)
		public goToMethodNamed: aName = (
			('[Unimplemented] goToMethodNamed: ' , aName) out
		)
		public runTests = (
			'[Unimplemented] runTests' out
		)
		public showHelp = (
			'[Unimplemented] showHelp' out
		)
		public showTests = (
			'[Unimplemented] showTests' out
		)
		public toggleConsole = (
			'[Unimplemented] toggleConsole' out
		)
		public showReferences = (
			'[Unimplemented] showReferences' out
		)
		public refreshPresenter = (
			(* TODO: make this look for current refreshable fragment and work on thta *)
			
			refresh
		)
		public goToClassNamed: aName = (
			('[Unimplemented] goToClassNamed: ' , aName) out
		)
		public goTo: names <Array[Symbol]> = (
			(* Open an appropriate view on the definition(s) of the provided selectors. *)
			
			| selectors <List[Symbol]> = Utilities computeSelectorsFrom: names. selectorSubjects <List[SelectorSubject]> = List withAll: (Utilities implementedSubsetOf: selectors). |
			
			(* Is there just one selector *)
			selectorSubjects size = 1 ifTrue: [
					
					(* does it have a  unique definition? *)
					
					(* (selectorSubjects first implementorList methodSubjects size = 1]) ifTrue: [(* open it in its class (or by itself if it's a class) *)] *)
					
					(* If so, open a list of its implementations *)
					enterSubject: selectorSubjects first implementorList
				]
				ifFalse: 
				(* Otherwise, show a list of all the possibilities *)
				[ showReferencesTo: names ]
		)
		public showReferencesTo: names <Array[Symbol]> = (
			(* Open a list of references to the provided selectors. *)
			
			| selectors <List[Symbol]> = Utilities computeSelectorsFrom: names. searchString <String> = selectors inject: ''
				into: [:acc <String> :sel <Symbol> | acc , sel , ';' ]. |
			enterSubject: (SearchResultsSubject onModel: searchString)
		)
		public openWorkspaces = (
			enterSubject:: ide theWorkspaceManager AllWorkspacesSubject new
		)
		public openRootNamespace = (
			enterSubject:: NamespaceSubject new
		)
	) : (
		public openSubject: s = (
			^into: body openSubject: s
		)
	)
	class SetView onSubject: s = ProgrammingPresenter onSubject: s (
	) (
		public title ^<String> = (
			^'Set'
		)
		public isKindOfSetView ^<Boolean> = (
			^true
		)
		isMyKind: other <Fragment> ^<Boolean> = (
			^other isKindOfSetView
		)
