		)
		public isKindOfVarDeclAST ^<Boolean> = (
			^true
		)
	) : ()
	public class VariableAST new = AST new (
		|
			public name <Symbol>
		|
	) (
		public apply: tool <ASTTool[T]> ^<T> = (
			^tool variableNode: self
		)
		public isKindOfVariableNode ^<Boolean> = (
			^true
		)
		public printOn: stream = (
			stream nextPutAll: class simpleName.
			stream nextPutAll: ': '.
			stream nextPutAll: name
		)
	) : ()
	public class VariablePatternAST new = PatternAST new (
		|
			variableName <Symbol>
		|
	) (
		public apply: tool <ASTTool[T]> ^<T> = (
			^tool variablePatternNode: self
		)
		public isKindOfVariablePatternAST ^<Boolean> = (
			^true
		)
	) : (
		public variableName: vn start: s end: e = (
			^self new variableName: vn;
				start: s;
				end: e;
				yourself
		)
	)
	public class WildcardPatternAST new = PatternAST new (
	) (
		public apply: tool <ASTTool[T]> ^<T> = (
			^tool wildcardPatternNode: self
		)
		public isKindOfWildcardPatternAST ^<Boolean> = (
			^true
		)
	) : (
		public start: s end: e = (
			^self new start: s;
				end: e;
				yourself
		)
	)
) : ()
