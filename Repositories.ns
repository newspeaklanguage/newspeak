Newspeak3
'Newspeak'
class Repositories usingPlatform: platform ide: webIde = (
(*
 User-visible git repositories scoped by Namespace. Companion to
 DraftsRepo (which is hidden and single-purpose, powering the per-
 member history UI); this module exposes named user-managed
 repositories the user explicitly registers, clones, browses, and
 (eventually) commits to / pushes / pulls.

 Each Repository's tracked content is the entries of a Namespace
 (a Map[Symbol, Object]); multi-repo membership emerges from the
 language's existing multi-namespace membership. There is no
 separate "extra classes" list.

 Phase 1 scope (this commit): Repository model + setup form +
 list page + log-view RepositoryPresenter. Clone-on-create works
 against public read-only repos via the CORS proxy.

 JS globals required (loaded via <script> tags in primordialsoup.html):
   window.git         - isomorphic-git facade
   window.LightningFS - FS constructor
   window.GitHttp     - isomorphic-git/http/web
*)
|
	private Root = webIde namespacing Root.
	private ide = webIde.
	private js = platform js.
	private global = js global.
	(* Built-in JS globals — always present, eager capture is safe. *)
	private JSPromise = global at: #Promise.
	private TextDecoder = global at: #TextDecoder.
	private JSON = global at: #JSON.
	private JSDate = global at: #Date.
	private console = global at: #console.
	(* CDN-loaded JS classes (window.LightningFS / window.git /
	   window.GitHttp) are NOT captured here. The Newspeak snapshot is
	   loaded via <script async>, so module construction can run before
	   the regular <script> tags that define these globals have finished
	   executing. Eager `global at: #LightningFS` at construction would
	   bind to `undefined` and stay that way. They're surfaced as `lazy
	   public` slots in the class body below, which read the live window
	   at first access. *)
	private Map = platform collections Map.
	private List = platform collections List.
	private Set = platform collections Set.
	private Subject = platform hopscotch Subject.
	private Presenter = platform hopscotch Presenter.
	private ProgrammingSubject = webIde browsing ProgrammingSubject.
	private ProgrammingPresenter = webIde browsing ProgrammingPresenter.
	private ClassMirror = platform mirrors ClassMirror.
	private ClassDeclarationBuilder = platform mirrors ClassDeclarationBuilder.
	private platformHolder = platform.
	private Color = platform graphics Color.
	private localStorage = platform js localStorage.
	styleButtonSize <Float> = 30.
	(* localStorage key holding the JSON-encoded list of Repository
	   configs. Restored on module construction; updated on
	   create / delete. *)
	repoConfigsKey = 'ns_vcs_repos'.
	(* localStorage key for the shared author identity (JSON {name,email})
	   used by every Repository's commits. Editable from the commit
	   dialog; mirrors the per-host PAT storage pattern in spirit. *)
	authorStorageKey = 'ns_vcs_author'.
|
	(* Register RepositoryPresenter as an inspector view for any object
	   answering isKindOfRepository. Effect: when the user clicks a
	   Repository entry in a NamespacePresenter (e.g. Root), the live
	   repository UI replaces the generic object inspector. Mirrors how
	   Documents.ns:81 registers DocumentPresenter for isKindOfDocument. *)
	webIde browsing addObjectViews: {RepositoryPresenter} forKind: 'isKindOfRepository'.
	(* Restoration of persisted repos is NOT called here. The
	   Repositories module is constructed inside HopscotchWebIDE's
	   slot init, which runs BEFORE the constructor body that calls
	   populateNamespaceUsingPlatform: + seedBootstrapNamespacesInto:.
	   Restoring at construction time would race that seeding: any
	   repo whose namespaceKey is a bootstrap namespace (e.g. Newspeak,
	   PrimordialSoup) would find that namespace absent, create an
	   empty placeholder, and seeding would then SKIP populating it
	   (it only seeds keys that aren't already in Root). Result: the
	   bootstrap namespace appears empty.
	   Instead, HopscotchWebIDE calls
	   `repositories restorePersistedRepositories` from its constructor
	   body after seeding finishes. *)
) (
public class Repository
	named: n <Symbol>
	namespaceKey: nk <String>
	namespace: ns <Map[Symbol, Object]>
	remoteUrl: u <String | Nil>
	storeNamed: storeName <String>
	defaultBranch: branch <String>
	corsProxyUrl: cp <String | Nil> = (
(* A user-visible git repository. Scope: the entries of `namespace`.
   Backing store: lightning-fs IndexedDB scope `storeName`. Remote:
   `remoteUrl` (nil for local-only). All git ops are Promise-based.

   `namespaceKey` is the Root key the namespace was registered under
   (or 'Root' for Root itself). Stored separately because the in-
   memory `namespace` reference can't be persisted directly; on
   restore from localStorage we look it back up by key. *)
|
	(* Identity-shaped slots — immutable. Changing these would break
	   the Root registration / IndexedDB store binding. *)
	public name <Symbol> = n.
	public localStoreName <String> = storeName.
	(* Target namespace — mutable. Rebinding is safe (doesn't touch
	   the IndexedDB store), but should go through rebindToNamespaceKey:
	   so namespaceKey and namespace stay in sync and the change is
	   persisted. *)
	public namespaceKey <String> ::= nk.
	public namespace <Map[Symbol, Object]> ::= ns.
	(* Settings — mutable so the user can fix them (e.g. wrong branch).
	   Setters are auto-generated; persist with
	   ide repositories persistRepository: aRepo after mutating. *)
	public remoteUrl <String | Nil> ::= u.
	public defaultBranch <String> ::= branch.
	public corsProxyUrl <String | Nil> ::= cp.
	(* fs / git / http are lazy slots in the class body — see comment
	   on the module-level lazy LightningFSClass / gitFacade /
	   gitHttpFacade slots for why we can't capture them eagerly. *)
	historyCache_slot
	blobCache_slot
	(* cloneStatus_slot: nil | #cloning | #cloned | #failed | #localOnly.
	   Tracks the lifecycle of the repository's working dir so the
	   presenter can render an honest state instead of hanging on
	   "Loading history..." when clone hasn't finished or has failed. *)
	cloneStatus_slot
	cloneError_slot
	(* Tracks whether `git init` has been run on `dir`. Cloned repos are
	   initialized as a side effect of cloneFromRemote; local-only repos
	   need explicit init on first commit. ensureInitialized is idempotent. *)
	initialized_slot
	(* author is a JS object {name, email} used by every commit. Defaults
	   to a placeholder; the commit dialog (52d) reads / writes
	   ns_vcs_author in localStorage and updates this slot per repo. *)
	author_slot
|
) (
lazy public fs = LightningFSClass new: localStoreName.
lazy public git = gitFacade.
lazy public http = gitHttpFacade.
public isKindOfRepository ^ <Boolean> = (^true)
public dir ^ <String> = (^'/work')
public cloneStatus ^ <Symbol | Nil> = (^cloneStatus_slot)
public cloneError ^ <String | Nil> = (^cloneError_slot)
public isClonedOrLocalOnly ^ <Boolean> = (
	^cloneStatus_slot = #cloned or: [cloneStatus_slot = #localOnly]
)
createJSObject = (^JSON parse: '{}')
createJSArray = (^JSON parse: '[]')
mkdirIgnoringExisting: path ^ <Alien> = (
	| p |
	p:: (fs at: #promises) mkdir: path.
	^p then: [:ok | nil] onRejected: [:err | nil]
)
public cloneFromRemote ^ <Alien> = (
	(* Shallow clone (depth 50) of remoteUrl into dir via the CORS proxy.
	   Honors defaultBranch as the ref to fetch; an empty defaultBranch
	   makes isomorphic-git use the remote's HEAD. Updates
	   cloneStatus_slot / cloneError_slot so the UI can render the state
	   without polling. Races against a hard 60s timeout so a hung clone
	   (CORS proxy down, bad branch in some edge cases, network stall)
	   doesn't keep the UI stuck on "Cloning..." indefinitely. *)
	| opts clonePromise timeoutPromise deferred timerId |
	remoteUrl isNil ifTrue: [
		cloneStatus_slot:: #localOnly.
		cloneError_slot:: nil.
		^JSPromise resolve: nil].
	cloneStatus_slot:: #cloning.
	cloneError_slot:: nil.
	opts:: createJSObject.
	opts at: 'fs' put: fs.
	opts at: 'http' put: http.
	opts at: 'dir' put: dir.
	opts at: 'url' put: remoteUrl.
	corsProxyUrl isNil ifFalse: [opts at: 'corsProxy' put: corsProxyUrl].
	(defaultBranch isNil or: [defaultBranch isEmpty]) ifFalse: [
		opts at: 'ref' put: defaultBranch].
	opts at: 'singleBranch' put: true.
	opts at: 'depth' put: 50.
	clonePromise:: (mkdirIgnoringExisting: dir) then: [:r1 |
		git clone: opts].
	deferred:: JSPromise withResolvers.
	timerId:: js global setTimeout: [
		(deferred at: 'reject') call: js undefined with: 'Clone timed out after 60s (is the CORS proxy running on ', (corsProxyUrl ifNil: ['<unset>']), '?)'.
		nil] with: 60000.
	timeoutPromise:: deferred at: 'promise'.
	^(JSPromise race: (raceArrayOf: clonePromise and: timeoutPromise))
		then: [:r |
			js global clearTimeout: timerId.
			cloneStatus_slot:: #cloned.
			cloneError_slot:: nil.
			nil]
		onRejected: [:err |
			js global clearTimeout: timerId.
			cloneStatus_slot:: #failed.
			cloneError_slot:: safeErrorString: err.
			JSPromise reject: err]
)
raceArrayOf: p1 and: p2 ^ <Alien> = (
	(* JS-side Array containing two Promises. Promise.race takes an
	   iterable; passing a Newspeak Array literal `{p1. p2}` would ship
	   a non-bilingual Newspeak object across the alien bridge and fail
	   rawPush:. *)
	| arr |
	arr:: createJSArray.
	arr push: p1.
	arr push: p2.
	^arr
)
safeErrorString: err = (
	(* Defensive printString — if the JS Error's toString throws (custom
	   getters, etc.) we mustn't propagate that out of the rejection
	   handler since raising inside a Promise then/onRejected closure
	   corrupts the alien bridge (see CLAUDE memory). *)
	^[err printString] on: Exception do: [:e | '<unprintable error>']
)
public wipeLocalStore ^ <Alien> = (
	(* Recursively delete the working dir from the lightning-fs store.
	   lightning-fs only exposes POSIX rmdir (empty dir) and unlink
	   (file); there's no recursive rm, so we walk the tree in
	   post-order. Resolves on any outcome — success, missing dir, or
	   partial failure — so callers can chain a navigation without
	   worrying about edge cases. *)
	^(removePathRecursively: dir)
		then: [:r | nil]
		onRejected: [:err | nil]
)
removePathRecursively: path <String> ^ <Alien> = (
	(* Stat the path. If a directory, recursively remove + rmdir; else
	   unlink. lightning-fs Stats exposes a string `type` property
	   ('file', 'dir', or 'symlink'). *)
	| fsPromises |
	fsPromises:: fs at: #promises.
	^(fsPromises stat: path)
		then: [:stats |
			(stats at: 'type') = 'dir'
				ifTrue: [removeDir: path withPromises: fsPromises]
				ifFalse: [fsPromises unlink: path]]
		onRejected: [:err | nil]
)
removeDir: path <String> withPromises: fsPromises <Alien> ^ <Alien> = (
	(* readdir + recursively remove every entry + rmdir the now-empty
	   directory. Uses JSPromise.all over a JS array of child-removal
	   promises (Newspeak Array {...} would fail the alien bridge). *)
	^(fsPromises readdir: path) then: [:entries |
		| childPromises childCount jsArr |
		childCount:: entries at: 'length'.
		jsArr:: createJSArray.
		0 to: childCount - 1 do: [:i |
			jsArr push:
				(removePathRecursively: path, '/', (entries at: i))].
		(JSPromise all: jsArr) then: [:r |
			fsPromises rmdir: path]]
)
public resetCloneState = (
	(* Drop the cached clone status / history / blobs so the next clone
	   attempt starts fresh. Does NOT touch the underlying lightning-fs
	   store; isomorphic-git's clone is tolerant of an existing dir with
	   prior .git content, so the next attempt typically Just Works. *)
	cloneStatus_slot:: nil.
	cloneError_slot:: nil.
	historyCache_slot:: nil.
)
public rebindToNamespaceKey: newKey <String> = (
	(* Repoint this repository at a different namespace, looked up in
	   Root. Atomic update of namespaceKey + namespace + persistence.
	   Raises if the key doesn't resolve to an existing namespace.
	   Doesn't touch the IndexedDB working tree -- the same on-disk
	   .ns files now scope to a different namespace. The first commit
	   after a rebind re-syncs the file preambles (Newspeak3\n
	   '<namespaceKey>'\n) to the new key. *)
	| newNs |
	newNs:: Root at: newKey asSymbol ifAbsent: [
		^Error signal: 'No namespace named ', newKey, ' in Root'].
	namespaceKey:: newKey.
	namespace:: newNs.
	ide repositories persistRepository: self
)
public restoreCloneStateAsClonedOrLocalOnly = (
	(* Used by Repositories>>restorePersistedRepositories on reload. The
	   IDB-backed working dir survived; mark the repo as cloned (or
	   local-only) so the presenter's startFetch gating lets git.log
	   run. A bad on-disk state surfaces as a Failed-history error
	   with a Retry button — better than hanging on "Loading...". *)
	cloneStatus_slot:: remoteUrl isNil ifTrue: [#localOnly] ifFalse: [#cloned].
	cloneError_slot:: nil.
	initialized_slot:: true
)
public history ^ <Alien> = (
	(* git.log on the work directory. Caches the result on
	   historyCache_slot so cachedHistory can render synchronously after
	   the first fetch. *)
	| opts |
	opts:: createJSObject.
	opts at: 'fs' put: fs.
	opts at: 'dir' put: dir.
	^(git log: opts) then: [:entries |
		historyCache_slot:: entries.
		entries]
)
public cachedHistory = (^historyCache_slot)
public invalidateHistoryCache = (historyCache_slot:: nil)
public listFilesAt: sha <String> ^ <Alien> = (
	(* git.listFiles {fs, dir, ref: sha}. Resolves to a JS array of
	   filepaths in the tree at that commit. *)
	| opts |
	opts:: createJSObject.
	opts at: 'fs' put: fs.
	opts at: 'dir' put: dir.
	opts at: 'ref' put: sha.
	^git listFiles: opts
)
blobCacheKey: filepath <String> sha: sha <String> = (^filepath, '@', sha)
blobCache = (
	blobCache_slot isNil ifTrue: [blobCache_slot:: Map new].
	^blobCache_slot
)
public cachedBlobAt: filepath <String> in: sha <String> = (
	blobCache_slot isNil ifTrue: [^nil].
	^blobCache_slot at: (blobCacheKey: filepath sha: sha) ifAbsent: [nil]
)
public readBlobAt: filepath <String> in: sha <String> ^ <Alien> = (
	(* Resolves to the decoded text of filepath at commit sha. Caches
	   the result on first read. *)
	| opts cached |
	cached:: cachedBlobAt: filepath in: sha.
	cached isNil ifFalse: [^JSPromise resolve: cached].
	opts:: createJSObject.
	opts at: 'fs' put: fs.
	opts at: 'dir' put: dir.
	opts at: 'oid' put: sha.
	opts at: 'filepath' put: filepath.
	^(git readBlob: opts) then: [:result |
		| content |
		content:: TextDecoder new decode: (result at: 'blob').
		blobCache at: (blobCacheKey: filepath sha: sha) put: content.
		content]
)
public snapshotFiles ^ <Map[Symbol, Object]> = (
	(* Walk this repo's namespace and emit a conventional-layout
	   snapshot. Returns a Map with two keys:
	     #files    -> Map[String, String]  ('<ClassName>.ns' -> source)
	     #skipped  -> List[String]         human-readable lines describing
	                                       every non-class entry that didn't
	                                       make it into the snapshot.
	   File source format: 'Newspeak3\n<namespaceKey>\n' + class
	   declaration source from the live mirror (nested classes inlined,
	   lazy slots preserved -- see MirrorsForPrimordialSoup.ns:627). *)
	| files skipped |
	files:: Map new.
	skipped:: List new.
	namespace keysAndValuesDo: [:key :value |
		value isKindOfBehavior
			ifTrue: [
				| cdm body |
				cdm:: (ClassMirror reflecting: value) mixin declaration.
				body:: 'Newspeak3', String newline,
					namespaceKey printString, String newline,
					cdm source.
				files at: key asString, '.ns' put: body]
			ifFalse: [
				| desc |
				desc:: [value class name asString]
					on: Exception do: [:e | '<unknown class>'].
				skipped add: key asString, ' (', desc, ')']].
	^Map new
		at: #files put: files;
		at: #skipped put: skipped;
		yourself
)
public author ^ <Alien> = (
	(* Per-commit identity. Per-Repository override (author_slot) wins;
	   else fall back to the module-level stored author from
	   localStorage; else a clearly-fake placeholder so first-time
	   commits are visibly bogus (and the dialog prompts before
	   commit anyway when hasStoredAuthor is false). *)
	author_slot isNil ifFalse: [^author_slot].
	storedAuthor isNil ifFalse: [^storedAuthor].
	^makeDefaultAuthor
)
public author: a <Alien> = (author_slot:: a)
makeDefaultAuthor ^ <Alien> = (
	| a |
	a:: createJSObject.
	a at: 'name' put: 'IDE User (unconfigured)'.
	a at: 'email' put: 'unconfigured@newspeak.local'.
	^a
)
ensureInitialized ^ <Alien> = (
	(* Idempotent. After first init, subsequent calls short-circuit
	   via Promise.resolve. *)
	(initialized_slot = true) ifTrue: [^JSPromise resolve: nil].
	^(mkdirIgnoringExisting: dir) then: [:r1 |
		| initOpts |
		initOpts:: createJSObject.
		initOpts at: 'fs' put: fs.
		initOpts at: 'dir' put: dir.
		(git init: initOpts) then: [:r2 |
			initialized_slot:: true.
			nil]]
)
listHEADFiles ^ <Alien> = (
	| listOpts |
	listOpts:: createJSObject.
	listOpts at: 'fs' put: fs.
	listOpts at: 'dir' put: dir.
	listOpts at: 'ref' put: 'HEAD'.
	^(git listFiles: listOpts)
		then: [:arr | arr]
		onRejected: [:err | createJSArray]
)
writeFileEnsuringDirs: relpath <String> with: content <String> ^ <Alien> = (
	^mkdirChainFrom: (parentDirsOf: relpath) index: 0 then:
		[(fs at: #promises) writeFile: dir, '/', relpath with: content]
)
parentDirsOf: relpath <String> ^ <Alien> = (
	| result idx |
	result:: createJSArray.
	idx:: relpath indexOf: '/' startingAt: 1.
	[idx > 0] whileTrue: [
		result push: dir, '/', (relpath copyFrom: 1 to: idx - 1).
		idx:: relpath indexOf: '/' startingAt: idx + 1].
	^result
)
mkdirChainFrom: dirs <Alien> index: i <Integer> then: thenBlock <[]> ^ <Alien> = (
	i >= (dirs at: 'length')
		ifTrue: [^thenBlock value]
		ifFalse: [^(mkdirIgnoringExisting: (dirs at: i)) then: [:r |
			mkdirChainFrom: dirs index: i + 1 then: thenBlock]]
)
public stageWholeNamespace: files <Map[String, String]> ^ <Alien> = (
	(* Stage `files` as the complete working-tree contents. Files in
	   HEAD that aren't in `files` are unlinked + git-removed. Resolves
	   to a JS {added, modified, removed} diff against HEAD.
	   WARNING: this scope replaces EVERY file in the working tree --
	   not what a namespace-scoped commit wants. Use
	   stageTopLevelNsReplacements: for that. *)
	^stageSubtreeReplacements: { '' } newFiles: files
)
public stageTopLevelNsReplacements: files <Map[String, String]> ^ <Alien> = (
	(* Stage `files` (top-level <Class>.ns map) as additions / updates.
	   Does NOT remove any HEAD file -- a class disappearing from a
	   user's namespace is not the same as the corresponding repo file
	   needing deletion, because a repo's top-level .ns set is the
	   union of every namespace that touches it (and we don't have a
	   per-namespace ownership manifest yet). Explicit removal lives
	   in a separate workflow. Resolves to a JS
	   {added, modified, removed} diff against HEAD; removed is
	   always empty. *)
	^ensureInitialized then: [:r |
		| writePromises noRemovals |
		noRemovals:: createJSArray.
		writePromises:: createJSArray.
		files keysAndValuesDo: [:fn :content |
			writePromises push: (writeFileEnsuringDirs: fn with: content)].
		(JSPromise all: writePromises) then: [:r2 |
			stageAndDiff: files removals: noRemovals]]
)
stageSubtreeReplacements: prefixes <Array[String]> newFiles: files <Map[String, String]> ^ <Alien> = (
	^ensureInitialized then: [:r |
		listHEADFiles then: [:headFiles |
			| priorUnderPrefixes removalPaths writePromises |
			priorUnderPrefixes:: createJSArray.
			0 to: (headFiles at: 'length') - 1 do: [:i |
				| p anyMatch |
				p:: headFiles at: i.
				anyMatch:: false.
				prefixes do: [:pref |
					(p startsWith: pref) ifTrue: [anyMatch:: true]].
				anyMatch ifTrue: [priorUnderPrefixes push: p]].
			removalPaths:: createJSArray.
			0 to: (priorUnderPrefixes at: 'length') - 1 do: [:i |
				| p = priorUnderPrefixes at: i. |
				(files includesKey: p) ifFalse: [removalPaths push: p]].
			writePromises:: createJSArray.
			files keysAndValuesDo: [:fn :content |
				writePromises push: (writeFileEnsuringDirs: fn with: content)].
			0 to: (removalPaths at: 'length') - 1 do: [:i |
				writePromises push:
					((fs at: #promises) unlink: dir, '/', (removalPaths at: i))].
			(JSPromise all: writePromises) then: [:r2 |
				stageAndDiff: files removals: removalPaths]]]
)
stageAndDiff: files <Map[String, String]> removals: removalPaths <Alien> ^ <Alien> = (
	| stagePromises filepathsForMatrix |
	stagePromises:: createJSArray.
	filepathsForMatrix:: createJSArray.
	files keysAndValuesDo: [:fn :content |
		| addOpts |
		addOpts:: createJSObject.
		addOpts at: 'fs' put: fs.
		addOpts at: 'dir' put: dir.
		addOpts at: 'filepath' put: fn.
		stagePromises push: (git add: addOpts).
		filepathsForMatrix push: fn].
	0 to: (removalPaths at: 'length') - 1 do: [:i |
		| p remOpts |
		p:: removalPaths at: i.
		remOpts:: createJSObject.
		remOpts at: 'fs' put: fs.
		remOpts at: 'dir' put: dir.
		remOpts at: 'filepath' put: p.
		stagePromises push: (git remove: remOpts).
		filepathsForMatrix push: p].
	(filepathsForMatrix at: 'length') = 0 ifTrue: [
		| empty |
		empty:: createJSObject.
		empty at: 'added' put: createJSArray.
		empty at: 'modified' put: createJSArray.
		empty at: 'removed' put: createJSArray.
		^JSPromise resolve: empty].
	^(JSPromise all: stagePromises) then: [:r |
		| matrixOpts |
		matrixOpts:: createJSObject.
		matrixOpts at: 'fs' put: fs.
		matrixOpts at: 'dir' put: dir.
		matrixOpts at: 'filepaths' put: filepathsForMatrix.
		(git statusMatrix: matrixOpts)
			then: [:matrix | classifyMatrix: matrix]
			onRejected: [:err | classifyAsAllAdded: files]]
)
classifyAsAllAdded: files <Map[String, String]> ^ <Alien> = (
	| added result |
	added:: createJSArray.
	files keysAndValuesDo: [:fn :content | added push: fn].
	result:: createJSObject.
	result at: 'added' put: added.
	result at: 'modified' put: createJSArray.
	result at: 'removed' put: createJSArray.
	^result
)
classifyMatrix: matrix <Alien> ^ <Alien> = (
	| added modified removed result |
	added:: createJSArray.
	modified:: createJSArray.
	removed:: createJSArray.
	0 to: (matrix at: 'length') - 1 do: [:i |
		| row path h w |
		row:: matrix at: i.
		path:: row at: 0.
		h:: row at: 1.
		w:: row at: 2.
		(h = 0 and: [w > 0]) ifTrue: [added push: path].
		(h = 1 and: [w = 2]) ifTrue: [modified push: path].
		(h = 1 and: [w = 0]) ifTrue: [removed push: path]].
	result:: createJSObject.
	result at: 'added' put: added.
	result at: 'modified' put: modified.
	result at: 'removed' put: removed.
	^result
)
public commit: message <String> ^ <Alien> = (
	(* Bare commit -- caller must have staged via stageWholeNamespace:
	   (or stageSubtreeReplacements:newFiles:) first. Resolves to the
	   new commit SHA. *)
	| refOpts |
	refOpts:: createJSObject.
	refOpts at: 'fs' put: fs.
	refOpts at: 'dir' put: dir.
	refOpts at: 'ref' put: 'HEAD'.
	^(git resolveRef: refOpts)
		then: [:headSha | commitWithParent: nil message: message]
		onRejected: [:err | commitWithParent: createJSArray message: message]
)
commitWithParent: parentArr <Alien | Nil> message: msg <String> ^ <Alien> = (
	| commitOpts |
	commitOpts:: createJSObject.
	commitOpts at: 'fs' put: fs.
	commitOpts at: 'dir' put: dir.
	commitOpts at: 'message' put: msg.
	commitOpts at: 'author' put: author.
	nil = parentArr ifFalse: [commitOpts at: 'parent' put: parentArr].
	^(git commit: commitOpts) then: [:sha |
		invalidateHistoryCache.
		sha]
)
public commitSnapshot: files <Map[String, String]> message: msg <String> ^ <Alien> = (
	(* End-to-end commit: stage `files` as the top-level <Class>.ns set
	   (subdirectory + non-.ns HEAD content untouched), then commit
	   with `msg` if anything actually changed. Resolves to the new
	   SHA on commit, or nil if there was nothing to commit. *)
	^(stageTopLevelNsReplacements: files) then: [:diff |
		| total |
		total:: (diff at: 'added') at: 'length'.
		total:: total + ((diff at: 'modified') at: 'length').
		total:: total + ((diff at: 'removed') at: 'length').
		total = 0
			ifTrue: [JSPromise resolve: nil]
			ifFalse: [commit: msg]]
)
public fetchAndResetHEADToRemote ^ <Alien> = (
	(* Re-baseline the local repo against the remote: git fetch the
	   configured branch, then advance refs/heads/<branch> to the
	   fetched commit and check it out. Any local commits not yet
	   pushed are lost. Used by the "Fetch from Remote" menu item to
	   refresh the IDE's local clone after pushes from elsewhere.
	   Resolves to the new HEAD SHA. *)
	| fetchOpts |
	remoteUrl isNil
		ifTrue: [^JSPromise reject: 'Local-only repo has no remote'].
	fetchOpts:: createJSObject.
	fetchOpts at: 'fs' put: fs.
	fetchOpts at: 'http' put: http.
	fetchOpts at: 'dir' put: dir.
	fetchOpts at: 'url' put: remoteUrl.
	fetchOpts at: 'ref' put: defaultBranch.
	fetchOpts at: 'singleBranch' put: true.
	corsProxyUrl isNil ifFalse: [
		fetchOpts at: 'corsProxy' put: corsProxyUrl].
	^(git fetch: fetchOpts) then: [:fetchResult |
		| refOpts |
		refOpts:: createJSObject.
		refOpts at: 'fs' put: fs.
		refOpts at: 'dir' put: dir.
		refOpts at: 'ref' put: 'refs/remotes/origin/', defaultBranch.
		(git resolveRef: refOpts) then: [:remoteSha |
			| writeRefOpts |
			writeRefOpts:: createJSObject.
			writeRefOpts at: 'fs' put: fs.
			writeRefOpts at: 'dir' put: dir.
			writeRefOpts at: 'ref' put: 'refs/heads/', defaultBranch.
			writeRefOpts at: 'value' put: remoteSha.
			writeRefOpts at: 'force' put: true.
			(git writeRef: writeRefOpts) then: [:r |
				| checkoutOpts |
				checkoutOpts:: createJSObject.
				checkoutOpts at: 'fs' put: fs.
				checkoutOpts at: 'dir' put: dir.
				checkoutOpts at: 'ref' put: defaultBranch.
				checkoutOpts at: 'force' put: true.
				(git checkout: checkoutOpts) then: [:cr |
					invalidateHistoryCache.
					blobCache_slot:: nil.
					remoteSha]]]]
)
public readHEADTextFiles ^ <Alien> = (
	(* Resolves to a JS object {path -> content} of every file at HEAD
	   in this repo. Empty object if HEAD doesn't exist yet (fresh init,
	   no commits) or any read error occurs. Returns JS object (not
	   Newspeak Map) because Newspeak Maps don't survive crossing the
	   JS Promise resolution boundary intact; callers convert via
	   jsObjectToMap: in their then: callback. *)
	^ensureInitialized
		then: [:r | readHEADTextFilesInner]
		onRejected: [:err | createJSObject]
)
readHEADTextFilesInner ^ <Alien> = (
	(* Resolve HEAD to a concrete SHA first, then read each path's
	   blob at that SHA. isomorphic-git's git.readBlob takes oid which
	   nominally accepts symbolic refs like 'HEAD', but in practice
	   resolving up front is more reliable across versions and gives
	   us a clean "HEAD doesn't exist" path via the resolveRef
	   rejection. *)
	| refOpts |
	refOpts:: createJSObject.
	refOpts at: 'fs' put: fs.
	refOpts at: 'dir' put: dir.
	refOpts at: 'ref' put: 'HEAD'.
	^(git resolveRef: refOpts)
		then: [:headSha | readHEADTextFilesAtSha: headSha]
		onRejected: [:err |
			console log: 'readHEADTextFiles: HEAD ref unresolved, treating as empty: ', err printString.
			createJSObject]
)
readHEADTextFilesAtSha: headSha <String> ^ <Alien> = (
	^listHEADFiles
		then: [:paths |
			| promises result count |
			count:: paths at: 'length'.
			result:: createJSObject.
			console log: 'readHEADTextFiles: HEAD=', headSha, ', listFiles returned ', count printString, ' paths'.
			count = 0
				ifTrue: [JSPromise resolve: result]
				ifFalse: [
					promises:: createJSArray.
					0 to: count - 1 do: [:i |
						| path |
						path:: paths at: i.
						promises push: ((readBlobAt: path in: headSha)
							then: [:content |
								result at: path put: content.
								nil]
							onRejected: [:err |
								console log: 'readBlob failed for ', path, ': ', err printString.
								nil])].
					(JSPromise all: promises) then: [:done |
						console log: 'readHEADTextFiles: collected ', (jsObjectKeyCount: result) printString, ' entries'.
						result]]]
		onRejected: [:err |
			console log: 'listHEADFiles rejected: ', err printString.
			createJSObject]
)
jsObjectKeyCount: jsObj <Alien> ^ <Integer> = (
	| Object keys |
	Object:: global at: #Object.
	keys:: Object keys: jsObj.
	^keys at: 'length'
)
) : (
)
public class RepositorySubject onModel: r <Repository>
	= ProgrammingSubject onModel: r (
(* Subject wrapping a Repository for display. *)
) (
public createPresenter ^ <Presenter> = (
	^RepositoryPresenter onRepositorySubject: self
)
public repository ^ <Repository> = (^model)
public title ^ <String> = (^'Repository: ', model name asString)
public isKindOfRepositorySubject ^ <Boolean> = (^true)
isMyKind: s <Subject> ^ <Boolean> = (
	^s isKindOfRepositorySubject
)
) : (
)
public class RepositoryPresenter onRepositorySubject: s <RepositorySubject>
	= ProgrammingPresenter onSubject: s (
(* Read-only view of a Repository: header (name + remote + HEAD short
   sha when known), log, and (later) action buttons. Phase 1 only
   loads the log.

   The primary constructor is `onRepositorySubject:`; class-side
   `onSubject:` is a secondary constructor used by `addObjectViews:
   forKind:` so an arbitrary ObjectSubject (e.g. a Root entry the
   user is inspecting) gets wrapped in a RepositorySubject for us. *)
|
loadStarted_slot ::= false.
loadFailed_slot
contentListSlot
|
) (
public isKindOfRepositoryPresenter ^ <Boolean> = (^true)
isMyKind: f <Fragment> ^ <Boolean> = (
	^f isKindOfRepositoryPresenter
)
public refreshFromAsync = (
	(* Public hook for external code (a Promise then/onRejected handler
	   on the wrapping subject's async clone/refresh path) to trigger a
	   real UI refresh — meaning one that bumps `uiGeneration` so the
	   cached presenter substance is invalidated and a fresh
	   `definition` runs against the latest subject state. Has to live
	   on the presenter as a public method because `updateGUI:` is
	   protected and only accessible via implicit-receiver sends from
	   the surrounding lexical scope. *)
	updateGUI: []
)
updateVisualsFromSameKind: oldPresenter <Self> ^ <Alien[Element]> = (
	(* Clear the cached substance so `definition` re-runs and picks up
	   the latest cachedHistory / cloneStatus from the underlying
	   Repository. Without this, an async clone-then-history flow that
	   ends with ide browsing updateCurrentDisplay refreshes the
	   wrapping window but the presenter keeps showing the old
	   "Cloning..." / "Loading history..." substance until the user
	   navigates away and back. Same pattern as
	   ClassPresenter>>updateVisualsFromSameKind: (Browsing.ns:4508). *)
	subject = oldPresenter subject ifFalse: [
		ensureSubstance.
		^replaceVisual: oldPresenter visual with: substance visual].
	substanceSlot:: nil.
	ensureSubstance.
	^super updateVisualsFromSameKind: oldPresenter
)
definition = (
	| cached |
	cached:: subject repository cachedHistory.
	(* Only fire the log fetch when the working dir is in a known-good
	   state. Firing while clone is in flight or after a failed clone
	   would call git.log on a partial repo, which can itself hang on
	   lightning-fs locks and pile up async work — exactly the failure
	   mode that wedged the IDE last time. *)
	(cached isNil
		and: [subject repository isClonedOrLocalOnly
		and: [loadStarted_slot not]]) ifTrue: [
		loadStarted_slot:: true.
		startFetch].
	^column: {
		helpSection.
		majorHeadingBlock: (
			row: {
				(label: subject title) bold.
				filler.
				expandButtonWithAction: [expandAll].
				smallBlank.
				collapseButtonWithAction: [collapseAll].
				smallBlank.
				refreshHistoryButton.
				smallBlank.
				helpButton.
				smallBlank.
				dropDownMenu: [repositoryMenu]}).
		mediumBlank.
		row: {
			(label: 'Remote: ') bold.
			label: (subject repository remoteUrl isNil
				ifTrue: ['(local only)']
				ifFalse: [subject repository remoteUrl]).
			filler}.
		row: {
			(label: 'Branch: ') bold.
			label: subject repository defaultBranch.
			filler}.
		row: {
			(label: 'Namespace: ') bold.
			(link: subject repository namespaceKey action: [
				| nsKey nsValue |
				nsKey:: subject repository namespaceKey asSymbol.
				nsValue:: Root at: nsKey ifAbsent: [nil].
				nsValue isNil ifFalse: [
					enterSubject:: (ide browsing NamespaceSubject
						onModel: nsValue key: nsKey)]])
				color: actionLinkColor.
			filler}.
		mediumBlank.
		bodyFor: cached
	}
)
refreshHistoryButton = (
	(* Invalidate the repository's history cache, reset the presenter's
	   load-state, and ask the IDE to redraw — which kicks off a fresh
	   git.log on the next render. *)
	^(imageButton: ide images refreshImage
		action: [updateGUI: [
			subject repository invalidateHistoryCache.
			loadStarted_slot:: false.
			loadFailed_slot:: nil]])
		height: styleButtonSize;
		toolTip: 'Refresh the commit log'
)
bodyFor: cached = (
	(* Render whichever state is true:
	   - Clone failed       → error message + Retry button.
	   - Clone in flight    → "Cloning..." placeholder.
	   - Status nil         → explicit "Load history" button.
	     (Restored persisted repos start here. We don't auto-fire
	     git.log because a corrupt IDB state can put isomorphic-git
	     into a sync CPU loop that wedges the browser. The user opts
	     in; recovery from a bad load is via the per-row Delete on
	     the list page.)
	   - Status cloned/local, cached nil → loading or failed.
	   - Already loaded     → the actual commit list, or
	     "No commits yet." *)
	subject repository cloneStatus = #failed ifTrue: [
		^column: {
			(label: 'Clone failed: ', subject repository cloneError)
				color: (Color r: 0.8 g: 0.1 b: 0.1).
			smallBlank.
			row: {
				button: 'Retry clone' action: [respondToRetryClone].
				filler}}].
	subject repository cloneStatus = #cloning ifTrue: [
		^label: 'Cloning...'].
	subject repository cloneStatus isNil ifTrue: [
		^column: {
			label: 'History not loaded. Click below to fetch — the call may hang the browser if the local store is corrupt; recover via the per-row Delete on the repository list.'.
			smallBlank.
			row: {
				button: 'Load history' action: [respondToLoadHistory].
				filler}}].
	cached isNil ifTrue: [
		loadFailed_slot isNil
			ifTrue: [^label: 'Loading history...']
			ifFalse: [^label: 'Failed to load history: ', loadFailed_slot]].
	(cached at: 'length') = 0 ifTrue: [
		^label: 'No commits yet.'].
	^logColumnFor: cached
)
respondToLoadHistory = (
	(* Explicit user-triggered load for restored repos. Promotes
	   cloneStatus to #cloned (or #localOnly), which unblocks the
	   presenter's startFetch gating on next render. *)
	updateGUI: [
		subject repository restoreCloneStateAsClonedOrLocalOnly.
		loadStarted_slot:: false.
		loadFailed_slot:: nil]
)
respondToRetryClone = (
	(* Reset the repository's clone state and re-run the clone-then-
	   populate-history dance, refreshing the UI when the inner Promise
	   settles so the user sees the result. cloneFromRemote already
	   stores its own error string via safeErrorString:; we just refresh
	   the display. *)
	| repo |
	repo:: subject repository.
	updateGUI: [
		repo resetCloneState.
		loadStarted_slot:: false.
		loadFailed_slot:: nil].
	repo cloneFromRemote
		then: [:r |
			repo invalidateHistoryCache.
			repo history then: [:log |
				updateGUI: []. nil]]
		onRejected: [:err |
			updateGUI: [].
			nil]
)
logColumnFor: entries = (
	| toggles |
	toggles:: List new.
	0 to: (entries at: 'length') - 1 do: [:i |
		toggles add: (logToggleFor: (entries at: i))].
	contentListSlot:: zebra: (taggedColumn: toggles).
	^contentListSlot
)
public expandAll = (
	contentListSlot isNil ifFalse: [
		contentListSlot childrenDo: [:each | each expand]]
)
public collapseAll = (
	contentListSlot isNil ifFalse: [
		contentListSlot childrenDo: [:each | each collapse]]
)
logToggleFor: entry = (
	| toggle sha |
	sha:: entry at: 'oid'.
	toggle:: collapsed: [collapsedLogRowFor: entry toggle: toggle]
		expanded: [expandedLogRowFor: entry toggle: toggle]
		initiallyExpanded: false
		tag: sha.
	^toggle
)
collapsedLogRowFor: entry toggle: toggle = (
	| sha shortSha message firstLine timestamp dateStr |
	sha:: entry at: 'oid'.
	shortSha:: sha copyFrom: 1 to: 7.
	message:: (entry at: 'commit') at: 'message'.
	firstLine:: firstLineOf: message.
	timestamp:: ((entry at: 'commit') at: 'author') at: 'timestamp'.
	dateStr:: formatTimestamp: timestamp.
	^row: {
		(link: shortSha action: [toggle expand]) color: actionLinkColor.
		smallBlank.
		label: dateStr.
		smallBlank.
		label: firstLine.
		filler}
)
expandedLogRowFor: entry toggle: toggle = (
	| sha shortSha message timestamp dateStr authorName |
	sha:: entry at: 'oid'.
	shortSha:: sha copyFrom: 1 to: 7.
	message:: (entry at: 'commit') at: 'message'.
	timestamp:: ((entry at: 'commit') at: 'author') at: 'timestamp'.
	dateStr:: formatTimestamp: timestamp.
	authorName:: ((entry at: 'commit') at: 'author') at: 'name'.
	^column: {
		row: {
			(link: shortSha action: [toggle collapse]) color: actionLinkColor.
			smallBlank.
			label: dateStr.
			smallBlank.
			label: authorName.
			filler}.
		smallBlank.
		(label: sha) smallFont.
		smallBlank.
		multilineLabelOf: message}
)
multilineLabelOf: text = (
	(* Render a multi-line commit body as a column of single-line
	   labels. Strips the trailing newline if any. *)
	| labels lines start lf size |
	labels:: List new.
	lines:: List new.
	lf:: String fromRunes: { 10 }.
	start:: 1.
	size:: text size.
	[start <= size] whileTrue: [
		| idx |
		idx:: text indexOf: lf startingAt: start.
		idx = 0
			ifTrue: [lines add: (text copyFrom: start to: size). start:: size + 1]
			ifFalse: [
				lines add: (text copyFrom: start to: idx - 1).
				start:: idx + 1]].
	lines do: [:line | labels add: (label: line)].
	^column: labels
)
repositoryMenu = (
	^menuWithLabelsAndActions: {
		{'Commit…'. [respondToCommit]}.
		{'Fetch from Remote'. [respondToFetch]}.
		{'Edit Settings'. [respondToEditSettings]}.
		{'Show Snapshot'. [respondToShowSnapshot]}.
		{'Show Diff (round-trip)'. [respondToShowRoundTripDiff]}.
		{'Delete Repository'. [respondToDelete]}.
		{'Delete and Wipe Local Store'. [respondToDeleteAndWipe]}.
		{'Inspect Presenter'. [respondToInspectPresenter]}}
)
respondToFetch = (
	(* Re-baseline this repo's HEAD against the remote. Any local
	   commits not yet pushed will be lost. Shows a progress notice
	   while the fetch is in flight; resets the history cache + UI
	   on success. *)
	| repo |
	repo:: subject repository.
	repo remoteUrl isNil ifTrue: [
		^js global alert: 'This repository has no remote configured.'].
	repo fetchAndResetHEADToRemote
		then: [:sha |
			updateGUI: [
				loadStarted_slot:: false.
				loadFailed_slot:: nil].
			js global alert: 'Fetched. New HEAD: ', (sha copyFrom: 1 to: 7).
			nil]
		onRejected: [:e |
			| msg |
			msg:: [e messageText] on: Exception do: [:e2 | nil].
			msg isNil ifTrue: [msg:: e printString].
			js global alert: 'Fetch failed: ', msg.
			nil]
)
respondToCommit = (
	| repo strategy |
	repo:: subject repository.
	strategy:: RepoCommitStrategy onRepository: repo.
	enterSubject:: ChangesetSubject onRepository: repo strategy: strategy
)
respondToShowRoundTripDiff = (
	(* Self-consistency smoke test: for every class in the repo's
	   namespace, snapshot it to .ns text, parse the text back, extract
	   the per-member map, and diff against the live mirror's per-member
	   map. If everything is wired up correctly the diff is empty
	   (modulo whitespace artifacts) for every class. Non-empty diffs
	   reveal bugs in snapshot / extractor / mirror-reader / parser
	   positions. *)
	| repo snap files anyDiffs |
	repo:: subject repository.
	snap:: repo snapshotFiles.
	files:: snap at: #files.
	anyDiffs:: 0.
	console log: '--- Round-trip diff for ', repo name asString, ' ---'.
	repo namespace keysAndValuesDo: [:key :value |
		value isKindOfBehavior ifTrue: [
			| src parsedSnap liveSnap diff |
			src:: files at: key asString, '.ns' ifAbsent: [nil].
			src isNil ifFalse: [
				[parsedSnap:: ide repositories extractedSnapshotFromSource: src.
				 liveSnap:: ide repositories liveSnapshotOf: value.
				 diff:: ide repositories diffSnapshot: parsedSnap to: liveSnap.
				 (ide repositories diffIsEmpty: diff) ifFalse: [
					anyDiffs:: anyDiffs + 1.
					console log: 'DIFF: ', key asString.
					console log: diff printString]]
					on: Exception do: [:e |
						| msg |
						msg:: [e messageText] on: Exception do: [:e2 | nil].
						msg isNil ifTrue: [msg:: e printString].
						anyDiffs:: anyDiffs + 1.
						console log: 'ERROR: ', key asString, ' -- ', msg.
						console log: 'src size: ', src size printString.
						console log: '--- full snapshot source for ', key asString, ' ---'.
						console log: src]]]].
	js global alert: 'Round-trip: ', anyDiffs printString,
		' class(es) with diffs or errors. See console.'
)
respondToShowSnapshot = (
	(* Smoke test: dump what snapshotFiles would commit. Summary to
	   alert, full file list + per-file char count + first-file source
	   + skipped entries to console.log. *)
	| repo snap files skipped summary firstKey |
	repo:: subject repository.
	snap:: repo snapshotFiles.
	files:: snap at: #files.
	skipped:: snap at: #skipped.
	summary:: repo name asString, ': ', files size printString,
		' file(s), ', skipped size printString,
		' skipped. See console for detail.'.
	console log: summary.
	console log: '--- Files ---'.
	files keysAndValuesDo: [:k :v |
		console log: '  ', k, ' (', v size printString, ' chars)'].
	files isEmpty ifFalse: [
		firstKey:: nil.
		files keysAndValuesDo: [:k :v | firstKey isNil ifTrue: [firstKey:: k]].
		console log: '--- Sample (', firstKey, ') ---'.
		console log: (files at: firstKey)].
	skipped isEmpty ifFalse: [
		console log: '--- Skipped ---'.
		skipped do: [:line | console log: '  ', line]].
	js global alert: summary
)
respondToEditSettings = (
	(* Open the settings form for this repository. *)
	enterSubject:: RepositorySettingsSubject onRepository: subject repository
)
respondToDelete = (
	(* Remove the Repository from Root, drop its persisted config, and
	   navigate back to the list. Does not garbage-collect the
	   underlying IndexedDB store. *)
	| repo |
	repo:: subject repository.
	updateGUI: [
		Root removeKey: repo name asSymbol ifAbsent: [].
		ide repositories unpersistRepositoryNamed: repo name.
		enterSubject:: RepositoryListSubject new]
)
respondToDeleteAndWipe = (
	(* Same as Delete Repository, plus wipes the working dir from
	   lightning-fs. Use this to recover from a wedged clone state. *)
	| repo |
	repo:: subject repository.
	repo wipeLocalStore then: [:r |
		updateGUI: [
			Root removeKey: repo name asSymbol ifAbsent: [].
			ide repositories unpersistRepositoryNamed: repo name.
			enterSubject:: RepositoryListSubject new].
		nil]
)
firstLineOf: msg = (
	| lf idx |
	lf:: String fromRunes: { 10 }.
	idx:: msg indexOf: lf.
	^idx = 0
		ifTrue: [msg]
		ifFalse: [msg copyFrom: 1 to: idx - 1]
)
formatTimestamp: tsSeconds = (
	(* Force Float arithmetic via asFloat so the JS Date constructor
	   sees a real millisecond value (alien bridge truncates Newspeak
	   Integer to 32 bits). *)
	^(JSDate new: tsSeconds asFloat * 1000) toLocaleString
)
startFetch = (
	(* Kick off the async history fetch. On resolve, updateGUI refreshes
	   the presenter so cachedHistory is non-nil on the next render. *)
	subject repository history
		then: [:log | updateGUI: []. nil]
		onRejected: [:err |
			updateGUI: [loadFailed_slot:: err printString]. nil]
)
helpText = (
	| mapping = Map new. |
	mapping
		at: #hopscotchExpandAllButton put: (expandButtonWithAction: [expandAll]);
		at: #hopscotchCollapseAllButton put: (collapseButtonWithAction: [collapseAll]);
		at: #hopscotchRefreshButton put: refreshHistoryButton;
		at: #hopscotchHelpButton put: helpButton;
		at: #repositoryMenuButton put: (dropDownMenu: [repositoryMenu]).
	^ampleforth: 'This is a repository presenter. It lists the commits in this
repository (newest first). Each row shows the short commit SHA (click to
expand), the commit date, and the first line of the commit message. Expanding
a row reveals the author, the full SHA, and the full commit message body.
The header provides the following buttons:
<ul>
<li> <div class="hopscotchExpandAllButton"> </div> Expands all commits in the list.</li>
<li> <div class="hopscotchCollapseAllButton"> </div> Collapses all commits in the list.</li>
<li> <div class="hopscotchRefreshButton"> </div> Re-fetches the log from the backing store (just in case of UI bugs).</li>
<li> <div class="hopscotchHelpButton"> </div> Shows this help message.</li>
<li> <div class="repositoryMenuButton"> </div> Opens a menu of additional operations, such as inspecting this presenter.</li>
</ul>' mapping: mapping
)
) : (
public onSubject: os <ObjectSubject> ^ <Instance> = (
	(* Inspector-side factory: wrap the underlying Repository in a
	   RepositorySubject so the user sees the live RepositoryPresenter
	   instead of the generic object inspector. Used by
	   `addObjectViews: forKind:`. *)
	^onRepositorySubject: (RepositorySubject onModel: os objectMirror reflectee)
)
)
public class RepositoryListSubject = ProgrammingSubject onModel: nil (
(* The "all my repositories" page. Enumerates Root for entries that
   answer isKindOfRepository. *)
) (
public createPresenter ^ <Presenter> = (
	^RepositoryListPresenter onSubject: self
)
public title ^ <String> = (^'Repositories')
public repositories ^ <List[Repository]> = (
	| repos |
	repos:: List new.
	Root keysAndValuesDo: [:k :v |
		([v isKindOfRepository] on: Exception do: [:e | false])
			ifTrue: [repos add: v]].
	^repos
)
public isKindOfRepositoryListSubject ^ <Boolean> = (^true)
isMyKind: s <Subject> ^ <Boolean> = (
	^s isKindOfRepositoryListSubject
)
) : (
)
public class RepositoryListPresenter onSubject: s <RepositoryListSubject>
	= ProgrammingPresenter onSubject: s (
) (
public isKindOfRepositoryListPresenter ^ <Boolean> = (^true)
isMyKind: f <Fragment> ^ <Boolean> = (
	^f isKindOfRepositoryListPresenter
)
definition = (
	| repos rows |
	repos:: subject repositories.
	rows:: List new.
	rows add: helpSection.
	rows add: (majorHeadingBlock: (
		row: {
			(label: subject title) bold.
			filler.
			newRepositoryButton.
			smallBlank.
			refreshListButton.
			smallBlank.
			helpButton.
			smallBlank.
			dropDownMenu: [listMenu]})).
	rows add: mediumBlank.
	repos isEmpty
		ifTrue: [rows add: (label: 'No repositories registered yet.')]
		ifFalse: [
			rows add: (zebra: (column:
				(repos collect: [:r | rowForRepository: r]))).
			rows add: smallBlank].
	^column: rows
)
rowForRepository: r <Repository> = (
	^row: {
		(link: r name asString action: [
			enterSubject:: RepositorySubject onModel: r]) color: actionLinkColor.
		smallBlank.
		label: (r remoteUrl isNil ifTrue: ['(local only)'] ifFalse: [r remoteUrl]).
		filler.
		dropDownMenu: [menuForRepository: r]}
)
menuForRepository: r <Repository> = (
	^menuWithLabelsAndActions: {
		{'Delete'. [respondToDeleteRow: r]}.
		{'Delete and Wipe Local Store'. [respondToDeleteAndWipeRow: r]}}
)
respondToDeleteRow: r <Repository> = (
	(* Remove the repository from Root + localStorage WITHOUT opening
	   it. Critical for recovering from a corrupt repo whose presenter
	   would hang the IDE if entered. *)
	updateGUI: [
		Root removeKey: r name asSymbol ifAbsent: [].
		ide repositories unpersistRepositoryNamed: r name]
)
respondToDeleteAndWipeRow: r <Repository> = (
	(* Same as delete, plus wipes the lightning-fs working dir so the
	   IDB store doesn't accumulate orphaned data. *)
	r wipeLocalStore then: [:x |
		updateGUI: [
			Root removeKey: r name asSymbol ifAbsent: [].
			ide repositories unpersistRepositoryNamed: r name].
		nil]
)
newRepositoryButton = (
	^button: 'New Repository' action: [respondToNew]
)
refreshListButton = (
	^(imageButton: ide images refreshImage
		action: [updateGUI: []])
		height: styleButtonSize;
		toolTip: 'Refresh the repository list'
)
respondToNew = (
	enterSubject:: RepositorySetupSubject new
)
listMenu = (
	^menuWithLabelsAndActions: {
		{'Inspect Presenter'. [respondToInspectPresenter]}}
)
helpText = (
	| mapping = Map new. |
	mapping
		at: #newRepositoryButton put: newRepositoryButton;
		at: #hopscotchRefreshButton put: refreshListButton;
		at: #hopscotchHelpButton put: helpButton;
		at: #listMenuButton put: (dropDownMenu: [listMenu]).
	^ampleforth: 'This is the repository list. It enumerates every git
repository registered in Root. Click a repository name to open its
presenter. The header provides the following buttons:
<ul>
<li> <div class="newRepositoryButton"> </div> Opens a form to register a new repository (clone an existing remote or initialize a local-only repo).</li>
<li> <div class="hopscotchRefreshButton"> </div> Refreshes the list (just in case of UI bugs).</li>
<li> <div class="hopscotchHelpButton"> </div> Shows this help message.</li>
<li> <div class="listMenuButton"> </div> Opens a menu of additional operations, such as inspecting this presenter.</li>
</ul>' mapping: mapping
)
) : (
)
public class RepositorySetupSubject = ProgrammingSubject onModel: nil (
(* Form-style subject for creating a new Repository. Captures user
   input (name, namespace key, remote URL, default branch, CORS proxy)
   and creates the Repository on confirm. *)
|
public repoName <String> ::= ''.
public namespaceKey <String> ::= 'Root'.
public createNewNamespace <Boolean> ::= false.
public remoteUrl <String> ::= ''.
public defaultBranch <String> ::= 'main'.
public corsProxyUrl <String> ::= 'http://localhost:9999'.
public errorMessage <String> ::= ''.
|
) (
public createPresenter ^ <Presenter> = (
	^RepositorySetupPresenter onSubject: self
)
public title ^ <String> = (^'New Repository')
public isKindOfRepositorySetupSubject ^ <Boolean> = (^true)
isMyKind: s <Subject> ^ <Boolean> = (
	^s isKindOfRepositorySetupSubject
)
public availableNamespaces ^ <List[String]> = (
	(* Every entry in Root that answers isKindOfNamespace, plus Root
	   itself as a default option. Names are returned as Strings (the
	   key under which the namespace is registered). *)
	| names |
	names:: List new.
	names add: 'Root'.
	Root keysAndValuesDo: [:k :v |
		([v isKindOfNamespace] on: Exception do: [:e | false])
			ifTrue: [names add: k asString]].
	^names
)
public resolveNamespace ^ <Map[Symbol, Object] | Nil> = (
	(* Look up the namespaceKey in Root; for the special key 'Root',
	   return Root itself. Returns nil if no match found and no
	   create-new flag set. *)
	namespaceKey = 'Root' ifTrue: [^Root].
	^Root at: namespaceKey asSymbol ifAbsent: [nil]
)
public submit = (
	(* Validate, build the Repository, register in Root, kick off the
	   clone if a remote was given, and return a RepositorySubject for
	   navigation. On validation failure returns nil with errorMessage
	   set; the presenter renders the error. *)
	| ns target storeName repo subjectInstance |
	repoName isEmpty ifTrue: [
		errorMessage:: 'Please enter a repository name.'.
		^nil].
	(Root includesKey: repoName asSymbol) ifTrue: [
		errorMessage:: 'An entry named "', repoName, '" already exists in Root.'.
		^nil].
	createNewNamespace
		ifTrue: [
			(Root includesKey: namespaceKey asSymbol) ifTrue: [
				errorMessage:: 'A namespace named "', namespaceKey, '" already exists in Root.'.
				^nil].
			ns:: ide namespacing freshNamespace.
			Root at: namespaceKey asSymbol put: ns]
		ifFalse: [
			ns:: resolveNamespace.
			ns isNil ifTrue: [
				errorMessage:: 'No namespace named "', namespaceKey, '" in Root. Tick "Create new namespace" to create one.'.
				^nil]].
	storeName:: 'newspeak-repo-', repoName.
	target:: remoteUrl isEmpty ifTrue: [nil] ifFalse: [remoteUrl].
	repo:: Repository
		named: repoName asSymbol
		namespaceKey: namespaceKey
		namespace: ns
		remoteUrl: target
		storeNamed: storeName
		defaultBranch: defaultBranch
		corsProxyUrl: corsProxyUrl.
	Root at: repoName asSymbol put: repo.
	persistRepository: repo.
	subjectInstance:: RepositorySubject onModel: repo.
	target isNil ifFalse: [
		(* Fire-and-forget clone. cloneFromRemote updates cloneStatus_slot
		   / cloneError_slot on the Repository (with safeErrorString:);
		   the presenter checks both and renders the right state. We use
		   `subjectInstance presenter updateGUI: []` (not
		   updateCurrentDisplay) because updateGUI: bumps uiGeneration,
		   which is what invalidates the cached presenter substance
		   downstream — updateCurrentDisplay alone just redraws the
		   cached substance and nothing changes. *)
		repo cloneFromRemote
			then: [:r |
				repo invalidateHistoryCache.
				repo history then: [:log |
					subjectInstance presenter refreshFromAsync. nil]]
			onRejected: [:err |
				subjectInstance presenter refreshFromAsync.
				nil]].
	^subjectInstance
)
) : (
)
public class RepositorySetupPresenter onSubject: s <RepositorySetupSubject>
	= ProgrammingPresenter onSubject: s (
|
nameEditor
namespaceEditor
remoteUrlEditor
defaultBranchEditor
corsProxyEditor
|
) (
public isKindOfRepositorySetupPresenter ^ <Boolean> = (^true)
isMyKind: f <Fragment> ^ <Boolean> = (
	^f isKindOfRepositorySetupPresenter
)
definition = (
	| rows |
	rows:: List new.
	rows add: helpSection.
	rows add: (majorHeadingBlock: (
		row: {
			(label: subject title) bold.
			filler.
			helpButton}));
		add: mediumBlank;
		add: (label: 'Register a new git repository. The repository is scoped by a Newspeak namespace: only the classes in that namespace are committed when you commit, and any commit you load will be installed into it. Multi-repo membership is achieved by having a class appear in multiple namespaces.');
		add: mediumBlank;
		add: (row: { (label: 'Name: ') bold. smallBlank. elastic: nameField. });
		add: mediumBlank;
		add: (row: { (label: 'Namespace: ') bold. smallBlank. elastic: namespaceField. });
		add: (row: {
			smallBlank.
			checkBoxFor: subject createNewNamespace.
			smallBlank.
			label: 'Create new namespace with this name'.
			filler});
		add: mediumBlank;
		add: (row: { (label: 'Remote URL: ') bold. smallBlank. elastic: remoteUrlField. });
		add: ((label: 'Leave blank for a local-only repository. HTTPS URLs require a CORS proxy.') italic);
		add: mediumBlank;
		add: (row: { (label: 'Default branch: ') bold. smallBlank. elastic: defaultBranchField. });
		add: mediumBlank;
		add: (row: { (label: 'CORS proxy: ') bold. smallBlank. elastic: corsProxyField. });
		add: ((label: 'Run python3 tool/cors-proxy.py to start the local CORS proxy on port 9999.') italic);
		add: mediumBlank;
		add: errorArea;
		add: (row: {
			filler.
			button: 'Create' action: [respondToCreate]}).
	^column: rows
)
nameField = (
	nameEditor:: codeMirror: subject repoName.
	nameEditor changeResponse: [:frag |
		subject repoName: frag textBeingAccepted].
	^nameEditor
)
namespaceField = (
	namespaceEditor:: codeMirror: subject namespaceKey.
	namespaceEditor changeResponse: [:frag |
		subject namespaceKey: frag textBeingAccepted].
	^namespaceEditor
)
remoteUrlField = (
	remoteUrlEditor:: codeMirror: subject remoteUrl.
	remoteUrlEditor changeResponse: [:frag |
		subject remoteUrl: frag textBeingAccepted].
	^remoteUrlEditor
)
defaultBranchField = (
	defaultBranchEditor:: codeMirror: subject defaultBranch.
	defaultBranchEditor changeResponse: [:frag |
		subject defaultBranch: frag textBeingAccepted].
	^defaultBranchEditor
)
corsProxyField = (
	corsProxyEditor:: codeMirror: subject corsProxyUrl.
	corsProxyEditor changeResponse: [:frag |
		subject corsProxyUrl: frag textBeingAccepted].
	^corsProxyEditor
)
checkBoxFor: flag <Boolean> = (
	(* Inline checkbox. Hopscotch doesn't expose a styled checkbox
	   composer, so we use a labeled button that flips the subject's
	   createNewNamespace flag and re-renders. *)
	^button: (subject createNewNamespace ifTrue: ['[x]'] ifFalse: ['[ ]'])
		action: [updateGUI: [
			subject createNewNamespace: subject createNewNamespace not]]
)
errorArea = (
	^subject errorMessage isEmpty
		ifTrue: [nothing]
		ifFalse: [(label: subject errorMessage) color: (Color r: 0.8 g: 0.1 b: 0.1)]
)
respondToCreate = (
	| newSubject |
	updateGUI: [
		(* Snap edited values back from the editors in case the user
		   didn't blur the field before clicking Create. *)
		nameEditor isNil ifFalse: [subject repoName: nameEditor textBeingAccepted].
		namespaceEditor isNil ifFalse: [subject namespaceKey: namespaceEditor textBeingAccepted].
		remoteUrlEditor isNil ifFalse: [subject remoteUrl: remoteUrlEditor textBeingAccepted].
		defaultBranchEditor isNil ifFalse: [subject defaultBranch: defaultBranchEditor textBeingAccepted].
		corsProxyEditor isNil ifFalse: [subject corsProxyUrl: corsProxyEditor textBeingAccepted].
		subject errorMessage: ''.
		newSubject:: subject submit.
		newSubject isNil ifFalse: [enterSubject:: newSubject]]
)
helpText = (
	^ampleforth: 'Repository setup form. The repository is keyed by Name (which will appear as an entry in Root). Namespace picks an existing namespace in Root to use as the repo''s scope; tick Create new namespace to create one with that name. Remote URL is optional (leave blank for a local-only repo).'
		mapping: Map new
)
) : (
)
public class RepositorySettingsSubject onRepository: r <Repository>
	= ProgrammingSubject onModel: r (
(* Edit form for the mutable settings of an existing Repository.
   Identity-shaped fields (name, store name) are not editable; only
   namespace, remote URL, default branch, and CORS proxy are.
   Saves update the repo in place and persist the change. *)
|
public namespaceKey <String> ::= ''.
public remoteUrl <String> ::= ''.
public defaultBranch <String> ::= ''.
public corsProxyUrl <String> ::= ''.
public errorMessage <String> ::= ''.
|
	(* Pre-fill from the live repository. *)
	namespaceKey:: r namespaceKey.
	remoteUrl:: r remoteUrl ifNil: [''].
	defaultBranch:: r defaultBranch.
	corsProxyUrl:: r corsProxyUrl ifNil: [''].
) (
public createPresenter ^ <Presenter> = (
	^RepositorySettingsPresenter onSubject: self
)
public repository ^ <Repository> = (^model)
public title ^ <String> = (^'Settings: ', model name asString)
public isKindOfRepositorySettingsSubject ^ <Boolean> = (^true)
isMyKind: s <Subject> ^ <Boolean> = (
	^s isKindOfRepositorySettingsSubject
)
public save ^ <RepositorySubject | Nil> = (
	(* Push the edited fields back onto the repository, persist, and
	   return a RepositorySubject for navigation back to the repo
	   presenter. On validation failure returns nil with errorMessage
	   set. *)
	defaultBranch isEmpty ifTrue: [
		errorMessage:: 'Default branch cannot be empty.'.
		^nil].
	namespaceKey isEmpty ifTrue: [
		errorMessage:: 'Namespace key cannot be empty.'.
		^nil].
	(namespaceKey = model namespaceKey) ifFalse: [
		((ide namespacing Root) includesKey: namespaceKey asSymbol) ifFalse: [
			errorMessage:: 'No namespace named ', namespaceKey, ' in Root.'.
			^nil].
		[model rebindToNamespaceKey: namespaceKey]
			on: Error
			do: [:e |
				errorMessage:: e messageText.
				^nil]].
	model remoteUrl: (remoteUrl isEmpty ifTrue: [nil] ifFalse: [remoteUrl]).
	model defaultBranch: defaultBranch.
	model corsProxyUrl: (corsProxyUrl isEmpty ifTrue: [nil] ifFalse: [corsProxyUrl]).
	ide repositories persistRepository: model.
	^RepositorySubject onModel: model
)
) : (
)
public class RepositorySettingsPresenter onSubject: s <RepositorySettingsSubject>
	= ProgrammingPresenter onSubject: s (
|
namespaceEditor
remoteUrlEditor
defaultBranchEditor
corsProxyEditor
|
) (
public isKindOfRepositorySettingsPresenter ^ <Boolean> = (^true)
isMyKind: f <Fragment> ^ <Boolean> = (
	^f isKindOfRepositorySettingsPresenter
)
definition = (
	| rows |
	rows:: List new.
	rows add: helpSection;
		add: (majorHeadingBlock: (
			row: {
				(label: subject title) bold.
				filler.
				helpButton.
				smallBlank.
				dropDownMenu: [settingsMenu]}));
		add: mediumBlank;
		add: (row: {
			(label: 'Name: ') bold.
			label: subject repository name asString.
			filler});
		add: ((label: 'Name cannot be edited — delete and recreate the repository to change it.') italic);
		add: mediumBlank;
		add: (row: { (label: 'Namespace: ') bold. smallBlank. elastic: namespaceField. });
		add: ((label: 'Existing Root key. First commit after a rebind re-syncs file preambles.') italic);
		add: mediumBlank;
		add: (row: { (label: 'Remote URL: ') bold. smallBlank. elastic: remoteUrlField. });
		add: ((label: 'Leave blank for a local-only repository.') italic);
		add: mediumBlank;
		add: (row: { (label: 'Default branch: ') bold. smallBlank. elastic: defaultBranchField. });
		add: mediumBlank;
		add: (row: { (label: 'CORS proxy: ') bold. smallBlank. elastic: corsProxyField. });
		add: mediumBlank;
		add: errorArea;
		add: (row: {
			filler.
			button: 'Cancel' action: [respondToCancel].
			smallBlank.
			button: 'Save' action: [respondToSave]}).
	^column: rows
)
settingsMenu = (
	^menuWithLabelsAndActions: {
		{'Inspect Presenter'. [respondToInspectPresenter]}}
)
namespaceField = (
	namespaceEditor:: codeMirror: subject namespaceKey.
	namespaceEditor changeResponse: [:frag |
		subject namespaceKey: frag textBeingAccepted].
	^namespaceEditor
)
remoteUrlField = (
	remoteUrlEditor:: codeMirror: subject remoteUrl.
	remoteUrlEditor changeResponse: [:frag |
		subject remoteUrl: frag textBeingAccepted].
	^remoteUrlEditor
)
defaultBranchField = (
	defaultBranchEditor:: codeMirror: subject defaultBranch.
	defaultBranchEditor changeResponse: [:frag |
		subject defaultBranch: frag textBeingAccepted].
	^defaultBranchEditor
)
corsProxyField = (
	corsProxyEditor:: codeMirror: subject corsProxyUrl.
	corsProxyEditor changeResponse: [:frag |
		subject corsProxyUrl: frag textBeingAccepted].
	^corsProxyEditor
)
errorArea = (
	^subject errorMessage isEmpty
		ifTrue: [nothing]
		ifFalse: [(label: subject errorMessage) color: (Color r: 0.8 g: 0.1 b: 0.1)]
)
respondToSave = (
	| newSubject |
	updateGUI: [
		(* Snap edited values back from the editors in case the user
		   didn't blur a field before clicking Save. *)
		namespaceEditor isNil ifFalse: [subject namespaceKey: namespaceEditor textBeingAccepted].
		remoteUrlEditor isNil ifFalse: [subject remoteUrl: remoteUrlEditor textBeingAccepted].
		defaultBranchEditor isNil ifFalse: [subject defaultBranch: defaultBranchEditor textBeingAccepted].
		corsProxyEditor isNil ifFalse: [subject corsProxyUrl: corsProxyEditor textBeingAccepted].
		subject errorMessage: ''.
		newSubject:: subject save.
		newSubject isNil ifFalse: [enterSubject:: newSubject]]
)
respondToCancel = (
	enterSubject:: RepositorySubject onModel: subject repository
)
helpText = (
	| mapping = Map new. |
	mapping
		at: #hopscotchHelpButton put: helpButton;
		at: #settingsMenuButton put: (dropDownMenu: [settingsMenu]).
	^ampleforth: 'Edit the mutable settings of this repository:
namespace, remote URL, default branch, CORS proxy. Saves update the
repository in place and persist the change to localStorage. Name and
storeName are identity fields and cannot be changed (delete and
recreate the repository to change them).
<br><br>
The header provides the following buttons:
<ul>
<li> <div class="hopscotchHelpButton"> </div> Shows this help message.</li>
<li> <div class="settingsMenuButton"> </div> Opens a menu of additional operations, such as inspecting this presenter.</li>
</ul>' mapping: mapping
)
) : (
)
public class ChangesetSubject onRepository: r <Repository> strategy: s <ApplyStrategy>
	= ProgrammingSubject onModel: nil (
(* Holds the state of a Changeset review session: the computed changeset,
   the user's draft commit message + author identity, expansion state for
   the diff tree, and submission-in-flight / error state. The strategy
   parameter is what drives Accept (currently always a RepoCommitStrategy
   pointing at the same repo; later it may be an install strategy, etc.). *)
|
	public repository = r.
	public strategy = s.
	changeset_slot.
	computeError_slot.
	public messageDraft <String> ::= ''.
	public authorNameDraft <String> ::= ''.
	public authorEmailDraft <String> ::= ''.
	public rememberAuthor <Boolean> ::= true.
	public submissionInFlight <Boolean> ::= false.
	submissionError_slot.
	expansion_slot.
	public editingAuthor <Boolean> ::= false.
|
	(* Prefill author drafts from the stored identity. If nothing stored,
	   start in editing-author mode so the user is prompted before
	   commit. *)
	authorNameDraft:: storedAuthorName ifNil: [''].
	authorEmailDraft:: storedAuthorEmail ifNil: [''].
	editingAuthor:: hasStoredAuthor not.
	expansion_slot:: Map new.
) (
public createPresenter ^ <Presenter> = (
	^ChangesetPresenter onSubject: self
)
public title ^ <String> = (
	^strategy actionLabel, ' to ', repository name asString
)
public isKindOfChangesetSubject ^ <Boolean> = (^true)
isMyKind: s <Subject> ^ <Boolean> = (^s isKindOfChangesetSubject)
public changeset = (^changeset_slot)
public computeError = (^computeError_slot)
public submissionError = (^submissionError_slot)
public toggleExpansion: key <String> = (
	expansion_slot at: key put: (expansion_slot at: key ifAbsent: [false]) not
)
public isExpanded: key <String> ^ <Boolean> = (
	^expansion_slot at: key ifAbsent: [false]
)
public computeAsync: refreshBlock <[]> = (
	(* Idempotent. First call kicks off computeChangesetFor:; subsequent
	   calls short-circuit. refreshBlock is the presenter's
	   refreshFromAsync hook, invoked when the changeset arrives (or
	   errors). Uses callback delivery to keep the resulting Newspeak
	   Map out of the JS Promise resolution boundary. *)
	changeset_slot isNil ifFalse: [^nil].
	computeError_slot isNil ifFalse: [^nil].
	computeChangesetFor: repository
		onComplete: [:cs |
			changeset_slot:: cs.
			refreshBlock value]
		onError: [:msg |
			computeError_slot:: msg.
			refreshBlock value]
)
public submit: refreshBlock <[]> = (
	(* Validate, then run the strategy's apply hook. refreshBlock bumps
	   the presenter on each state transition. On success the apply
	   hook returns a Promise that resolves to a SHA (or nil for
	   no-op); the dialog navigates back to the repo presenter. *)
	| input valid |
	submissionInFlight ifTrue: [^nil].
	submissionError_slot:: nil.
	input:: Map new
		at: #message put: messageDraft;
		at: #authorName put: authorNameDraft;
		at: #authorEmail put: authorEmailDraft;
		at: #rememberAuthor put: rememberAuthor;
		yourself.
	valid:: strategy validate: input onError: [:m |
		submissionError_slot:: m.
		refreshBlock value].
	valid ifFalse: [^nil].
	submissionInFlight:: true.
	refreshBlock value.
	(strategy apply: changeset_slot withInput: input)
		then: [:result |
			submissionInFlight:: false.
			refreshBlock value.
			nil]
		onRejected: [:e |
			| msg |
			msg:: [e messageText] on: Exception do: [:e2 | nil].
			msg isNil ifTrue: [msg:: e printString].
			submissionInFlight:: false.
			submissionError_slot:: 'Apply failed: ', msg.
			refreshBlock value.
			nil]
)
) : (
)
public class ChangesetPresenter onSubject: s <ChangesetSubject>
	= ProgrammingPresenter onSubject: s (
(* Renders a Changeset review session: header, summary, expandable
   diff tree, skipped list, commit message field, author area,
   Accept/Cancel. Strategy-driven action label. *)
|
	loadStarted_slot ::= false.
	messageEditor
	authorNameEditor
	authorEmailEditor
|
) (
public isKindOfChangesetPresenter ^ <Boolean> = (^true)
isMyKind: f <Fragment> ^ <Boolean> = (^f isKindOfChangesetPresenter)
public refreshFromAsync = (
	(* Bump uiGeneration so cached substance is invalidated and a fresh
	   definition runs against the latest subject state. *)
	updateGUI: []
)
updateVisualsFromSameKind: oldPresenter <Self> ^ <Alien> = (
	subject = oldPresenter subject ifFalse: [
		ensureSubstance.
		^replaceVisual: oldPresenter visual with: substance visual].
	substanceSlot:: nil.
	ensureSubstance.
	^super updateVisualsFromSameKind: oldPresenter
)
definition = (
	((subject changeset isNil)
		and: [(subject computeError isNil)
		and: [loadStarted_slot not]]) ifTrue: [
		loadStarted_slot:: true.
		subject computeAsync: [refreshFromAsync]].
	^column: {
		majorHeadingBlock: (
			row: {
				(label: subject title) bold.
				filler}).
		mediumBlank.
		bodyArea.
		mediumBlank.
		skippedArea.
		mediumBlank.
		outOfScopeArea.
		mediumBlank.
		messageArea.
		mediumBlank.
		authorArea.
		mediumBlank.
		errorArea.
		mediumBlank.
		buttonRow}
)
bodyArea = (
	subject computeError isNil ifFalse: [
		^(label: 'Failed to compute changeset: ', subject computeError)
			color: (Color r: 0.8 g: 0.1 b: 0.1)].
	subject changeset isNil ifTrue: [
		^label: 'Computing changeset...'].
	(subject changeset at: #classDiffs) isEmpty ifTrue: [
		^label: 'No changes to commit.'].
	^column: {
		(label: summaryLine) bold.
		smallBlank.
		classDiffsList}
)
summaryLine = (
	| diffs added changed skipped outOfScope |
	diffs:: subject changeset at: #classDiffs.
	skipped:: (subject changeset at: #skipped) size.
	outOfScope:: (subject changeset at: #outOfScope ifAbsent: [List new]) size.
	added:: 0. changed:: 0.
	diffs keysAndValuesDo: [:k :cd |
		(cd at: #status) = #new ifTrue: [added:: added + 1].
		(cd at: #status) = #changed ifTrue: [changed:: changed + 1]].
	^changed printString, ' changed | ',
		added printString, ' new | ',
		skipped printString, ' skipped | ',
		outOfScope printString, ' in HEAD but not in namespace'
)
classDiffsList = (
	| diffs toggles names |
	diffs:: subject changeset at: #classDiffs.
	names:: List new.
	diffs keysAndValuesDo: [:k :v | names add: k].
	(* Sort by class name for stable presentation. String `<` isn't
	   defined in this runtime; use Browsing Utilities' lexical
	   comparator. *)
	names:: names asArray sort: [:a :b |
		ide browsing Utilities
			lexicallyLessOrEqual: a asString
			than: b asString].
	toggles:: List new.
	names do: [:name |
		toggles add: (classToggleFor: name diff: (diffs at: name))].
	^zebra: (taggedColumn: toggles)
)
classToggleFor: name <Symbol> diff: cd <Map> = (
	| toggle status statusLabel |
	status:: cd at: #status.
	statusLabel:: status asString.
	toggle:: collapsed: [
			row: {
				(link: name asString action: [toggle expand])
					color: actionLinkColor.
				smallBlank.
				(label: '(', statusLabel, ')') italic.
				filler}]
		expanded: [
			column: {
				row: {
					(link: name asString action: [toggle collapse])
						color: actionLinkColor.
					smallBlank.
					(label: '(', statusLabel, ')') italic.
					filler}.
				smallBlank.
				classDiffDetailFor: cd classPath: name asString}]
		initiallyExpanded: false
		tag: name asString.
	^toggle
)
classDiffDetailFor: cd <Map> classPath: cpath <String> = (
	| status |
	status:: cd at: #status.
	status = #new ifTrue: [
		^(label: 'New class. Source will be committed.') italic].
	status = #removed ifTrue: [
		^(label: 'Removed from namespace. File will be deleted.') italic].
	status = #changed ifTrue: [
		^changedClassDetailFor: (cd at: #diff) classPath: cpath].
	^label: 'unknown status: ', status asString
)
changedClassDetailFor: diff <Map> classPath: cpath <String> = (
	(* Section order per Newspeak class-presenter convention: header,
	   lazy slots, nested classes, methods, class methods. *)
	| sections |
	sections:: List new.
	sections add: (headerSectionFor: diff classPath: cpath).
	sections add: (memberSectionToggleFor: 'lazy slots'
		kind: #lazySlots
		diff: (diff at: #lazySlots)
		classPath: cpath).
	sections add: (nestedSectionToggleFor: (diff at: #nestedClasses)
		classPath: cpath).
	sections add: (memberSectionToggleFor: 'methods'
		kind: #methods
		diff: (diff at: #methods)
		classPath: cpath).
	sections add: (memberSectionToggleFor: 'class methods'
		kind: #classMethods
		diff: (diff at: #classMethods)
		classPath: cpath).
	^column: sections
)
headerSectionFor: diff <Map> classPath: cpath <String> = (
	(diff at: #headerChanged) ifFalse: [
		^row: { (label: '  header: unchanged') italic. filler}].
	^expandableSection: 'header: changed'
		tag: cpath, '/header'
		bodyBlock: [
			sideBySideOld: (diff at: #oldHeader) new: (diff at: #newHeader)]
)
memberSectionToggleFor: sectionLabel <String> kind: kind <Symbol>
	diff: mDiff <Map> classPath: cpath <String> = (
	| added removed changed total summary sectionTag |
	added:: (mDiff at: #added) size.
	removed:: (mDiff at: #removed) size.
	changed:: (mDiff at: #changed) size.
	total:: added + removed + changed.
	total = 0 ifTrue: [
		^row: { (label: '  ', sectionLabel, ': unchanged') italic. filler}].
	summary:: sectionLabel, ': ', changed printString, ' changed, ',
		added printString, ' added, ', removed printString, ' removed'.
	sectionTag:: cpath, '/', kind asString.
	^expandableSection: summary
		tag: sectionTag
		bodyBlock: [memberRowsFor: mDiff classPath: sectionTag]
)
nestedSectionToggleFor: nDiff <Map> classPath: cpath <String> = (
	| sectionTag |
	nDiff isEmpty ifTrue: [
		^row: { (label: '  nested classes: unchanged') italic. filler}].
	sectionTag:: cpath, '/nestedClasses'.
	^expandableSection: 'nested classes: ', nDiff size printString, ' affected'
		tag: sectionTag
		bodyBlock: [nestedRowsFor: nDiff classPath: sectionTag]
)
expandableSection: summary <String> tag: tag <String> bodyBlock: bodyBlock <[]> = (
	| toggle |
	toggle:: collapsed: [
			row: {
				(link: '  ', summary action: [toggle expand]) color: actionLinkColor.
				filler}]
		expanded: [
			column: {
				row: {
					(link: '  ', summary action: [toggle collapse]) color: actionLinkColor.
					filler}.
				bodyBlock value}]
		initiallyExpanded: false
		tag: tag.
	^toggle
)
memberRowsFor: mDiff <Map> classPath: cpath <String> = (
	| toggles |
	toggles:: List new.
	(mDiff at: #added) do: [:m |
		toggles add: (memberToggle: m sign: '+'
			label: 'New source' isChange: false classPath: cpath)].
	(mDiff at: #removed) do: [:m |
		toggles add: (memberToggle: m sign: '-'
			label: 'Removed source' isChange: false classPath: cpath)].
	(mDiff at: #changed) do: [:m |
		toggles add: (memberToggle: m sign: '~'
			label: nil isChange: true classPath: cpath)].
	^taggedColumn: toggles
)
memberToggle: m <Map> sign: sign <String> label: lbl <String | Nil>
	isChange: isChange <Boolean> classPath: cpath <String> = (
	| toggle name tag display |
	name:: m at: #name.
	tag:: cpath, '/', sign, name asString.
	display:: '    ', sign, ' ', name asString.
	toggle:: collapsed: [
			row: {
				(link: display action: [toggle expand]) color: actionLinkColor.
				filler}]
		expanded: [
			column: {
				row: {
					(link: display action: [toggle collapse]) color: actionLinkColor.
					filler}.
				isChange
					ifTrue: [sideBySideOld: (m at: #oldSource) new: (m at: #newSource)]
					ifFalse: [singlePaneSource: (m at: #source) label: lbl]}]
		initiallyExpanded: false
		tag: tag.
	^toggle
)
nestedRowsFor: nDiff <Map> classPath: cpath <String> = (
	| toggles |
	toggles:: List new.
	nDiff keysAndValuesDo: [:name :entry |
		toggles add: (nestedToggleFor: name entry: entry classPath: cpath)].
	^taggedColumn: toggles
)
nestedToggleFor: name <Symbol> entry: cd <Map> classPath: cpath <String> = (
	| toggle tag status display |
	tag:: cpath, '/', name asString.
	status:: cd at: #status ifAbsent: [#changed].
	status = #added ifTrue: [
		display:: '    + ', name asString, ' (new nested class)'.
		^row: { (label: display) italic. filler}].
	status = #removed ifTrue: [
		display:: '    - ', name asString, ' (removed nested class)'.
		^row: { (label: display) italic. filler}].
	display:: '    ~ ', name asString.
	toggle:: collapsed: [
			row: {
				(link: display action: [toggle expand]) color: actionLinkColor.
				filler}]
		expanded: [
			column: {
				row: {
					(link: display action: [toggle collapse]) color: actionLinkColor.
					filler}.
				changedClassDetailFor: cd classPath: tag}]
		initiallyExpanded: false
		tag: tag.
	^toggle
)
singlePaneSource: src <String> label: lbl <String> = (
	| cm |
	cm:: codeMirror: src.
	cm readOnly: true.
	^column: { (label: lbl) italic. cm}
)
sideBySideOld: oldSrc <String> new: newSrc <String> = (
	| oldCm newCm |
	oldCm:: codeMirror: oldSrc.
	oldCm readOnly: true.
	newCm:: codeMirror: newSrc.
	newCm readOnly: true.
	^row: {
		column: { (label: 'Old (HEAD)') italic. oldCm}.
		smallBlank.
		column: { (label: 'New (live)') italic. newCm}}
)
skippedArea = (
	| skipped rows |
	subject changeset isNil ifTrue: [^nothing].
	skipped:: subject changeset at: #skipped.
	skipped isEmpty ifTrue: [^nothing].
	rows:: List new.
	rows add: ((label: 'Skipped non-class entries (', skipped size printString, '):') bold).
	skipped do: [:s |
		rows add: (row: { label: '  - ', s. filler})].
	^column: rows
)
outOfScopeArea = (
	| oos rows |
	subject changeset isNil ifTrue: [^nothing].
	oos:: subject changeset at: #outOfScope ifAbsent: [List new].
	oos isEmpty ifTrue: [^nothing].
	rows:: List new.
	rows add: ((label: 'In HEAD but not in this namespace (', oos size printString, '): left untouched by this commit') bold).
	oos do: [:name |
		rows add: (row: { label: '  - ', name. filler})].
	^column: rows
)
messageArea = (
	subject strategy requiresMessage ifFalse: [^nothing].
	messageEditor:: codeMirror: subject messageDraft.
	messageEditor changeResponse: [:frag |
		subject messageDraft: frag textBeingAccepted].
	^column: {
		(label: subject strategy messagePrompt, ' *') bold.
		messageEditor}
)
authorArea = (
	subject strategy requiresAuthor ifFalse: [^nothing].
	subject editingAuthor ifTrue: [^authorEditForm].
	^row: {
		(label: 'Author: ') bold.
		label: subject authorNameDraft, ' <', subject authorEmailDraft, '>'.
		smallBlank.
		button: 'Edit' action: [updateGUI: [subject editingAuthor: true]].
		filler}
)
authorEditForm = (
	authorNameEditor:: codeMirror: subject authorNameDraft.
	authorNameEditor changeResponse: [:frag |
		subject authorNameDraft: frag textBeingAccepted].
	authorEmailEditor:: codeMirror: subject authorEmailDraft.
	authorEmailEditor changeResponse: [:frag |
		subject authorEmailDraft: frag textBeingAccepted].
	^column: {
		(label: 'Author identity') bold.
		row: { (label: '  Name: ') bold. smallBlank. elastic: authorNameEditor }.
		row: { (label: '  Email: ') bold. smallBlank. elastic: authorEmailEditor }.
		row: {
			button: (subject rememberAuthor ifTrue: ['[x]'] ifFalse: ['[ ]'])
				action: [updateGUI: [
					subject rememberAuthor: subject rememberAuthor not]].
			smallBlank.
			label: 'Remember for future commits'.
			filler}}
)
errorArea = (
	subject submissionError isNil ifTrue: [^nothing].
	^(label: subject submissionError) color: (Color r: 0.8 g: 0.1 b: 0.1)
)
buttonRow = (
	| canSubmit |
	canSubmit:: subject submissionInFlight not
		and: [subject changeset isNil not
		and: [(subject changeset at: #classDiffs) isEmpty not]].
	^row: {
		filler.
		button: 'Cancel' action: [respondToCancel].
		smallBlank.
		canSubmit
			ifTrue: [button: subject strategy actionLabel action: [respondToAccept]]
			ifFalse: [(label: subject strategy actionLabel) italic]}
)
respondToCancel = (
	enterSubject:: RepositorySubject onModel: subject repository
)
respondToAccept = (
	(* Snap form values back from editors in case the user didn't blur. *)
	updateGUI: [
		messageEditor isNil ifFalse: [
			subject messageDraft: messageEditor textBeingAccepted].
		authorNameEditor isNil ifFalse: [
			subject authorNameDraft: authorNameEditor textBeingAccepted].
		authorEmailEditor isNil ifFalse: [
			subject authorEmailDraft: authorEmailEditor textBeingAccepted].
		subject submit: [refreshFromAsync]]
)
) : (
)
class PerMemberMirrorReader onMirror: m <ClassDeclarationMirror> = (
(* Walks a live ClassDeclarationMirror and returns the same per-member
   source map shape as PerMemberExtractor. The "live" half of any diff
   over a Newspeak class. *)
|
	mirror <ClassDeclarationMirror> = m.
|
) (
public extract ^ <Map[Symbol, Object]> = (
	^extractMirror: mirror
)
extractMirror: cdm <ClassDeclarationMirror> ^ <Map[Symbol, Object]> = (
	| result methods classMethods lazies nested |
	result:: Map new.
	result at: #name put: cdm name.
	result at: #header put: cdm header source.

	methods:: Map new.
	cdm instanceSide methods do: [:m |
		methods at: m name put: m source].
	result at: #methods put: methods.

	lazies:: Map new.
	cdm instanceSide lazySlots do: [:ls |
		lazies at: ls name put: ls source].
	result at: #lazySlots put: lazies.

	classMethods:: Map new.
	cdm classSide methods do: [:m |
		classMethods at: m name put: m source].
	result at: #classMethods put: classMethods.

	nested:: Map new.
	cdm instanceSide nestedClasses do: [:nc |
		nested at: nc name put: (extractMirror: nc)].
	result at: #nestedClasses put: nested.

	^result
)
) : (
)
public class ApplyStrategy = (
(* Abstract base for "what happens when the user accepts a Changeset."
   Concretes: RepoCommitStrategy for repository commits. Future:
   InstallToNamespaceStrategy for AI-proposal review,
   StagedEditorsApplyStrategy for atomic install of unaccepted
   editors. The dialog (ChangesetPresenter) renders the same way
   regardless of strategy; the strategy supplies the action label,
   message-field config, validation, and apply hook. *)
) (
public actionLabel ^ <String> = (subclassResponsibility)
public requiresMessage ^ <Boolean> = (subclassResponsibility)
public messagePrompt ^ <String> = (^'Message')
public requiresAuthor ^ <Boolean> = (^false)
public validate: input <Map[Symbol, Object]> onError: errBlock <[:String]> ^ <Boolean> = (
	(* Default: no validation. Subclasses override; on first error,
	   call errBlock with the message string and return false. *)
	^true
)
public apply: changeset <Map[Symbol, Object]> withInput: input <Map[Symbol, Object]> ^ <Alien> = (
	subclassResponsibility
)
) : (
)
public class RepoCommitStrategy onRepository: r <Repository> = ApplyStrategy (
(* Repository-commit apply strategy. Validates message + author, then
   on apply: writes author to the repo, stages every snapshot file,
   commits with the message. Resolves to the new commit SHA, or nil
   if there was nothing to commit. *)
|
	public repository = r.
|
) (
public actionLabel = (^'Commit')
public requiresMessage = (^true)
public messagePrompt = (^'Commit message')
public requiresAuthor = (^true)
public validate: input onError: errBlock = (
	| msg name email |
	msg:: input at: #message ifAbsent: [''].
	msg isEmpty ifTrue: [errBlock value: 'Commit message is required'. ^false].
	name:: input at: #authorName ifAbsent: [''].
	name isEmpty ifTrue: [errBlock value: 'Author name is required'. ^false].
	email:: input at: #authorEmail ifAbsent: [''].
	email isEmpty ifTrue: [errBlock value: 'Author email is required'. ^false].
	^true
)
public apply: changeset withInput: input = (
	| message name email authorObj |
	message:: input at: #message.
	name:: input at: #authorName.
	email:: input at: #authorEmail.
	(input at: #rememberAuthor ifAbsent: [false]) ifTrue: [
		saveAuthorName: name email: email].
	authorObj:: JSON parse: '{}'.
	authorObj at: 'name' put: name.
	authorObj at: 'email' put: email.
	repository author: authorObj.
	^repository commitSnapshot: (changeset at: #files) message: message
)
) : (
)
lazy public LightningFSClass = global at: #LightningFS.
lazy public gitFacade = global at: #git.
lazy public gitHttpFacade = global at: #GitHttp.
public liveSnapshotOf: aClass <Behavior> ^ <Map[Symbol, Object]> = (
	(* Per-member map for a live class, same shape as
	   PerMemberExtractor produces from a parsed .ns source. *)
	^(PerMemberMirrorReader onMirror:
		(ClassMirror reflecting: aClass) mixin declaration) extract
)
public extractedSnapshotFromSource: src <String> ^ <Map[Symbol, Object]> = (
	(* Parse a conventional .ns source string and return the per-member
	   map. Routes through ClassDeclarationBuilder fromUnitSource: --
	   the same path Browsing's Compile File menu uses -- which calls
	   the platform compiler's predictive parser internally (not the
	   combinatorial NewspeakParsing parser, which has divergent grammar
	   behavior on some forms; see VCSIsomorphicGitBackendProvider /
	   nested DraftsRepo round-trip failure). The resulting builder is
	   API-compatible with ClassDeclarationMirror per HopscotchWebIDE
	   walkClassDecl:intoPath:files: comment at line 360, so
	   PerMemberMirrorReader walks either kind interchangeably. *)
	| builder |
	builder:: ClassDeclarationBuilder fromUnitSource: src.
	^(PerMemberMirrorReader onMirror: builder) extract
)
public diffSnapshot: oldSnap <Map> to: newSnap <Map> ^ <Map[Symbol, Object]> = (
	(* Pure: produce a per-member diff between two snapshots.
	   Result map keys:
	     #name           -> Symbol
	     #headerChanged  -> Boolean
	     #oldHeader      -> String (preserved both ways for the diff view)
	     #newHeader      -> String
	     #methods        -> {#added, #removed, #changed}
	     #classMethods   -> same
	     #lazySlots      -> same
	     #nestedClasses  -> Map[Symbol, {#status: #added | #removed | (recursive diff)}]
	   #added / #removed entries:  {#name, #source}
	   #changed entries:           {#name, #oldSource, #newSource} *)
	| result |
	result:: Map new.
	result at: #name put: (newSnap at: #name).
	result at: #headerChanged put: ((oldSnap at: #header) = (newSnap at: #header)) not.
	result at: #oldHeader put: (oldSnap at: #header).
	result at: #newHeader put: (newSnap at: #header).
	result at: #methods put:
		(diffMembers: (oldSnap at: #methods) to: (newSnap at: #methods)).
	result at: #lazySlots put:
		(diffMembers: (oldSnap at: #lazySlots) to: (newSnap at: #lazySlots)).
	result at: #classMethods put:
		(diffMembers: (oldSnap at: #classMethods) to: (newSnap at: #classMethods)).
	result at: #nestedClasses put:
		(diffNested: (oldSnap at: #nestedClasses) to: (newSnap at: #nestedClasses)).
	^result
)
diffMembers: oldMap <Map> to: newMap <Map> ^ <Map[Symbol, Object]> = (
	| added removed changed allNames |
	added:: List new.
	removed:: List new.
	changed:: List new.
	allNames:: Set new.
	oldMap keysAndValuesDo: [:k :v | allNames add: k].
	newMap keysAndValuesDo: [:k :v | allNames add: k].
	allNames do: [:name |
		(oldMap includesKey: name) ifTrue: [
			(newMap includesKey: name) ifTrue: [
				| o n |
				o:: oldMap at: name.
				n:: newMap at: name.
				o = n ifFalse: [
					changed add: (Map new
						at: #name put: name;
						at: #oldSource put: o;
						at: #newSource put: n;
						yourself)]]
			ifFalse: [
				removed add: (Map new
					at: #name put: name;
					at: #source put: (oldMap at: name);
					yourself)]]
		ifFalse: [
			added add: (Map new
				at: #name put: name;
				at: #source put: (newMap at: name);
				yourself)]].
	^Map new
		at: #added put: added;
		at: #removed put: removed;
		at: #changed put: changed;
		yourself
)
diffNested: oldNested <Map> to: newNested <Map> ^ <Map[Symbol, Object]> = (
	| result allNames |
	result:: Map new.
	allNames:: Set new.
	oldNested keysAndValuesDo: [:k :v | allNames add: k].
	newNested keysAndValuesDo: [:k :v | allNames add: k].
	allNames do: [:name |
		(oldNested includesKey: name) ifTrue: [
			(newNested includesKey: name) ifTrue: [
				| sub |
				sub:: diffSnapshot: (oldNested at: name)
					to: (newNested at: name).
				(* Only include nested-class entries with actual
				   differences. *)
				(diffIsEmpty: sub) ifFalse: [
					result at: name put: sub]]
			ifFalse: [
				result at: name put: (Map new
					at: #status put: #removed;
					at: #snapshot put: (oldNested at: name);
					yourself)]]
		ifFalse: [
			result at: name put: (Map new
				at: #status put: #added;
				at: #snapshot put: (newNested at: name);
				yourself)]].
	^result
)
public computeChangesetFor: repo <Repository>
	onComplete: doneBlock <[:Map[Symbol, Object]]>
	onError: errBlock <[:String]> = (
	(* Asynchronously compute a Changeset map and invoke doneBlock with
	   it. Callback-style on purpose: a Newspeak Map can't survive
	   resolving a JS Promise with it (rawPush fails on the eventual
	   Symbol key lookup `at: #classDiffs`), so we deliver the result
	   via a continuation block called from inside the .then: handler
	   while still in Newspeak land.

	   Changeset map keys:
	     #classDiffs -> Map[Symbol, ClassDiff]
	     #skipped    -> List[String]
	     #files      -> Map[String, String]  (snapshot, ready to stage)
	   ClassDiff variants:
	     {#status: #new,      #liveSnapshot: ...}
	     {#status: #removed,  #headSnapshot: ...}
	     {#status: #changed,  #diff: PerMemberDiff,
	                          #headSnapshot: ..., #liveSnapshot: ...}
	   Classes whose live source matches HEAD verbatim are omitted from
	   classDiffs entirely. *)
	| snap files skipped |
	snap:: repo snapshotFiles.
	files:: snap at: #files.
	skipped:: snap at: #skipped.
	(repo readHEADTextFiles)
		then: [:headFilesJS |
			| headFiles classDiffs result outOfScope |
			(* Scope HEAD to top-level <Class>.ns files only -- subdirectory
			   files (e.g. out, tool) and non-.ns files (README, LICENSE,
			   .gitignore) are not part of the namespace-scoped commit
			   surface. *)
			headFiles:: filterTopLevelNsFiles: (jsObjectToMap: headFilesJS).
			classDiffs:: Map new.
		(* Walk every live class. *)
		files keysAndValuesDo: [:path :liveSrc |
			| className headSrc |
			className:: classNameFromFilename: path.
			headSrc:: headFiles at: path ifAbsent: [nil].
			headSrc isNil
				ifTrue: [
					(* New class: not in HEAD. *)
					classDiffs at: className put: (Map new
						at: #status put: #new;
						at: #liveSnapshot put:
							(liveSnapshotOf: (repo namespace at: className));
						yourself)]
				ifFalse: [
					(* Both sides have it. Diff iff content differs at
					   the source-string level; THEN also iff the parsed
					   per-member structure actually has differences --
					   format-only changes (whitespace, trailing blanks,
					   comment positions) collapse to an empty per-member
					   diff and would be misleading noise in the dialog. *)
					headSrc = liveSrc ifFalse: [
						| headSnap liveSnap diff |
						headSnap:: extractedSnapshotFromSource: headSrc.
						liveSnap:: liveSnapshotOf: (repo namespace at: className).
						diff:: diffSnapshot: headSnap to: liveSnap.
						(diffIsEmpty: diff) ifFalse: [
							classDiffs at: className put: (Map new
								at: #status put: #changed;
								at: #diff put: diff;
								at: #headSnapshot put: headSnap;
								at: #liveSnapshot put: liveSnap;
								yourself)]]]].
		(* Walk HEAD for "out of scope" classes: top-level <X>.ns files
		   that AREN'T in this namespace's snapshot. These are not
		   "removed" from the commit's perspective -- the repo holds
		   the union of every namespace that touches it, and we don't
		   yet have a per-namespace ownership manifest to disambiguate.
		   We surface them as an informational list so the user can
		   see what else lives in the repo at HEAD; the commit step
		   leaves them untouched. *)
		outOfScope:: List new.
		headFiles keysAndValuesDo: [:path :headSrc |
			(files includesKey: path) ifFalse: [
				outOfScope add: (classNameFromFilename: path) asString]].
		result:: Map new
			at: #classDiffs put: classDiffs;
			at: #skipped put: skipped;
			at: #outOfScope put: outOfScope;
			at: #files put: files;
			yourself.
		(* Hand the Newspeak Map directly to the continuation block;
		   do NOT resolve the Promise with it (would force the Map
		   across the JS bridge and corrupt subsequent at:/isEmpty
		   calls on it). *)
		doneBlock value: result.
		nil]
	onRejected: [:e |
		| msg |
		msg:: [e messageText] on: Exception do: [:e2 | nil].
		msg isNil ifTrue: [msg:: e printString].
		errBlock value: msg.
		nil]
)
isTopLevelNsFile: path <String> ^ <Boolean> = (
	(* True iff path looks like a top-level Newspeak class file:
	   ends in '.ns' and contains no path separator. The user-visible
	   commit scope is exactly the namespace's top-level <Class>.ns
	   files; subdirectory .ns files (out/, tool/, tests/...) and
	   non-.ns files (README, LICENSE, .gitignore, ...) are out of
	   scope and must not be touched by stage/commit. *)
	^(path endsWith: '.ns') and: [(path indexOf: '/') = 0]
)
filterTopLevelNsFiles: hf <Map[String, String]> ^ <Map[String, String]> = (
	| result |
	result:: Map new.
	hf keysAndValuesDo: [:path :content |
		(isTopLevelNsFile: path) ifTrue: [
			result at: path put: content]].
	^result
)
jsObjectToMap: jsObj <Alien> ^ <Map[String, Object]> = (
	(* Convert a plain JS object (alien) to a Newspeak Map by iterating
	   its own enumerable keys via Object.keys. Used to bring Promise-
	   chained JS state back into Newspeak Map land. *)
	| Object keys result |
	Object:: global at: #Object.
	keys:: Object keys: jsObj.
	result:: Map new.
	0 to: (keys at: 'length') - 1 do: [:i |
		| k |
		k:: keys at: i.
		result at: k put: (jsObj at: k)].
	^result
)
public diffIsEmpty: diff <Map> ^ <Boolean> = (
	(* True iff a PerMemberDiff has no actual member-level changes.
	   Used to suppress classes (and nested classes) whose snapshot
	   source string differs from HEAD only by reformatting -- the
	   per-member extraction collapses those down to identical-source
	   member maps, so the diff is empty. We don't want the dialog to
	   list a class as "changed" if there's nothing to show on
	   drill-down. *)
	(diff at: #headerChanged) ifTrue: [^false].
	(memberDiffIsEmpty: (diff at: #methods)) ifFalse: [^false].
	(memberDiffIsEmpty: (diff at: #lazySlots)) ifFalse: [^false].
	(memberDiffIsEmpty: (diff at: #classMethods)) ifFalse: [^false].
	(diff at: #nestedClasses) keysAndValuesDo: [:k :nested |
		(nested at: #status ifAbsent: [nil]) isNil
			ifTrue: [(diffIsEmpty: nested) ifFalse: [^false]]
			ifFalse: [^false]].
	^true
)
public memberDiffIsEmpty: mDiff <Map> ^ <Boolean> = (
	^(mDiff at: #added) isEmpty
		and: [(mDiff at: #removed) isEmpty
		and: [(mDiff at: #changed) isEmpty]]
)
classNameFromFilename: path <String> ^ <Symbol> = (
	(* 'Browsing.ns' -> #Browsing. The snapshot only emits top-level
	   '<ClassName>.ns'; nested classes are inline in the parent file
	   so no path-segment splitting needed here. *)
	((path endsWith: '.ns'))
		ifTrue: [^(path copyFrom: 1 to: path size - 3) asSymbol]
		ifFalse: [^path asSymbol]
)
public storedAuthor ^ <Alien | Nil> = (
	(* Pull the user's commit identity from localStorage. Returns a JS
	   {name, email} object on success, nil if not configured or
	   parse-failed. Shared across every Repository. *)
	| raw |
	raw:: [localStorage getItem: authorStorageKey]
		on: Exception do: [:e | nil].
	(raw isNil or: [raw isKindOfString not]) ifTrue: [^nil].
	^[JSON parse: raw] on: Exception do: [:e | nil]
)
public storedAuthorName ^ <String | Nil> = (
	| a |
	a:: storedAuthor.
	a isNil ifTrue: [^nil].
	^a at: 'name'
)
public storedAuthorEmail ^ <String | Nil> = (
	| a |
	a:: storedAuthor.
	a isNil ifTrue: [^nil].
	^a at: 'email'
)
public hasStoredAuthor ^ <Boolean> = (
	| a |
	a:: storedAuthor.
	a isNil ifTrue: [^false].
	((a at: 'name') isNil or: [(a at: 'email') isNil]) ifTrue: [^false].
	^((a at: 'name') isEmpty) not and: [((a at: 'email') isEmpty) not]
)
public saveAuthorName: name <String> email: email <String> = (
	(* Persist a {name, email} JS object under ns_vcs_author so every
	   Repository's commits use the same identity. *)
	| obj |
	obj:: JSON parse: '{}'.
	obj at: 'name' put: name.
	obj at: 'email' put: email.
	[localStorage setItem: authorStorageKey to: (JSON stringify: obj)]
		on: Exception do: [:e | ]
)
public list ^ <RepositoryListSubject> = (
	(* Convenience entry point: ide repositories list returns a Subject
	   you can hand to ide browsing navigateTo:. Equivalent to
	   `RepositoryListSubject new`. *)
	^RepositoryListSubject new
)
public setup ^ <RepositorySetupSubject> = (
	(* Convenience entry point for `ide repositories setup`: opens the
	   New Repository form. Equivalent to `RepositorySetupSubject new`. *)
	^RepositorySetupSubject new
)
loadPersistedConfigs ^ <Alien | Nil> = (
	(* Returns a JS array of {name, namespaceKey, storeName, remoteUrl,
	   defaultBranch, corsProxyUrl} objects parsed from localStorage, or
	   nil if no entry exists / parsing failed. *)
	| raw |
	raw:: [localStorage getItem: repoConfigsKey]
		on: Exception do: [:e | nil].
	(raw isNil or: [raw isKindOfString not]) ifTrue: [^nil].
	^[JSON parse: raw] on: Exception do: [:e | nil]
)
savePersistedConfigs: jsArr <Alien> = (
	(* Stringify and write a JS array of configs back to localStorage. *)
	| str |
	str:: JSON stringify: jsArr.
	[localStorage setItem: repoConfigsKey to: str]
		on: Exception do: [:e | ]
)
configFromRepository: repo <Repository> ^ <Alien> = (
	(* Build a JS object of the repo's persisted fields. *)
	| cfg |
	cfg:: JSON parse: '{}'.
	cfg at: 'name' put: repo name asString.
	cfg at: 'namespaceKey' put: repo namespaceKey.
	cfg at: 'storeName' put: repo localStoreName.
	cfg at: 'remoteUrl' put: (repo remoteUrl ifNil: ['']).
	cfg at: 'defaultBranch' put: repo defaultBranch.
	cfg at: 'corsProxyUrl' put: (repo corsProxyUrl ifNil: ['']).
	^cfg
)
public persistRepository: repo <Repository> = (
	(* Append or replace the repo's config in the persisted list, keyed
	   by name. *)
	| existing newArr len i cfg keptOne replaced |
	existing:: loadPersistedConfigs.
	newArr:: JSON parse: '[]'.
	replaced:: false.
	existing isNil ifFalse: [
		len:: existing at: 'length'.
		i:: 0.
		[i < len] whileTrue: [
			keptOne:: existing at: i.
			(keptOne at: 'name') = repo name asString
				ifTrue: [
					newArr push: (configFromRepository: repo).
					replaced:: true]
				ifFalse: [newArr push: keptOne].
			i:: i + 1]].
	replaced ifFalse: [newArr push: (configFromRepository: repo)].
	savePersistedConfigs: newArr
)
public unpersistRepositoryNamed: name <Symbol | String> = (
	(* Drop the named repo's config from the persisted list. No-op if
	   absent. *)
	| existing newArr len i keptOne nameStr |
	existing:: loadPersistedConfigs.
	existing isNil ifTrue: [^self].
	nameStr:: name asString.
	newArr:: JSON parse: '[]'.
	len:: existing at: 'length'.
	i:: 0.
	[i < len] whileTrue: [
		keptOne:: existing at: i.
		(keptOne at: 'name') = nameStr ifFalse: [newArr push: keptOne].
		i:: i + 1].
	savePersistedConfigs: newArr
)
public repositoriesForNamespaceKey: key <String> ^ <List[Repository]> = (
	(* Reverse lookup: every Repository registered in Root whose
	   namespaceKey matches `key`. Used by Browsing's NamespacePresenter
	   to render "Repository:" link rows so the namespace ↔ repo
	   relationship is discoverable from both sides. Multiple
	   repositories may target the same namespace (e.g. one user-
	   visible mirror + a backup clone with a different remote);
	   the list may be empty if nothing targets this key. *)
	| result |
	result:: List new.
	Root keysAndValuesDo: [:k :v |
		v isKindOfRepository
			ifTrue: [v namespaceKey = key ifTrue: [result add: v]]].
	^result
)
public restorePersistedRepositories = (
	(* Called from HopscotchWebIDE's constructor body after seeding so
	   bootstrap namespaces (Newspeak, PrimordialSoup) are fully
	   populated by the time we look them up. Pulls saved configs out
	   of localStorage and reconstructs Repository instances,
	   registering each in Root. If the repo's namespaceKey points at
	   an absent key, a fresh empty namespace is created with that key
	   (a legitimate case: the user previously bound a repo to a
	   namespace they've since removed -- this restores the binding).
	   Errors are swallowed per-entry: one bad config shouldn't
	   prevent the rest from restoring. *)
	
	| configs len i cfg name namespaceKey ns repo |
	configs:: loadPersistedConfigs.
	configs isNil ifTrue: [ ^self ].
	len:: configs at: 'length'.
	i:: 0.
	[ i < len ] whileTrue: [
			cfg:: configs at: i.
			[
				name:: cfg at: 'name'.
				namespaceKey:: cfg at: 'namespaceKey'.
				(Root includesKey: name asSymbol) ifTrue: [ (* Already restored or shadowed — skip. *) ]
					ifFalse: [
						ns:: namespaceKey = 'Root' ifTrue: [ Root ]
							ifFalse: [
								Root at: namespaceKey asSymbol
									ifAbsent: [
										| fresh |
										fresh:: ide namespacing freshNamespace.
										Root at: namespaceKey asSymbol put: fresh.
										fresh
									]
							].
						repo:: Repository named: name asSymbol
							namespaceKey: namespaceKey
							namespace: ns
							remoteUrl: ((cfg at: 'remoteUrl') isEmpty ifTrue: [ nil ]
								ifFalse: [ cfg at: 'remoteUrl' ])
							storeNamed: (cfg at: 'storeName')
							defaultBranch: (cfg at: 'defaultBranch')
							corsProxyUrl: ((cfg at: 'corsProxyUrl') isEmpty ifTrue: [ nil ]
								ifFalse: [ cfg at: 'corsProxyUrl' ]).
						
						(* Deliberately leave cloneStatus_slot nil on restored
					   repos. The presenter shows an explicit "Load
					   history" button instead of auto-firing git.log,
					   because a corrupt IDB state can put isomorphic-git
					   into a sync CPU loop that the browser cannot
					   recover from (no setTimeout fires while the main
					   thread is hung). The user opts in to loading; if
					   the repo is bad they can recover via the per-row
					   Delete on the list page. *)
						Root at: name asSymbol put: repo
					]
			] on: Exception
				do: [:e |
					('Repositories: failed to restore config #' , i printString , ': ' , e messageText) out
				].
			i:: i + 1
		]
)
) : (
)
