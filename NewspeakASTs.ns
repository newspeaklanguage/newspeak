	public class MessageAST new = AST new (
		|
			public selector <Symbol>
			public arguments <List[ExpressionAST]>
			public isEventual <Boolean> ::= false.
			
			(* Explicit value-site type arguments, e.g. the [Integer] in `Box[Integer] new`.
	   nil = none supplied; otherwise a List[TypeAST]. See GENERIC_METHODS_INFERENCE_SPEC.md. *)
			public typeArguments
		|
	) (
		public apply: tool <ASTTool[T]> ^<T> = (
			^tool messageNode: self
