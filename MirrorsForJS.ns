			(* The selectors of every send in the method, decoded from its V5 bytecode record (psoup MethodMirror parity; drives senders). Methods without a record - JS-only bodies, images predating dual emission, reflectively edited classes - answer the empty list. *)

			| record |
			nil = simulation ifTrue: [ ^List new ].
			record:: bytecodeRecord.
			nil = record ifTrue: [ ^List new ].
			^(simulation SelectorCollector overBytecode: (record at: 1)
				literals: (record at: 2)) selectors
