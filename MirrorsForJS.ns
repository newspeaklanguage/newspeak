		originalHeaderSource ^<String> = (
			^prvtIR headerSource
		)
		public name ^<Symbol> = (
			^compilation names fullyQualifiedNameToSimple: qualifiedName
		)
	) : ()
	class MethodBuilder reflecting: mir in: mb source: s = Object new (
		|
			reflecteeX <IntermediateMethod> = mir.
			definingMixinX <MixinBuilder> = mb.
			public source <String> = s.
		|
	) (
		public accessModifier = (
			^reflecteeX accessModifier
		)
		public definingMixin ^<MixinBuilder> = (
			^definingMixinX
		)
		public name ^<Symbol> = (
			^reflecteeX name
		)
		public simpleName ^<Symbol> = (
			^reflecteeX name
		)
	) : ()
	class MethodMirror name: n accessModifier: a mixin: m source: s = Object new (
		|
			public name <Symbol> = n.
			public accessModifier <Symbol> = a.
			public definingMixin <MixinMirror> = m.
			private sourceIndex <Integer> = s.
		|
	) (
		public isKindOfMethodMirror ^<Boolean> = (
			^true
		)
		public = other = (
			other isKindOfMethodMirror ifFalse: [ ^false ].
			^name = other name and: [ definingMixin = other definingMixin ]
		)
		public hash ^<Integer> = (
			^name hash bitXor: class hash
		)
		public isSynthetic ^<Boolean> = (
			(* MixinMirror>>methods already filters out isSynthetic methods, so any
	   MethodMirror that exists in user-facing groups is non-synthetic.
	   Returning false here matches what the IDE sees. A real fix would
	   thread the flag through the constructor. *)
			
			^false
