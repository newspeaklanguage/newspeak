public testSiblingCanAccessPublicMethod = (
(* Test that sibling class can access public method of another sibling *)
    | middleClass = LexicalScopeOuter new LexicalScopeMiddle.
      eset = typechecker typecheckMethodSource: 'test ^ <Number> = (^LexicalScopeSibling new siblingPublicMethod)' ofClass: middleClass. |
    assert: [eset isEmpty]
        description: 'Should allow sibling to access sibling public method'.
)

(* ===== BATCH 12: CLOSURE + LEXICAL SCOPE TESTS ===== *)
public testClosureInInnerAccessingOuter = (
(* Test that a closure defined in inner class can directly access outer private slot *)
    | innerClass = ClosureLexicalOuter new ClosureLexicalMiddle new ClosureLexicalInner.
      eset = typechecker typecheckMethodSource: 'test ^ <Number> = (| closure <[Number]> = [outerPrivateSlot]. | ^closure value)' ofClass: innerClass. |
    assert: [eset isEmpty]
        description: 'Should allow closure in inner class to access outer private slot'.
)

public testClosureInInnerAccessingMiddle = (
(* Test that a closure defined in inner class can directly access middle private slot *)
    | innerClass = ClosureLexicalOuter new ClosureLexicalMiddle new ClosureLexicalInner.
      eset = typechecker typecheckMethodSource: 'test ^ <Number> = (| closure <[Number]> = [middlePrivateSlot]. | ^closure value)' ofClass: innerClass. |
    assert: [eset isEmpty]
        description: 'Should allow closure in inner class to access middle private slot'.
)

public testClosureInInnerAccessingInner = (
(* Test that a closure defined in inner class can access its own private slot *)
    | innerClass = ClosureLexicalOuter new ClosureLexicalMiddle new ClosureLexicalInner.
      eset = typechecker typecheckMethodSource: 'test ^ <Number> = (| closure <[Number]> = [innerPrivateSlot]. | ^closure value)' ofClass: innerClass. |
    assert: [eset isEmpty]
        description: 'Should allow closure in inner class to access its own private slot'.
)

public testClosureCallingOuterMethod = (
(* Test that a closure can call outer private method via lexical scope *)
    | innerClass = ClosureLexicalOuter new ClosureLexicalMiddle new ClosureLexicalInner.
      eset = typechecker typecheckMethodSource: 'test ^ <Number> = (| closure <[Number]> = [outerPrivateMethod]. | ^closure value)' ofClass: innerClass. |
    assert: [eset isEmpty]
        description: 'Should allow closure to call outer private method'.
)

public testNestedClosureAccessingOuter = (
(* Test that nested closures maintain lexical scope *)
    | innerClass = ClosureLexicalOuter new ClosureLexicalMiddle new ClosureLexicalInner.
      eset = typechecker typecheckMethodSource: 'test ^ <Number> = (| outerClosure <[[Number]]> = [[outerPrivateSlot]]. innerClosure <[Number]> = outerClosure value. | ^innerClosure value)' ofClass: innerClass. |
    assert: [eset isEmpty]
        description: 'Should allow nested closures to access outer private slot'.
)

public testClosureWithParamAccessingOuter = (
(* Test that closure with parameters can still access lexical scope *)
    | innerClass = ClosureLexicalOuter new ClosureLexicalMiddle new ClosureLexicalInner.
      eset = typechecker typecheckMethodSource: 'test ^ <Number> = (| closure <[:Number | Number]> = [:x <Number> | x + outerPrivateSlot]. | ^closure value: 5)' ofClass: innerClass. |
    assert: [eset isEmpty]
        description: 'Should allow closure with parameters to access outer private slot'.
)

public testMiddleClosureAccessingOuter = (
(* Test that closure in middle class can access outer private slot *)
    | middleClass = ClosureLexicalOuter new ClosureLexicalMiddle.
      eset = typechecker typecheckMethodSource: 'test ^ <Number> = (| closure <[Number]> = [outerPrivateSlot]. | ^closure value)' ofClass: middleClass. |
    assert: [eset isEmpty]
        description: 'Should allow closure in middle class to access outer private slot'.
)

public testMiddleClosureAccessingMiddle = (
(* Test that closure in middle class can access middle private slot *)
    | middleClass = ClosureLexicalOuter new ClosureLexicalMiddle.
      eset = typechecker typecheckMethodSource: 'test ^ <Number> = (| closure <[Number]> = [middlePrivateSlot]. | ^closure value)' ofClass: middleClass. |
    assert: [eset isEmpty]
        description: 'Should allow closure in middle class to access its own private slot'.
)

public testOuterClosureAccessingPrivate = (
(* Test that closure in outer class can access outer private slot *)
    | eset = typechecker typecheckMethodSource: 'test ^ <Number> = (| closure <[Number]> = [outerPrivateSlot]. | ^closure value)' ofClass: ClosureLexicalOuter. |
    assert: [eset isEmpty]
        description: 'Should allow closure in outer class to access its own private slot'.
)

public testClosurePassedAsParameter = (
(* Test that closure maintains lexical scope when passed to a method *)
    | innerClass = ClosureLexicalOuter new ClosureLexicalMiddle new ClosureLexicalInner.
      eset = typechecker typecheckMethodSource: 'test ^ <Number> = (| closure <[Number]> = [outerPrivateSlot]. executor <[:[Number] | Number]> = [:c <[Number]> | c value]. | ^executor value: closure)' ofClass: innerClass. |
    assert: [eset isEmpty]
        description: 'Should maintain lexical scope when closure is passed as parameter'.
)

public testClosureInLocalVariable = (
(* Test that closure stored in local variable maintains lexical scope *)
    | innerClass = ClosureLexicalOuter new ClosureLexicalMiddle new ClosureLexicalInner.
      eset = typechecker typecheckMethodSource: 'test ^ <Number> = (| c1 <[Number]> = [outerPrivateSlot]. c2 <[Number]> = c1. | ^c2 value)' ofClass: innerClass. |
    assert: [eset isEmpty]
        description: 'Should maintain lexical scope when closure is stored in local variable'.
)

public testClosureAccessingOuterFromMiddle = (
(* Test that closure in middle class can access outer AND call outer method *)
    | middleClass = ClosureLexicalOuter new ClosureLexicalMiddle.
      eset = typechecker typecheckMethodSource: 'test ^ <Number> = (| closure <[Number]> = [outerPrivateSlot + outerPrivateMethod]. | ^closure value)' ofClass: middleClass. |
    assert: [eset isEmpty]
        description: 'Should allow closure to access both slot and method from outer scope'.
)

(* ========== BATCH 12: Lexical Scope + Inheritance Tests ========== *)

public testInnerAccessDerivedPrivateSlot = (
(* Test that inner class can access derived class's private slot via lexical scope *)
    | innerClass = InheritanceLexicalDerived new InnerClass.
      eset = typechecker typecheckMethodSource: 'test ^ <Number> = (^derivedPrivateSlot)' ofClass: innerClass. |
    assert: [eset isEmpty]
        description: 'Inner class should access derived private slot via lexical scope'.
)

public testInnerAccessDerivedPrivateMethod = (
(* Test that inner class can access derived class's private method via lexical scope *)
    | innerClass = InheritanceLexicalDerived new InnerClass.
      eset = typechecker typecheckMethodSource: 'test ^ <Number> = (^derivedPrivateMethod)' ofClass: innerClass. |
    assert: [eset isEmpty]
        description: 'Inner class should access derived private method via lexical scope'.
)

public testInnerCannotAccessInheritedProtectedSlot = (
(* Test that inner class CANNOT access inherited protected slot via lexical scope.
   Lexical scope only sees members defined in the enclosing class, not inherited ones. *)
    | innerClass = InheritanceLexicalDerived new InnerClass.
      eset = typechecker typecheckMethodSource: 'test ^ <Number> = (^baseProtectedSlot)' ofClass: innerClass. |
    assert: [assertErrorSet: eset containsMessageWith: 'is not defined on type']
        description: 'Inner class should NOT access inherited protected slot (not in lexical scope)'.
)

public testInnerCannotAccessInheritedProtectedMethod = (
(* Test that inner class CANNOT access inherited protected method via lexical scope.
   Lexical scope only sees members defined in the enclosing class, not inherited ones. *)
    | innerClass = InheritanceLexicalDerived new InnerClass.
      eset = typechecker typecheckMethodSource: 'test ^ <Number> = (^baseProtectedMethod)' ofClass: innerClass. |
    assert: [assertErrorSet: eset containsMessageWith: 'is not defined on type']
        description: 'Inner class should NOT access inherited protected method (not in lexical scope)'.
)

public testInnerCannotAccessInheritedPublicSlot = (
(* Test that inner class CANNOT access inherited public slot via lexical scope.
   Lexical scope only sees members defined in the enclosing class, not inherited ones. *)
    | innerClass = InheritanceLexicalDerived new InnerClass.
      eset = typechecker typecheckMethodSource: 'test ^ <Number> = (^basePublicSlot)' ofClass: innerClass. |
    assert: [assertErrorSet: eset containsMessageWith: 'is not defined on type']
        description: 'Inner class should NOT access inherited public slot (not in lexical scope)'.
)

public testInnerCannotAccessInheritedPublicMethod = (
(* Test that inner class CANNOT access inherited public method via lexical scope.
   Lexical scope only sees members defined in the enclosing class, not inherited ones. *)
    | innerClass = InheritanceLexicalDerived new InnerClass.
      eset = typechecker typecheckMethodSource: 'test ^ <Number> = (^basePublicMethod)' ofClass: innerClass. |
    assert: [assertErrorSet: eset containsMessageWith: 'is not defined on type']
        description: 'Inner class should NOT access inherited public method (not in lexical scope)'.
)

public testInnerSeesOverriddenSlot = (
(* Test that inner class sees overridden slot from derived class, not base *)
    | innerClass = InheritanceLexicalDerived new InnerClass.
      eset = typechecker typecheckMethodSource: 'test ^ <Number> = (^overriddenSlot)' ofClass: innerClass. |
    assert: [eset isEmpty]
        description: 'Inner class should see overridden slot from derived class'.
)

public testInnerSeesOverriddenMethod = (
(* Test that inner class sees overridden method from derived class (returns Integer), not base (returns Number) *)
    | innerClass = InheritanceLexicalDerived new InnerClass.
      eset = typechecker typecheckMethodSource: 'test ^ <Integer> = (^overriddenMethod)' ofClass: innerClass. |
    assert: [eset isEmpty]
        description: 'Inner class should see overridden method from derived class (Integer return type)'.
)

public testInnerCannotAccessBasePrivateSlot = (
(* Test that inner class CANNOT access base private slot, even via lexical scope *)
    | innerClass = InheritanceLexicalDerived new InnerClass.
      eset = typechecker typecheckMethodSource: 'test ^ <Number> = (^basePrivateSlot)' ofClass: innerClass. |
    assert: [assertErrorSet: eset containsMessageWith: 'is not defined on type']
        description: 'Inner class should NOT access base private slot (not inherited)'.
)

public testInnerCannotAccessBasePrivateMethod = (
(* Test that inner class CANNOT access base private method, even via lexical scope *)
    | innerClass = InheritanceLexicalDerived new InnerClass.
      eset = typechecker typecheckMethodSource: 'test ^ <Number> = (^basePrivateMethod)' ofClass: innerClass. |
    assert: [assertErrorSet: eset containsMessageWith: 'is not defined on type']
        description: 'Inner class should NOT access base private method (not inherited)'.
)

(* ========== BATCH 13: Empty Closure Tests ========== *)

public testEmptyClosureReturnsNil = (
(* Test that empty closure [] has type that returns Nil *)
    | eset = typechecker typecheckMethodSource: 'test ^ <Nil> = (| emptyClosure <[Nil]> = []. | ^emptyClosure value)' ofClass: EmptyClosureTest. |
    assert: [eset isEmpty]
        description: 'Empty closure should have type [Nil] and return nil'.
)

public testEmptyClosureInExpression = (
(* Test that empty closure can be used in expression *)
    | eset = typechecker typecheckMethodSource: 'test = (| c <[Nil]> = []. | c value)' ofClass: EmptyClosureTest. |
    assert: [eset isEmpty]
        description: 'Empty closure should work in expression'.
)

public testReturnEmptyClosure = (
(* Test that a method can return an empty closure *)
    | eset = typechecker typecheckMethodSource: 'test ^ <[Nil]> = (^[])' ofClass: EmptyClosureTest. |
    assert: [eset isEmpty]
        description: 'Should be able to return empty closure'.
)

(* ========== BATCH 14: Non-Local Return Tests ========== *)

public testNLRFromClosure = (
(* Test that closure with non-local return works *)
    | middleClass = NLRTestOuter new NLRTestMiddle.
      eset = typechecker typecheckMethodSource: 'test ^ <Number> = (| closure <[Number]> = [^42]. | closure value. ^999)' ofClass: middleClass. |
    assert: [eset isEmpty]
        description: 'Closure with non-local return should typecheck'.
)

public testNLRReturnsCorrectType = (
(* Test that NLR returns value of correct type matching enclosing method *)
    | middleClass = NLRTestOuter new NLRTestMiddle.
      eset = typechecker typecheckMethodSource: 'test ^ <Number> = (| closure <[Number]> = [^42]. | ^closure value)' ofClass: middleClass. |
    assert: [eset isEmpty]
        description: 'NLR should return type matching enclosing method'.
)

public testNLRWithWrongType = (
(* Test that NLR with wrong type is caught *)
    | middleClass = NLRTestOuter new NLRTestMiddle.
      eset = typechecker typecheckMethodSource: 'test ^ <String> = (| closure = [^42]. | ^closure value)' ofClass: middleClass. |
    assert: [assertErrorSet: eset containsMessageWith: 'not a subtype']
        description: 'NLR returning wrong type should be caught'.
)

public testNLRInNestedClosure = (
(* Test NLR from deeply nested closure *)
    | innerClass = NLRTestOuter new NLRTestMiddle new NLRTestInner.
      eset = typechecker typecheckMethodSource: 'test ^ <Number> = (| nestedClosure <[[DoesNotMatter]]> = [[^100]]. | nestedClosure value value. ^999)' ofClass: innerClass. |
    assert: [eset isEmpty]
        description: 'NLR from nested closure should work'.
)

(* ========== BATCH 15: Tuple Tests ========== *)

public testCreateNumberTuple = (
(* Test creating a homogeneous tuple of numbers with proper tuple type *)
    | eset = typechecker typecheckMethodSource: 'test ^ <{Number. Number. Number}> = (^{1. 2. 3})' ofClass: TupleTestClass. |
    assert: [eset isEmpty]
        description: 'Should create tuple with type {Number. Number. Number}'.
)

public testCreateMixedTuple = (
(* Test creating a heterogeneous tuple with different types for each element *)
    | eset = typechecker typecheckMethodSource: 'test ^ <{Integer. String. Boolean}> = (^{1. ''hello''. true})' ofClass: TupleTestClass. |
    assert: [eset isEmpty]
        description: 'Should create tuple with type {Integer. String. Boolean}'.
)

public testEmptyTuple = (
(* Test creating an empty tuple with empty tuple type *)
    | eset = typechecker typecheckMethodSource: 'test ^ <{}> = (^{})' ofClass: TupleTestClass. |
    assert: [eset isEmpty]
        description: 'Should create tuple with empty type {}'.
)

public testAccessFirstElementOfNumberTuple = (
(* Test that accessing first element of number tuple returns Number *)
    | eset = typechecker typecheckMethodSource: 'test ^ <Number> = (| tuple <{Number. Number. Number}> = {10. 20. 30}. | ^tuple at: 1)' ofClass: TupleTestClass. |
    assert: [eset isEmpty]
        description: 'Accessing element 1 of {Number. Number. Number} should return Number'.
)

public testAccessSecondElementOfMixedTuple = (
(* Test that accessing second element of mixed tuple returns String *)
    | eset = typechecker typecheckMethodSource: 'test ^ <String> = (| tuple <{Integer. String. Boolean}> = {42. ''world''. false}. | ^tuple at: 2)' ofClass: TupleTestClass. |
    assert: [eset isEmpty]
        description: 'Accessing element 2 of {Integer. String. Boolean} should return String'.
)

public testAccessThirdElementOfMixedTuple = (
(* Test that accessing third element of mixed tuple returns Boolean *)
    | eset = typechecker typecheckMethodSource: 'test ^ <Boolean> = (| tuple <{Integer. String. Boolean}> = {99. ''test''. true}. | ^tuple at: 3)' ofClass: TupleTestClass. |
    assert: [eset isEmpty]
        description: 'Accessing element 3 of {Integer. String. Boolean} should return Boolean'.
)

public testSingleElementTuple = (
(* Test creating a single-element tuple *)
    | eset = typechecker typecheckMethodSource: 'test ^ <{String}> = (^{''single''})' ofClass: TupleTestClass. |
    assert: [eset isEmpty]
        description: 'Should create single-element tuple with type {String}'.
)

public testNestedTuple = (
(* Test creating a nested tuple *)
    | eset = typechecker typecheckMethodSource: 'test ^ <{{Number. Number}. String}> = (^{{1. 2}. ''nested''})' ofClass: TupleTestClass. |
    assert: [eset isEmpty]
        description: 'Should create nested tuple with type {{Number. Number}. String}'.
)

public testTupleSubtyping = (
(* Test that {Integer. Integer} is a subtype of {Number. Number} *)
    | eset = typechecker typecheckMethodSource: 'test ^ <{Number. Number}> = (^{1. 2})' ofClass: TupleTestClass. |
    assert: [eset isEmpty]
        description: 'Tuple {Integer. Integer} should be subtype of {Number. Number}'.
)

public testTupleWrongElementCount = (
(* Test that wrong number of elements is caught *)
    | eset = typechecker typecheckMethodSource: 'test ^ <{Number. Number}> = (^{1. 2. 3})' ofClass: TupleTestClass. |
    assert: [assertErrorSet: eset containsMessageWith: 'not a subtype']
        description: 'Tuple with wrong element count should not typecheck'.
)

public testTupleAsArrayWithUnion = (
(* Test that tuple {Integer. Float} is assignable to Array[Number] *)
    | eset = typechecker typecheckMethodSource: 'test ^ <Array[Number]> = (^{22. 3.14})' ofClass: TupleTestClass. |
    assert: [eset isEmpty]
        description: 'Tuple {Integer. Float} should be subtype of Array[Number]'.
)

public testClosureWithIntegerReturnAssignedToNumberClosure = (
(* Test that a closure returning Integer can be assigned to [:Number] type *)
    | eset = typechecker typecheckMethodSource: 'test = (| c <[:Number]> = [:x <Number> | 42]. |)' ofClass: TupleTestClass. |
    assert: [eset isEmpty]
        description: 'Closure [:Number | Integer] should be assignable to <[:Number]>'.
)

public testToDoWithEmptyClosureBody = (
(* Test to:do: with empty closure body *)
    | eset = typechecker typecheckMethodSource: 'test = (1 to: 2 do: [:i <Number> | ])' ofClass: TupleTestClass. |
    assert: [eset isEmpty]
        description: 'to:do: should accept closure with Number parameter'.
)

public testTupleIterationWithUnion = (
(* Test iteration over tuple with dynamic index using type conversion *)
    | eset = typechecker typecheckMethodSource: 'test = (1 to: 2 do: [:i <Number> | | x <Number> | x:: {22. 3.14} at: i asInteger])' ofClass: TupleTestClass. |
    assert: [eset isEmpty]
        description: 'Should allow iteration over tuple using asInteger conversion'.
)

public testTupleAsArrayHomogeneous = (
(* Test that homogeneous tuple works as array *)
    | eset = typechecker typecheckMethodSource: 'test ^ <Array[Integer]> = (^{1. 2. 3})' ofClass: TupleTestClass. |
    assert: [eset isEmpty]
        description: 'Tuple {Integer. Integer. Integer} should be subtype of Array[Integer]'.
)

public testTupleAsArrayWithBroaderUnion = (
(* Test that tuple with mixed types works with broader union *)
    | eset = typechecker typecheckMethodSource: 'test ^ <Array[Object]> = (^{1. ''hello''. true})' ofClass: TupleTestClass. |
    assert: [eset isEmpty]
        description: 'Mixed tuple should be subtype of Array[Object]'.
)

public testUnderscoreArrayNotAccessible = (
(* Test that internal name _Array is not globally available *)
    | eset = typechecker typecheckMethodSource: 'test = (| x <_Array> |)' ofClass: TupleTestClass. |
    assert: [eset isEmpty not]
        description: '_Array should not be accessible'.
)

public testUnderscoreObjectNotAccessible = (
(* Test that internal name _Object is not globally available *)
    | eset = typechecker typecheckMethodSource: 'test = (| x <_Object> |)' ofClass: TupleTestClass. |
    assert: [eset isEmpty not]
        description: '_Object should not be accessible'.
)

public testTupleNonLiteralAccess = (
(* Test accessing tuple with non-literal index returns union type *)
    | eset = typechecker typecheckMethodSource: 'test: i <Integer> ^ <Number> = (| tuple <{Integer. Float}> = {42. 3.14}. | ^tuple at: i)' ofClass: TupleTestClass. |
    assert: [eset isEmpty]
        description: 'Non-literal index on {Integer. Float} should return Number (union)'.
)

public testUnionAssignToSupertype = (
(* Test that union type can be assigned to variable of supertype *)
    | eset = typechecker typecheckMethodSource: 'test: i <Integer> = (| x <Number> | x:: {22. 3.14} at: i)' ofClass: TupleTestClass. |
    assert: [eset isEmpty]
        description: 'Union Integer | Float from tuple should assign to Number variable'.
)

public testClosureReturningUnion = (
(* Test closure with explicit return type accepting union *)
    | eset = typechecker typecheckMethodSource: 'test = (| c <[:Integer | Number]> = [:i <Integer> | {22. 3.14} at: i]. |)' ofClass: TupleTestClass. |
    assert: [eset isEmpty]
        description: 'Closure should accept union Integer | Float as Number return type'.
)

(* ========== BATCH 16: Class Method Tests ========== *)

public testClassMethodReturningInstance = (
(* Test class method with Instance return type *)
    | eset = typechecker typecheckMethodSource: 'new ^ <Instance> = (^self new: 0)' ofClass: (ObjectMirror reflecting: FactoryClass) getClass reflectee. |
    assert: [eset isEmpty]
        description: 'Class method should return Instance type'.
)

public testClassMethodNew = (
(* Test factory method pattern *)
    | eset = typechecker typecheckMethodSource: 'new: v <Number> ^ <Instance> = (| instance <Instance> = super new. | instance setValue: v. ^instance)' ofClass: (ObjectMirror reflecting: FactoryClass) getClass reflectee. |
    assert: [eset isEmpty]
        description: 'Factory method should work with Instance type'.
)

public testClassMethodNonInstance = (
(* Test class method that doesn't return Instance *)
    | eset = typechecker typecheckMethodSource: 'classMethod ^ <Number> = (^42)' ofClass: (ObjectMirror reflecting: FactoryClass) getClass reflectee. |
    assert: [eset isEmpty]
        description: 'Class method can return non-Instance type'.
)

public testInstanceResolvedToCorrectClass = (
(* Test that Instance resolves to the actual class type *)
    | eset = typechecker typecheckMethodSource: 'create ^ <Instance> = (| obj <Instance> = self new. | ^obj)' ofClass: (ObjectMirror reflecting: FactoryClass) getClass reflectee. |
    assert: [eset isEmpty]
        description: 'Instance should resolve to FactoryClass type'.
)

toplevelClass1 = (
	^'
class Sample = (
(*Top level test class for typechecker.*)
|
	public publicTypedSlot1 <ToplevelClass1>
	protectedTypedSlot2 <ToplevelClass2>
	private privateTypedSlot3 <Collections List>
	public publicSlot4
	protectedSlot5
	private privateSlot6
|
) (
  class N2 = (
  |
	public publicTypedSlot1 <ToplevelClass1>
	protectedTypedSlot2 <ToplevelClass2>
	private privateTypedSlot3 <Collections List>
	public publicSlot4
	protectedSlot5
	private privateSlot6
  |)
  (
    class N2N2 = (
    |
	public publicTypedSlot1 <ToplevelClass1>
	protectedTypedSlot2 <ToplevelClass2>
	private privateTypedSlot3 <Collections List>
	public publicSlot4
	protectedSlot5
	private privateSlot6
    |)
    (

       argsWithType: a1 <ToplevelClass1 PublicN1> and: a2 <ToplevelClass1 N2> ^ <Symbol> = (
	     ^#argsWithType:
       )
    ) : () (* end N2N2 *)
    private class PrivateN2N3 = (
    |
	public publicTypedSlot1 <toplevelClass1>
	protectedTypedSlot2 <toplevelClass2>
	private privateTypedSlot3 <Collections List>
	public publicSlot4
	protectedSlot5
	private privateSlot6
    |)
    (

      argsWithType: a1 <ToplevelClass1 PublicN1> and: a2 <ToplevelClass1 N2> ^ <Symbol> = (
	  ^#argsWithType:
      )
    ) : () (* end PrivateN2N3 *)
    public class PublicN2N1 = (
    |
	public publicTypedSlot1 <ToplevelClass1>
	protectedTypedSlot2 <ToplevelClass2>
	private privateTypedSlot3 <Collections List>
	public publicSlot4
	protectedSlot5
	private privateSlot6
    |)
   (

      argsWithType: a1 <ToplevelClass1 PublicN1> and: a2 <ToplevelClass1 N2> ^ <Symbol> = (
        ^#argsWithType:
      )
    ) : () (* end PublicN2N1 *)

    argsNoType: a1 and: a2 = ()
    argsNoTypeWithExplicitSelf: a1 and: a2 ^ <Self> = ()
    argsWithType: a1 <ToplevelClass1 PublicN1> and: a2 <ToplevelClass1 N2> ^ <Symbol> = (
      ^#argsWithType:
    )
  ) : () (* end N2 *)
  private class PrivateN3 = (
  |
	public publicTypedSlot1 <ToplevelClass1>
	protectedTypedSlot2 <ToplevelClass2>
	private privateTypedSlot3 <Collections List>
	public publicSlot4
	protectedSlot5
	private privateSlot6
  |)
  (
  class N3N2 = (
  |
	public publicTypedSlot1 <ToplevelClass1>
	protectedTypedSlot2 <ToplevelClass2>
	private privateTypedSlot3 <Collections List>
	public publicSlot4
	protectedSlot5
	private privateSlot6
  |)
  (

    argsNoType: a1 and: a2 = ()
    argsNoTypeWithExplicitSelf: a1 and: a2 ^ <Self> = ()
    argsWithType: a1 <ToplevelClass1 PublicN1> and: a2 <ToplevelClass1 N2> ^ <Symbol> = (
      ^#argsWithType:
    )
    noArgsNoType = ()
    noArgsWithExplicitSelf ^ <Self> = ( )
    noArgsWithType ^ <String> = (
      ^''noArgsWithType''
    )
    private privateArgsNoType: a1 and: a2 = ()
  ) : () (* end N3N2 *)
  private class PrivateN3N3 = (
  |
	public publicTypedSlot1 <ToplevelClass1>
	protectedTypedSlot2 <ToplevelClass2>
	private privateTypedSlot3 <Collections List>
	public publicSlot4
	protectedSlot5
	private privateSlot6
  |)
  (

    argsNoType: a1 and: a2 = ()
    argsNoTypeWithExplicitSelf: a1 and: a2 ^ <Self> = ()
    argsWithType: a1 <ToplevelClass1 PublicN1> and: a2 <ToplevelClass1 N2> ^ <Symbol> = (
      ^#argsWithType:
    )
    noArgsNoType = ()
    noArgsWithExplicitSelf ^ <Self> = ()
    noArgsWithType ^ <String> = (
      ^''noArgsWithType''
    )
  ) : () (* end N3N3 *)

  public class PublicN3N1 = (
  |
	public publicTypedSlot1 <ToplevelClass1>
	protectedTypedSlot2 <ToplevelClass2>
	private privateTypedSlot3 <Collections List>
	public publicSlot4
	protectedSlot5
	private privateSlot6
  |)
  (

    argsNoType: a1 and: a2 = ()
    argsNoTypeWithExplicitSelf: a1 and: a2 ^ <Self> = ()
    argsWithType: a1 <ToplevelClass1 PublicN1> and: a2 <ToplevelClass1 N2> ^ <Symbol> = (
      ^#argsWithType:
    )
    noArgsNoType = ()
    noArgsWithExplicitSelf ^ <Self> = ()
    noArgsWithType ^ <String> = (
      ^''noArgsWithType''
    )
