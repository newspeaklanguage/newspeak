Newspeak3
'Root'
class AIAccess usingPlatform: platform = (
(*
 Provides AI model access from Newspeak. Supports multiple providers
 via the Provider abstraction. Manages multi-turn conversations with
 tool use (function calling), enabling an AI to query the IDE and vice versa.

 Usage:
   | ai provider session |
   ai:: AIAccess usingPlatform: platform.
   provider:: ai AnthropicProvider apiKey: 'sk-...' model: 'claude-sonnet-4-20250514'.
   session:: ai Session provider: provider tools: {}.
   session systemPrompt:: 'You are a Newspeak programming assistant.'.
   (session sendMessage: 'What is Newspeak?') then: [:reply | transcript show: reply].
*)
(* Only class-imports and the platform handle go in the slot block —
   they must be safe at AIAccess-construction time, which now happens
   during platform construction (Hopscotch reads `p aiAccess` from its
   slot block). The JS-side handles (global, JSON, Promise) are forced
   lazily at module body, so they're only fetched on first actual API
   call — well after primordialsoup snapshot creation, when JS aliens
   are live. *)
|
	private retainedPlatform = platform.
	private List = platform collections List.
	private Map = platform collections Map.
|
) (
public class Tool name: n <String> description: d <String> inputSchema: s <String> handler: h <[:Alien]> = (
(*
 A function-callable tool the AI can invoke during a session. The Session
 carries a List[Tool] and translates these into the provider's native
 tool-declaration shape via buildToolsPayload: for each turn.

   name        a stable identifier the model uses to call the tool;
               typically snake_case (e.g. 'get_class_source').
   description prose shown to the model so it understands when to call.
   inputSchema a JSON-Schema *string* describing the tool's arguments.
               Parsed via JSON.parse at translation time. Use a string
               (not a parsed object) so it can be authored as a literal.
   handler     a one-arg block invoked with the parsed input alien (a JS
               object matching inputSchema). May return a String (textual
               tool result), a value whose printString is the result, or
               an Alien[Promise] that resolves to either. May raise; the
               raise is converted to an is_error tool_result.
*)
|
	public name <String> = n.
	public description <String> = d.
	public inputSchema <String> = s.
	public handler <[:Alien]> = h.
|
) (
) : (
)
public class Provider = (
(*
 Abstract base for AI providers (Anthropic, Gemini, etc.). Each provider
 owns BOTH the wire protocol (complete:) AND the internal shape of
 conversation history:

   addUserText:toMessages:           append a user-role message
   appendAssistantResponse:          append an assistant-role message
                                     from a complete:-resolved response
   messagesAsRequestPayload:         turn the history into the request
                                     payload that complete: ships
   extractTextFromResponse:          pull plain text out of a response
                                     for the UI's send-promise value
   displayMessagesFromMessages:      translate the history to neutral
                                     {role, text} tuples for the UI

 Session is a thin coordinator that delegates all shape-y work to the
 provider via these methods; it never inspects message internals or
 response internals directly. Adding a new provider therefore means
 implementing this interface against the provider's native shape — the
 Session is provider-agnostic.

 Tool-use support is optional. Providers that don't translate tools
 inherit hasToolUse: ^false and the tool-loop is skipped. Providers
 that do support tools also implement toolUseBlocksFrom:,
 makeToolResult:content:isError:, buildToolsPayload:, and
 addToolResults:toMessages: (which wraps a list of tool-result
 blocks/parts into a user-role message in the provider's native shape).
*)
) (
public complete: messages <Alien[Array]>
	system: systemPrompt <String>
	tools: tools <Alien[Array] | UndefinedObject>
	maxTokens: maxTokens <Integer>
	^ <Alien[Promise]> = (
	(* Ship the request to the provider's API and return a Promise that
	   resolves to the *parsed* response body (whatever native shape the
	   provider returns; the parsing-and-resolving discipline is per
	   provider). The Promise rejects with a String reason on HTTP error
	   or other API failure — rejection MUST be via Promise.reject from
	   inside any then: closure, never via Newspeak Error signal:, to
	   avoid corrupting primordialsoup's JS-Promise alien bridge.
	   messages is whatever the provider's messagesAsRequestPayload:
	   produces. tools is whatever the provider's buildToolsPayload:
	   produces, or nil if no tools / no tool support. *)
	subclassResponsibility
)
public addUserText: text <String> toMessages: messages <List> = (
	(* Append a user-role message carrying the given text, in the
	   provider's native shape. Returns self. *)
	subclassResponsibility
)
public appendAssistantResponse: response <Alien> toMessages: messages <List> = (
	(* Given the parsed response from complete:, append an assistant-role
	   entry to the history in the provider's native shape. May raise
	   (within a Session.completeWithToolLoop on:Exception backstop) if
	   the response has no usable content — preferred to silently storing
	   a half-formed entry that poisons subsequent turns. *)
	subclassResponsibility
)
public messagesAsRequestPayload: messages <List> ^ <Alien[Array]> = (
	(* Convert the message history into the JS array that complete: will
	   carry as the request payload. Most providers just JSArray-ify
	   their stored messages, since they're already in native shape. *)
	subclassResponsibility
)
public extractTextFromResponse: response <Alien> ^ <String> = (
	(* Extract the assistant's text from the response, for the user-facing
	   send-promise's resolution value. Should NOT raise on malformed
	   responses (return '' instead); appendAssistantResponse: is where
	   shape validation belongs. *)
	subclassResponsibility
)
public displayMessagesFromMessages: messages <List> ^ <List> = (
	(* Walk the history producing {role <String>, text <String>} tuples
	   for UI rendering. Role is always 'user' or 'assistant' (translate
	   native role names like Gemini's 'model'). Skip entries with no
	   display text (tool results, empty turns). *)
	subclassResponsibility
)
public hasToolUse: response <Alien> ^ <Boolean> = (
	(* True if the response asks us to call one or more tools. Providers
	   without tool-use translation inherit this default of false and the
	   tool loop is bypassed. *)
	^false
)
public toolUseBlocksFrom: response <Alien> ^ <List> = (
	(* Only called when hasToolUse: returns true. Returns a List of
	   provider-native tool-call records (each with at minimum 'id',
	   'name', 'input' fields the Session can hand to executeToolCall:).
	   Providers that support tool use override; others may leave as
	   subclassResponsibility since hasToolUse:'s default prevents the
	   call. *)
	subclassResponsibility
)
public makeToolResult: id <String> content: text isError: err <Boolean> ^ <Alien> = (
	(* Build a tool-result message in the provider's native shape, to be
	   appended to messages and sent on the next turn. content (text) is
	   either a String (textual result) or an array of content blocks.
	   Only providers that support tool use need to implement this. *)
	subclassResponsibility
)
public buildToolsPayload: toolDefs <List[Tool]> ^ <Alien | UndefinedObject> = (
	(* Translate the IDE's neutral Tool definitions to the provider's
	   tool-declaration shape, or nil if no tools (or no tool support).
	   Default: nil. *)
	^nil
)
public addToolResults: results <Alien[Array]> toMessages: messages <List> = (
	(* Wrap a list of tool-result blocks/parts (each produced by
	   makeToolResult:content:isError:) into a single user-role message in
	   the provider's native shape, and append to messages. Called once
	   per tool-loop round, after every executeToolCall: promise has
	   resolved. Providers that support tool use must implement;
	   tool-less providers never reach this path (hasToolUse: defaults to
	   false). *)
	subclassResponsibility
)
safeAt: receiver <Object> field: field <String | Integer> = (
	(* Defensive JS field access for *structural navigation*. JS
	   `undefined` USUALLY maps to Newspeak `nil` in primordialsoup's
	   alien bridge, but not in every edge case (e.g. some object
	   shapes where the at: dispatch raises rather than returns nil).
	   Wrap every field access on response-tree nodes in this so a
	   deviant shape produces nil rather than blowing up the chat
	   session. Returns nil for missing fields or non-respondent
	   receivers; otherwise returns the field value AS-IS — which may
	   still be JS undefined for callers that read scalar leaves
	   directly. For those, use safeStringAt:field: instead. *)
	receiver isNil ifTrue: [^nil].
	^[receiver at: field] on: Exception do: [:e | nil]
)
safeStringAt: receiver <Object> field: field <String | Integer> ^ <String | UndefinedObject> = (
	(* Defensive String-field access. Like safeAt: but additionally
	   filters out JS undefined / null / non-String values that the
	   alien bridge sometimes passes through as values which fail
	   isNil. Returns nil if the field is missing or not a String,
	   otherwise the String value.

	   Mechanism: a real String concatenated with the empty String
	   returns itself. Anything else (JS undefined, JS null, numbers,
	   objects) raises on `,` and is normalised to nil. Cheap, single
	   alien round-trip, no type-class guessing.

	   Use this at every leaf where you read a string field from an
	   alien (response.parts[i].text, tool name, etc.) and intend to
	   use it in a String context. *)
	| v |
	receiver isNil ifTrue: [^nil].
	v:: [receiver at: field] on: Exception do: [:e | nil].
	v isNil ifTrue: [^nil].
	^[v , ''] on: Exception do: [:e | nil]
)
) : (
)
public class AnthropicProvider apiKey: key <String> model: mdl <String> = Provider (
(*
 Provider for Anthropic's Messages API (Claude models). Conversation
 messages are stored in Anthropic's native shape:

   user message:      {role: 'user', content: <string> | <array of blocks>}
   assistant message: {role: 'assistant', content: <array of blocks>}

 Content blocks are typed: 'text', 'tool_use' (assistant calling a tool),
 'tool_result' (user providing tool output back). The Messages API
 returns a top-level content array of these blocks plus a stop_reason
 — 'end_turn' for normal completion, 'tool_use' for tool-calling.

 The browser direct-access header is required because we POST from a
 browser; production deployments should proxy via a server.
*)
|
	public apiKey <String> = key.
	(* Mutable so the chat UI can switch models mid-session. The session's
	   history is untouched — the next turn just goes to the new model. *)
	public model <String> ::= mdl.
	private apiUrl <String> = 'https://api.anthropic.com/v1/messages'.
	private apiVersion <String> = '2023-06-01'.
|
) (
public availableModels ^ <List[String]> = (
	^{
		'claude-opus-4-7'.
		'claude-sonnet-4-6'.
		'claude-haiku-4-5'.
		'claude-sonnet-4-20250514'.  (* legacy default, for back-compat *)
	}
)
public displayNameFor: modelId <String> ^ <String> = (
	modelId = 'claude-opus-4-7' ifTrue: [^'Opus 4.7'].
	modelId = 'claude-sonnet-4-6' ifTrue: [^'Sonnet 4.6'].
	modelId = 'claude-haiku-4-5' ifTrue: [^'Haiku 4.5'].
	modelId = 'claude-sonnet-4-20250514' ifTrue: [^'Sonnet 4 (legacy)'].
	^modelId
)
public complete: messages <Alien[Array]>
	system: systemPrompt <String>
	tools: tools <Alien[Array]>
	maxTokens: maxTokens <Integer>
	^ <Alien[Promise]> = (
	| body headers options |

	body:: createJSObject.
	body at: 'model' put: model.
	body at: 'max_tokens' put: maxTokens.
	body at: 'messages' put: messages.
	systemPrompt isEmpty ifFalse: [
		(* Send system as a content-block array with cache_control so Anthropic
		   caches the (long, static) Newspeak prompt across turns. *)
		| sysArr textBlock cacheControl |
		sysArr:: createJSArray.
		textBlock:: createJSObject.
		textBlock at: 'type' put: 'text'.
		textBlock at: 'text' put: systemPrompt.
		cacheControl:: createJSObject.
		cacheControl at: 'type' put: 'ephemeral'.
		textBlock at: 'cache_control' put: cacheControl.
		sysArr push: textBlock.
		body at: 'system' put: sysArr.
	].
	tools isNil ifFalse: [
		(tools at: 'length') > 0 ifTrue: [
			body at: 'tools' put: tools.
		].
	].

	headers:: createJSObject.
	headers at: 'Content-Type' put: 'application/json'.
	headers at: 'x-api-key' put: apiKey.
	headers at: 'anthropic-version' put: apiVersion.
	headers at: 'anthropic-dangerous-direct-browser-access' put: 'true'.

	options:: createJSObject.
	options at: 'method' put: 'POST'.
	options at: 'headers' put: headers.
	options at: 'body' put: (JSON stringify: body).

	^(global fetch: apiUrl with: options) then: [:response |
		[
			| status statusText |
			(* See GeminiProvider doRequest: for the rationale on
			   status >= 400 and on returning Promise.reject instead of
			   raising. *)
			status:: safeAt: response field: 'status'.
			statusText:: safeAt: response field: 'statusText'.
			statusText isNil ifTrue: [statusText:: ''].
			(status isNil or: [status >= 400])
				ifTrue: [
					(global at: 'Promise') reject: ('Anthropic API error: ',
						(status isNil
							ifTrue: ['(no status)']
							ifFalse: [status printString]),
						' ', statusText)
				]
				ifFalse: [response json]
		] on: Exception do: [:e |
			(global at: 'Promise') reject: ('Anthropic provider error: ', (errorDescription: e))
		]
	]
)
public addUserText: text <String> toMessages: messages <List> = (
	| userMsg <Alien> |
	userMsg:: createJSObject.
	userMsg at: 'role' put: 'user'.
	userMsg at: 'content' put: text.
	messages add: userMsg
)
public appendAssistantResponse: response <Alien> toMessages: messages <List> = (
	(* Pull the content array from the response and store it as an
	   assistant entry. Raises on missing content (the on:Exception
	   backstop in Session.completeWithToolLoop converts the raise to
	   a JS Promise rejection). *)
	| assistantMsg <Alien> content <Alien | UndefinedObject> sr |
	content:: safeAt: response field: 'content'.
	content isNil ifTrue: [
		sr:: safeAt: response field: 'stop_reason'.
		sr isNil ifTrue: [sr:: '(absent)'].
		Error signal: 'Anthropic response missing content. stop_reason: ', sr printString
	].
	assistantMsg:: createJSObject.
	assistantMsg at: 'role' put: 'assistant'.
	assistantMsg at: 'content' put: content.
	messages add: assistantMsg
)
public messagesAsRequestPayload: messages <List> ^ <Alien[Array]> = (
	(* apiMessages already holds Anthropic-shaped entries; just JSArray-ify. *)
	| arr <Alien[Array]> |
	arr:: createJSArray.
	messages do: [:m | arr push: m].
	^arr
)
public extractTextFromResponse: response <Alien> ^ <String> = (
	(* Concatenate text from all 'text' blocks in the content array.
	   Every JS access goes through safeAt:/safeStringAt: so a
	   malformed response — including one with JS undefined leaves —
	   yields '' rather than raising into the user's chat. *)
	| content len result <String> text |
	content:: safeAt: response field: 'content'.
	len:: safeAt: content field: 'length'.
	len isNil ifTrue: [^''].
	result:: ''.
	0 to: len - 1 do: [:i <Integer> |
		| block |
		block:: safeAt: content field: i.
		((safeStringAt: block field: 'type') = 'text') ifTrue: [
			text:: safeStringAt: block field: 'text'.
			text isNil ifFalse: [result:: result, text]
		]
	].
	^result
)
public displayMessagesFromMessages: messages <List> ^ <List> = (
	(* Walks apiMessages — entries we constructed ourselves via
	   addUserText: / appendAssistantResponse: / the tool loop. We still
	   use safeStringAt: at scalar leaves because the assistant message's
	   content array carries blocks we got from the API, which can
	   include non-text blocks (tool_use, future block types) whose
	   'text' is JS undefined; isNil doesn't catch undefined.

	   For user entries with array content (tool_result messages), skip:
	   they're not for the human reader. For assistant entries, gather
	   only 'text' blocks. *)
	| result <List> |
	result:: List new.
	messages do: [:msg <Alien> |
		| role <String> content |
		role:: msg at: 'role'.
		content:: msg at: 'content'.
		role = 'user' ifTrue: [
			content isKindOfString ifTrue: [
				result add: {role. content}
			]
		].
		role = 'assistant' ifTrue: [
			| text <String> len |
			text:: ''.
			len:: safeAt: content field: 'length'.
			len isNil ifFalse: [
				0 to: len - 1 do: [:i <Integer> |
					| block t |
					block:: safeAt: content field: i.
					(safeStringAt: block field: 'type') = 'text' ifTrue: [
						t:: safeStringAt: block field: 'text'.
						t isNil ifFalse: [text:: text, t]
					]
				]
			].
			text isEmpty ifFalse: [
				result add: {role. text}
			]
		]
	].
	^result
)
public hasToolUse: response <Alien> ^ <Boolean> = (
	^(safeAt: response field: 'stop_reason') = 'tool_use'
)
public toolUseBlocksFrom: response <Alien> ^ <List> = (
	(* Filter the response's content array for blocks of type 'tool_use'.
	   Each such block has 'id', 'name', 'input' fields the Session uses
	   to dispatch the tool call. *)
	| content len blocks <List> |
	content:: safeAt: response field: 'content'.
	len:: safeAt: content field: 'length'.
	blocks:: List new.
	len isNil ifTrue: [^blocks].
	0 to: len - 1 do: [:i <Integer> |
		| block |
		block:: safeAt: content field: i.
		((safeStringAt: block field: 'type') = 'tool_use') ifTrue: [blocks add: block]
	].
	^blocks
)
public makeToolResult: id <String> content: text isError: err <Boolean> ^ <Alien> = (
	(* Build a tool_result content block referencing the original tool_use
	   by id. Anthropic carries these inside a user-role message's content
	   array — the Session.completeWithToolLoop tool-loop branch assembles
	   that wrapper. *)
	| block <Alien> |
	block:: createJSObject.
	block at: 'type' put: 'tool_result'.
	block at: 'tool_use_id' put: id.
	block at: 'content' put: text.
	err ifTrue: [block at: 'is_error' put: true].
	^block
)
public buildToolsPayload: toolDefs <List[Tool]> ^ <Alien[Array] | UndefinedObject> = (
	(* Anthropic's tools-array shape: each entry has name, description,
	   and input_schema (parsed JSON object). Returns nil if no tools, so
	   the request body's 'tools' field is omitted. *)
	| arr <Alien[Array]> |
	toolDefs isEmpty ifTrue: [^nil].
	arr:: createJSArray.
	toolDefs do: [:t <Tool> |
		| obj <Alien> |
		obj:: createJSObject.
		obj at: 'name' put: t name.
		obj at: 'description' put: t description.
		obj at: 'input_schema' put: (JSON parse: t inputSchema).
		arr push: obj
	].
	^arr
)
public addToolResults: results <Alien[Array]> toMessages: messages <List> = (
	(* Anthropic carries the round's tool_result blocks inside a single
	   user-role message whose content is the array of blocks. *)
	| msg <Alien> |
	msg:: createJSObject.
	msg at: 'role' put: 'user'.
	msg at: 'content' put: results.
	messages add: msg
)
) : (
)
public class Session provider: p <Provider> tools: toolList <List[Tool]> = (
(*
 A multi-turn AI conversation bound to one provider. Holds the message
 history, the available tools, the system prompt, and the on-update
 callback. UI code typically calls sendMessage: to drive a turn and
 displayMessages to read the conversation back for rendering.

 Session is provider-agnostic: every operation that touches message
 internals is delegated to `provider`. The history (apiMessages) is
 stored in whatever native shape `provider` builds — Session never
 inspects it directly.
*)
|
	public provider <Provider> = p.
	private toolDefs <List[Tool]> = toolList.
	private toolMap <Map[String, Tool]> = Map new.
	(* Conversation history. The shape of each entry is opaque to Session —
	   only `provider` knows what messages look like in its native API. Use
	   provider methods (addUserText:toMessages:, displayMessagesFromMessages:,
	   etc.) to inspect or mutate. *)
	public apiMessages <List[Alien]> = List new.
	public systemPrompt <String> ::= 'You are a helpful Newspeak programming assistant.'.
	public maxTokens <Integer> ::= 4096.
	(* Optional zero-arg callback invoked when conversation state changes
	   (a user message added, an assistant turn appended, an error
	   recorded). Used by chat UIs to refresh without polling. *)
	public onUpdate <[] | UndefinedObject>
|
	toolList do: [:t <Tool> | toolMap at: t name put: t].
) (
executeToolCall: toolUseBlock <Alien> ^ <Alien[Promise]> = (
	(* Resolve a tool-use block to a tool-result promise. The toolUseBlock
	   is whatever toolUseBlocksFrom: returned for this provider — by
	   contract it has 'id', 'name', 'input' top-level fields (Anthropic's
	   native tool_use block shape; GeminiProvider builds shim objects
	   with the same surface). The tool_result is constructed via the
	   provider so its wire shape stays provider-native.

	   Tool handlers may return either a synchronous value or an
	   Alien[Promise]; both are normalized to a Promise here. Errors at
	   any point (unknown tool, handler raise, handler-returned promise
	   rejection) produce an is_error tool_result that the AI sees on
	   the next turn — rather than a silent chat hang. *)
	| toolName <String | UndefinedObject> input <Alien> tool <Tool | UndefinedObject>
	  id <String | UndefinedObject> resultOrPromise stage <String> safeId <String> |
	stage:: 'read id'.
	[
		id:: toolUseBlock at: 'id'.
		stage:: 'read name'.
		toolName:: toolUseBlock at: 'name'.
		stage:: 'read input'.
		input:: toolUseBlock at: 'input'.
	] on: Exception do: [:e |
		| dump |
		dump:: [JSON stringify: toolUseBlock] on: Exception do: [:e2 | '(unstringifiable)'].
		^(global at: 'Promise') reject:
			'[executeToolCall stage: ', stage, '] ', (errorDescription: e), ' | block: ', dump
	].
	safeId:: id isNil ifTrue: ['(no id)'] ifFalse: [id].
	toolName isNil ifTrue: [
		| dump |
		dump:: [JSON stringify: toolUseBlock] on: Exception do: [:e2 | '(unstringifiable)'].
		^(global at: 'Promise') reject:
			'Tool call missing name field | block: ', dump
	].
	tool:: toolMap at: toolName ifAbsent: [
		^Promise resolve: (provider
			makeToolResult: safeId
			content: 'Unknown tool: ', toolName
			isError: true)
	].
	resultOrPromise:: [tool handler value: input]
		on: Exception
		do: [:e |
			| msg <String> |
			(* Be defensive about extracting the error message: some
			   exceptions (e.g. CannotReturn from a stale stored block)
			   raise when sent messageText, which would turn the original
			   tool failure into a silent chat hang. *)
			msg:: [
				'Error: ', e messageText
			] on: Exception do: [:e2 |
				[
					'Error: ', e printString
				] on: Exception do: [:e3 |
					'Error: <unprintable exception>'
				]
			].
			^Promise resolve: (provider
				makeToolResult: id
				content: msg
				isError: true)
		].
	(* Promise-returning handler: chain. *)
	(resultOrPromise isKindOfJSAlien and: [resultOrPromise includesKey: 'then']) ifTrue: [
		^resultOrPromise
			then: [:text | provider makeToolResult: id content: text isError: false]
			onError: [:err |
				provider
					makeToolResult: id
					content: 'Error: ', err printString
					isError: true
			]
	].
	(* Synchronous result. *)
	^Promise resolve: (provider makeToolResult: id content: resultOrPromise isError: false)
)
completeWithToolLoop ^ <Alien[Promise]> = (
	(* One turn of the conversation, with recursion to handle tool-use
	   rounds. Ships the current apiMessages to the provider, appends the
	   assistant response, and either:
	     - If the response contains tool_use blocks: execute each tool,
	       append a user-role tool_result message holding the outcomes,
	       recurse to send the results back to the model.
	     - Else: extract the assistant's text and resolve the outer
	       promise with it.

	   The entire then-block body is wrapped in on:Exception do:
	   returning a Promise.reject. Provider methods (appendAssistant-
	   Response:, missingFieldError:on:) raise on malformed responses; if
	   we let that raise unwind out of this then-closure, primordial-
	   soup's JS-Promise bridge loses the rejection (the closure's
	   rawPush: never runs and the next then-callback in the chain fires
	   with garbage on the alien stack — observed as receiving
	   document.documentElement on follow-up turns). See
	   NEWSPEAK_JS_PROMISE_NOTES_2026-05-18.md for the deep dive. *)
	^(provider
		complete: (provider messagesAsRequestPayload: apiMessages)
		system: systemPrompt
		tools: (provider buildToolsPayload: toolDefs)
		maxTokens: maxTokens
	) then: [:response |
		| stage <String> |
		stage:: 'start of then'.
		[
			stage:: 'appendAssistantResponse:'.
			provider appendAssistantResponse: response toMessages: apiMessages.

			stage:: 'hasToolUse:'.
			(provider hasToolUse: response)
				ifTrue: [
					| toolBlocks <List> promises <Alien[Array]> |
					stage:: 'toolUseBlocksFrom:'.
					toolBlocks:: provider toolUseBlocksFrom: response.
					promises:: createJSArray.
					stage:: 'executeToolCall: dispatch'.
					toolBlocks do: [:tb <Alien> | promises push: (executeToolCall: tb)].
					(* Await all tool results, then hand them to the
					   provider to wrap into a user-role message in its
					   native shape (Anthropic: content array of
					   tool_result blocks; Gemini: parts array of
					   functionResponse parts), then recurse to send
					   them back to the model. *)
					stage:: 'Promise.all then'.
					(Promise all: promises) then: [:results <Alien[Array]> |
						| innerStage <String> |
						innerStage:: 'addToolResults:toMessages:'.
						[
							provider addToolResults: results toMessages: apiMessages.
							notifyUpdate.
							innerStage:: 'recursive completeWithToolLoop'.
							completeWithToolLoop
						] on: Exception do: [:e |
							notifyUpdate.
							(global at: 'Promise') reject: ('[stage: ', innerStage, '] ', (errorDescription: e))
						]
					]
				]
				ifFalse: [
					stage:: 'notifyUpdate (no tool use)'.
					notifyUpdate.
					stage:: 'extractTextFromResponse:'.
					provider extractTextFromResponse: response
				]
		] on: Exception do: [:e |
			| dump |
			notifyUpdate.
			(* Include the raw provider response in the rejection. This is
			   the single most useful piece of context when something goes
			   wrong — protocol drift, vendor returning a new part shape,
			   or a freshly added provider following the recipe — and it
			   lets the user paste the chat error verbatim into a bug
			   report instead of us having to instrument fresh diagnostic
			   code each time the AI says something unexpected. *)
			dump:: [JSON stringify: response] on: Exception do: [:e2 | '(unstringifiable response)'].
			(global at: 'Promise') reject: ('[stage: ', stage, '] ', (errorDescription: e), ' | response: ', dump)
		]
	]
)
notifyUpdate = (
	(* Fire the on-update callback if one is wired. Used by chat UIs to
	   refresh on conversation state change without polling. *)
	onUpdate isNil ifFalse: [onUpdate value].
)
public sendMessage: text <String> ^ <Alien[Promise]> = (
	(* User-facing entry: append the user's text to the history, drive
	   the tool-loop, and return a Promise that resolves to the
	   assistant's final text. *)
	provider addUserText: text toMessages: apiMessages.
	notifyUpdate.

	^(completeWithToolLoop) then: [:responseText <String> |
		notifyUpdate.
		responseText
	]
)
public displayMessages ^ <List> = (
	(* Returns a List of {role <String>, text <String>} tuples for UI
	   rendering, in conversation order. Skips entries that don't have
	   displayable text (tool results, etc.). *)
	^provider displayMessagesFromMessages: apiMessages
)
public clearHistory = (
	(* Reset the conversation history. The provider config (model, key)
	   is untouched — the next sendMessage: starts a fresh conversation
	   on the same provider. *)
	apiMessages removeAll.
	notifyUpdate.
)
) : (
)
public class GeminiProvider apiKey: key <String> model: mdl <String> = Provider (
(*
 Provider for Google's Gemini API. Conversation messages are stored in
 Gemini's native shape:

   user message:      {role: 'user',  parts: [{text: '...'}]}
   assistant message: {role: 'model', parts: [{text: '...'}, ...]}

 The 'model' role is mapped to 'assistant' for UI rendering. complete:
 ships these straight into the request body without per-turn translation.
 The response is returned as Gemini's raw JSON;
 appendAssistantResponse: and extractTextFromResponse: navigate it
 directly via safeAt:.

 Tool calls (Gemini function-calling) are translated to and from
 Anthropic's tool-block surface so Session.completeWithToolLoop works
 uniformly across providers:

   - Outgoing: buildToolsPayload: wraps the IDE's Tool list as
     [{functionDeclarations: [...]}]. Gemini's declaration shape uses
     'parameters' rather than Anthropic's 'input_schema'.
   - Incoming functionCall parts: toolUseBlocksFrom: builds shim JS
     objects with 'id', 'name', 'input' top-level fields so the
     Session can dispatch them with no Gemini-specific path. Gemini
     does not issue tool-call ids of its own, so we synthesise one
     ('gem-N') per call and stash the call's name in pendingCallNames
     so makeToolResult: can recover it. The map is replaced (not
     accumulated) at the start of each tool-loop round.
   - Outgoing tool results: makeToolResult: builds a functionResponse
     part; addToolResults:toMessages: wraps the round's parts into a
     user-role message ({role: 'user', parts: [...]}).

 Quirks:
   - Free-tier accounts hit aggressive rate limiting (429s).
   - Gemini intermittently returns a 200-OK with empty body ({}); see
     attemptComplete:'s retry logic.
*)
|
	public apiKey <String> ::= key.
	public model <String> ::= mdl.
	private toolCallCounter <Integer> ::= 0.
	private pendingCallNames <Map[String, String]> ::= Map new.
|
) (
public availableModels ^ <List[String]> = (
	(* The set of available models on the Google API drifts faster than
	   this code can track — if you get a 404 from generateContent, the
	   model name in your chat doc is stale; pick a current one from
	   https://ai.google.dev/gemini-api/docs/models. *)
	^{
		'gemini-2.5-pro'.
		'gemini-2.5-flash'.
		'gemini-2.0-flash'.
	}
)
public displayNameFor: modelId <String> ^ <String> = (
	modelId = 'gemini-2.5-pro' ifTrue: [^'Gemini 2.5 Pro'].
	modelId = 'gemini-2.5-flash' ifTrue: [^'Gemini 2.5 Flash'].
	modelId = 'gemini-2.0-flash' ifTrue: [^'Gemini 2.0 Flash'].
	^modelId
)
public addUserText: text <String> toMessages: messages <List> = (
	| userMsg <Alien> parts <Alien[Array]> textPart <Alien> |
	parts:: createJSArray.
	textPart:: createJSObject.
	textPart at: 'text' put: text.
	parts push: textPart.
	userMsg:: createJSObject.
	userMsg at: 'role' put: 'user'.
	userMsg at: 'parts' put: parts.
	messages add: userMsg
)
public appendAssistantResponse: response <Alien> toMessages: messages <List> = (
	(* Walk candidates[0].content.parts. safeAt: returns nil on any
	   missing/malformed level and cascades through subsequent safeAt:
	   calls (which short-circuit on nil receiver), so a single terminal
	   isNil check covers every way the response can be unusable: no
	   candidates, empty candidates array (safety block, the {} anomaly
	   we retried, etc.), missing content, missing parts. The raw
	   response is dumped in missingFieldError: for diagnosis. *)
	| candidates firstCandidate firstContent parts assistantMsg <Alien> |
	candidates:: safeAt: response field: 'candidates'.
	firstCandidate:: safeAt: candidates field: 0.
	firstContent:: safeAt: firstCandidate field: 'content'.
	parts:: safeAt: firstContent field: 'parts'.
	parts isNil ifTrue: [^missingFieldError: 'candidates[0].content.parts' on: response].
	assistantMsg:: createJSObject.
	assistantMsg at: 'role' put: 'model'.
	assistantMsg at: 'parts' put: parts.
	messages add: assistantMsg
)
missingFieldError: field <String> on: response <Alien> = (
	(* Raise with the field name and the raw response stringified so the
	   user has all the diagnostic context (safety block details, error
	   bodies, model-deprecation messages, etc.) in one error string.
	   The Session.completeWithToolLoop on:Exception backstop converts
	   the raise to a JS Promise rejection. *)
	| stringified <String> |
	stringified:: [(global at: 'JSON') stringify: response]
		on: Exception do: [:e | '(unstringifiable response)'].
	Error signal: 'Gemini response missing ', field, '. Raw: ', stringified
)
public messagesAsRequestPayload: messages <List> ^ <Alien[Array]> = (
	(* apiMessages already holds Gemini-shaped entries; just JSArray-ify. *)
	| arr <Alien[Array]> |
	arr:: createJSArray.
	messages do: [:m | arr push: m].
	^arr
)
public extractTextFromResponse: response <Alien> ^ <String> = (
	(* Defensive walk of candidates[0].content.parts. Returns '' if any
	   level is absent or malformed, rather than raising into the user's
	   chat. (appendAssistantResponse: surfaces shape problems instead;
	   this method is purely for "what's the text payload?".) *)
	| candidates length firstCandidate firstContent parts result <String> text plen |
	result:: ''.
	candidates:: safeAt: response field: 'candidates'.
	length:: safeAt: candidates field: 'length'.
	(length isNil or: [length = 0]) ifTrue: [^result].
	firstCandidate:: safeAt: candidates field: 0.
	firstContent:: safeAt: firstCandidate field: 'content'.
	parts:: safeAt: firstContent field: 'parts'.
	plen:: safeAt: parts field: 'length'.
	plen isNil ifTrue: [^result].
	0 to: plen - 1 do: [:i <Integer> |
		| part |
		part:: safeAt: parts field: i.
		text:: safeStringAt: part field: 'text'.
		text isNil ifFalse: [result:: result, text]
	].
	^result
)
public displayMessagesFromMessages: messages <List> ^ <List> = (
	(* Walks apiMessages — entries we constructed ourselves via
	   addUserText: / appendAssistantResponse: / addToolResults:.
	   functionCall parts (assistant side, after tool use) and
	   functionResponse parts (user side, tool-result messages) carry no
	   text. safeStringAt: guarantees we get nil-or-real-String, never
	   JS undefined (which sneaks past isNil and crashes String concat). *)
	| result <List> |
	result:: List new.
	messages do: [:msg <Alien> |
		| role <String> displayRole <String> parts <Alien[Array]> text <String> plen |
		role:: msg at: 'role'.
		displayRole:: role = 'model' ifTrue: ['assistant'] ifFalse: [role].
		parts:: msg at: 'parts'.
		text:: ''.
		plen:: safeAt: parts field: 'length'.
		plen isNil ifFalse: [
			0 to: plen - 1 do: [:i <Integer> |
				| t |
				t:: safeStringAt: (safeAt: parts field: i) field: 'text'.
				t isNil ifFalse: [text:: text, t]
			]
		].
		text isEmpty ifFalse: [
			result add: {displayRole. text}
		]
	].
	^result
)
responsePartsOf: response <Alien> ^ <Alien | UndefinedObject> = (
	(* Pull candidates[0].content.parts defensively. Used by hasToolUse:
	   and toolUseBlocksFrom: to find functionCall parts. Returns nil if
	   any level is missing or malformed. *)
	| candidates firstCandidate firstContent |
	candidates:: safeAt: response field: 'candidates'.
	firstCandidate:: safeAt: candidates field: 0.
	firstContent:: safeAt: firstCandidate field: 'content'.
	^safeAt: firstContent field: 'parts'
)
public hasToolUse: response <Alien> ^ <Boolean> = (
	(* True if any part in the assistant's response is a functionCall.
	   Gemini does not set a tool-use-specific stop_reason; the only
	   reliable signal is a functionCall part with a non-nil name.

	   Gate on functionCall.name rather than on functionCall itself.
	   Reason: on text-only parts, safeAt: of the missing 'functionCall'
	   field may yield JS undefined rather than Newspeak nil (the alien
	   bridge isn't uniform here — see safeAt:'s docstring), and
	   `undefined isNil` is false, so a functionCall isNil ifFalse:
	   guard incorrectly admits text parts. The two-step safeAt: chain
	   ending in 'name' is reliable because safeAt: short-circuits on
	   nil receivers, and only a real functionCall has a name. *)
	| parts plen result |
	parts:: responsePartsOf: response.
	plen:: safeAt: parts field: 'length'.
	plen isNil ifTrue: [^false].
	result:: false.
	0 to: plen - 1 do: [:i <Integer> |
		| name |
		name:: safeStringAt: (safeAt: (safeAt: parts field: i) field: 'functionCall') field: 'name'.
		name isNil ifFalse: [result:: true]
	].
	^result
)
public toolUseBlocksFrom: response <Alien> ^ <List> = (
	(* Collect every functionCall part as a shim JS object that exposes
	   'id', 'name', 'input' at the top level — matching Anthropic's
	   tool_use block surface so Session.executeToolCall: needs no
	   provider-specific path. Synthesise an opaque id per call and
	   remember it under pendingCallNames so makeToolResult: can recover
	   the function name (Gemini matches function responses to calls by
	   name, not id; the id is purely a Session-side handle). The map
	   is reset here so previous-round entries don't accumulate. *)
	| parts plen blocks |
	pendingCallNames:: Map new.
	blocks:: List new.
	parts:: responsePartsOf: response.
	plen:: safeAt: parts field: 'length'.
	plen isNil ifTrue: [^blocks].
	0 to: plen - 1 do: [:i <Integer> |
		| part fc name args id shim |
		part:: safeAt: parts field: i.
		fc:: safeAt: part field: 'functionCall'.
		name:: safeStringAt: fc field: 'name'.
		(* Gate on a non-nil name, not on fc — see hasToolUse: rationale.
		   On text parts the missing functionCall surfaces as JS
		   undefined that fails isNil, so a `fc isNil ifFalse:` guard
		   would let text parts through and produce malformed shims. *)
		name isNil ifFalse: [
			args:: safeAt: fc field: 'args'.
			args isNil ifTrue: [args:: createJSObject].
			toolCallCounter:: toolCallCounter + 1.
			id:: 'gem-', toolCallCounter printString.
			pendingCallNames at: id put: name.
			shim:: createJSObject.
			shim at: 'id' put: id.
			shim at: 'name' put: name.
			shim at: 'input' put: args.
			blocks add: shim
		]
	].
	^blocks
)
public makeToolResult: id <String> content: text isError: err <Boolean> ^ <Alien> = (
	(* Build a Gemini functionResponse part. Gemini has no standard
	   is_error flag; convention is to put the failure text under
	   'error' instead of 'result' in the response payload so the model
	   sees the distinction. The function name is recovered from
	   pendingCallNames; if the id is missing (shouldn't happen in
	   normal flow) we fall back to 'unknown' so the response still
	   carries useful diagnostics. *)
	| name part funcResp respBody |
	name:: pendingCallNames at: id ifAbsent: ['unknown'].
	respBody:: createJSObject.
	err
		ifTrue: [respBody at: 'error' put: text]
		ifFalse: [respBody at: 'result' put: text].
	funcResp:: createJSObject.
	funcResp at: 'name' put: name.
	funcResp at: 'response' put: respBody.
	part:: createJSObject.
	part at: 'functionResponse' put: funcResp.
	^part
)
public buildToolsPayload: toolDefs <List[Tool]> ^ <Alien[Array] | UndefinedObject> = (
	(* Gemini's tools field shape: [{functionDeclarations: [...]}].
	   Each declaration uses 'parameters' for its JSON Schema rather
	   than Anthropic's 'input_schema'. Returns nil if no tools, so the
	   request body's 'tools' field is omitted. *)
	| arr declarations toolEntry |
	toolDefs isEmpty ifTrue: [^nil].
	declarations:: createJSArray.
	toolDefs do: [:t <Tool> |
		| decl |
		decl:: createJSObject.
		decl at: 'name' put: t name.
		decl at: 'description' put: t description.
		decl at: 'parameters' put: (JSON parse: t inputSchema).
		declarations push: decl
	].
	toolEntry:: createJSObject.
	toolEntry at: 'functionDeclarations' put: declarations.
	arr:: createJSArray.
	arr push: toolEntry.
	^arr
)
public addToolResults: results <Alien[Array]> toMessages: messages <List> = (
	(* Gemini carries the round's functionResponse parts inside a single
	   user-role message whose 'parts' is the array of parts. *)
	| msg <Alien> |
	msg:: createJSObject.
	msg at: 'role' put: 'user'.
	msg at: 'parts' put: results.
	messages add: msg
)
public complete: messages <Alien[Array]>
system: systemPrompt <String>
tools: tools <Alien[Array] | UndefinedObject>
maxTokens: maxTokens <Integer>
^ <Alien[Promise]> = (
	(* Gemini intermittently returns 200-OK with an empty body ({}) — no
	   candidates field at all. Retry up to 3 attempts before giving up.
	   Safety-blocked responses (candidates present but empty, with
	   promptFeedback) are NOT retried — only the no-candidates case is —
	   since a safety block is a real model decision, not a transient. *)
	^attemptComplete: messages
		system: systemPrompt
		tools: tools
		maxTokens: maxTokens
		triesLeft: 3
)
attemptComplete: messages <Alien[Array]>
system: systemPrompt <String>
tools: tools <Alien[Array] | UndefinedObject>
maxTokens: maxTokens <Integer>
triesLeft: triesLeft <Integer>
^ <Alien[Promise]> = (
	(* Single attempt + retry-on-empty. The recursive call is via Promise
	   chaining (return another Promise from a then: block); A+ flattens
	   so the outer Promise still resolves to the eventual response (or
	   the last empty one, when retries are exhausted — at which point
	   appendAssistantResponse: will raise via missingFieldError:). *)
	^(doRequest: messages system: systemPrompt tools: tools maxTokens: maxTokens) then: [:response <Alien> |
		| candidates |
		candidates:: safeAt: response field: 'candidates'.
		(candidates isNil and: [triesLeft > 1])
			ifTrue: [
				attemptComplete: messages
					system: systemPrompt
					tools: tools
					maxTokens: maxTokens
					triesLeft: triesLeft - 1
			]
			ifFalse: [response]
	]
)
doRequest: messages <Alien[Array]>
system: systemPrompt <String>
tools: tools <Alien[Array] | UndefinedObject>
maxTokens: maxTokens <Integer>
^ <Alien[Promise]> = (
	(* Build the request body, POST to Gemini, return a Promise that
	   resolves to the parsed JSON body (success) or rejects with a
	   diagnostic string (HTTP error or other failure). *)
	| body <Alien> headers <Alien> options <Alien> apiUrl <String> |
	body:: createJSObject.
	(* messages is already Gemini-shaped (built via addUserText: and
	   appendAssistantResponse:), so it goes straight into the body. *)
	body at: 'contents' put: messages.
	systemPrompt isEmpty ifFalse: [
		| sysInst <Alien> sysParts <Alien[Array]> textPart <Alien> |
		sysInst:: createJSObject.
		sysParts:: createJSArray.
		textPart:: createJSObject.
		textPart at: 'text' put: systemPrompt.
		sysParts push: textPart.
		sysInst at: 'parts' put: sysParts.
		body at: 'systemInstruction' put: sysInst
	].
	tools isNil ifFalse: [
		(tools at: 'length') > 0 ifTrue: [
			body at: 'tools' put: tools
		]
	].

	apiUrl:: 'https://generativelanguage.googleapis.com/v1beta/models/',
		model, ':generateContent'.
	headers:: createJSObject.
	headers at: 'Content-Type' put: 'application/json'.
	headers at: 'x-goog-api-key' put: apiKey.
	options:: createJSObject.
	options at: 'method' put: 'POST'.
	options at: 'headers' put: headers.
	options at: 'body' put: (JSON stringify: body).

	^(global fetch: apiUrl with: options) then: [:response <Alien> |
		[
			| status <Integer | UndefinedObject> statusText <String | UndefinedObject> |
			(* Check status as a number (via at:) rather than response.ok.
			   ok is a getter; primordialsoup's alien bridge does not
			   reliably invoke getters via either at: or unary sends. *)
			status:: safeAt: response field: 'status'.
			statusText:: safeAt: response field: 'statusText'.
			statusText isNil ifTrue: [statusText:: ''].
			(status isNil or: [status >= 400])
				ifTrue: [
					(* Return a JS-rejected Promise rather than `Error signal:`.
					   Raising a Newspeak exception inside a closure passed to
					   `jsPromise then:` unwinds non-locally through the alien
					   bridge BEFORE the expat's rawPush: runs, leaving the
					   alien stack in a state where the next chained then-
					   callback receives garbage. Returning Promise.reject(...)
					   keeps the rejection on the JS Promise side, which A+
					   propagates correctly. *)
					(global at: 'Promise') reject: ('Gemini API error: ',
						(status isNil
							ifTrue: ['(no status)']
							ifFalse: [status printString]),
						' ', statusText)
				]
				ifFalse: [response json]
		] on: Exception do: [:e |
			(* Backstop: any raise from inside the then-block (e.g. unexpected
			   MNU) becomes a JS-side rejection, never a non-local unwind
			   through the bridge. *)
			(global at: 'Promise') reject: ('Gemini provider error: ', (errorDescription: e))
		]
	]
)
) : (
)
(* Lazy module-body slots — must appear between class declarations and
   regular method declarations, per the Newspeak grammar's sideDecl
   ordering. Forced on first access, well after snapshot creation when
   JS aliens are live. `lazy public` is the only access form the parser
   accepts; de-facto privacy isn't compromised since nothing outside
   AIAccess references these. *)
lazy public global = retainedPlatform js global.
lazy public JSON = global at: #JSON.
lazy public Promise = global at: #Promise.
createJSObject ^ <Alien> = (
	(* Returns a fresh empty JS object (`{}`) we can populate with at:put:
	   and pass through the alien bridge. We round-trip through JSON.parse
	   rather than calling the JS Object constructor because primordialsoup
	   exposes parsed JSON values as ordinary alien receivers — direct
	   construction of `new Object()` via at:'Object'/new sometimes returns
	   handles that don't accept dynamic property writes the same way. *)
	^JSON parse: '{}'
)
createJSArray ^ <Alien> = (
	(* Sibling to createJSObject — a fresh empty JS Array, supports push:
	   and indexed at:put:. Used for building messages/contents/parts
	   arrays in provider request bodies. *)
	^JSON parse: '[]'
)
errorDescription: e <Exception> ^ <String> = (
	(* Defensive non-nil String description of an exception for
	   error reporting that crosses a String boundary — Promise.reject:
	   and markError: both blow up or surface as 'nil' if the
	   exception's messageText is nil.

	   Order:
	     1. e messageText if non-nil (the author's intent).
	     2. e class name printString — at least the kind of error.
	     3. e printString — last-ditch.
	     4. '<unprintable exception>' if even printString raises.

	   Each step is wrapped so an alien-bridge or method-lookup hiccup
	   at any layer doesn't sink the whole error path. *)
	^[
		| mt |
		mt:: [e messageText] on: Exception do: [:e2 | nil].
		mt isNil
			ifTrue: [[e class name printString] on: Exception do: [:e2 |
				[e printString] on: Exception do: [:e3 | '<unprintable exception>']]]
			ifFalse: [mt]
	] on: Exception do: [:e4 | '<unprintable exception>']
)
public webFetch: url <String> ^ <Alien[Promise]> = (
	(* Generic GET helper exposed to tools (web_fetch). Returns a Promise
	   that resolves to the response body as a String, or rejects with a
	   diagnostic string on HTTP error.

	   Like the provider doRequest: methods, we check status as a number
	   rather than response.ok (getter access via the alien bridge is
	   unreliable), and reject via Promise.reject rather than `Error
	   signal:` to avoid unwinding through the bridge from inside a
	   then-closure. *)
	| options <Alien> |
	options:: createJSObject.
	options at: 'method' put: 'GET'.
	^(global fetch: url with: options) then: [:response <Alien> |
		[
			| status <Integer | UndefinedObject> |
			status:: safeAt: response field: 'status'.
			(status isNil or: [status >= 400])
				ifTrue: [
					(global at: 'Promise') reject: ('HTTP ',
						(status isNil
							ifTrue: ['(no status)']
							ifFalse: [status printString]),
						' fetching ', url)
				]
				ifFalse: [response text]
		] on: Exception do: [:e |
			(global at: 'Promise') reject: ('webFetch error: ', (errorDescription: e))
		]
	]
)
) : (
)
