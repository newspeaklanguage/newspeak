Newspeak3
'Root'
class TwoViewEditorApp packageUsing: manifest = Object new (
	|
		private TwoViewEditor = manifest TwoViewEditor.
	|
) (
	public main: platform <HopscotchPlatform> args: args = (
		| ui = TwoViewEditor usingPlatform: platform. |
		platform hopscotch HopscotchWindow openSubject: (ui TwoViewEditorSubject initialContents: 'Edit me               ')
	)
) : ()
