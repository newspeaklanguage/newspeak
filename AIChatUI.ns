Newspeak3
'Root'
class AIChatUI usingPlatform: platform aiAccess: ai = (
(*
 Chat UI for interacting with an AI model from within the Newspeak IDE.
 Provides a ChatSubject and ChatPresenter that can be navigated to
 like any other IDE view.

 Usage:
   | chatUI provider session subject |
   chatUI:: AIChatUI usingPlatform: platform aiAccess: ai.
   subject:: chatUI AIChatSetupSubject onModel: ai AnthropicProvider.
   enterSubject: subject.
*)
|
	private List = platform collections List.
	private Subject = platform hopscotch Subject.
	private Presenter = platform hopscotch Presenter.
	private Color = platform graphics Color.
	private localStorage = platform js localStorage.
	private Session = ai Session.
|
) (
public class AIChatSetupSubject onModel: providerClass = Subject onModel: providerClass (
(*
 Subject for the initial chat setup screen where the user enters
 their API key. The model is a provider class (e.g. AnthropicProvider).
 The class name is used to derive the localStorage key for persisting
 the API key.
*)
|
	public apiKey <String> ::= ''.
	public modelName <String> ::= 'claude-sonnet-4-6'.
	public errorMessage <String>
|
	(* Try to restore API key from localStorage *)
	[apiKey:: localStorage getItem: storageKey.
	 apiKey isNil ifTrue: [apiKey:: ''].
	] on: Error do: [:e | ].
) (
storageKey ^ <String> = (
	^'ns_ai_apikey_', model name
)
public providerClass = ( ^model )
public createProvider = (
	^model apiKey: apiKey model: modelName
)
public createSession: provider = (
	^Session provider: provider tools: {}
)
public startChat ^ <ChatSubject> = (
	| provider session |
	apiKey isEmpty ifTrue: [
		errorMessage:: 'Please enter an API key.'.
		^nil
	].
	(* Persist key for convenience *)
	[localStorage setItem: storageKey to: apiKey] on: Error do: [:e | ].
	provider:: createProvider.
	session:: createSession: provider.
	^newChatSubjectFor: session
)
public newChatSubjectFor: session = (
	^ChatSubject onModel: session
)
public title ^ <String> = ( ^'AI Chat Setup' )
public createPresenter = ( ^AIChatSetupPresenter onSubject: self )
public isKindOfAIChatSetupSubject = ( ^true )
isMyKind: other = ( ^other isKindOfAIChatSetupSubject )
) : (
)
public class AIChatSetupPresenter onSubject: s = Presenter onSubject: s (
|
	keyEditor
	modelEditor
|
) (
definition = (
	^column: {
		helpSection.
		row: {
			(label: 'AI Chat Setup') bold.
			filler.
			helpButton.
			dropDownMenu: [actionsMenu].
		}.
		mediumBlank.
		label: 'Enter your API key to start a chat session.'.
		label: 'The key is stored in your browser''s localStorage.'.
		mediumBlank.
		row: {
			(label: 'API Key: ') bold.
			elastic: apiKeyField.
		}.
		mediumBlank.
		row: {
			(label: 'Model: ') bold.
			elastic: modelField.
		}.
		mediumBlank.
		errorArea.
		row: {
			filler.
			button: 'Start Chat' action: [respondToStart].
		}.
	}
)
actionsMenu = (
	^menuWithLabelsAndActions: {
		{'Inspect Presenter'. [respondToInspectPresenter]}.
	}
)
respondToInspectPresenter = (
)
public helpText ^ <Fragment> = (
	^textDisplay:
		'Use this page to configure access to an AI provider. Enter your API key in the API Key field. The key is stored in your browser''s localStorage, so you only need to enter it once. Enter the model name in the Model field, then press Start Chat.'
)
apiKeyField = (
	keyEditor:: codeMirror: subject apiKey.
	keyEditor changeResponse: [:frag |
		subject apiKey: frag textBeingAccepted.
	].
	^keyEditor
)
modelField = (
	modelEditor:: codeMirror: subject modelName.
	modelEditor changeResponse: [:frag |
		subject modelName: frag textBeingAccepted.
	].
	^modelEditor
)
errorArea = (
	subject errorMessage isNil ifTrue: [^blank: 0].
	^(label: subject errorMessage) color: (Color r: 0.8 g: 0 b: 0).
)
respondToStart = (
	| chatSubject |
	subject apiKey: keyEditor textBeingAccepted.
	subject modelName: modelEditor textBeingAccepted.
	updateGUI: [
		chatSubject:: subject startChat.
	].
	chatSubject isNil ifFalse: [
		enterSubject: chatSubject.
	].
)
public isKindOfAIChatSetupPresenter = ( ^true )
isMyKind: other = ( ^other isKindOfAIChatSetupPresenter )
) : (
)
public class ChatSubject onModel: s = Subject onModel: s (
(*
 Subject for a chat conversation. The model is an AIAccess Session.
 Exposes the conversation state and handles sending messages.
*)
|
	public draft <String> ::= ''.
	public waiting <Boolean> ::= false.
	public errorMessage <String>
|
) (
public session = ( ^model )
public messages ^ <List> = (
	^session displayMessages
)
public sendDraft ^ <Alien[Promise]> = (
	| text |
	text:: draft.
	text isEmpty ifTrue: [^nil].
	draft:: ''.
	waiting:: true.
	errorMessage:: nil.
	^session sendMessage: text
)
public sendText: text <String> ^ <Alien[Promise]> = (
	(* Send a literal text — used by the input editor's accept path so the
	   send does not depend on subject draft, which could be raced to ''
	   by CodeMirror's change event when the editor is cleared. *)
	text isEmpty ifTrue: [^nil].
	draft:: ''.
	waiting:: true.
	errorMessage:: nil.
	^session sendMessage: text
)
public markComplete = (
	waiting:: false.
)
public markError: msg <String> = (
	waiting:: false.
	errorMessage:: msg.
)
public clearHistory = (
	session clearHistory.
	draft:: ''.
	errorMessage:: nil.
)
public title ^ <String> = ( ^'Chat' )
public createPresenter = ( ^ChatPresenter onSubject: self )
public isKindOfChatSubject = ( ^true )
isMyKind: other = ( ^other isKindOfChatSubject )
) : (
)
public class ChatStatusPresenter onSubject: s = Presenter onSubject: s () (
definition = (
	subject waiting ifTrue: [
		^column: {
			(label: '…thinking…') italic.
			(label: 'Model: ', currentModelName) color: (Color r: 0.5 g: 0.5 b: 0.5).
		}
	].
	^modelPicker
)
currentModelName = (
	| provider |
	provider:: subject session provider.
	^provider displayNameFor: provider model
)
modelPicker = (
	| provider |
	provider:: subject session provider.
	^row: {
		label: 'Model: ', currentModelName, ' '.
		dropDownMenu: [
			menuWithLabelsAndActions:
				(provider availableModels collect: [:m |
					{provider displayNameFor: m.
					 [updateGUI: [provider model: m]]}
				])
		]
	}
)
public isKindOfChatStatusPresenter = ( ^true )
isMyKind: other = ( ^other isKindOfChatStatusPresenter )
) : (
)
public class ChatInputPresenter onSubject: s = Presenter onSubject: s (
|
	inputEditor
|
) (
definition = (
	inputEditor:: codeMirror: subject draft.
	(* Sync draft on each keystroke so it survives presenter refreshes. *)
	inputEditor changeResponse: [:frag | subject draft: frag textBeingAccepted].
	inputEditor acceptResponse: [:frag | respondToSend].
	^column: { inputEditor }
)
respondToSend = (
	| promise text |
	(* Capture text locally before clearing/updateGUI so the value isn't
	   raced to '' by CodeMirror's change event firing on text:''. Clear
	   and leaveEditState happen BEFORE updateGUI so the re-render replaces
	   the already-clean editor rather than a fresh one whose JS visual
	   keeps isInEditState true. *)
	text:: inputEditor textBeingAccepted.
	text isEmpty ifTrue: [^self].
	inputEditor text: ''.
	inputEditor leaveEditState.
	updateGUI: [
		promise:: subject sendText: text.
	].
	promise isNil ifTrue: [^self].
	promise
		then: [:reply | updateGUI: [subject markComplete]]
		onError: [:err | updateGUI: [subject markError: err printString]].
)
public isKindOfChatInputPresenter = ( ^true )
isMyKind: other = ( ^other isKindOfChatInputPresenter )
) : (
)
public class ChatPresenter onSubject: s = Presenter onSubject: s () (
definition = (
	^column: {
		helpSection.
		headingBar.
		mediumBlank.
		elastic: messagesArea.
		mediumBlank.
		statusFragment.
		inputFragment.
	}
)
headingBar = (
	^row: {
		(label: 'Chat') bold.
		filler.
		button: 'Clear' action: [updateGUI: [subject clearHistory]].
		helpButton.
		dropDownMenu: [actionsMenu].
	}
)
statusFragment = ( ^ChatStatusPresenter onSubject: subject )
inputFragment = ( ^ChatInputPresenter onSubject: subject )
actionsMenu = (
	^menuWithLabelsAndActions: {
		{'Inspect Presenter'. [respondToInspectPresenter]}.
	}
)
respondToInspectPresenter = (
)
public helpText ^ <Fragment> = (
	^textDisplay:
		'Chat with the configured AI provider.

Type a message in the input area at the bottom and submit it to send. The conversation history is shown above; press Clear to start a new conversation.

Just above the input there is a status block: while a request is in flight it shows ''…thinking…''; otherwise it shows the current model with a dropdown to switch. Available models (Anthropic):
  - Opus 4.7 — most capable; best for hard refactors and multi-step tool use; most expensive and highest latency.
  - Sonnet 4.6 — balanced default; good for most code lookup and editing.
  - Haiku 4.5 — fastest and cheapest; best for quick navigation and short questions.

Switching models preserves the conversation history — the next turn just goes to the new model with the full prior transcript as context. The first turn after a switch pays a one-time cache miss for the system prompt (Anthropic''s prompt cache is keyed by model); subsequent turns on the new model cache normally.

The picker is hidden while a request is in flight, to avoid switching in the middle of a tool-use loop.'
)
messagesArea = (
	| fragments |
	fragments:: List new.
	subject messages do: [:msg |
		fragments add: (messageFragment: msg).
		fragments add: smallBlank.
	].
	subject errorMessage isNil ifFalse: [
		fragments add: ((label: 'Error: ', subject errorMessage)
			color: (Color r: 0.8 g: 0 b: 0)).
	].
	fragments isEmpty ifTrue: [
		fragments add: (label: 'Send a message to start a conversation.') italic.
	].
	^column: fragments
)
public isKindOfChatPresenter = ( ^true )
isMyKind: other = ( ^other isKindOfChatPresenter )
messageFragment: msg = (
	| role text labelText bg border fontStyle |
	role:: msg at: 1.
	text:: msg at: 2.
	role = 'user'
		ifTrue: [
			labelText:: 'You'.
			bg:: outer AIChatUI userTurnBackground.
			border:: outer AIChatUI userTurnBorder.
			fontStyle:: 'italic'.
		]
		ifFalse: [
			labelText:: 'Assistant'.
			bg:: outer AIChatUI assistantTurnBackground.
			border:: outer AIChatUI assistantTurnBorder.
			fontStyle:: 'normal'.
		].
	^html: '<div style="display:flex; flex-direction:row; align-items:flex-start; border:1px solid ', border, '; border-radius:6px; padding:8px 12px; margin:4px 0; background-color:', bg, ';">',
		'<div style="min-width:5em; max-width:5em; padding-right:1em; text-align:right; flex-shrink:0;"><strong>', labelText, '</strong></div>',
		'<div style="flex:1; min-width:0;"><span style="white-space:pre-wrap; font-style:', fontStyle, ';">',
		text,
		'</span></div></div>'
)
) : (
)
public assistantTurnBackground = ( ^'#edf2ee' )
public userTurnBorder = ( ^'#b8d4ec' )
public userTurnBackground = ( ^'#eef4fb' )
public assistantTurnBorder = ( ^'#b0c8b4' )
public errorTurnBackground = ( ^'#fdecea' )
public errorTurnBorder = ( ^'#d68682' )
) : (
)
