		public asArray = (
			(* Uint8Array is array-like (has [length] and integer-indexed access),
	   which is enough for callers that pass the result to
	   [Function.prototype.apply] (e.g. String class>>withAll:). For callers
	   that need a real JS Array, [Array.from(self)] would be needed; add
	   when something breaks for that reason. *)
			
			^self
		)
		public asString ^<String> = (
			^copyStringFrom: 1 to: size
		)
		public copyByteArrayFrom: start <Integer> to: end <Integer> ^<ByteArray> = (
			(* Uint8Array.slice returns a fresh Uint8Array of the subrange. *)
			
			^_js call: (_js propertyOf: self at: (_js literal: 'slice'))
				with: {start - 1. end. }
		)
		public copyFrom: start <Integer> to: end <Integer> ^<ByteArray> = (
			^_js call: (_js propertyOf: self at: (_js literal: 'slice'))
				with: {start - 1. end. }
		)
		public copyStringFrom: start <Integer> to: end <Integer> ^<String> = (
			(* Subrange of bytes as a String. JS String.fromCharCode.apply(null, bytes) works for any ASCII-or-low-Unicode subarray. *)
			
			| sub = _js call: (_js propertyOf: self at: (_js literal: 'subarray'))
				with: {start - 1. end. }. |
			^_js call: (_js propertyOf: (_js propertyOf: (_js ident: 'String')
						at: (_js literal: 'fromCharCode'))
					at: (_js literal: 'apply'))
