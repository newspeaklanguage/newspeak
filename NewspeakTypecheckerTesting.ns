class LexicalScopeOuter = (
(* Multi-level nested class structure for testing lexical scope access *)
|
  private outerPrivateSlot <Number> = 100.
  protected outerProtectedSlot <Number> = 200.
  public outerPublicSlot <Number> = 300.
  shadowedSlot <Number> = 999.
|
) (
  (* Nested classes must come before methods *)
  public class LexicalScopeMiddle = (
  (* Level 2: Middle nested class *)
  |
    private middlePrivateSlot <Number> = 10.
    protected middleProtectedSlot <Number> = 20.
    public middlePublicSlot <Number> = 30.
    shadowedSlot <Number> = 888.
  |
  ) (
    (* Nested class must come before methods *)
    public class LexicalScopeInner = (
    (* Level 3: Innermost nested class *)
    |
      private innerPrivateSlot <Number> = 1.
      protected innerProtectedSlot <Number> = 2.
      public innerPublicSlot <Number> = 3.
      shadowedSlot <Number> = 777.
    |
    ) (
      private innerPrivateMethod ^ <Number> = (^10)
      protected innerProtectedMethod ^ <Number> = (^20)
      public innerPublicMethod ^ <Number> = (^30)
      shadowedMethod ^ <Number> = (^7777)

      (* Test methods for lexical scope access *)
      public testAccessOuterPrivateSlot ^ <Number> = (^outerPrivateSlot)
      public testAccessOuterPrivateMethod ^ <Number> = (^outerPrivateMethod)
      public testAccessMiddlePrivateSlot ^ <Number> = (^middlePrivateSlot)
      public testAccessMiddlePrivateMethod ^ <Number> = (^middlePrivateMethod)
      public testShadowing ^ <Number> = (^shadowedSlot)
    ) : ()

    private middlePrivateMethod ^ <Number> = (^100)
    protected middleProtectedMethod ^ <Number> = (^200)
    public middlePublicMethod ^ <Number> = (^300)
    shadowedMethod ^ <Number> = (^8888)

    (* Test methods for lexical scope access *)
    public testAccessOuterPrivateSlot ^ <Number> = (^outerPrivateSlot)
    public testAccessOuterPrivateMethod ^ <Number> = (^outerPrivateMethod)
    public testShadowing ^ <Number> = (^shadowedSlot)

    (*  Test methods for sibling access *)
    public testSiblingPrivateSlot = (LexicalScopeSibling new siblingPrivateSlot)
    public testSiblingPrivateMethod = (LexicalScopeSibling new siblingPrivateMethod)
    public testSiblingProtectedSlot = (LexicalScopeSibling new siblingProtectedSlot)
    public testSiblingProtectedMethod = (LexicalScopeSibling new siblingProtectedMethod)
    public testSiblingPublicSlot ^ <Number> = (^LexicalScopeSibling new siblingPublicSlot)
    public testSiblingPublicMethod ^ <Number> = (^LexicalScopeSibling new siblingPublicMethod)
  ) : ()

  public class LexicalScopeSibling = (
  (* Level 2: Sibling to Middle, for testing sibling access restrictions *)
  |
    private siblingPrivateSlot <Number> = 50.
    protected siblingProtectedSlot <Number> = 60.
    public siblingPublicSlot <Number> = 70.
  |
  ) (
    private siblingPrivateMethod ^ <Number> = (^500)
    protected siblingProtectedMethod ^ <Number> = (^600)
    public siblingPublicMethod ^ <Number> = (^700)
  ) : ()

  private outerPrivateMethod ^ <Number> = (^1000)
  protected outerProtectedMethod ^ <Number> = (^2000)
  public outerPublicMethod ^ <Number> = (^3000)
  shadowedMethod ^ <Number> = (^9999)
) : ()
class ClosureLexicalOuter = (
(* Multi-level nested class structure for testing lexical scope within closures *)
|
  private outerPrivateSlot <Number> = 100.
  protected outerProtectedSlot <Number> = 200.
  public outerPublicSlot <Number> = 300.
|
) (
  public class ClosureLexicalMiddle = (
  (* Level 2: Middle nested class with closures *)
  |
    private middlePrivateSlot <Number> = 10.
    protected middleProtectedSlot <Number> = 20.
    public middlePublicSlot <Number> = 30.
  |
  ) (
    public class ClosureLexicalInner = (
    (* Level 3: Innermost nested class with closure methods *)
    |
      private innerPrivateSlot <Number> = 1.
      protected innerProtectedSlot <Number> = 2.
      public innerPublicSlot <Number> = 3.
    |
    ) (
      (* Closure accessing outer private slot *)
      public closureAccessingOuter = (
        ^[outerPrivateSlot]
      )

      (* Closure accessing middle private slot *)
      public closureAccessingMiddle = (
        ^[middlePrivateSlot]
      )

      (* Closure accessing inner private slot *)
      public closureAccessingInner = (
        ^[innerPrivateSlot]
      )

      (* Method that takes closure and executes it *)
      public executeClosureWithParam: closure ^ <Number> = (
        ^closure value
      )

      (* Closure accessing outer private method *)
      public closureCallingOuterMethod = (
        ^[outerPrivateMethod]
      )

      (* Nested closure: closure returning closure *)
      public nestedClosureAccessingOuter = (
        ^[[outerPrivateSlot]]
      )

      (* Closure with parameter that still accesses lexical scope *)
      public closureWithParamAccessingOuter = (
        ^[:x | x + outerPrivateSlot]
      )
    ) : ()

    (* Middle class methods with closures *)
    public closureAccessingOuter = (
      ^[outerPrivateSlot]
    )

    public closureAccessingMiddle = (
      ^[middlePrivateSlot]
    )

    (* Method returning closure that accesses private slot *)
    public getClosureAccessingPrivate = (
      ^[middlePrivateSlot]
    )
  ) : ()

  private outerPrivateMethod ^ <Number> = (^1000)
  protected outerProtectedMethod ^ <Number> = (^2000)
  public outerPublicMethod ^ <Number> = (^3000)

  (* Outer method with closure accessing private slot *)
  public outerClosureAccessingPrivate = (
    ^[outerPrivateSlot]
  )
) : ()

class InheritanceLexicalBase = (
(* Base class for testing interaction between inheritance and lexical scope *)
|
  private basePrivateSlot <Number> = 1000.
  protected baseProtectedSlot <Number> = 2000.
  public basePublicSlot <Number> = 3000.
  protected overriddenSlot <Number> = 4000.
|
) (
  private basePrivateMethod ^ <Number> = (^10000)
  protected baseProtectedMethod ^ <Number> = (^20000)
  public basePublicMethod ^ <Number> = (^30000)
  protected overriddenMethod ^ <Number> = (^40000)
) : ()

class InheritanceLexicalDerived = InheritanceLexicalBase (
(* Derived class with nested inner class to test lexical scope + inheritance *)
|
  private derivedPrivateSlot <Number> = 100.
  protected derivedProtectedSlot <Number> = 200.
  public derivedPublicSlot <Number> = 300.
  protected overriddenSlot <Integer> = 400.
|
) (
  (* Nested class must come before methods *)
  public class InnerClass = (
  (* Inner class that tests access to derived and inherited members *)
  |
    private innerPrivateSlot <Number> = 10.
    protected innerProtectedSlot <Number> = 20.
    public innerPublicSlot <Number> = 30.
  |
  ) (
    (* Note: Inner class can only access members lexically defined in the derived class,
       not inherited members. Lexical scope is about textual structure, not inheritance. *)
  ) : ()

  private derivedPrivateMethod ^ <Number> = (^1000)
  protected derivedProtectedMethod ^ <Number> = (^2000)
  public derivedPublicMethod ^ <Number> = (^3000)
  protected overriddenMethod ^ <Integer> = (^4000)
) : ()

