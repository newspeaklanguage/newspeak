		public sendTo: receiver = (
			(* DNU only on genuine lookup failure. If the method IS found, any
     exception it raises must propagate untouched to the surrounding
     on:do: machinery — the previous version caught such exceptions and
     converted them into a DNU on the original selector, masking real
     errors (e.g. a ParserError inside compileClassSource:within: was
     reported as MessageNotUnderstood: compileClassSource:within:). *)

			| f |
			f:: _js propertyOf: receiver at: mangledSelector.
			((_js prefixOperator: 'typeof ' on: f) == 'function') ifFalse: [
					^_js call: (_js propertyOf: receiver at: (_js literal: 'dnu'))
						with: {self. }
