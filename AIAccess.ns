Newspeak3
'Root'
class AIAccess usingPlatform: platform = (
(*
 Provides AI model access from Newspeak. Supports multiple providers
 via the Provider abstraction. Manages multi-turn conversations with
 tool use (function calling), enabling an AI to query the IDE and vice versa.

 Usage:
   | ai provider session |
   ai:: AIAccess usingPlatform: platform.
   provider:: ai AnthropicProvider apiKey: 'sk-...' model: 'claude-sonnet-4-20250514'.
   session:: ai Session provider: provider tools: {}.
   session systemPrompt:: 'You are a Newspeak programming assistant.'.
   (session sendMessage: 'What is Newspeak?') then: [:reply | transcript show: reply].
*)
|
	private List = platform collections List.
	private Map = platform collections Map.
	private global = platform js global.
	private JSON = global at: #JSON.
	private Promise = global at: #Promise.
|
) (
public class Tool name: n description: d inputSchema: s handler: h = (
|
	public name <String> = n.
	public description <String> = d.
	public inputSchema <String> = s.
	public handler = h.
|
) (
) : (
)
public class Provider = (
) (
public complete: messages <Alien[Array]>
	system: systemPrompt <String>
	tools: tools <Alien[Array]>
	maxTokens: maxTokens <Integer>
	^ <Alien[Promise]> = (
	subclassResponsibility
)
) : (
)
public class AnthropicProvider apiKey: key model: mdl = Provider (
|
	public apiKey <String> = key.
	(* Mutable so the chat UI can switch models mid-session. The session's
	   history is untouched — the next turn just goes to the new model. *)
	public model <String> ::= mdl.
	private apiUrl = 'https://api.anthropic.com/v1/messages'.
	private apiVersion = '2023-06-01'.
|
) (
public availableModels ^ <List[String]> = (
	^{
		'claude-opus-4-7'.
		'claude-sonnet-4-6'.
		'claude-haiku-4-5'.
		'claude-sonnet-4-20250514'.  (* legacy default, for back-compat *)
	}
)
public displayNameFor: modelId <String> ^ <String> = (
	modelId = 'claude-opus-4-7' ifTrue: [^'Opus 4.7'].
	modelId = 'claude-sonnet-4-6' ifTrue: [^'Sonnet 4.6'].
	modelId = 'claude-haiku-4-5' ifTrue: [^'Haiku 4.5'].
	modelId = 'claude-sonnet-4-20250514' ifTrue: [^'Sonnet 4 (legacy)'].
	^modelId
)
public complete: messages <Alien[Array]>
	system: systemPrompt <String>
	tools: tools <Alien[Array]>
	maxTokens: maxTokens <Integer>
	^ <Alien[Promise]> = (
	| body headers options |

	body:: createJSObject.
	body at: 'model' put: model.
	body at: 'max_tokens' put: maxTokens.
	body at: 'messages' put: messages.
	systemPrompt isEmpty ifFalse: [
		(* Send system as a content-block array with cache_control so Anthropic
		   caches the (long, static) Newspeak prompt across turns. *)
		| sysArr textBlock cacheControl |
		sysArr:: createJSArray.
		textBlock:: createJSObject.
		textBlock at: 'type' put: 'text'.
		textBlock at: 'text' put: systemPrompt.
		cacheControl:: createJSObject.
		cacheControl at: 'type' put: 'ephemeral'.
		textBlock at: 'cache_control' put: cacheControl.
		sysArr push: textBlock.
		body at: 'system' put: sysArr.
	].
	tools isNil ifFalse: [
		(tools at: 'length') > 0 ifTrue: [
			body at: 'tools' put: tools.
		].
	].

	headers:: createJSObject.
	headers at: 'Content-Type' put: 'application/json'.
	headers at: 'x-api-key' put: apiKey.
	headers at: 'anthropic-version' put: apiVersion.
	headers at: 'anthropic-dangerous-direct-browser-access' put: 'true'.

	options:: createJSObject.
	options at: 'method' put: 'POST'.
	options at: 'headers' put: headers.
	options at: 'body' put: (JSON stringify: body).

	^(global fetch: apiUrl with: options) then: [:response |
		(response at: 'ok')
			ifFalse: [
				Error signal: 'Anthropic API error: ',
					(response at: 'status') printString,
					' ', (response at: 'statusText')
			].
		response json
	]
)
) : (
)
public class Session provider: p tools: toolList = (
|
	public provider <Provider> = p.
	private toolDefs = toolList.
	private toolMap = Map new.
	(* Full API message history, including tool_use/tool_result messages.
	   Each element is an Alien (JS message object). *)
	public apiMessages = List new.
	public systemPrompt <String> ::= 'You are a helpful Newspeak programming assistant.'.
	public maxTokens <Integer> ::= 4096.
	(* Optional callback invoked when conversation state changes. *)
	public onUpdate
|
	toolList do: [:t <Tool> | toolMap at: t name put: t].
) (
buildToolsJS ^ <Alien> = (
	| arr |
	toolDefs isEmpty ifTrue: [^nil].
	arr:: createJSArray.
	toolDefs do: [:t |
		| obj |
		obj:: createJSObject.
		obj at: 'name' put: t name.
		obj at: 'description' put: t description.
		obj at: 'input_schema' put: (JSON parse: t inputSchema).
		arr push: obj.
	].
	^arr
)
apiMessagesAsJSArray ^ <Alien> = (
	| arr |
	arr:: createJSArray.
	apiMessages do: [:m | arr push: m].
	^arr
)
extractTextFrom: response ^ <String> = (
	| content result |
	content:: response at: 'content'.
	result:: ''.
	0 to: (content at: 'length') - 1 do: [:i |
		| block |
		block:: content at: i.
		(block at: 'type') = 'text' ifTrue: [
			result:: result, (block at: 'text').
		].
	].
	^result
)
hasToolUse: response ^ <Boolean> = (
	^(response at: 'stop_reason') = 'tool_use'
)
toolUseBlocksFrom: response ^ <List> = (
	| content blocks |
	content:: response at: 'content'.
	blocks:: List new.
	0 to: (content at: 'length') - 1 do: [:i |
		| block |
		block:: content at: i.
		(block at: 'type') = 'tool_use' ifTrue: [
			blocks add: block.
		].
	].
	^blocks
)
executeToolCall: toolUseBlock ^ <Alien[Promise]> = (
	| toolName input tool id resultOrPromise |
	id:: toolUseBlock at: 'id'.
	toolName:: toolUseBlock at: 'name'.
	input:: toolUseBlock at: 'input'.
	tool:: toolMap at: toolName ifAbsent: [
		^Promise resolve: (makeToolResult: id
			content: 'Unknown tool: ', toolName
			isError: true)
	].
	resultOrPromise:: [tool handler value: input]
		on: Exception
		do: [:e |
			| msg |
			(* Be defensive about extracting the error message: some
			   exceptions (e.g. CannotReturn from a stale stored block)
			   raise when sent messageText, which would turn the original
			   tool failure into a silent chat hang. Fall back to
			   printString, then a generic placeholder. *)
			msg:: [
				'Error: ', e messageText
			] on: Exception do: [:e2 |
				[
					'Error: ', e printString
				] on: Exception do: [:e3 |
					'Error: <unprintable exception>'
				]
			].
			^Promise resolve: (makeToolResult: id
				content: msg
				isError: true)
		].
	(* Promise-returning handler: chain. *)
	(resultOrPromise isKindOfJSAlien and: [resultOrPromise includesKey: 'then']) ifTrue: [
		^resultOrPromise
			then: [:text | makeToolResult: id content: text isError: false]
			onError: [:err |
				makeToolResult: id
					content: 'Error: ', err printString
					isError: true
			]
	].
	(* Synchronous result. *)
	^Promise resolve: (makeToolResult: id content: resultOrPromise isError: false)
)
makeToolResult: id content: text isError: err ^ <Alien> = (
	| block |
	block:: createJSObject.
	block at: 'type' put: 'tool_result'.
	block at: 'tool_use_id' put: id.
	block at: 'content' put: text.
	err ifTrue: [block at: 'is_error' put: true].
	^block
)
completeWithToolLoop ^ <Alien[Promise]> = (
	^(provider
		complete: apiMessagesAsJSArray
		system: systemPrompt
		tools: buildToolsJS
		maxTokens: maxTokens
	) then: [:response |
		| assistantMsg content |
		(* Defensive: we have observed intermittent 200-OK responses with no
		   content array (CDN edge case / refusal-with-no-body / transient
		   server-side glitch). Failing fast here keeps the history clean —
		   storing an undefined content corrupts apiMessages and breaks every
		   subsequent send. *)
		content:: response at: 'content'.
		content isNil ifTrue: [
			Error signal: 'API response missing content. stop_reason: ',
				([(response at: 'stop_reason') printString]
					on: Error do: [:e | '(absent)'])
		].
		assistantMsg:: createJSObject.
		assistantMsg at: 'role' put: 'assistant'.
		assistantMsg at: 'content' put: content.
		apiMessages add: assistantMsg.

		(hasToolUse: response)
			ifTrue: [
				| toolBlocks promises |
				toolBlocks:: toolUseBlocksFrom: response.
				promises:: createJSArray.
				toolBlocks do: [:tb | promises push: (executeToolCall: tb)].
				(* Await all tool results, then continue the conversation. *)
				(Promise all: promises) then: [:results |
					| toolResultMsg |
					toolResultMsg:: createJSObject.
					toolResultMsg at: 'role' put: 'user'.
					toolResultMsg at: 'content' put: results.
					apiMessages add: toolResultMsg.
					notifyUpdate.
					completeWithToolLoop
				]
			]
			ifFalse: [
				notifyUpdate.
				extractTextFrom: response
			]
	]
)
notifyUpdate = (
	onUpdate isNil ifFalse: [onUpdate value].
)
public sendMessage: text <String> ^ <Alien[Promise]> = (
	| userMsg |
	userMsg:: createJSObject.
	userMsg at: 'role' put: 'user'.
	userMsg at: 'content' put: text.
	apiMessages add: userMsg.
	notifyUpdate.

	^(completeWithToolLoop) then: [:responseText |
		notifyUpdate.
		responseText
	]
)
public displayMessages ^ <List> = (
	| result |
	result:: List new.
	apiMessages do: [:msg |
		| role |
		role:: msg at: 'role'.
		role = 'user' ifTrue: [
			| content |
			content:: msg at: 'content'.
			(* User messages with string content are user-typed text.
			   User messages with array content are tool results (skip). *)
			content isKindOfString ifTrue: [
				result add: {role. content}.
			].
		].
		role = 'assistant' ifTrue: [
			| text content |
			text:: ''.
			content:: msg at: 'content'.
			(* Defensive: prior to the completeWithToolLoop content-validation
			   fix, an undefined-content response could end up in history.
			   Don't crash the UI when rendering such a message. *)
			content isNil ifFalse: [
				0 to: (content at: 'length') - 1 do: [:i |
					| block |
					block:: content at: i.
					(block at: 'type') = 'text' ifTrue: [
						text:: text, (block at: 'text').
					].
				].
			].
			text isEmpty ifFalse: [
				result add: {role. text}.
			].
		].
	].
	^result
)
public clearHistory = (
	apiMessages removeAll.
	notifyUpdate.
)
) : (
)
public class GeminiProvider apiKey: key model: mdl = Provider (
|
	public apiKey <String> ::= key.
	public model <String> ::= mdl.
|
) (
public availableModels ^ <List[String]> = (
	^{
		'gemini-1.5-pro-latest'.
		'gemini-1.5-flash-latest'.
	}
)
public displayNameFor: modelId <String> ^ <String> = (
	modelId = 'gemini-1.5-pro-latest' ifTrue: [^'Gemini 1.5 Pro'].
	modelId = 'gemini-1.5-flash-latest' ifTrue: [^'Gemini 1.5 Flash'].
	^modelId
)
public complete: messages <Alien[Array]>
system: systemPrompt <String>
tools: tools <Alien[Array]>
maxTokens: maxTokens <Integer>
^ <Alien[Promise]> = (
	| body headers options apiUrl geminiContents sysInst |
	
	body:: createJSObject.
	
	(* 1. Translate standard messages array to Gemini 'contents' format *)
	geminiContents:: createJSArray.
	0 to: (messages at: 'length') - 1 do: [:i |
		| msg geminiMsg parts textPart role |
		msg:: messages at: i.
		geminiMsg:: createJSObject.
		
		(* Map 'assistant' role to 'model' for Gemini *)
		role:: msg at: 'role'.
		role = 'assistant' 
			ifTrue: [geminiMsg at: 'role' put: 'model']
			ifFalse: [geminiMsg at: 'role' put: role].
			
		parts:: createJSArray.
		textPart:: createJSObject.
		textPart at: 'text' put: (msg at: 'content').
		parts push: textPart.
		
		geminiMsg at: 'parts' put: parts.
		geminiContents push: geminiMsg.
	].
	body at: 'contents' put: geminiContents.

	(* 2. Handle System Prompt *)
	systemPrompt isEmpty ifFalse: [
		| sysParts textPart |
		sysInst:: createJSObject.
		sysParts:: createJSArray.
		textPart:: createJSObject.
		textPart at: 'text' put: systemPrompt.
		sysParts push: textPart.
		sysInst at: 'parts' put: sysParts.
		body at: 'systemInstruction' put: sysInst.
	].

	(* Note: Tool translation omitted here for brevity, 
	   but would follow a similar mapping to Gemini's FunctionDeclaration *)

	apiUrl:: 'https://generativelanguage.googleapis.com/v1beta/models/' , model , ':generateContent'.

	headers:: createJSObject.
	headers at: 'Content-Type' put: 'application/json'.
	headers at: 'x-goog-api-key' put: apiKey.

	options:: createJSObject.
	options at: 'method' put: 'POST'.
	options at: 'headers' put: headers.
	options at: 'body' put: (JSON stringify: body).

^(global fetch: apiUrl with: options) then: [:response |
		(response at: 'ok')
			ifFalse: [
				Error signal: 'Gemini API error: ', 
					(response at: 'status') printString, ' ', 
					(response at: 'statusText')
			].
		
		(* Parse the JSON, then translate it to the IDE's expected format *)
		response json then: [:geminiJson |
			| mockResponse contentArray candidates firstCandidate parts |
			
			mockResponse:: createJSObject.
			contentArray:: createJSArray.
			
			candidates:: geminiJson at: 'candidates'.
			(candidates isNil not and: [(candidates at: 'length') > 0]) ifTrue: [
				firstCandidate:: candidates at: 0.
				parts:: (firstCandidate at: 'content') at: 'parts'.
				
				0 to: (parts at: 'length') - 1 do: [:i |
					| part textBlock |
					part:: parts at: i.
					(part at: 'text') isNil ifFalse: [
						textBlock:: createJSObject.
						textBlock at: 'type' put: 'text'.
						textBlock at: 'text' put: (part at: 'text').
						contentArray push: textBlock.
					].
				].
			].
			
			mockResponse at: 'content' put: contentArray.
			(* Satisfy the stop_reason check in completeWithToolLoop *)
			mockResponse at: 'stop_reason' put: 'end_turn'. 
			
			mockResponse
		]
	]
)
) : (
)
createJSObject ^ <Alien> = (
	^JSON parse: '{}'
)
createJSArray ^ <Alien> = (
	^JSON parse: '[]'
)
public webFetch: url <String> ^ <Alien[Promise]> = (
	| options |
	options:: createJSObject.
	options at: 'method' put: 'GET'.
	^(global fetch: url with: options) then: [:response |
		(response at: 'ok') ifFalse: [
			Error signal: 'HTTP ', (response at: 'status') printString, ' fetching ', url
		].
		response text
	]
)
) : (
)
