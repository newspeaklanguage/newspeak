Newspeak3
'Mirrors'
class SqueakMirrorTestingConfiguration packageTestsUsing: ideNamespace = Object new (
	|
		SqueakMirrorTesting = ideNamespace SqueakMirrorTesting.
	|
) (
	public testModulesUsingPlatform: platform minitest: minitest ^<{MirrorTesting}> = (
		^{SqueakMirrorTesting usingPlatform: platform minitest: minitest. }
	)
) : ()
