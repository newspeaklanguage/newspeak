		)
		public stepInto ^<ThreadMirror> = (
			thread stepInto: reflectee.
			^threadMirror
		)
		public stepOut ^<ThreadMirror> = (
			thread stepOut: reflectee.
			^threadMirror
		)
		public stepOver ^<ThreadMirror> = (
			thread stepOver: reflectee.
			^threadMirror
		)
		public stepThrough ^<ThreadMirror> = (
