Newspeak3
'Root'
class AIChatUI usingPlatform: platform aiAccess: ai = (
(*
 Chat UI for interacting with an AI model from within the Newspeak IDE.
 Provides a ChatSubject and ChatPresenter that can be navigated to
 like any other IDE view.

 Usage:
   | chatUI provider session subject |
   chatUI:: AIChatUI usingPlatform: platform aiAccess: ai.
   subject:: chatUI AIChatSetupSubject onModel: ai AnthropicProvider.
   enterSubject: subject.
*)
|
	private List = platform collections List.
	private Subject = platform hopscotch Subject.
	private Presenter = platform hopscotch Presenter.
	private Color = platform graphics Color.
	private localStorage = platform js localStorage.
	private Session = ai Session.
|
) (
public class AIChatSetupSubject onModel: providerClass <Class> = Subject onModel: providerClass (
(*
 Subject for the initial chat setup screen where the user enters
 their API key and chooses a model. The Subject's model is the
 provider *class* (e.g. AnthropicProvider) — not an instance, since
 the instance is what startChat will construct from the key+model
 the user types here. The class name is used to derive a per-provider
 localStorage key so each provider's key is remembered independently.
*)
|
	public apiKey <String> ::= ''.
	public modelName <String> ::= 'claude-sonnet-4-6'.
	public errorMessage <String | UndefinedObject>
|
	(* Best-effort restore of the API key. localStorage may be unavailable
	   (private browsing, embedded contexts); on any failure we just leave
	   apiKey as ''. *)
	[apiKey:: localStorage getItem: storageKey.
	 apiKey isNil ifTrue: [apiKey:: ''].
	] on: Error do: [:e | ].
) (
storageKey ^ <String> = (
	(* Per-provider key so switching between Anthropic and Gemini doesn't
	   clobber the other's stored API key. *)
	^'ns_ai_apikey_', model name
)
public providerClass ^ <Class> = ( ^model )
public createProvider ^ <Provider> = (
	^model apiKey: apiKey model: modelName
)
public createSession: provider <Provider> ^ <Session> = (
	^Session provider: provider tools: {}
)
public startChat ^ <ChatSubject | UndefinedObject> = (
	(* Validate, persist the key, build a session, and return a ChatSubject
	   the caller can navigate to. Returns nil (and sets errorMessage) if
	   the form is incomplete — caller checks for nil before navigating. *)
	| provider <Provider> session <Session> |
	apiKey isEmpty ifTrue: [
		errorMessage:: 'Please enter an API key.'.
		^nil
	].
	[localStorage setItem: storageKey to: apiKey] on: Error do: [:e | ].
	provider:: createProvider.
	session:: createSession: provider.
	^newChatSubjectFor: session
)
public newChatSubjectFor: session <Session> ^ <ChatSubject> = (
	^ChatSubject onModel: session
)
public title ^ <String> = ( ^'AI Chat Setup' )
public createPresenter = ( ^AIChatSetupPresenter onSubject: self )
public isKindOfAIChatSetupSubject ^ <Boolean> = ( ^true )
isMyKind: other ^ <Boolean> = ( ^other isKindOfAIChatSetupSubject )
) : (
)
public class AIChatSetupPresenter onSubject: s = Presenter onSubject: s (
(*
 Presenter for the AIChatSetupSubject. Renders the API-key + model entry
 form, and on submit invokes subject startChat which (if validation
 passes) returns a ChatSubject we navigate to via enterSubject:.
*)
|
	keyEditor
	modelEditor
|
) (
definition = (
	^column: {
		helpSection.
		row: {
			(label: 'AI Chat Setup') bold.
			filler.
			helpButton.
			dropDownMenu: [actionsMenu].
		}.
		mediumBlank.
		label: 'Enter your API key to start a chat session.'.
		label: 'The key is stored in your browser''s localStorage.'.
		mediumBlank.
		row: {
			(label: 'API Key: ') bold.
			elastic: apiKeyField.
		}.
		mediumBlank.
		row: {
			(label: 'Model: ') bold.
			elastic: modelField.
		}.
		mediumBlank.
		errorArea.
		row: {
			filler.
			button: 'Start Chat' action: [respondToStart].
		}.
	}
)
actionsMenu = (
	^menuWithLabelsAndActions: {
		{'Inspect Presenter'. [respondToInspectPresenter]}.
	}
)
respondToInspectPresenter = (
)
public helpText ^ <Fragment> = (
	^textDisplay:
		'Use this page to configure access to an AI provider. Enter your API key in the API Key field. The key is stored in your browser''s localStorage, so you only need to enter it once. Enter the model name in the Model field, then press Start Chat.'
)
apiKeyField = (
	(* Keystroke-sync into the subject so the value survives presenter
	   refreshes — same pattern as ChatInputPresenter's inputEditor. *)
	keyEditor:: codeMirror: subject apiKey.
	keyEditor changeResponse: [:frag |
		subject apiKey: frag textBeingAccepted.
	].
	^keyEditor
)
modelField = (
	modelEditor:: codeMirror: subject modelName.
	modelEditor changeResponse: [:frag |
		subject modelName: frag textBeingAccepted.
	].
	^modelEditor
)
errorArea = (
	subject errorMessage isNil ifTrue: [^blank: 0].
	^(label: subject errorMessage) color: (Color r: 0.8 g: 0 b: 0).
)
respondToStart = (
	(* Re-read the editors before delegating to the subject (defensive —
	   change response should already have synced, but a missed
	   notification would silently send the previous draft). If startChat
	   succeeds, navigate to the new ChatSubject; on validation failure it
	   returns nil and writes errorMessage which the next render shows. *)
	| chatSubject <ChatSubject | UndefinedObject> |
	subject apiKey: keyEditor textBeingAccepted.
	subject modelName: modelEditor textBeingAccepted.
	updateGUI: [
		chatSubject:: subject startChat.
	].
	chatSubject isNil ifFalse: [
		enterSubject: chatSubject.
	].
)
public isKindOfAIChatSetupPresenter ^ <Boolean> = ( ^true )
isMyKind: other ^ <Boolean> = ( ^other isKindOfAIChatSetupPresenter )
) : (
)
public class ChatSubject onModel: s <Session> = Subject onModel: s (
(*
 Subject for a chat conversation. The Subject's model is an AIAccess
 Session, which owns the actual API messages and tool list. ChatSubject
 layers per-UI state on top: the in-progress draft, the waiting flag
 (true while a request is in flight, used to swap the status presenter
 between "…thinking…" and the model picker), and a transient
 errorMessage shown after a failed turn.
*)
|
	public draft <String> ::= ''.
	public waiting <Boolean> ::= false.
	public errorMessage <String | UndefinedObject>
|
) (
public session ^ <Session> = ( ^model )
public messages ^ <List> = (
	^session displayMessages
)
public sendDraft ^ <Alien[Promise] | UndefinedObject> = (
	(* Legacy path: send whatever is currently in draft. The new input
	   editor uses sendText: instead (see comment there for why). Kept so
	   external callers (programmatic chats) can still send-by-draft. *)
	| text <String> |
	text:: draft.
	text isEmpty ifTrue: [^nil].
	draft:: ''.
	waiting:: true.
	errorMessage:: nil.
	^session sendMessage: text
)
public sendText: text <String> ^ <Alien[Promise] | UndefinedObject> = (
	(* Send a literal text — used by the input editor's accept path so the
	   send does not depend on subject draft, which could be raced to ''
	   by CodeMirror's change event when the editor is cleared. *)
	text isEmpty ifTrue: [^nil].
	draft:: ''.
	waiting:: true.
	errorMessage:: nil.
	^session sendMessage: text
)
public markComplete = (
	waiting:: false.
)
public markError: msg <String> = (
	waiting:: false.
	errorMessage:: msg.
)
public clearHistory = (
	session clearHistory.
	draft:: ''.
	errorMessage:: nil.
)
public title ^ <String> = ( ^'Chat' )
public createPresenter = ( ^ChatPresenter onSubject: self )
public isKindOfChatSubject ^ <Boolean> = ( ^true )
isMyKind: other ^ <Boolean> = ( ^other isKindOfChatSubject )
) : (
)
public class ChatStatusPresenter onSubject: s = Presenter onSubject: s (
(*
 The status block above the input editor. While a request is in flight
 (subject waiting = true) shows "…thinking…" and the current model;
 otherwise shows a model picker dropdown so the user can swap models
 between turns without losing history. The picker is intentionally
 hidden mid-flight to avoid switching providers/models inside a
 tool-use loop.
*)
) (
definition = (
	subject waiting ifTrue: [
		^column: {
			(label: '…thinking…') italic.
			(label: 'Model: ', currentModelName) color: (Color r: 0.5 g: 0.5 b: 0.5).
		}
	].
	^modelPicker
)
currentModelName ^ <String> = (
	| provider <Provider> |
	provider:: subject session provider.
	^provider displayNameFor: provider model
)
modelPicker = (
	| provider <Provider> |
	provider:: subject session provider.
	^row: {
		label: 'Model: ', currentModelName, ' '.
		dropDownMenu: [
			menuWithLabelsAndActions:
				(provider availableModels collect: [:m <String> |
					{provider displayNameFor: m.
					 [updateGUI: [provider model: m]]}
				])
		]
	}
)
public isKindOfChatStatusPresenter ^ <Boolean> = ( ^true )
isMyKind: other ^ <Boolean> = ( ^other isKindOfChatStatusPresenter )
) : (
)
public class ChatInputPresenter onSubject: s = Presenter onSubject: s (
(*
 The CodeMirror editor below the messages area. On accept (Enter/submit)
 captures the text, clears the editor, and routes the send through
 subject sendText: — the Promise resolution updates the waiting flag
 via markComplete / markError:.
*)
|
	inputEditor
|
) (
definition = (
	inputEditor:: codeMirror: subject draft.
	(* Sync draft on each keystroke so it survives presenter refreshes. *)
	inputEditor changeResponse: [:frag | subject draft: frag textBeingAccepted].
	inputEditor acceptResponse: [:frag | respondToSend].
	^column: { inputEditor }
)
respondToSend = (
	(* Capture text locally before clearing/updateGUI so the value isn't
	   raced to '' by CodeMirror's change event firing on text:''. Clear
	   and leaveEditState happen BEFORE updateGUI so the re-render replaces
	   the already-clean editor rather than a fresh one whose JS visual
	   keeps isInEditState true. *)
	| promise <Alien[Promise] | UndefinedObject> text <String> |
	text:: inputEditor textBeingAccepted.
	text isEmpty ifTrue: [^self].
	inputEditor text: ''.
	inputEditor leaveEditState.
	updateGUI: [
		promise:: subject sendText: text.
	].
	promise isNil ifTrue: [^self].
	promise
		then: [:reply | updateGUI: [subject markComplete]]
		onError: [:err | updateGUI: [subject markError: err printString]].
)
public isKindOfChatInputPresenter ^ <Boolean> = ( ^true )
isMyKind: other ^ <Boolean> = ( ^other isKindOfChatInputPresenter )
) : (
)
public class ChatPresenter onSubject: s = Presenter onSubject: s (
(*
 Top-level presenter for a chat conversation. Composes three sub-areas:

   messagesArea  scrollable transcript of prior turns (built from
                 subject messages — a List of {role. text} pairs).
   statusFragment  the "thinking" indicator / model picker
                   (delegated to ChatStatusPresenter so it can refresh
                   independently of the messages area).
   inputFragment   the CodeMirror input editor + send wiring
                   (delegated to ChatInputPresenter).

 Splitting the status and input into their own presenters lets the
 chat-as-document path in AI_IDE_Support reuse them by stacking
 dedicated thinking/input ampletes around the document body.
*)
) (
definition = (
	^column: {
		helpSection.
		headingBar.
		mediumBlank.
		elastic: messagesArea.
		mediumBlank.
		statusFragment.
		inputFragment.
	}
)
headingBar = (
	^row: {
		(label: 'Chat') bold.
		filler.
		button: 'Clear' action: [updateGUI: [subject clearHistory]].
		helpButton.
		dropDownMenu: [actionsMenu].
	}
)
statusFragment = ( ^ChatStatusPresenter onSubject: subject )
inputFragment = ( ^ChatInputPresenter onSubject: subject )
actionsMenu = (
	^menuWithLabelsAndActions: {
		{'Inspect Presenter'. [respondToInspectPresenter]}.
	}
)
respondToInspectPresenter = (
)
public helpText ^ <Fragment> = (
	^textDisplay:
		'Chat with the configured AI provider.

Type a message in the input area at the bottom and submit it to send. The conversation history is shown above; press Clear to start a new conversation.

Just above the input there is a status block: while a request is in flight it shows ''…thinking…''; otherwise it shows the current model with a dropdown to switch. Available models (Anthropic):
  - Opus 4.7 — most capable; best for hard refactors and multi-step tool use; most expensive and highest latency.
  - Sonnet 4.6 — balanced default; good for most code lookup and editing.
  - Haiku 4.5 — fastest and cheapest; best for quick navigation and short questions.

Switching models preserves the conversation history — the next turn just goes to the new model with the full prior transcript as context. The first turn after a switch pays a one-time cache miss for the system prompt (Anthropic''s prompt cache is keyed by model); subsequent turns on the new model cache normally.

The picker is hidden while a request is in flight, to avoid switching in the middle of a tool-use loop.'
)
messagesArea = (
	| fragments <List> |
	fragments:: List new.
	subject messages do: [:msg <Array> |
		fragments add: (messageFragment: msg).
		fragments add: smallBlank.
	].
	subject errorMessage isNil ifFalse: [
		fragments add: ((label: 'Error: ', subject errorMessage)
			color: (Color r: 0.8 g: 0 b: 0)).
	].
	fragments isEmpty ifTrue: [
		fragments add: (label: 'Send a message to start a conversation.') italic.
	].
	^column: fragments
)
public isKindOfChatPresenter ^ <Boolean> = ( ^true )
isMyKind: other ^ <Boolean> = ( ^other isKindOfChatPresenter )
messageFragment: msg <Array> = (
	(* msg is a two-element {role <String>. text <String>} pair, as built
	   by the provider's displayMessagesFromMessages:. The role determines
	   the colour and label; the text is rendered with white-space:pre-wrap
	   so newlines and indentation in code-bearing replies survive. *)
	| role <String> text <String> labelText <String> bg <String> border <String> fontStyle <String> |
	role:: msg at: 1.
	text:: msg at: 2.
	role = 'user'
		ifTrue: [
			labelText:: 'You'.
			bg:: outer AIChatUI userTurnBackground.
			border:: outer AIChatUI userTurnBorder.
			fontStyle:: 'italic'.
		]
		ifFalse: [
			labelText:: 'Assistant'.
			bg:: outer AIChatUI assistantTurnBackground.
			border:: outer AIChatUI assistantTurnBorder.
			fontStyle:: 'normal'.
		].
	^html: '<div style="display:flex; flex-direction:row; align-items:flex-start; border:1px solid ', border, '; border-radius:6px; padding:8px 12px; margin:4px 0; background-color:', bg, ';">',
		'<div style="min-width:5em; max-width:5em; padding-right:1em; text-align:right; flex-shrink:0;"><strong>', labelText, '</strong></div>',
		'<div style="flex:1; min-width:0;"><span style="white-space:pre-wrap; font-style:', fontStyle, ';">',
		text,
		'</span></div></div>'
)
) : (
)
(* Shared colour palette for the user/assistant/error turn bubbles —
   both the inline ChatPresenter and the chat-as-document path in
   AI_IDE_Support read these so the two views stay visually consistent. *)
public assistantTurnBackground ^ <String> = ( ^'#edf2ee' )
public userTurnBorder ^ <String> = ( ^'#b8d4ec' )
public userTurnBackground ^ <String> = ( ^'#eef4fb' )
public assistantTurnBorder ^ <String> = ( ^'#b0c8b4' )
public errorTurnBackground ^ <String> = ( ^'#fdecea' )
public errorTurnBorder ^ <String> = ( ^'#d68682' )
) : (
)
