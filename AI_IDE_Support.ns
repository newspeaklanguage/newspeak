Newspeak3
'Root'
class AI_IDE_Support usingPlatform: platform ide: webIde aiAccess: aiAccessModule chatUI: chatUIModule = (
(*
 IDE module providing AI integration. Instantiates and exposes the
 general-purpose AIAccess and AIChatUI modules, and defines
 IDE-specific tools that allow an AI model to query the IDE via mirrors.

 This module follows the standard IDE module pattern: it is parameterized
 by the platform and the IDE, and is instantiated by HopscotchWebIDE.

 Other IDE presenters can access AI functionality through this module,
 e.g., to embed a ChatSubject in a method or class presenter.
*)
|
	(* IDE dependencies *)
	private Root = webIde namespacing Root.
	private systemScope = webIde namespacing systemScope.
	private ClassMirror = platform mirrors ClassMirror.
	private ObjectMirror = platform mirrors ObjectMirror.
	private ActivationMirror = platform mirrors ActivationMirror.
	private ClassDeclarationBuilder = platform mirrors ClassDeclarationBuilder.
	private List = platform collections List.
	private Map = platform collections Map.
	private ide = webIde.

	(* General-purpose AI modules *)
	public aiAccess = aiAccessModule.
	public chatUI = chatUIModule.

	(* Re-export commonly needed classes for use by other IDE modules *)
	public Tool = aiAccess Tool.
	public Provider = aiAccess Provider.
	public AnthropicProvider = aiAccess AnthropicProvider.
	public Session = aiAccess Session.
	private AIChatSetupSubject = chatUI AIChatSetupSubject.
	private AIChatSetupPresenter = chatUI AIChatSetupPresenter.
	private BaseChatSubject = chatUI ChatSubject.
	private BaseChatPresenter = chatUI ChatPresenter.

	(* --- AI focus state ---

	   Brain buttons in the IDE install a focus describing what the user is
	   currently asking the chat about. Three orthogonal pieces of state:

	   1. currentFocusBlock — a [ ^String ] block producing a description on
	      demand. Returned by the current_focus tool. A block (not a snapshot)
	      lets the description reflect live state — e.g. an in-progress
	      unaccepted edit, post-replacement updated source.

	   2. currentFocusValidator — a [ ^Boolean ] block that checks whether the
	      focused entity still exists. Run on every current_focus call. Returns
	      false (or raises) → focus is cleared. This catches all paths by which
	      an entity can disappear (explicit delete, add_or_replace_nested_class,
	      etc.) without each path needing to know about the focus.

	   3. focusKind / focusClassPath / focusSide / focusSelector — structured
	      identity used by isFocusedOnX:... matchers. Brain-button highlighting
	      compares against this rather than the Subject that installed the
	      focus. Reason: atomic install only forwards mixin objects, not
	      individual methods, so MethodMirror equality fails after a replace,
	      MirrorGroupSubject>>updateElements creates a fresh MethodSubject,
	      and any Subject-object-identity check fails. Structural matching
	      survives that. *)

	currentFocusBlock
	currentFocusValidator
	(* focusKind: #class | #classHeader | #method | #lazySlot | nil *)
	focusKind
	(* focusClassPath: String, dotted path *)
	focusClassPath
	(* focusSide: 'instance' | 'class' | nil *)
	focusSide
	(* focusSelector: Symbol — method or lazy-slot name, or nil *)
	focusSelector

	(* Single shared chat subject, lazily created on first use (e.g. when the
	   user clicks any brain button). Once created, all brain buttons reuse it
	   so the conversation continues as the user navigates. *)
	sharedChatSubject_slot

	(* AI-proposed code changes staged for atomic install. Keyed by
	   changeset id (e.g. "cs1"); the value is a List of change records
	   (Maps with kind, class_name, side, and either source or selector
	   plus old_source). Cleared on apply or discard. *)
	proposedChangesets = Map new.
	nextChangesetIdNum ::= 0.
|
) (

(* --- IDE-specific chat setup --- *)

public class IDEChatSetupSubject onModel: providerClass = AIChatSetupSubject onModel: providerClass (
(*
 Overrides session creation to include IDE-specific tools, and uses
 IDE-aware presenter and chat subject subclasses.
*)
) (

public createSession: provider = (
	| session |
	session:: Session provider: provider tools: tools.
	session systemPrompt: newspeakSystemPrompt.
	^session
)

public createPresenter = (
	^IDEChatSetupPresenter onSubject: self
)

public newChatSubjectFor: session = (
	| chat |
	chat:: IDEChatSubject onModel: session.
	(* Cache as the shared chat so subsequent brain clicks reuse this session. *)
	sharedChatSubject_slot:: chat.
	^chat
)

public isKindOfIDEChatSetupSubject = ( ^true )
isMyKind: other = ( ^other isKindOfIDEChatSetupSubject )

) : (
)

public class IDEChatSubject onModel: session = BaseChatSubject onModel: session (
(*
 IDE-aware chat subject; returns an IDE presenter so Inspect Presenter works.
*)
) (

public createPresenter = (
	^IDEChatPresenter onSubject: self
)

public isKindOfIDEChatSubject = ( ^true )
isMyKind: other = ( ^other isKindOfIDEChatSubject )

) : (
)

public class IDEChatSetupPresenter onSubject: s = AIChatSetupPresenter onSubject: s () (

respondToInspectPresenter = (
	enterSubject: (ide browsing ObjectSubject onModel: (ObjectMirror reflecting: self))
)

public isKindOfIDEChatSetupPresenter = ( ^true )
isMyKind: other = ( ^other isKindOfIDEChatSetupPresenter )

) : (
)

public class IDEChatPresenter onSubject: s = BaseChatPresenter onSubject: s () (

respondToInspectPresenter = (
	enterSubject: (ide browsing ObjectSubject onModel: (ObjectMirror reflecting: self))
)

public isKindOfIDEChatPresenter = ( ^true )
isMyKind: other = ( ^other isKindOfIDEChatPresenter )

) : (
)

(* --- Focus management ---

   A presenter signals what the user is asking about by installing a focus
   block. The chat does NOT push the focus into the conversation; it is pulled
   on demand via the current_focus tool. The block is re-evaluated on every
   pull, so live state (e.g. unaccepted edits) flows through automatically.
   To clear focus, pass nil. *)

(* Internal: install a description block and an existence validator.
   Brain buttons should call the kind-specific setXFocusOn: helpers below
   rather than this one; those also set the structured identity slots
   required by isFocusedOnX: matchers. *)
installFocusDescription: aBlock validator: aValidator = (
	currentFocusBlock:: aBlock.
	currentFocusValidator:: aValidator.
)

(* Kind-specific focus installers. Each sets:
   - the structured identity (focusKind, focusClassPath, focusSide,
     focusSelector) used by isFocusedOnX:... matchers for brain-button
     highlighting,
   - a description block returned by the current_focus AI tool,
   - an existence validator that re-checks the entity on every read. *)

public setClassFocusOn: cdm = (
	| qname |
	qname:: qualifiedNameOf: cdm.
	focusKind:: #class.
	focusClassPath:: qname.
	focusSide:: nil.
	focusSelector:: nil.
	installFocusDescription: ['Class: ', qname]
		validator: [classStillExists: cdm]
)

public setClassHeaderFocusOn: cdm = (
	| qname |
	qname:: qualifiedNameOf: cdm.
	focusKind:: #classHeader.
	focusClassPath:: qname.
	focusSide:: nil.
	focusSelector:: nil.
	installFocusDescription: ['Class header (factory + slots) of class ', qname]
		validator: [classStillExists: cdm]
)

public setMethodFocusOn: cdm side: side selector: sel = (
	| qname selSym |
	qname:: qualifiedNameOf: cdm.
	selSym:: sel asSymbol.
	focusKind:: #method.
	focusClassPath:: qname.
	focusSide:: side.
	focusSelector:: selSym.
	installFocusDescription: ['Method: ', qname, ' (', side, ' side) >> ', selSym asString]
		validator: [methodStillExists: cdm side: side selector: selSym]
)

public setLazySlotFocusOn: cdm side: side name: name = (
	| qname nameSym |
	qname:: qualifiedNameOf: cdm.
	nameSym:: name asSymbol.
	focusKind:: #lazySlot.
	focusClassPath:: qname.
	focusSide:: side.
	focusSelector:: nameSym.
	installFocusDescription: ['Lazy slot: ', qname, ' (', side, ' side) >> ', nameSym asString]
		validator: [lazySlotStillExists: cdm side: side name: nameSym]
)

(* Structural matchers — brain buttons call these so highlighting tracks
   the focused entity (class path + side + selector) regardless of whether
   the Subject object survived atomic install. *)

public isFocusedOnClass: cdm ^ <Boolean> = (
	focusKind = #class ifFalse: [^false].
	^focusClassPath = (qualifiedNameOf: cdm)
)

public isFocusedOnClassHeader: cdm ^ <Boolean> = (
	focusKind = #classHeader ifFalse: [^false].
	^focusClassPath = (qualifiedNameOf: cdm)
)

public isFocusedOnMethod: cdm side: side selector: sel ^ <Boolean> = (
	focusKind = #method ifFalse: [^false].
	focusClassPath = (qualifiedNameOf: cdm) ifFalse: [^false].
	focusSide = side ifFalse: [^false].
	^focusSelector = sel asSymbol
)

public isFocusedOnLazySlot: cdm side: side name: name ^ <Boolean> = (
	focusKind = #lazySlot ifFalse: [^false].
	focusClassPath = (qualifiedNameOf: cdm) ifFalse: [^false].
	focusSide = side ifFalse: [^false].
	^focusSelector = name asSymbol
)

(* Existence checks used by the structured focus validators. Each resolves
   the qualified class path freshly through the namespace and compares via
   ClassDeclarationMirror>>= (which compares the underlying mixins). After
   atomic-install instance forwarding, a replaced class's old mirror and a
   freshly-resolved mirror compare equal because both reach the same
   (forwarded) mixin. Deletions cause resolveClassPath: to raise; the
   on:Error handler returns false. *)

public classStillExists: cdm ^ <Boolean> = (
	^[(resolveClassPath: (qualifiedNameOf: cdm)) = cdm]
		on: Error do: [:e | false]
)

public methodStillExists: cdm side: side selector: sel ^ <Boolean> = (
	^[
		| resolved mixin |
		resolved:: resolveClassPath: (qualifiedNameOf: cdm).
		resolved = cdm
			and: [
				mixin:: side = 'class'
					ifTrue: [resolved classSide]
					ifFalse: [resolved instanceSide].
				(findMethodMirrorNamed: sel inMixin: mixin) isNil not
			]
	] on: Error do: [:e | false]
)

public lazySlotStillExists: cdm side: side name: name ^ <Boolean> = (
	^[
		| resolved mixin |
		resolved:: resolveClassPath: (qualifiedNameOf: cdm).
		resolved = cdm
			and: [
				mixin:: side = 'class'
					ifTrue: [resolved classSide]
					ifFalse: [resolved instanceSide].
				(findLazySlotMirrorNamed: name inMixin: mixin) isNil not
			]
	] on: Error do: [:e | false]
)

public clearFocus = (
	currentFocusBlock:: nil.
	currentFocusValidator:: nil.
	focusKind:: nil.
	focusClassPath:: nil.
	focusSide:: nil.
	focusSelector:: nil.
)

public currentFocusDescription ^ <String> = (
	currentFocusBlock isNil ifTrue: [^'(no focus set)'].
	(* Validate first: if the focused entity no longer exists (because a
	   changeset deleted or replaced its enclosing class etc.), drop the
	   focus instead of returning stale text. *)
	currentFocusValidator isNil ifFalse: [
		([currentFocusValidator value] on: Error do: [:e | false]) ifFalse: [
			clearFocus.
			^'(no focus set)'
		]
	].
	^[currentFocusBlock value]
		on: Error
		do: [:e | '(focus block raised: ', e messageText, ')']
)

(* Entry point for the toolbar brain button: if the user has already saved an
   API key for the Anthropic provider, go straight to a chat; otherwise return
   the setup subject so the user can enter a key. *)
public chatLauncher = (
	^ensureSharedChat
)

(* Return the cached shared chat subject, or — if no chat has been created yet
   — a setup subject the caller can navigate to so the user can enter a key.
   The setup subject's startChat caches the resulting chat in sharedChatSubject_slot. *)
public ensureSharedChat = (
	| setup chat |
	sharedChatSubject_slot isNil ifFalse: [^sharedChatSubject_slot].
	setup:: IDEChatSetupSubject onModel: AnthropicProvider.
	setup apiKey isEmpty ifTrue: [^setup].
	chat:: setup startChat.
	chat isNil ifTrue: [^setup].
	(* startChat goes through newChatSubjectFor:, which has already cached. *)
	^sharedChatSubject_slot
)

(* --- Class lookup helpers --- *)

classDeclarationNamed: name <String> ^ <ClassDeclarationMirror> = (
	| cls |
	cls:: Root at: name asSymbol ifAbsent: [
		Error signal: 'Class not found: ', name
	].
	cls isKindOfBehavior ifFalse: [
		Error signal: 'Not a class: ', name
	].
	^(ClassMirror reflecting: cls) mixin declaration
)

resolveNamespacePath: path <String> ^ <Object> = (
	(* Navigate the namespace tree starting at Root. A leading 'Root.' segment
	   is optional. Returns the entry (which may be a Namespace, a class, a
	   Document, an Image, etc.). Signals an error if a segment is not found. *)
	| parts start current |
	parts:: path isEmpty ifTrue: [{}] ifFalse: [path findTokens: '.'].
	current:: Root.
	start:: (parts isEmpty not and: [(parts at: 1) = 'Root'])
		ifTrue: [2] ifFalse: [1].
	start to: parts size do: [:i |
		| seg = parts at: i. |
		current:: current at: seg asSymbol ifAbsent: [
			Error signal: 'Not found in namespace path: ', seg
		].
	].
	^current
)

kindOf: value <Object> ^ <String> = (
	value isKindOfNamespace ifTrue: [^'namespace'].
	value isKindOfBehavior ifTrue: [^'class'].
	value isKindOfDocument ifTrue: [^'document'].
	value isKindOfString ifTrue: [^'string'].
	value isKindOfJSAlien ifTrue: [
		('IMG' = (value at: 'nodeName')) ifTrue: [^'image'].
		^'alien'
	].
	^'other'
)

public qualifiedNameOf: cdm <ClassDeclarationMirror> ^ <String> = (
	(* Walks the enclosing-class chain to produce a dotted path,
	   e.g. "RuntimeForHopscotchForHTML.Platform.Images". *)
	| path enclosing |
	path:: cdm simpleName.
	enclosing:: cdm enclosingClass.
	[enclosing isNil] whileFalse: [
		path:: enclosing simpleName, '.', path.
		enclosing:: enclosing enclosingClass.
	].
	^path
)

resolveClassPath: path <String> ^ <ClassDeclarationMirror> = (
	| parts cdm |
	parts:: path findTokens: '.'.
	cdm:: classDeclarationNamed: (parts at: 1).
	2 to: parts size do: [:i |
		| nestedName found |
		nestedName:: (parts at: i) asSymbol.
		found:: false.
		cdm instanceSide nestedClasses do: [:nc |
			nc simpleName = nestedName ifTrue: [
				cdm:: nc.
				found:: true.
			].
		].
		found ifFalse: [
			Error signal: 'Nested class not found: ', (parts at: i),
				' in ', cdm simpleName
		].
	].
	^cdm
)

namespaceSubjectForPath: path <String> ^ <Object> = (
	(* Build a NamespaceSubject for the namespace at the given dotted path,
	   or for Root if the path is empty or 'Root'. Raises an error if the
	   path resolves to something that is not a Namespace. *)
	| parts ns key |
	(path isEmpty or: [path = 'Root']) ifTrue: [
		^ide browsing NamespaceSubject new
	].
	ns:: resolveNamespacePath: path.
	ns isKindOfNamespace ifFalse: [
		Error signal: path, ' is not a namespace (it is a ', (kindOf: ns), ')'
	].
	parts:: path findTokens: '.'.
	key:: (parts at: parts size) asSymbol.
	^ide browsing NamespaceSubject onModel: ns key: key
)

formatAccess: am ^ <String> = (
	am = #public ifTrue: [^'public '].
	am = #private ifTrue: [^'private '].
	^''
)

(* --- Proposed-changeset helpers --- *)

freshChangesetId ^ <String> = (
	nextChangesetIdNum:: nextChangesetIdNum + 1.
	^'cs', nextChangesetIdNum printString
)

mixinForChange: change ^ <Object> = (
	| cdm side |
	cdm:: resolveClassPath: (change at: 'class_name').
	side:: (change includesKey: 'side')
		ifTrue: [change at: 'side']
		ifFalse: ['instance'].
	^side = 'class' ifTrue: [cdm classSide] ifFalse: [cdm instanceSide]
)

findMethodMirrorNamed: selector <Symbol> inMixin: mixin ^ <Object> = (
	mixin methods do: [:mm | mm name = selector ifTrue: [^mm]].
	^nil
)

findLazySlotMirrorNamed: selector <Symbol> inMixin: mixin ^ <Object> = (
	mixin lazySlots do: [:ls | ls name = selector ifTrue: [^ls]].
	^nil
)

isMemberKind: kind ^ <Boolean> = (
	^kind = 'add_or_replace_method'
		or: [kind = 'delete_method'
		or: [kind = 'add_or_replace_lazy_slot'
		or: [kind = 'delete_lazy_slot']]]
)

validateChange: change ^ <Object> = (
	(* Returns a Map record of the validated change. Raises if invalid. *)
	| kind record |
	kind:: change at: 'kind'.
	record:: Map new.
	record at: 'kind' put: kind.
	record at: 'class_name' put: (change at: 'class_name').
	(isMemberKind: kind) ifTrue: [
		| side mixin sel old |
		side:: (change includesKey: 'side') ifTrue: [change at: 'side'] ifFalse: ['instance'].
		(side = 'instance' or: [side = 'class']) ifFalse: [
			Error signal: 'side must be "instance" or "class", got: ', side
		].
		record at: 'side' put: side.
		mixin:: mixinForChange: change.
		kind = 'add_or_replace_method' ifTrue: [
			record at: 'source' put: (change at: 'source'). ^record
		].
		kind = 'add_or_replace_lazy_slot' ifTrue: [
			record at: 'source' put: (change at: 'source'). ^record
		].
		kind = 'delete_method' ifTrue: [
			sel:: (change at: 'selector') asSymbol.
			record at: 'selector' put: sel.
			old:: findMethodMirrorNamed: sel inMixin: mixin.
			old isNil ifTrue: [
				Error signal: 'No method ', sel, ' on the ', side, ' side of ',
					(record at: 'class_name')
			].
			record at: 'old_source' put: old source.
			^record
		].
		kind = 'delete_lazy_slot' ifTrue: [
			sel:: (change at: 'selector') asSymbol.
			record at: 'selector' put: sel.
			old:: findLazySlotMirrorNamed: sel inMixin: mixin.
			old isNil ifTrue: [
				Error signal: 'No lazy slot ', sel, ' on the ', side, ' side of ',
					(record at: 'class_name')
			].
			record at: 'old_source' put: old source.
			^record
		].
	].
	kind = 'set_class_header' ifTrue: [
		| cdm |
		record at: 'source' put: (change at: 'source').
		cdm:: resolveClassPath: (record at: 'class_name').
		record at: 'old_source' put: cdm header source.
		^record
	].
	kind = 'add_or_replace_nested_class' ifTrue: [
		(* class_name is the enclosing class (must already exist). *)
		record at: 'source' put: (change at: 'source').
		resolveClassPath: (record at: 'class_name').
		^record
	].
	kind = 'delete_nested_class' ifTrue: [
		| segments cdm |
		segments:: (record at: 'class_name') findTokens: '.'.
		segments size < 2 ifTrue: [
			Error signal: 'delete_nested_class requires a nested class path (got top-level: ',
				(record at: 'class_name'),
				'). Top-level deletion is not supported by this tool.'
		].
		cdm:: resolveClassPath: (record at: 'class_name').
		record at: 'old_source' put: cdm source.
		^record
	].
	kind = 'add_top_level_class' ifTrue: [
		| name existing |
		record at: 'source' put: (change at: 'source').
		name:: change at: 'class_name'.
		existing:: Root at: name asSymbol ifAbsent: [nil].
		existing isNil ifFalse: [
			Error signal: 'A top-level entry named ', name, ' already exists in Root'
		].
		^record
	].
	Error signal: 'Unknown change kind: ', kind
)

formatChangesetId: id records: records ^ <String> = (
	| result count |
	count:: records size.
	result:: 'Changeset ', id, ' (', count printString,
		(count = 1 ifTrue: [' change):'] ifFalse: [' changes):']), '\n'.
	records do: [:r |
		| kind sideStr |
		kind:: r at: 'kind'.
		sideStr:: (r includesKey: 'side')
			ifTrue: [' (', (r at: 'side'), ' side)']
			ifFalse: [''].
		result:: result, '\n[', kind, '] ', (r at: 'class_name'), sideStr.
		(kind = 'delete_method' or: [kind = 'delete_lazy_slot']) ifTrue: [
			result:: result, ' >> ', (r at: 'selector') asString, '\n',
				'--- removing\n', (r at: 'old_source'), '\n'.
		] ifFalse: [
			kind = 'set_class_header' ifTrue: [
				result:: result, '\n--- old header\n', (r at: 'old_source'), '\n',
					'+++ new header\n', (r at: 'source'), '\n'.
			] ifFalse: [
				kind = 'delete_nested_class' ifTrue: [
					result:: result, '\n--- removing class\n', (r at: 'old_source'), '\n'.
				] ifFalse: [
					(* add_or_replace_method, add_or_replace_lazy_slot,
					   add_or_replace_nested_class, add_top_level_class *)
					result:: result, '\n+++ new source\n', (r at: 'source'), '\n'.
				]
			]
		].
	].
	result:: result, '\nWhen the user approves, call apply_changeset with id "', id, '".'.
	^result
)

intermediateOf: builder = (
	(* Reach into a {Class,Mixin}Builder's private 'intermediate' slot.
	   AtomicInstallWrapper>>install:into: uses the same trick. *)
	^((ObjectMirror reflecting: builder) getSlot: #intermediate) reflectee
)

patchEnclosingOf: childClassBuilder withParent: parentClassBuilder = (
	(* When we navigate DOWN from a top-level builder into
	   instanceSide.nestedClasses, the nested IR's enclosingClass is the
	   parent IntermediateClassDeclaration (set in buildIntermediate:from:within:).
	   But ClassDeclarationBuilder>>enclosingClass expects an IntermediateMixin
	   (the parent's instance-side mixin) — see the patch at line 572 of
	   MirrorsForPrimordialSoup.ns, which only runs on the mirror-up path.
	   Mirror that patch here so the compiler can walk the scope chain. *)
	| childIR parentInstanceSideIR |
	childIR:: intermediateOf: childClassBuilder.
	parentInstanceSideIR:: intermediateOf: parentClassBuilder instanceSide.
	childIR enclosingClass: parentInstanceSideIR.
)

navigateToBuilderForSegments: segments <Array> withBuilderMap: builderByTopLevel ^ <Object> = (
	(* Resolve a dotted class path (given as segments) to a ClassDeclarationBuilder.
	   For top-level segments, fetch or create the cached top-level builder.
	   For nested segments, walk DOWN inside it, patching enclosingClass linkages
	   as we go (see patchEnclosingOf:withParent: for why). *)
	| topName targetClassBuilder |
	topName:: segments at: 1.
	targetClassBuilder:: builderByTopLevel at: topName ifAbsent: [
		| topCdm topBuilder |
		topCdm:: classDeclarationNamed: topName.
		topBuilder:: topCdm asBuilder.
		builderByTopLevel at: topName put: topBuilder.
		topBuilder
	].
	2 to: segments size do: [:i |
		| seg found |
		seg:: segments at: i.
		found:: nil.
		targetClassBuilder instanceSide nestedClasses do: [:ncBuilder |
			ncBuilder name = seg ifTrue: [found:: ncBuilder]
		].
		found isNil ifTrue: [
			Error signal: 'Nested class not found in builder tree: ', seg,
				' (under ', topName, ')'
		].
		patchEnclosingOf: found withParent: targetClassBuilder.
		targetClassBuilder:: found
	].
	^targetClassBuilder
)

applyOneRecord: r withBuilderMap: builderByTopLevel = (
	| kind segments targetClassBuilder side mixinBuilder |
	kind:: r at: 'kind'.
	kind = 'add_top_level_class' ifTrue: [
		| newBuilder name |
		newBuilder:: ClassDeclarationBuilder fromSource: (r at: 'source').
		name:: newBuilder name asSymbol.
		(builderByTopLevel includesKey: name) ifTrue: [
			Error signal: 'Top-level builder for ', name,
				' already present in this changeset (duplicate add or conflict)'
		].
		builderByTopLevel at: name put: newBuilder.
		^self
	].
	kind = 'delete_nested_class' ifTrue: [
		| parentBuilder targetName |
		segments:: (r at: 'class_name') findTokens: '.'.
		parentBuilder:: navigateToBuilderForSegments: (segments copyFrom: 1 to: segments size - 1)
			withBuilderMap: builderByTopLevel.
		targetName:: (segments at: segments size) asSymbol.
		parentBuilder instanceSide nestedClasses removeMirrorNamed: targetName.
		^self
	].
	(* All remaining kinds operate on a target class identified by class_name. *)
	segments:: (r at: 'class_name') findTokens: '.'.
	targetClassBuilder:: navigateToBuilderForSegments: segments
		withBuilderMap: builderByTopLevel.
	kind = 'set_class_header' ifTrue: [
		^targetClassBuilder header source: (r at: 'source')
	].
	kind = 'add_or_replace_nested_class' ifTrue: [
		^targetClassBuilder instanceSide nestedClasses addFromSource: (r at: 'source')
	].
	(* Member-level kinds: route through instance or class side. *)
	side:: r at: 'side'.
	mixinBuilder:: side = 'class'
		ifTrue: [targetClassBuilder classSide]
		ifFalse: [targetClassBuilder instanceSide].
	kind = 'add_or_replace_method' ifTrue: [
		^mixinBuilder methods addFromSource: (r at: 'source')
	].
	kind = 'delete_method' ifTrue: [
		^mixinBuilder methods removeMirrorNamed: (r at: 'selector')
	].
	kind = 'add_or_replace_lazy_slot' ifTrue: [
		^mixinBuilder lazySlots addFromSource: (r at: 'source')
	].
	kind = 'delete_lazy_slot' ifTrue: [
		^mixinBuilder lazySlots removeMirrorNamed: (r at: 'selector')
	].
	Error signal: 'Unknown change kind in apply: ', kind
)

applyChangesetRecords: records = (
	(* Aggregates changes per top-level class and installs them as one
	   atomic transaction via the platform's atomic installer. *)
	| builderByTopLevel builders newTopLevelNames mixins |
	builderByTopLevel:: Map new.
	newTopLevelNames:: List new.
	records do: [:r |
		(r at: 'kind') = 'add_top_level_class' ifTrue: [
			newTopLevelNames add: (r at: 'class_name')
		].
		applyOneRecord: r withBuilderMap: builderByTopLevel
	].
	builders:: List new.
	builderByTopLevel keysAndValuesDo: [:k :v | builders add: v].
	mixins:: ide installFromBuilders: builders.
	(* The atomic installer returns mirrors but does NOT add new top-level
	   classes to the IDE namespace on primordialsoup (the JS mirror builders
	   do; the wasm ones don't). Mirror the IDE's own post-install step. *)
	mixins do: [:m |
		(newTopLevelNames includes: m name) ifTrue: [
			Root at: m name asSymbol put: m declaration applyToObject reflectee
		]
	].
)

(* --- IDE tool definitions --- *)

public tools ^ <List> = (
	^{
		getClassSourceTool.
		getMemberSourceTool.
		getClassHeaderTool.
		listClassMembersTool.
		sendersTool.
		implementorsTool.
		searchClassesTool.
		listNamespaceTool.
		getDocumentTool.
		webFetchTool.
		currentFocusTool.
		navigateToClassTool.
		navigateToNamespaceTool.
		navigateToDocumentTool.
		showTestsTool.
		runTestsTool.
		proposeChangesTool.
		applyChangesetTool.
	}
)

getClassSourceTool ^ <Tool> = (
	^Tool
		name: 'get_class_source'
		description: 'Get the full source code of a Newspeak class. Use a dotted path for nested classes (e.g. "ShapeLibrary.Circle").'
		inputSchema: '{"type":"object","properties":{"class_name":{"type":"string","description":"Class name or dotted path (e.g. MyClass or Outer.Inner)"}},"required":["class_name"]}'
		handler: [:input |
			(resolveClassPath: (input at: 'class_name')) source
		]
)

getMemberSourceTool ^ <Tool> = (
	^Tool
		name: 'get_member_source'
		description: 'Get the source of a method or a lazy slot in a class. Specify the selector (the member''s name) including colons for keyword methods (e.g. "at:put:"). Searches the named class side''s methods first, then its lazy slots. For ordinary (non-lazy) slot declarations, use get_class_header.'
		inputSchema: '{"type":"object","properties":{"class_name":{"type":"string","description":"Class name or dotted path"},"selector":{"type":"string","description":"Method or lazy-slot name (e.g. foo, at:put:, +)"},"side":{"type":"string","enum":["instance","class"],"description":"Which side of the class (default: instance)"}},"required":["class_name","selector"]}'
		handler: [:input |
			| cdm mixin selector found result |
			cdm:: resolveClassPath: (input at: 'class_name').
			selector:: (input at: 'selector') asSymbol.
			mixin:: ((input at: 'side') = 'class')
				ifTrue: [cdm classSide]
				ifFalse: [cdm instanceSide].
			found:: false.
			result:: ''.
			mixin methods do: [:mm |
				mm name = selector ifTrue: [
					result:: mm source.
					found:: true.
				].
			].
			found ifFalse: [
				mixin lazySlots do: [:ls |
					ls name = selector ifTrue: [
						result:: ls source.
						found:: true.
					].
				].
			].
			found ifFalse: [
				Error signal: 'No method or lazy slot named ', selector,
					' in ', cdm simpleName
			].
			result
		]
)

getClassHeaderTool ^ <Tool> = (
	^Tool
		name: 'get_class_header'
		description: 'Get just the class header (factory method signature, superclass clause, slot declarations) without the method bodies.'
		inputSchema: '{"type":"object","properties":{"class_name":{"type":"string","description":"Class name or dotted path"}},"required":["class_name"]}'
		handler: [:input |
			(resolveClassPath: (input at: 'class_name')) header source
		]
)

listClassMembersTool ^ <Tool> = (
	^Tool
		name: 'list_class_members'
		description: 'List all members (methods, slots, nested classes, lazy slots) of a class with their access modifiers. Does not include source code - use get_member_source for that.'
		inputSchema: '{"type":"object","properties":{"class_name":{"type":"string","description":"Class name or dotted path"}},"required":["class_name"]}'
		handler: [:input |
			| cdm result |
			cdm:: resolveClassPath: (input at: 'class_name').
			result:: 'Class: ', cdm simpleName, '\n'.
			result:: result, 'Factory: ', cdm primaryFactorySelector, '\n'.

			result:: result, '\nSlots:\n'.
			cdm instanceSide slots do: [:sm |
				result:: result, '  ', (formatAccess: sm accessModifier),
					sm name,
					(sm isMutable ifTrue: [' (mutable)'] ifFalse: [' (immutable)']),
					'\n'.
			].

			result:: result, '\nInstance methods:\n'.
			cdm instanceSide methods do: [:mm |
				result:: result, '  ', (formatAccess: mm accessModifier),
					mm name, '\n'.
			].

			cdm instanceSide lazySlots do: [:ls |
				result:: result, '  ',
					(formatAccess: ls accessModifier),
					'lazy ', ls name, '\n'.
			].

			result:: result, '\nClass methods:\n'.
			cdm classSide methods do: [:mm |
				result:: result, '  ', (formatAccess: mm accessModifier),
					mm name, '\n'.
			].

			result:: result, '\nNested classes:\n'.
			cdm instanceSide nestedClasses do: [:nc |
				result:: result, '  ', (formatAccess: nc accessModifier),
					nc simpleName, '\n'.
			].

			result
		]
)

sendersTool ^ <Tool> = (
	^Tool
		name: 'senders_of'
		description: 'Find all methods that send a given message selector. Returns the defining class and method for each sender.'
		inputSchema: '{"type":"object","properties":{"selector":{"type":"string","description":"The message selector to search for (e.g. add:, printString, +)"}},"required":["selector"]}'
		handler: [:input |
			| selector result count |
			selector:: (input at: 'selector') asSymbol.
			result:: 'Senders of #', selector, ':\n'.
			count:: 0.
			systemScope sendersOf: selector do: [:mirror |
				count:: count + 1.
				mirror isKindOfMethodMirror ifTrue: [
					result:: result, '  ',
						(qualifiedNameOf: mirror definingMixin declaration), ' >> ',
						mirror name, '\n'.
				] ifFalse: [
					mirror isKindOfLazySlotMirror ifTrue: [
						result:: result, '  ',
							(qualifiedNameOf: mirror definingMixin declaration), ' >> ',
							mirror name, ' (lazy slot)\n'.
					] ifFalse: [
						mirror isKindOfClassDeclarationMirror ifTrue: [
							result:: result, '  ',
								(qualifiedNameOf: mirror), ' (class header)\n'.
						]
					]
				]
			].
			count = 0 ifTrue: [
				result:: result, '  (none found)\n'.
			].
			result
		]
)

implementorsTool ^ <Tool> = (
	^Tool
		name: 'implementors_of'
		description: 'Find all classes that implement a given message selector. Returns the defining class and access modifier for each implementor.'
		inputSchema: '{"type":"object","properties":{"selector":{"type":"string","description":"The message selector to search for"}},"required":["selector"]}'
		handler: [:input |
			| selector result count |
			selector:: (input at: 'selector') asSymbol.
			result:: 'Implementors of #', selector, ':\n'.
			count:: 0.
			systemScope implementorsOf: selector do: [:mirror |
				count:: count + 1.
				mirror isKindOfLazySlotMirror ifTrue: [
					result:: result, '  ',
						(formatAccess: mirror accessModifier),
						(qualifiedNameOf: mirror definingMixin declaration), ' >> ',
						mirror name, ' (lazy slot)\n'.
				].
				mirror isKindOfMethodMirror ifTrue: [
					result:: result, '  ',
						(formatAccess: mirror accessModifier),
						(qualifiedNameOf: mirror definingMixin declaration), ' >> ',
						mirror name, '\n'.
				].
				mirror isKindOfClassDeclarationMirror ifTrue: [
					result:: result, '  ',
						(qualifiedNameOf: mirror), ' (class/slot)\n'.
				].
			].
			count = 0 ifTrue: [
				result:: result, '  (none found)\n'.
			].
			result
		]
)

listNamespaceTool ^ <Tool> = (
	^Tool
		name: 'list_namespace'
		description: 'List the entries of a Newspeak namespace. With no argument (or an empty path), lists the IDE Root namespace. Use a dotted path to drill into a nested namespace (e.g. "Icons" or "Root.Icons"). Each entry is reported as "name (kind)" where kind is one of: namespace, class, document, string, image, alien, other.'
		inputSchema: '{"type":"object","properties":{"path":{"type":"string","description":"Optional dotted path to a namespace. Empty or omitted means Root."}}}'
		handler: [:input |
			| path ns label result |
			(* input is a JS Alien — use includesKey: rather than at:ifAbsent:,
			   which the alien does not understand. *)
			path:: (input includesKey: 'path')
				ifTrue: [input at: 'path']
				ifFalse: [''].
			ns:: resolveNamespacePath: path.
			label:: path isEmpty ifTrue: ['Root'] ifFalse: [path].
			result:: 'Namespace ', label, ':\n'.
			ns keysAndValuesDo: [:k :v |
				result:: result, '  ', k, ' (', (kindOf: v), ')\n'.
			].
			result
		]
)

currentFocusTool ^ <Tool> = (
	^Tool
		name: 'current_focus'
		description: 'Return a description of what the user is currently asking about in the IDE — the class, method, namespace, document or other entity they pointed the chat at, plus any in-progress (unaccepted) edits if relevant. Returns "(no focus set)" if the user has not indicated a focus. Call this first whenever the user refers to "this", "here", or names a member without a class, before guessing.'
		inputSchema: '{"type":"object","properties":{}}'
		handler: [:input |
			currentFocusDescription
		]
)

webFetchTool ^ <Tool> = (
	^Tool
		name: 'web_fetch'
		description: 'Fetch a URL and return its response body as text. Useful for consulting the published Newspeak language specification and grammar (https://newspeaklanguage.org/spec/newspeak-spec.tex) or the tutorial (https://newspeaklanguage.org/pubs/newspeak-2025-tutorial.pdf), and for other web lookups. The response is returned as a single string; for binary content (PDFs, images) the text decoding may be lossy.'
		inputSchema: '{"type":"object","properties":{"url":{"type":"string","description":"Absolute URL to fetch (https:// or http://)."}},"required":["url"]}'
		handler: [:input |
			aiAccess webFetch: (input at: 'url')
		]
)

getDocumentTool ^ <Tool> = (
	^Tool
		name: 'get_document'
		description: 'Get the textual contents of an IDE document (e.g. a literate/Ampleforth document stored in a namespace). Specify the document name or a dotted path to its location in the namespace tree.'
		inputSchema: '{"type":"object","properties":{"name":{"type":"string","description":"Document name or dotted path (e.g. \"MyNotes\")."}},"required":["name"]}'
		handler: [:input |
			| path entry |
			path:: input at: 'name'.
			entry:: resolveNamespacePath: path.
			entry isKindOfDocument ifFalse: [
				Error signal: 'Not a document: ', path, ' (it is a ', (kindOf: entry), ')'
			].
			entry contents
		]
)

searchClassesTool ^ <Tool> = (
	^Tool
		name: 'search_classes'
		description: 'Search for classes whose name contains the given substring. Searches both top-level and nested classes.'
		inputSchema: '{"type":"object","properties":{"query":{"type":"string","description":"Substring to search for in class names (case-sensitive)"}},"required":["query"]}'
		handler: [:input |
			| query result count |
			query:: input at: 'query'.
			result:: 'Classes matching "', query, '":\n'.
			count:: 0.
			systemScope allClassesDo: [:cdm |
				(cdm simpleName includesSubstring: query) ifTrue: [
					count:: count + 1.
					result:: result, '  ', (formatAccess: cdm accessModifier),
						(qualifiedNameOf: cdm), '\n'.
				].
			].
			count = 0 ifTrue: [
				result:: result, '  (none found)\n'.
			].
			result
		]
)

navigateToClassTool ^ <Tool> = (
	^Tool
		name: 'navigate_to_class'
		description: 'Navigate the IDE to a class, opening a class presenter on it. Use a dotted path for nested classes (e.g. "ShapeLibrary.Circle"). Side effect: the IDE jumps; use only when the user has expressed intent to navigate.'
		inputSchema: '{"type":"object","properties":{"class_name":{"type":"string","description":"Class name or dotted path"}},"required":["class_name"]}'
		handler: [:input |
			| cdm |
			cdm:: resolveClassPath: (input at: 'class_name').
			ide browsing navigateTo: (ide browsing ClassSubject onDeclaration: cdm).
			'Opened class ', (qualifiedNameOf: cdm)
		]
)

navigateToNamespaceTool ^ <Tool> = (
	^Tool
		name: 'navigate_to_namespace'
		description: 'Navigate the IDE to a namespace, opening a namespace presenter. With no argument (or empty path), opens Root. Use a dotted path for nested namespaces (e.g. "Icons" or "Root.Icons"). Side effect: the IDE jumps.'
		inputSchema: '{"type":"object","properties":{"path":{"type":"string","description":"Optional dotted path. Empty or omitted means Root."}}}'
		handler: [:input |
			| path subject |
			path:: (input includesKey: 'path')
				ifTrue: [input at: 'path']
				ifFalse: [''].
			subject:: namespaceSubjectForPath: path.
			ide browsing navigateTo: subject.
			'Opened namespace ', subject title
		]
)

navigateToDocumentTool ^ <Tool> = (
	^Tool
		name: 'navigate_to_document'
		description: 'Navigate the IDE to an Ampleforth document by name or dotted path. Side effect: the IDE jumps.'
		inputSchema: '{"type":"object","properties":{"name":{"type":"string","description":"Document name or dotted path"}},"required":["name"]}'
		handler: [:input |
			| path entry |
			path:: input at: 'name'.
			entry:: resolveNamespacePath: path.
			entry isKindOfDocument ifFalse: [
				Error signal: 'Not a document: ', path, ' (it is a ', (kindOf: entry), ')'
			].
			ide browsing navigateTo: (ide documents DocumentSubject onModel: entry).
			'Opened document ', path
		]
)

showTestsTool ^ <Tool> = (
	^Tool
		name: 'show_tests'
		description: 'Open the test-suite view for a test configuration class — equivalent to clicking the [show tests] link on a test configuration''s class entry. Pass the test configuration class''s dotted path. This does not run the suite.'
		inputSchema: '{"type":"object","properties":{"class_name":{"type":"string","description":"Test configuration class name or dotted path"}},"required":["class_name"]}'
		handler: [:input |
			| cdm classSubject |
			cdm:: resolveClassPath: (input at: 'class_name').
			classSubject:: ide browsing ClassSubject onDeclaration: cdm.
			classSubject isTestConfiguration ifFalse: [
				Error signal: (qualifiedNameOf: cdm), ' is not a test configuration class'
			].
			ide browsing navigateTo: classSubject inactiveTestingSubject.
			'Opened test suite for ', (qualifiedNameOf: cdm)
		]
)

runTestsTool ^ <Tool> = (
	^Tool
		name: 'run_tests'
		description: 'Run the test suite for a test configuration class — equivalent to clicking the [run tests] link on a test configuration''s class entry. The IDE jumps to the in-progress test view; if the test runner raises, the IDE navigates to a debugging thread subject instead. Pass the test configuration class''s dotted path.'
		inputSchema: '{"type":"object","properties":{"class_name":{"type":"string","description":"Test configuration class name or dotted path"}},"required":["class_name"]}'
		handler: [:input |
			| cdm classSubject thread |
			cdm:: resolveClassPath: (input at: 'class_name').
			classSubject:: ide browsing ClassSubject onDeclaration: cdm.
			classSubject isTestConfiguration ifFalse: [
				Error signal: (qualifiedNameOf: cdm), ' is not a test configuration class'
			].
			thread:: ActivationMirror invokeSuspended:
				[ide browsing navigateTo: classSubject testingSubject].
			thread resume.
			thread isFulfilled ifFalse: [
				ide browsing navigateTo: (ide debugging ThreadSubject onModel: thread)
			].
			'Running tests for ', (qualifiedNameOf: cdm)
		]
)

proposeChangesTool ^ <Tool> = (
	^Tool
		name: 'propose_changes'
		description: 'Stage a set of code edits for atomic installation. Does NOT install. Returns a textual diff plus a changeset id. After calling this, present the diff to the user and wait for explicit approval ("apply", "ok", "go ahead") before calling apply_changeset. If the user wants something different, refine the changes and propose again.

Each entry in the changes array is one of:
- {kind: "add_or_replace_method",       class_name, side?, source}
- {kind: "delete_method",               class_name, side?, selector}
- {kind: "add_or_replace_lazy_slot",    class_name, side?, source}
- {kind: "delete_lazy_slot",            class_name, side?, selector}
- {kind: "set_class_header",            class_name, source}
- {kind: "add_or_replace_nested_class", class_name, source}  -- class_name is the ENCLOSING class
- {kind: "delete_nested_class",         class_name}          -- class_name is the nested class to remove
- {kind: "add_top_level_class",         class_name, source}  -- class_name must match the simpleName in source

class_name is a dotted path; side defaults to "instance" for member ops. source is full Newspeak source. Multiple changes in one call install atomically — use this for mutually dependent edits.

Top-level class DELETION is not supported by this tool (different mechanism, not part of atomic install). Renaming a class is not supported either; set_class_header preserves the simple name.'
		inputSchema: '{"type":"object","properties":{"changes":{"type":"array","items":{"type":"object","properties":{"kind":{"type":"string","enum":["add_or_replace_method","delete_method","add_or_replace_lazy_slot","delete_lazy_slot","set_class_header","add_or_replace_nested_class","delete_nested_class","add_top_level_class"]},"class_name":{"type":"string"},"side":{"type":"string","enum":["instance","class"]},"selector":{"type":"string"},"source":{"type":"string"}},"required":["kind","class_name"]}}},"required":["changes"]}'
		handler: [:input |
			| changes records id |
			changes:: input at: 'changes'.
			records:: List new.
			(* changes is a JS array, not a Newspeak Collection; iterate by index. *)
			0 to: (changes at: 'length') - 1 do: [:i |
				records add: (validateChange: (changes at: i))
			].
			records isEmpty ifTrue: [
				Error signal: 'No changes provided'
			].
			id:: freshChangesetId.
			proposedChangesets at: id put: records.
			formatChangesetId: id records: records
		]
)

applyChangesetTool ^ <Tool> = (
	^Tool
		name: 'apply_changeset'
		description: 'Atomically install a previously proposed changeset. Call this only after the user has reviewed the diff returned by propose_changes and explicitly approved. On success returns "Applied changeset <id>". On failure the atomic install rolls back, so no partial state is left in the running system.'
		inputSchema: '{"type":"object","properties":{"id":{"type":"string","description":"The changeset id returned by propose_changes"}},"required":["id"]}'
		handler: [:input |
			| id records |
			id:: input at: 'id'.
			records:: proposedChangesets at: id ifAbsent: [
				Error signal: 'No such changeset: ', id, ' (already applied, discarded, or never proposed)'
			].
			applyChangesetRecords: records.
			proposedChangesets removeKey: id.
			'Applied changeset ', id
		]
)

(* --- Convenience API --- *)

(* Create a session with the IDE tools pre-configured. *)
public createSessionWithProvider: provider <Provider> ^ <Session> = (
	| session |
	session:: Session provider: provider tools: tools.
	session systemPrompt: newspeakSystemPrompt.
	^session
)

(* Create a ChatSubject backed by a new session with IDE tools. *)
public createChatWithProvider: provider <Provider> ^ <IDEChatSubject> = (
	^IDEChatSubject onModel: (createSessionWithProvider: provider)
)

(* System prompt — Newspeak cheat sheet, cached by AnthropicProvider. *)
public newspeakSystemPrompt ^ <String> = (
	^'You are a programming assistant for the Newspeak programming language, embedded in the Newspeak Web IDE. Use the tools listed below to look up actual definitions in the user''s running IDE rather than guessing from training — Newspeak documentation is sparse and recall is unreliable. Prefer concise answers; when the user asks about code, show the source you found via tools.

# Newspeak essentials

Newspeak is a pure message-based, object-capability language in the Smalltalk family.

- No global namespace, no static state, no class variables, no pool variables.
- Names are always method invocations (auto-generated getters); there are no variable references.
- No assignment operator; slot writes happen through generated setters.
- Method invocation is the only operation: e m is always a send. There is no dot between receiver and selector.
- Classes nest arbitrarily. Inheritance is via mixins; the superclass clause is itself a message send.

# Class declarations

A class header has the form:
  class Name primaryFactoryHeader = SuperFactory (| slots |) ( instanceMembers ) : ( classSideMembers )

The first parenthesized block after = is the instance initializer (slot declarations plus setup code). The next parenthesized block is the body of instance-side members. The optional ": (...)" declares class-side members.

Examples:

  class Point x: i y: j = (| public x ::= i. public y ::= j. |) (
    public printString = (^''x='', x printString, '' y='', y printString)
  ) : ()

  class ShapeLibrary usingPlatform: platform = (
    | private List = platform collections List. |) (
    public class Shape = ( ... )( ... ) : ()
    public class Circle = Shape (...)(...) : ()
  ) : ()

A top-level module definition is a class whose factory takes a manifest or platform parameter. The manifest/platform supplies the module''s dependencies — modules and library objects it needs.

# Slots vs methods (very easy to confuse — these are distinct syntactic forms)

SLOTS sit inside vertical bars |...| and use a bare expression (NO parentheses around the initializer, NO method body).

  | public x = 0.                   "immutable slot, initialized to 0"
    public x ::= 0.                 "mutable slot (auto-generated setter x:)"
    public x.                       "mutable slot, defaults to nil"
    lazy public x = computeIt.      "lazy immutable slot; computeIt is evaluated on first access"
    lazy public x ::= computeIt.    "lazy mutable slot"
    protected y. private z.         "narrower visibility — same forms"
  |

Mutually recursive (simultaneous) slot declarations use double bars: || a = ... . b = ... . ||

METHODS sit OUTSIDE the slot bars and DO use parentheses around the body:

  public m = ( ^expr )
  public m: arg = ( body. ^result )
  public m ^ <ReturnType> = ( body )

The presence or absence of "( ... )" after "=" is the only thing distinguishing a no-arg method from a slot. "lazy slotName = computeIt." is a slot. "lazy slotName = ( computeIt )" is wrong — there is no "lazy" method modifier.

# Setter syntax

- Implicit-receiver setter:  slot:: value.   (short for self slot: value.)
- Explicit-receiver setter:  obj slot: value.
- "::" is ONLY for implicit-receiver setter sends. Never use it with an explicit receiver.

# Sends

Five send forms with distinct visibility rules:

- Ordinary             e m       Receiver e; only public members.
- Self                 self m    Public, protected, private of self''s class.
- Super                super m   Public, protected of superclasses.
- Implicit (here)      m         Looks up in enclosing lexical scope (any modifier), then in self''s superclasses (public/protected).
- Outer                outer C m C names a lexically enclosing class. Reaches members declared in C (any modifier) and public/protected of C''s superclasses.

# Access modifiers

public, protected, private. The default modifier on a declared member is protected.

# Member ordering

Inside a class body, ALL nested-class declarations must precede method declarations. The compiler enforces this.

# Comments and literals

- Comments:  (* ... *)   nestable.
- Strings:   single-quote delimited; doubled apostrophe for a literal quote.
- Symbols:   #foo  #at:put:
- Numbers:   42  3.14
- Booleans:  true  false
- Nil:       nil
- Tuples:    { a. b. c }
- Blocks:    [:x | body]   invoked via value, value:, value:value:, etc.

# Types (advisory only)

Type annotations are unenforced documentation read by the typechecker (a linter). Placement:

- After slot:              public x <Integer> = 0.
- After parameter:         m: x <Integer>
- After method header:     m ^ <Boolean> = ( ... )
- Class generics:          class Map <[K, V]> new: cap = ... ( ... ) : ()
- Generic instantiation:   List[Point]  Map[String, Integer]

# Reflection (mirrors)

Get mirrors from "platform mirrors":

- ClassMirror reflecting: aClass       class mirror.
- ObjectMirror reflecting: anObject    object mirror.

On a ClassMirror:
- mixin                  the MixinMirror.
- mixin declaration      ClassDeclarationMirror (source, header, instanceSide, classSide).
- mixin methods, mixin slots, mixin lazySlots, mixin nestedClasses.

# Platform and IDE namespace

The platform object p exposes capabilities:
  p kernel  p collections  p mirrors  p actors  p js  p hopscotch  p graphics  p fonts  p text

p js global is the JavaScript global namespace.

The IDE maintains an extra-linguistic namespace at "ide namespacing Root" — a Map keyed by Symbol. Sub-namespaces include Icons (image aliens) and Categories. Top-level classes, documents, and other values live directly in Root.

Namespace protocol: at:, at:put:, at:ifAbsent:, keys, keysAndValuesDo:, includesKey:, predicate isKindOfNamespace.

# Ampleforth documents

An Ampleforth document is a live HTML document that mixes prose with embedded live Hopscotch widgets. Documents are first-class IDE entities, stored in the namespace as instances of Document subclasses (one class per named document, nested in the IDE''s documentHolder).

Document slots:
- name <String>
- contents <String>                      the HTML text.
- mediaRegistry <Map[String, Blob]>      embedded media (images, audio, video).

Document inherits from ProgrammingPresenter, so all Hopscotch fragment builders are available (label:, link:, button:, column:, row:, holder:, image:, textDisplay:, ...). This is so amplet expressions evaluated against a Document can use those builders directly.

The get_document tool returns the document''s contents (HTML).

# Amplets

An amplet is a placeholder inside a document''s HTML:

  <div class="ampleforth" ampletId="..." name="EXPR" contenteditable="false"> ... </div>

The "name" attribute is a Newspeak expression. When the document renders, each amplet''s expression is evaluated as a message send against the host Document instance; the resulting Fragment replaces the placeholder.

Because Document inherits from ProgrammingPresenter, amplet expressions can call fragment builders directly, e.g.:

- label: ''Hello''
- button: ''Run'' action: [doSomething]
- inspect: anObject
- evaluate: ''someExpression''
- column: { ... }   row: { ... }

Document also offers addMethodFromSource:, addClassFromSource:, addLazySlotFromSource:, so an amplet can extend its host document''s API mid-document. Document''s doesNotUnderstand: looks up unknown names in Root, so amplets can reach top-level entities directly.

Amplet evaluation is incremental: if an amplet''s expression text hasn''t changed since the last render (tracked by ampletId), the existing fragment is reused — important for preserving UI state.

# Style guidelines

- Whitespace between keyword and argument: "at: 1 put: x" (not "at:1 put:x").
- For a keyword argument that is itself a keyword send, prefer "foo:: x bar: y" over "foo: (x bar: y)".
- Comments precede the construct they describe.
- Never use "::" with an explicit receiver — that is invalid syntax.
- Keep classes before methods inside the class body.

# Navigating nested classes

Classes nest, often several levels deep, and only top-level (module) classes have a unique simple name. Tool output always reports a class by its *dotted path* from the top-level module — e.g. "RuntimeForHopscotchForHTML.Platform.Images" means the class "Images" nested in "Platform" nested in the top-level class "RuntimeForHopscotchForHTML". Treat the leftmost segment as the module that "owns" the definition. Pass the same dotted path back into get_class_source, get_class_header, list_class_members, get_member_source to read or drill into that class.

If you find an inner class by simple name and want to know where it is defined, you can either rely on the dotted path the tools return, or run implementors_of on the class''s own name — the matches will be the enclosing classes'' headers and slots that expose it.

# Using the IDE tools

Prefer tool calls to recalling from training data — many features here are specific to this codebase.

- list_namespace      List entries of a namespace; defaults to Root; dotted paths like Icons or Root.Icons drill in.
- search_classes      Substring search across all classes (including nested), returns dotted paths.
- get_class_source    Full source of a class. Use dotted paths for nested classes (e.g. Outer.Inner).
- get_class_header    Just the header (factory, superclass, slots).
- list_class_members  Structured listing with access modifiers, both sides.
- get_member_source   Source of a method or a lazy slot. Set side: "class" for class-side; default is instance.
- senders_of, implementors_of    Cross-cutting selector lookups across the system.
- get_document        HTML contents of a Document, by name or dotted path.
- current_focus       What the user is currently asking about — set when the user opens the chat from a presenter or otherwise signals focus. Call this FIRST when the user says "this", "here", "the current method", refers to a member without naming its class, or otherwise speaks deictically. If the focus is "(no focus set)", ask the user or use other tools.
- web_fetch           Fetch any URL and return its text body. Use this when you need the authoritative definition of a Newspeak construct. The published reference material is:
                        - Newspeak Language Specification (grammar in EBNF + prose):
                          https://newspeaklanguage.org/spec/newspeak-spec.tex
                        - Newspeak 2025 Tutorial (PDF; text extraction may be lossy):
                          https://newspeaklanguage.org/pubs/newspeak-2025-tutorial.pdf

The following tools have SIDE EFFECTS — they move the IDE''s view. Use them only when the user has expressed intent to navigate, not as a way to gather information (the read-only tools above are for that):

- navigate_to_class       Open a class presenter on the named class (dotted path).
- navigate_to_namespace   Open a namespace presenter; defaults to Root.
- navigate_to_document    Open an Ampleforth document by name or dotted path.
- show_tests              Open the test-suite view for a test configuration class (does not run the suite).
- run_tests               Run the test suite for a test configuration class and open the in-progress view.

# Modifying code

To modify code in the running system, ALWAYS use the two-step propose/apply pattern. NEVER call apply_changeset without the user''s explicit go-ahead.

1. Call propose_changes with the full set of mutually dependent edits. A changeset installs atomically — if it has parts that depend on each other (e.g. a new method that calls another new method, or a method rename with all its sender updates), put them in ONE call so they take effect together.
2. The tool returns a textual diff and a changeset id. Show the diff to the user (you can paraphrase what it does, but include the actual diff text). Ask for confirmation.
3. Only when the user has clearly approved ("apply", "yes", "go ahead", "looks good"), call apply_changeset with the id. If they want changes, propose a new changeset and discard the prior id.

Supported change kinds (each is one entry in the `changes` array):
- add_or_replace_method       {class_name, side?, source}     -- member op; side defaults to "instance"
- delete_method               {class_name, side?, selector}
- add_or_replace_lazy_slot    {class_name, side?, source}
- delete_lazy_slot            {class_name, side?, selector}
- set_class_header            {class_name, source}             -- replace header (slots, factory, superclass); simple name must stay the same
- add_or_replace_nested_class {class_name, source}             -- class_name is the ENCLOSING class; nested classes always live on the instance side
- delete_nested_class         {class_name}                     -- class_name is the nested class to remove (rejected for top-level)
- add_top_level_class         {class_name, source}             -- class_name must match the simpleName in source; class is added to Root

The `source` for a method is the full Newspeak method source (e.g. "foo: x = ( ^x + 1 )"), including the header. The `source` for a lazy slot is the slot declaration (e.g. "lazy myCache = computeIt."). The `source` for a class header is everything from `class` up through the slot bars (no body parens). The `source` for an add_or_replace_nested_class / add_top_level_class is a full Newspeak class declaration including instance side and class side bodies. The `selector` is the name including colons for keyword methods (e.g. "at:put:").

Things this tool does NOT do:
- Top-level class deletion (uses a different mechanism outside atomic install)
- Renaming a class (set_class_header preserves the simple name)
- Class-side nested classes (rare in Newspeak; add_or_replace_nested_class is always instance side)

If you need any of these, tell the user the tool doesn''t support it and stop.

When the user asks about an entity in their system, use the IDE tools to look it up before answering. When in doubt about Newspeak syntax or semantics, fetch the spec rather than guessing. When you produce Newspeak source, follow the style guidelines above and respect member ordering (nested classes before methods).'
)

) : (
)
