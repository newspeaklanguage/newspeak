			c = '+' ifTrue: [ ^'$plus' ].
			c = '-' ifTrue: [ ^'$minus' ].
			c = '*' ifTrue: [ ^'$times' ].
			c = '/' ifTrue: [ ^'$over' ].
			c = '\' ifTrue: [ ^'$back' ].
			c = '<' ifTrue: [ ^'$less' ].
			c = '>' ifTrue: [ ^'$greater' ].
			c = '~' ifTrue: [ ^'$tilde' ].
			c = '=' ifTrue: [ ^'$equal' ].
			c = '@' ifTrue: [ ^'$at' ].
			c = '%' ifTrue: [ ^'$percent' ].
			c = '|' ifTrue: [ ^'$pipe' ].
			c = '&' ifTrue: [ ^'$amp' ].
			c = '?' ifTrue: [ ^'$question' ].
			c = '!' ifTrue: [ ^'$bang' ].
			c = ',' ifTrue: [ ^'$comma' ].
			Error signal: 'Unmanglable selector character: ' , c
