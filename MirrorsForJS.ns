			count:: _js propertyOf: rawFrames at: (_js literal: 'length').
			innermost:: nil.
			prev:: nil.
			prevSelector:: nil.
			1 to: count do: [:i |
					frameRec:: _js propertyOf: rawFrames at: (i - 1).
					recSelector:: _js propertyOf: frameRec at: (_js literal: 'selector').
					simMethod:: sim transplantMethodMixinNamed: (_js propertyOf: frameRec at: (_js literal: 'mixin'))
						selector: recSelector
						receiver: (_js propertyOf: frameRec at: (_js literal: 'receiver')).

					(* The doIt and its blocks are homed in a synthetic method installed nowhere - unresolvable by name. Their records carry the compiler's synthetic selector: mount them on the freshly V5-compiled doIt method (same bare expression source, so the source coordinates agree). *)
					isDoIt:: false.
					(nil = simMethod and: [ (nil = doItMethod) not ]) ifTrue: [
							'DoItWith:' = recSelector ifTrue: [
									simMethod:: doItMethod.
									isDoIt:: true
								]
						].
					nil = simMethod ifFalse: [
							(* A block record (blk = the block's source start) is a CLOSURE activation of the home method: same compilation unit, but its captured args are the BLOCK's parameters - they must not be mounted into the home method's argument slots, where the slot mapper would present them under the wrong names. A doIt method record mounts the canonical psoup activation (receiver = the evaluation receiver, arguments {ctxt. scope.}). *)
							blkRaw:: _js propertyOf: frameRec at: (_js literal: 'blk').
							blk:: (_js operator: '==' with: blkRaw and: (_js ident: 'null'))
								ifTrue: [ 0 ]
								ifFalse: [ blkRaw ].
							act:: sim transplantFrameFor: simMethod
								receiver: (isDoIt
									ifTrue: [ rcvr ]
									ifFalse: [ _js propertyOf: frameRec at: (_js literal: 'receiver') ])
								arguments: (blk > 0
									ifTrue: [ {} ]
									ifFalse: [
										isDoIt
											ifTrue: [ {nil. rawScope. } ]
											ifFalse: [ _js propertyOf: frameRec at: (_js literal: 'args') ]
									]).
							(isDoIt and: [ 0 = blk ]) ifTrue: [ doItRecordFramed:: true ].

							(* Display bci: where this frame invoked its callee - the ADJACENT RAW record's method, whether or not that record itself resolved to a frame. Stored site for instrumented multi-site selectors, static derivation for single-site ones; a block frame with neither falls back to the block's first mapped instruction; bci 1 otherwise. *)
							calleeSel:: calleeSelectorFor: prevSelector exception: ex.
							b:: 0.
							nil = calleeSel ifFalse: [
									siteRaw:: _js propertyOf: frameRec at: (_js literal: 'site').
									site:: (_js operator: '==' with: siteRaw and: (_js ident: 'null'))
										ifTrue: [ 0 ]
										ifFalse: [ siteRaw ].
									b:: sim transplantBciFor: simMethod callee: calleeSel site: site
								].
							(0 = b and: [ blk > 0 ]) ifTrue: [
									b:: sim bciAtOrAfterSourceStart: blk in: simMethod
								].
							0 = b ifFalse: [ act bci: b ].
							restoreLocalsOf: act from: frameRec method: simMethod in: sim.
							nil = innermost ifTrue: [ innermost:: act ].
							nil = prev ifFalse: [ prev sender: act ].
							prev:: act
						].
					prevSelector:: recSelector
				].

			(* The doIt method frame normally mounts from its own record above; this append covers captures that lost it (e.g. truncated record chains). *)
			(nil = doItMethod or: [ doItRecordFramed ]) ifFalse: [
					doItFrame:: sim transplantFrameFor: doItMethod receiver: rcvr arguments: {nil. rawScope. }.
					calleeSel:: calleeSelectorFor: prevSelector exception: ex.
					nil = calleeSel ifFalse: [
							b:: sim transplantBciFor: doItMethod callee: calleeSel site: 0.
							0 = b ifFalse: [ doItFrame bci: b ]
						].
					nil = innermost ifTrue: [ innermost:: doItFrame ].
					nil = prev ifFalse: [ prev sender: doItFrame ].
					prev:: doItFrame
				].
			nil = innermost ifTrue: [
					^ThreadMirror state: #broken result: (ObjectMirror reflecting: ex)
				].

			(* Continue restarts the OUTERMOST frame: give it its statement-level entry point. *)
			nil = prev ifFalse: [
					prev restartBci: ([ statementRestartBciFor: prev in: sim ]
						on: Exception
						do: [:noStatement | 1 ])
				].
			sim adoptBrokenStack: innermost.
			simThread:: simulatorModule SimulatedThread over: sim.
			simThread state: #broken.
			simThread result: ex.
			^ThreadMirror onSimulated: simThread
		)
		restoreLocalsOf: act from: frameRec method: simMethod in: sim = (
			(* Best-effort restore of the frame's captured locals (statement-level restart + slot inspection): the shadow record's values matched by SOURCE NAME against the V5 local layout, obtained from the method's own debugInfo (doIts) or by recompiling the method source in its defining mixin's scope. DIRECT locals only: a closure-captured local lives in a remote vector on the V5 side while the JS capture holds the plain value - restoring it raw would corrupt the vector slot, so those stay nil. Any failure leaves the frame as it was. *)

			| names vals di lvs limit n v |
			names:: _js propertyOf: frameRec at: (_js literal: 'localNames').
			(_js operator: '==' with: names and: (_js ident: 'null')) ifTrue: [ ^self ].
			vals:: _js propertyOf: frameRec at: (_js literal: 'locals').
			(_js operator: '==' with: vals and: (_js ident: 'null')) ifTrue: [ ^self ].
			[
				di:: transplantDebugInfoFor: simMethod of: act in: sim.
				nil = di ifTrue: [ ^self ].
				lvs:: di localVariables.
				limit:: _js propertyOf: names at: (_js literal: 'length').
				1 to: limit do: [:i |
						n:: _js propertyOf: names at: i - 1.
						v:: _js propertyOf: vals at: i - 1.
						lvs do: [:lv |
								(lv name = n and: [ 0 = lv contextDepth and: [ nil = lv remoteVector ] ]) ifTrue: [
										(* zeroOriginOffset is COMBINED-space (params included): DebugMapper getValueOf: reads tempAt: offset + 1 directly - write exactly where the mapper reads. (The bytecode pushLocal space is locals-only and adds numArgs; that is a different coordinate system.) *)
										act tempAt: lv zeroOriginOffset + 1 put: v
									]
							]
					]
			]
				on: Exception
				do: [:restoreFailed | nil ]
		)
		transplantDebugInfoFor: simMethod of: act in: sim ^<DebugInfo | nil> = (
			(* The V5 DebugInfo describing simMethod's local layout: carried directly by runtime-compiled doIts, recompiled from source for deployed methods (same text, both compilers, so layouts agree). nil-tolerant throughout. *)

			| src nsClass |
			nil = simMethod debugInfo ifFalse: [ ^simMethod debugInfo ].
			nil = bytecodeCompilationModule ifTrue: [ ^nil ].
			src:: sim sourceOf: act.
			nil = src ifTrue: [ ^nil ].
			nsClass:: sim newspeakClassApplying: simMethod mixin
				startingAt: (_js call: (_js propertyOf: (_js ident: 'Object')
						at: (_js literal: 'getPrototypeOf'))
					with: {act receiver. }).
			nil = nsClass ifTrue: [ ^nil ].
			^(bytecodeCompilationModule Compiler new compileMethodSource: src
				within: (ClassMirror reflecting: nsClass) mixin) debugInfo
		)
		statementRestartBciFor: act in: sim ^<Integer> = (
			(* The bci of the top-level statement containing the frame's display bci - the sound Continue entry point (empty operand stack, no live control flow at top-level statement boundaries, locals restored to their at-failure values). 1 whenever anything is unresolvable: Continue then degrades to a full restart. *)

			(* Coordinates: everything stays in RAW parser coordinates - bciMap interval starts ARE parser node starts. A doIt's map came from a standalone parse of the same bare expression (sourceStart 0), so map values align with a fresh parse at bias 0; a deployed method's map came from the class-source parse (values minus sourceStart are zero-anchored at the method start), so the fresh standalone parse's own origin - the parsed declaration's start - is subtracted as bias. *)

			| simMethod src root stmts bias failStart stmt map i entryBci bestBci best s candidates |
			simMethod:: act method.
			nil = simMethod ifTrue: [ ^1 ].
			nil = simMethod record ifTrue: [ ^1 ].
			src:: sim sourceOf: act.
			nil = src ifTrue: [ ^1 ].
			#DoIt = simMethod selector
				ifTrue: [
					root:: parsing CommonParser new parseExpression: src.
					stmts:: root statements.
					bias:: 0
				]
				ifFalse: [
					root:: parsing CommonParser new parseMethodDeclaration: src.
					stmts:: root body statements.
					bias:: root start
				].
			map:: simMethod bciMap.

			(* The raw source start of the frame's current position: the nearest mapped entry at or before the display bci. *)
			failStart:: nil.
			bestBci:: -1.
			i:: 1.
			[ i + 2 <= map size ] whileTrue: [
					entryBci:: map at: i.
					(entryBci <= act bci and: [ entryBci > bestBci ]) ifTrue: [
							bestBci:: entryBci.
							failStart:: (map at: i + 1) - simMethod sourceStart
						].
					i:: i + 3
				].
			nil = failStart ifTrue: [ ^1 ].
			stmt:: nil.
			stmts do: [:each |
					(* Parenthesize the arithmetic INSIDE the comparisons: Newspeak binary operators are uniform-precedence left-associative, so a bare `failStart <= each end - bias` is `(failStart <= each end) - bias` - a boolean minus a number, silently coerced by JS and then DNUing on ifTrue: (found 2026-07-22). *)
					((each start - bias) <= failStart and: [ failStart <= (each end - bias) ]) ifTrue: [ stmt:: each ]
				].
			nil = stmt ifTrue: [ ^1 ].

			(* All mapped bcis of the failing statement; the simulator derives the sound entry - the start of the push-run into the earliest method-level one - since the map marks only sends and stores, never a statement's first instruction. *)
			candidates:: List new.
			i:: 1.
			[ i + 2 <= map size ] whileTrue: [
					s:: (map at: i + 1) - simMethod sourceStart.
					(s >= (stmt start - bias) and: [ s <= (stmt end - bias) ]) ifTrue: [
							candidates add: (map at: i)
						].
					i:: i + 3
				].
			candidates isEmpty ifTrue: [ ^1 ].
			best:: sim statementEntryAmong: candidates in: simMethod.
			0 = best ifTrue: [ ^1 ].
			^best
		)
		calleeSelectorFor: rawCalleeSelector <String | nil> exception: ex ^<String | nil> = (
			(* The selector to look for in the CALLER's bytecode when deriving a transplant frame's bci. A doesNotUnderstand: callee means the source-level send was the MNU's own message: dNU is invoked by the DNU catcher machinery, so its selector never appears at the call site. Any probe failure keeps the raw selector. *)

			nil = rawCalleeSelector ifTrue: [ ^nil ].
			'doesNotUnderstand:' = rawCalleeSelector ifFalse: [ ^rawCalleeSelector ].
			^[ ex message selector ] on: Exception do: [:probeFailed | rawCalleeSelector ]
		)
		doItSimMethodFor: expression <String> receiver: rcvr scope: rawScope <Map> in: sim ^<SimulatedMethod | nil> = (
			(* The V5-compiled doIt of a failed evaluation, ready for restart-quality frames (the method record's own frame and its blocks' frames alike). Compiled from the same bare expression the JS doIt was, so shadow-record source coordinates agree. nil when the bytecode pipeline is unavailable; a compile failure raises to the caller's backstop. *)

			| bcc im simMethod |
			bcc:: bytecodeCompilationModule.
			nil = bcc ifTrue: [ ^nil ].
			im:: bcc Compiler new compileExpressionSource: expression
				debugMapper: nil
				withScope: rawScope
				inMixin: (ObjectMirror reflecting: rcvr) getClass mixin.
			simMethod:: simulatorModule SimulatedMethod record: (bytecodeRecordFor: im)
				mixin: (sim runtimeMixinForDebugOf: rcvr)
				selector: #DoIt
				accessModifier: #public.
			simMethod sourceText: expression.
			simMethod debugInfo: im debugInfo.
			^simMethod
		)
	)

	public installDebugHook: presenter <[:ThreadMirror]> = (
		(* Arm the Stage 3 debugger: an unhandled signal then reconstructs the failed stack and this hook presents it. NSDebugHook is called from the boundary catch with RAW (exception, shadowFrames); a Newspeak closure IS a plain JS function, so it is assigned directly and receives the raw arguments. All failures are swallowed here (and again at the boundary): the debugger must never worsen the original failure. *)

		| hook |
		hook:: [:ex :frames |
				[ presenter value: (ActivationMirror threadForShadowFrames: frames exception: ex) ]
					on: Exception
					do: [:e | nil ].
				nil
			].
		_js assign: (_js ident: 'NSDebugHook') toBe: hook
	)
	brokenEvalReasonFor: rawErr = (
		(* The exception object a broken thread presents. NS exceptions (newspeakClass set - the same raw-vs-NS test as the kernel's protectedBodyOf:) pass through; a raw JS error - which reaches the evaluation boundary only without a reconstruction unwind - wraps into a kernel Exception carrying its JS description, so the results list can print it. Module-level: reached by here-sends from ObjectMirror. *)

		| c ex |
		c:: _js propertyOf: rawErr at: (_js literal: 'newspeakClass').
		(_js operator: '!=' with: c and: (_js ident: 'null')) ifTrue: [ ^rawErr ].
		ex:: Exception new.
		ex messageText: (kernelModule describeRawError: rawErr).
		^ex
	)
	bytecodeRecordFor: im ^<Array> = (
		(* The runtime bytecode-record array for a freshly V5-compiled intermediate method, in the MM-record layout the simulator consumes: [bytes, literals, numArgs, numLocals, maxStack, bciMap, sourceStart] (see Newspeak2JSCompilation encodeBytecodeOf:, whose deploy-time encoding this mirrors at runtime). Module-level: reached by here-sends from ObjectMirror (debugExpression:) and ActivationMirror (frame evaluate:). *)

		| bciMap |
		bciMap:: List new.
		nil = im debugInfo ifFalse: [
				im debugInfo bciSourceMapping keysAndValuesDo: [:bci :interval |
						bciMap add: bci; add: interval first; add: interval last
					]
			].
		^{im bytes asArray. im literals asArray. im argCount. im maxLocals. im maxStack. bciMap asArray. 0. }
	)
	class CompileOnlyInternalKernel new = Object new (
		(* Satisfies IntermediatesForPrimordialSoup's imports for compile-only use of the bytecode compilation pipeline: the dual-emission path reads bytes and literals off IntermediateMethods and never assembles a psoup Method, so the Method and MethodMetadata bindings are never used. (Same stub as DeploymentManager's.) *)

	) (
		public Method = (
			^nil
		)
		public MethodMetadata = (
			^nil
		)
	) : ()
	class FrameMethodMirror name: n <Symbol> accessModifier: a <Symbol> mixin: m <MixinMirror | nil> sourceText: s <String | nil> = Object new (
		(* A method mirror for a simulated frame whose method has no browsable MethodMirror: a runtime-compiled doIt, or a frame whose defining mixin could not be located. Carries source TEXT directly (possibly nil - the UI shows its absence marker), unlike the regular MethodMirror whose source: parameter is an index into the deployed sources array. *)

		|
			public name <Symbol> = n.
			public accessModifier <Symbol> = a.
			public definingMixin <MixinMirror | nil> = m.
			public source <String | nil> = s.
		|
	) (
		public isKindOfMethodMirror ^<Boolean> = (
			^true
		)
		public isSynthetic ^<Boolean> = (
			^true
		)
		public simpleName ^<Symbol> = (
			^name
		)
		public selectors ^<List[Symbol]> = (
			^List new
		)
		public hash ^<Integer> = (
			^name hash bitXor: class hash
		)
		public = other ^<Boolean> = (
			other isKindOfMethodMirror ifFalse: [ ^false ].
			^name = other name and: [ definingMixin = other definingMixin ]
		)
	) : ()
	public class LocalSlotMirror name: n <String> value: v <ObjectMirror> = Object new (
		(* A named local (parameter or temporary) of an activation, psoup API. *)

		|
			public name <String> = n.
			public value <ObjectMirror> = v.
		|
	) (
		public isKindOfLocalSlotMirror ^<Boolean> = (
			^true
		)
	) : ()

	(* reflectees at: self put: activation *)
	public class AtomicInstallWrapper new = Object new (
		(* :TODO :Bogus *)
		
	) (
		public install: builders <List[ClassDeclarationBuilder]> into: ns <Map[Symbol, Object]> ^<List[MixinMirror]> = (
			(* Nothing atomic about this. We'd have to implement the whole thing in JS, and even then, it needs to be a transaction *)
			
			#BOGUS yourself.
			^builders collect: [:b <ClassDeclarationBuilder> |
					| mm <MixinMirror> |
					mm:: b install instanceSide.
					ns at: b name
						ifAbsent: [
							ns at: b name put: (mm apply: Object withName: b name) reflectee
						].
					mm
				]
		)
	) : ()
	public class ClosureMirror reflecting: c <Closure> = Object new (
		(* Read-only introspection on a closure. Source / definingMethod /
   receiver depend on closure metadata wiring in the JS code generator
   (Tier 3 / debugger track). *)
		
		|
			public reflectee <Closure> = c.
			definingActivation <Activation> = definingActivationOf: c.
		|
	) (
		
		(* reflectees at: self put: c. *)
		public source ^<String | nil> = (
			(* Closure source requires closure metadata wiring in the code
	   generator (debugger track); nil = unavailable, which the browsing
	   code treats as a displayable absence. *)

			^nil
		)
		public definingMethod ^<MethodMirror | nil> = (
			(* See [source]. *)

			^nil
		)
		public receiver ^<ObjectMirror> = (
			(* Best effort: without activation metadata the receiver is unknown. *)

			^ObjectMirror reflecting: nil
		)
		public isKindOfClosureMirror ^<Boolean> = (
			^true
		)
		public = other = (
			other isKindOfClosureMirror ifFalse: [ ^false ].
			^_js operator: '===' with: reflectee and: other reflectee
		)
		public hash ^<Integer> = (
			^(identityHashOf: reflectee) bitXor: class hash
		)
		public isDead ^<Boolean> = (
			(* JS closures don't have a notion of "dead" — they exist as long as
	   anything references them. Always false for now. *)
			
			^false
		)
	) : ()
	public class LazySlotActivationMirror reflecting: a <Activation> thread: t <Thread> = ActivationMirror reflecting: a
		thread: t (
		(* :TODO :Bogus
Mirror for the activation of a lazy slot. It takes care of computing the right sender, providing the current sourceRange considering the particular grammar , providing access to compiling the lazy slot code etc *)
		
	) (
	) : ()
	public class LazySlotBuilder reflecting: ir <IntermediateLazySlot> in: mb <MixinBuilder> = Object new (
		(* Trivial delegations to the underlying IntermediateLazySlot for the
   IDE's read path. Mutation (rename, etc.) requires Tier 2 work. *)
		
		|
			public prvtIntermediate <IntermediateLazySlot> = ir.
			prvtMixinBuilder <MixinBuilder> = mb.
		|
	) (
		public source = (
			^prvtIntermediate source
		)
		public name = (
			^prvtIntermediate name
		)
		public simpleName = (
			^prvtIntermediate name
		)
		public accessModifier = (
			^prvtIntermediate accessModifier
		)
		public isMutable ^<Boolean> = (
			^prvtIntermediate isMutable
		)
		public definingMixin = (
			^prvtMixinBuilder
		)
		public isKindOfLazySlotMirror ^<Boolean> = (
			^true
		)
	) : ()
	classDeclIRFor: mixin within: enclosing = (
		| source = 'Newspeak3 ''Uncategorized'' ' , (ClassDeclarationMirror reflecting: mixin) source. |
		
		(* ('compiling class:', source) out. *)
		^compiler compileClassSource: source within: enclosing
	)
	classMixinOf: m <InstanceMixin> ^<ClassMixin | nil> = (
		(* Sometimes we need to get the class side of a mixin. Since reflectee is not exposed by MixinMirror, we must rely
	on knowledge of the runtime structure. Returns nil if [m] has no
	meta side (some bootstrapping / metaclass corner cases) — avoids
	producing a Mixin with undefined runtimeMixin. *)
		
		| meta |
		meta:: _js propertyOf: (_js propertyOf: m at: (_js literal: 'runtimeMixin'))
			at: (_js literal: 'meta').
		(_js operator: '===' with: meta and: (_js ident: 'undefined')) ifTrue: [ ^nil ].
		^Mixin fromRuntimeMixin: meta
	)
	private identityHashOf: object ^<Integer> = (
		(* Compute an identity hash for [object]. Different paths by JS type
	   because primitives (number / string / boolean) can't have a
	   [hashCode] property assigned to them in JS strict mode (which is
	   what the compiler emits). For Newspeak objects we keep the
	   lazy-hashCode pattern (assign on first read).

	   The previous body did the [hashCode] dance unconditionally and
	   threw [Cannot create property on number 'N'] whenever an
	   ObjectMirror reflected on a primitive (a common case in the
	   Object Presenter). *)
		
		| t <String> |
		t:: _js prefixOperator: 'typeof ' on: object.
		t = 'number' ifTrue: [ ^_js operator: '|' with: object and: (_js literal: 0) ].
		t = 'string' ifTrue: [ ^object hash ].
		t = 'boolean' ifTrue: [ ^object ifTrue: [ 1 ] ifFalse: [ 0 ] ].
		[
			_js prefixOperator: '!'
				on: (_js propertyOf: object at: (_js literal: 'hashCode'))
		] whileTrue: [
				_js assign: (_js propertyOf: object at: (_js literal: 'hashCode'))
					toBe: (_js verbatim: 'Math.random() * 0x3FFFFFF | 0')
			].
		^_js propertyOf: object at: (_js literal: 'hashCode')
	)
	sourceForMethod: methodName <String> ofMixin: m <Mixin> ^<String> = (
		| _js = generation factory. sourceIndex <Integer> |
		sourceIndex:: sourceIndexForMethod: methodName ofMixin: m.
		^_js propertyOf: (_js ident: 'sources') at: sourceIndex
	)
	sourceIndexForMethod: methodName <String> ofMixin: m <Mixin> ^<Integer> = (
		| _js = generation factory. methodMetadata |
		methodMetadata:: (_js propertyOf: m at: (_js literal: 'methods')) select: [:e |
				(_js propertyOf: e at: 'name') = methodName
			].
		^_js propertyOf: methodMetadata at: 'source'
		(* compute the source index from the metadata *)
		
	)
	public installer ^<AtomicInstallWrapper> = (
		^AtomicInstallWrapper new
	)
) : ()