			(* Must match the compiler's NameMangler _mangleSelector: exactly, binary selectors included (#- is $$minus, #<= is $$less$equal). The previous version handled only keyword, unary and qualified selectors, so a runtime-constructed Message for a binary selector could never find its target property and reported a spurious DNU. *)

			(isBinarySelector: selector) ifTrue: [
